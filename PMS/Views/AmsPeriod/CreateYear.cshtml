@model AccFiscalYear
@{
    ViewData["Title"] = "New fiscal year";
}
<form asp-action="CreateYear" method="post">
    @Html.AntiForgeryToken()
    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="YearName" class="form-label"></label>
            <input asp-for="YearName" class="form-control" maxlength="50" required placeholder="e.g. FY 2025-26" />
        </div>
        <div class="col-md-3">
            <label asp-for="StartDate" class="form-label"></label>
            <input asp-for="StartDate" class="form-control" type="date" required />
        </div>
        <div class="col-md-3">
            <label asp-for="EndDate" class="form-label"></label>
            <input asp-for="EndDate" class="form-control" type="date" required />
        </div>
        <div class="col-md-4">
            <label asp-for="Status" class="form-label"></label>
            <select asp-for="Status" class="form-select">
                <option value="Open">Open</option>
                <option value="Closed">Closed</option>
                <option value="Locked">Locked</option>
            </select>
        </div>
    </div>
    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>
