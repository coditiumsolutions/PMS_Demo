@model IEnumerable<PMS.Models.Transfer>

@{
    ViewData["Title"] = "Transfers";
    ViewData["ListingTitle"] = "All Transfers";
    ViewData["ListingDescription"] = "Manage property transfer records";
    ViewData["ListingRecordCount"] = Model?.Count() ?? 0;
    ViewData["ListingAddUrl"] = ViewBag.CanCreate == true ? Url.Action("Create") : null;
    ViewData["ListingAddText"] = "New Transfer";

    var extraActions = "<a href=\"" + Url.Action("Index", "TransferFee") + "\" class=\"btn btn-outline-info btn-sm\">" +
        "<i class=\"bi bi-tags me-1\" aria-hidden=\"true\"></i>Transfer Fee Module</a>";
    if (ViewBag.ShowDuplicateFileTransferLink as bool? == true)
    {
        extraActions += "<a href=\"" + Url.Action("Index", "DuplicateFileTransfer") + "\" class=\"btn btn-outline-primary btn-sm\">" +
            "<i class=\"bi bi-files me-1\" aria-hidden=\"true\"></i>Duplicate file transfer</a>";
    }
    ViewData["ListingExtraActions"] = extraActions;
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<form method="get" asp-action="Index" class="mb-4 pms-transfer-listing">
    <div class="pms-transfer-search-wrap pms-listing-search-wrap">
        <div class="row g-2 align-items-end flex-lg-nowrap">
            <div class="col-12 col-md-6 col-lg-4">
                <div class="pms-compact-field">
                    <label for="customerIdFilter" class="form-label">Customer ID</label>
                    <input type="text"
                           name="customerIdFilter"
                           id="customerIdFilter"
                           class="form-control"
                           value="@ViewBag.CustomerIdFilter" />
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <div class="pms-compact-field pms-select-dropdown">
                    <label for="workflowFilter" class="form-label">Workflow Status</label>
                    <select name="workflowFilter" id="workflowFilter" class="form-select" onchange="this.form.submit()">
                        <option value="">All</option>
                        @if (ViewBag.WorkflowStatuses != null)
                        {
                            foreach (var s in (string[])ViewBag.WorkflowStatuses)
                            {
                                <option value="@s" selected="@(ViewBag.WorkflowFilter == s)">@s</option>
                            }
                        }
                    </select>
                </div>
            </div>
            <div class="col-12 col-lg-4">
                <div class="d-flex flex-wrap gap-2 pms-transfer-search-actions">
                    <button type="submit" class="btn btn-primary btn-sm flex-grow-1">
                        <i class="bi bi-search me-1" aria-hidden="true"></i>Search
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm flex-grow-1">
                        <i class="bi bi-arrow-counterclockwise me-1" aria-hidden="true"></i>Clear
                    </a>
                </div>
            </div>
        </div>
    </div>
</form>

<div class="card pms-grid-card pms-listing-flat pms-saas-grid pms-transfer-listing">
    <div class="card-body">
        <partial name="Listing/_GridToolbar" />

        <div class="table-responsive pms-saas-table-wrap">
            <table class="table pms-saas-table" id="transfersTable">
                <thead>
                    <tr>
                        <th>Transfer ID</th>
                        <th>Customer ID</th>
                        <th>Customer / Project</th>
                        <th>Seller</th>
                        <th>Buyer</th>
                        <th>Workflow</th>
                        <th>Created</th>
                        <th class="pms-saas-th-actions">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model)
                    {
                        var isInitiated = string.Equals(t.WorkFlowStatus?.Trim(), "Created", StringComparison.OrdinalIgnoreCase)
                            || string.Equals(t.WorkFlowStatus?.Trim(), "Initiated", StringComparison.OrdinalIgnoreCase);
                        <tr>
                            <td data-label="Transfer ID"><span class="badge bg-secondary">@t.TransferID</span></td>
                            <td data-label="Customer ID"><code>@t.CustomerID</code></td>
                            <td data-label="Customer / Project">
                                @if (t.Customer?.PaymentPlan?.Project != null)
                                {
                                    <span class="pms-pill pms-pill--info">@t.Customer.PaymentPlan.Project.ProjectName</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td data-label="Seller"><span class="pms-cell-truncate" title="@t.SellerName">@(t.SellerName ?? "—")</span></td>
                            <td data-label="Buyer"><span class="pms-cell-truncate" title="@t.BuyerName">@(t.BuyerName ?? "—")</span></td>
                            <td data-label="Workflow">
                                @if (t.WorkFlowStatus == "Approved")
                                { <span class="pms-pill pms-pill--success">@t.WorkFlowStatus</span> }
                                else if (t.WorkFlowStatus == "Created")
                                { <span class="pms-pill pms-pill--info">@t.WorkFlowStatus</span> }
                                else if (t.WorkFlowStatus == "Pending")
                                { <span class="pms-pill pms-pill--warning">@t.WorkFlowStatus</span> }
                                else
                                { <span class="pms-pill pms-pill--warning">@(t.WorkFlowStatus ?? "—")</span> }
                            </td>
                            <td data-label="Created"><span class="text-nowrap">@t.CreatedAt.ToString("MMM dd, yyyy")</span></td>
                            <td class="pms-saas-td-actions" data-label="Actions">
                                <div class="pms-row-actions" role="group">
                                    <a asp-action="Details" asp-route-id="@t.TransferID" class="btn btn-sm btn-outline-secondary" title="Details">
                                        <i class="bi bi-eye" aria-hidden="true"></i>
                                    </a>
                                    @if (t.WorkFlowStatus == "Approved")
                                    {
                                        <a asp-action="TransferLetter" asp-route-id="@t.TransferID" target="_blank" class="btn btn-sm btn-outline-success" title="Transfer Letter">
                                            <i class="bi bi-file-earmark-text" aria-hidden="true"></i>
                                        </a>
                                    }
                                    else
                                    {
                                        <a asp-action="TransferReceipt" asp-route-id="@t.TransferID" target="_blank" class="btn btn-sm btn-outline-warning" title="Transfer Receipt">
                                            <i class="bi bi-receipt" aria-hidden="true"></i>
                                        </a>
                                    }
                                    @if ((ViewBag.CanEdit == true) && t.WorkFlowStatus != "Approved")
                                    {
                                        <a asp-action="Edit" asp-route-id="@t.TransferID" class="btn btn-sm btn-outline-primary" title="Edit">
                                            <i class="bi bi-pencil-square" aria-hidden="true"></i>
                                        </a>
                                    }
                                    @if (ViewBag.CanDelete == true && isInitiated)
                                    {
                                        <form asp-action="Delete" asp-route-id="@t.TransferID" method="post" class="d-inline" onsubmit="return confirm('Delete this transfer?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                                <i class="bi bi-trash" aria-hidden="true"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#transfersTable').DataTable({
                pageLength: 25,
                order: [[6, 'desc']],
                columnDefs: [{ orderable: false, targets: 7 }]
            });
        });
    </script>
}
