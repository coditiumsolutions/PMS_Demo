@model IEnumerable<PMS.Models.Transfer>

@{
    ViewData["Title"] = "Transfers";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"></h2>
    <div class="d-flex gap-2">
        <a asp-controller="TransferFee" asp-action="Index" class="btn btn-outline-info">
            <i class="fas fa-tags me-2"></i>Transfer Fee Module
        </a>
        @if (ViewBag.CanCreate == true)
        {
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>New Transfer
        </a>
        }
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<form method="get" asp-action="Index" class="mb-4">
    <div class="card">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label fw-bold">Customer ID</label>
                    <input type="text" name="customerIdFilter" class="form-control form-control-sm" placeholder="Search by Customer ID" value="@ViewBag.CustomerIdFilter" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">Workflow Status</label>
                    <select name="workflowFilter" class="form-select form-select-sm" onchange="this.form.submit()">
                        <option value="">All</option>
                        @if (ViewBag.WorkflowStatuses != null)
                        {
                            foreach (var s in (string[])ViewBag.WorkflowStatuses)
                            {
                                <option value="@s" selected="@(ViewBag.WorkflowFilter == s)">@s</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">&nbsp;</label>
                    <div class="d-flex gap-2 align-items-center">
                        <button type="submit" class="btn btn-primary btn-sm">
                            <i class="fas fa-search me-2"></i>Search
                        </button>
                        <a asp-action="Index" class="btn btn-secondary btn-sm">
                            <i class="fas fa-times me-2"></i>Clear
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover" id="transfersTable">
                <thead class="table-dark">
                    <tr>
                        <th>Transfer ID</th>
                        <th>Customer ID</th>
                        <th>Customer / Project</th>
                        <th>Seller</th>
                        <th>Buyer</th>
                        <th>Workflow</th>
                        <th>Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model)
                    {
                        var isInitiated = string.Equals(t.WorkFlowStatus?.Trim(), "Created", StringComparison.OrdinalIgnoreCase)
                            || string.Equals(t.WorkFlowStatus?.Trim(), "Initiated", StringComparison.OrdinalIgnoreCase);
                        <tr>
                            <td><span class="badge bg-secondary">@t.TransferID</span></td>
                            <td><code>@t.CustomerID</code></td>
                            <td>
                                @if (t.Customer?.PaymentPlan?.Project != null)
                                {
                                    <span class="badge bg-info">@t.Customer.PaymentPlan.Project.ProjectName</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>@(t.SellerName ?? "—")</td>
                            <td>@(t.BuyerName ?? "—")</td>
                            <td>
                                @if (t.WorkFlowStatus == "Approved")
                                { <span class="badge bg-success">@t.WorkFlowStatus</span> }
                                else if (t.WorkFlowStatus == "Created")
                                { <span class="badge bg-primary">@t.WorkFlowStatus</span> }
                                else
                                { <span class="badge bg-warning">@(t.WorkFlowStatus ?? "—")</span> }
                            </td>
                            <td>@t.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a asp-action="Details" asp-route-id="@t.TransferID" class="btn btn-sm btn-outline-info" title="Details">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    @if (t.WorkFlowStatus == "Approved")
                                    {
                                        <a asp-action="TransferLetter" asp-route-id="@t.TransferID" target="_blank" class="btn btn-sm btn-outline-success" title="Transfer Letter">
                                            <i class="fas fa-file-alt"></i>
                                        </a>
                                    }
                                    else
                                    {
                                        <a asp-action="TransferReceipt" asp-route-id="@t.TransferID" target="_blank" class="btn btn-sm btn-outline-warning" title="Transfer Receipt">
                                            <i class="fas fa-receipt"></i>
                                        </a>
                                    }
                                    @if ((ViewBag.CanEdit == true) && t.WorkFlowStatus != "Approved")
                                    {
                                        <a asp-action="Edit" asp-route-id="@t.TransferID" class="btn btn-sm btn-outline-primary" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                    }
                                    @if (ViewBag.CanDelete == true && isInitiated)
                                    {
                                        <form asp-action="Delete" asp-route-id="@t.TransferID" method="post" class="d-inline" onsubmit="return confirm('Delete this transfer?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#transfersTable').DataTable({
                pageLength: 25,
                order: [[6, 'desc']],
                columnDefs: [{ orderable: false, targets: 7 }]
            });
        });
    </script>
}
