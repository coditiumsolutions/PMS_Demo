@model IEnumerable<PMS.Models.Transfer>

@{
    ViewData["Title"] = "Transfers";
    ViewData["ListingTitle"] = "All Transfers";
    ViewData["ListingRecordCount"] = Model?.Count() ?? 0;
    ViewData["ListingAddUrl"] = ViewBag.CanCreate == true ? Url.Action("Create") : null;
    ViewData["ListingAddText"] = "New Transfer";
    ViewData["SearchCollapseId"] = "transferSearchCollapse";

    var extraActions = "<a href=\"" + Url.Action("Index", "TransferFee") + "\" class=\"btn btn-outline-info btn-sm\">" +
        "<i class=\"bi bi-tags me-1\" aria-hidden=\"true\"></i>Transfer Fee Module</a>";
    if (ViewBag.ShowDuplicateFileTransferLink as bool? == true)
    {
        extraActions += "<a href=\"" + Url.Action("Index", "DuplicateFileTransfer") + "\" class=\"btn btn-outline-primary btn-sm\">" +
            "<i class=\"bi bi-files me-1\" aria-hidden=\"true\"></i>Duplicate file transfer</a>";
    }
    ViewData["ListingExtraActions"] = extraActions;
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<form method="get" asp-action="Index" class="mb-4">
    <div class="card pms-search-card">
        <partial name="Listing/_SearchCardHeader" />
        <div class="collapse show" id="transferSearchCollapse">
            <div class="card-body">
                <div class="row g-3 pms-search-fields align-items-end">
                    <div class="col-12 col-md-6 col-lg-3 col-search">
                        <div class="form-floating">
                            <input type="text"
                                   name="customerIdFilter"
                                   id="customerIdFilter"
                                   class="form-control"
                                   placeholder="Customer ID"
                                   value="@ViewBag.CustomerIdFilter" />
                            <label for="customerIdFilter">Customer ID</label>
                        </div>
                    </div>
                    <div class="col-12 col-md-6 col-lg-3 col-search">
                        <div class="form-floating">
                            <select name="workflowFilter" id="workflowFilter" class="form-select" onchange="this.form.submit()">
                                <option value="">All</option>
                                @if (ViewBag.WorkflowStatuses != null)
                                {
                                    foreach (var s in (string[])ViewBag.WorkflowStatuses)
                                    {
                                        <option value="@s" selected="@(ViewBag.WorkflowFilter == s)">@s</option>
                                    }
                                }
                            </select>
                            <label for="workflowFilter">Workflow Status</label>
                        </div>
                    </div>
                    <div class="col-12 col-lg-6 col-search">
                        <div class="d-flex justify-content-end gap-2 pms-search-actions border-0 mt-0 pt-0">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-search me-1" aria-hidden="true"></i>Search
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-counterclockwise me-1" aria-hidden="true"></i>Clear
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

<div class="card pms-grid-card">
    <div class="card-body">
        <partial name="Listing/_GridToolbar" />

        <div class="table-responsive">
            <table class="table table-hover align-middle pms-enterprise-table" id="transfersTable">
                <thead>
                    <tr>
                        <th>Transfer ID</th>
                        <th>Customer ID</th>
                        <th>Customer / Project</th>
                        <th>Seller</th>
                        <th>Buyer</th>
                        <th>Workflow</th>
                        <th>Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model)
                    {
                        var isInitiated = string.Equals(t.WorkFlowStatus?.Trim(), "Created", StringComparison.OrdinalIgnoreCase)
                            || string.Equals(t.WorkFlowStatus?.Trim(), "Initiated", StringComparison.OrdinalIgnoreCase);
                        <tr>
                            <td><span class="badge bg-secondary">@t.TransferID</span></td>
                            <td><code>@t.CustomerID</code></td>
                            <td>
                                @if (t.Customer?.PaymentPlan?.Project != null)
                                {
                                    <span class="badge bg-info">@t.Customer.PaymentPlan.Project.ProjectName</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td><span class="pms-cell-truncate" title="@t.SellerName">@(t.SellerName ?? "—")</span></td>
                            <td><span class="pms-cell-truncate" title="@t.BuyerName">@(t.BuyerName ?? "—")</span></td>
                            <td>
                                @if (t.WorkFlowStatus == "Approved")
                                { <span class="badge bg-success">@t.WorkFlowStatus</span> }
                                else if (t.WorkFlowStatus == "Created")
                                { <span class="badge bg-primary">@t.WorkFlowStatus</span> }
                                else if (t.WorkFlowStatus == "Pending")
                                { <span class="badge bg-warning text-dark">@t.WorkFlowStatus</span> }
                                else
                                { <span class="badge bg-warning text-dark">@(t.WorkFlowStatus ?? "—")</span> }
                            </td>
                            <td>@t.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td>
                                <div class="btn-group pms-action-group" role="group">
                                    <a asp-action="Details" asp-route-id="@t.TransferID" class="btn btn-sm btn-outline-secondary" title="Details">
                                        <i class="bi bi-eye" aria-hidden="true"></i>
                                    </a>
                                    @if (t.WorkFlowStatus == "Approved")
                                    {
                                        <a asp-action="TransferLetter" asp-route-id="@t.TransferID" target="_blank" class="btn btn-sm btn-outline-success" title="Transfer Letter">
                                            <i class="bi bi-file-earmark-text" aria-hidden="true"></i>
                                        </a>
                                    }
                                    else
                                    {
                                        <a asp-action="TransferReceipt" asp-route-id="@t.TransferID" target="_blank" class="btn btn-sm btn-outline-warning" title="Transfer Receipt">
                                            <i class="bi bi-receipt" aria-hidden="true"></i>
                                        </a>
                                    }
                                    @if ((ViewBag.CanEdit == true) && t.WorkFlowStatus != "Approved")
                                    {
                                        <a asp-action="Edit" asp-route-id="@t.TransferID" class="btn btn-sm btn-outline-primary" title="Edit">
                                            <i class="bi bi-pencil-square" aria-hidden="true"></i>
                                        </a>
                                    }
                                    @if (ViewBag.CanDelete == true && isInitiated)
                                    {
                                        <form asp-action="Delete" asp-route-id="@t.TransferID" method="post" class="d-inline" onsubmit="return confirm('Delete this transfer?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                                <i class="bi bi-trash" aria-hidden="true"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#transfersTable').DataTable({
                pageLength: 25,
                order: [[6, 'desc']],
                columnDefs: [{ orderable: false, targets: 7 }]
            });
        });
    </script>
}
