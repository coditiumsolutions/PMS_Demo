@model PMS.Models.Transfer
@{
    ViewData["Title"] = "Transfer Details";
    var isApproved = Model.WorkFlowStatus == "Approved";
}
<div style="display:none;">@Html.AntiForgeryToken()</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div class="d-flex align-items-center gap-3">
        <span class="badge bg-light text-dark px-3 py-2">
            <i class="fas fa-exchange-alt me-2" style="color: #6f42c1;"></i>
            <strong>@Model.TransferID</strong>
        </span>
        <span class="badge @(isApproved ? "bg-success" : "bg-warning")">@(Model.WorkFlowStatus ?? "—")</span>
    </div>
    <div>
        @if (!isApproved)
        {
            <a asp-action="Edit" asp-route-id="@Model.TransferID" class="btn btn-primary me-2">
                <i class="fas fa-edit me-2"></i>Edit
            </a>
        }
        @if (isApproved)
        {
            <a asp-action="TransferLetter" asp-route-id="@Model.TransferID" target="_blank" class="btn btn-sm btn-success me-2" title="Transfer Letter">
                <i class="fas fa-file-alt"></i>
            </a>
        }
        <a asp-controller="Customer" asp-action="Details" asp-route-id="@Model.CustomerID" class="btn btn-outline-info me-2">
            <i class="fas fa-user me-2"></i>Customer File
        </a>
        <a asp-action="Index" class="btn btn-outline-primary">
            <i class="fas fa-arrow-left me-2"></i>Back to List
        </a>
    </div>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-header p-0">
        <ul class="nav nav-tabs customer-tabs" id="transferTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="summary-tab" data-bs-toggle="tab" data-bs-target="#summary" type="button" role="tab">Summary</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="seller-tab" data-bs-toggle="tab" data-bs-target="#seller" type="button" role="tab">Seller</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="buyer-tab" data-bs-toggle="tab" data-bs-target="#buyer" type="button" role="tab">Buyer</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="payment-tab" data-bs-toggle="tab" data-bs-target="#payment" type="button" role="tab">Payment & Fee</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="comments-tab" data-bs-toggle="tab" data-bs-target="#comments" type="button" role="tab">Details & Comments</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="attachments-tab" data-bs-toggle="tab" data-bs-target="#attachments" type="button" role="tab"><i class="fas fa-paperclip me-1"></i>Attachments</button>
            </li>
        </ul>
    </div>
    <div class="card-body">
        <div class="tab-content" id="transferTabContent">
            <div class="tab-pane fade show active" id="summary" role="tabpanel">
                <div class="row">
                    <div class="col-md-6 mb-2">
                        <div class="detail-field">
                            <label><i class="fas fa-id-badge me-2"></i>Transfer ID</label>
                            <p><code>@Model.TransferID</code></p>
                        </div>
                    </div>
                    <div class="col-md-6 mb-2">
                        <div class="detail-field">
                            <label><i class="fas fa-folder me-2"></i>Customer ID (File)</label>
                            <p><a asp-controller="Customer" asp-action="Details" asp-route-id="@Model.CustomerID">@Model.CustomerID</a></p>
                        </div>
                    </div>
                    <div class="col-md-6 mb-2">
                        <div class="detail-field">
                            <label><i class="fas fa-project-diagram me-2"></i>Project</label>
                            <p>@(Model.Customer?.PaymentPlan?.Project?.ProjectName ?? "—")</p>
                        </div>
                    </div>
                    <div class="col-md-6 mb-2">
                        <div class="detail-field">
                            <label><i class="fas fa-route me-2"></i>Workflow Status</label>
                            <p><span class="badge @(isApproved ? "bg-success" : "bg-warning")">@(Model.WorkFlowStatus ?? "—")</span></p>
                        </div>
                    </div>
                    <div class="col-md-6 mb-2">
                        <div class="detail-field">
                            <label><i class="fas fa-calendar me-2"></i>Created</label>
                            <p>@Model.CreatedAt.ToString("MMM dd, yyyy HH:mm")</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="tab-pane fade" id="seller" role="tabpanel">
                <div class="row">
                    <div class="col-md-6 mb-2"><div class="detail-field"><label>Seller Name</label><p>@(Model.SellerName ?? "—")</p></div></div>
                    <div class="col-md-6 mb-2"><div class="detail-field"><label>Father Name</label><p>@(Model.SellerFatherName ?? "—")</p></div></div>
                    <div class="col-md-6 mb-2"><div class="detail-field"><label>CNIC</label><p>@(Model.SellerCNIC ?? "—")</p></div></div>
                    <div class="col-md-6 mb-2"><div class="detail-field"><label>Contact</label><p>@(Model.SellerContact ?? "—")</p></div></div>
                    <div class="col-12 mb-2"><div class="detail-field"><label>Address</label><p>@(Model.SellerAddress ?? "—")</p></div></div>
                </div>
            </div>
            <div class="tab-pane fade" id="buyer" role="tabpanel">
                <div class="row">
                    <div class="col-md-6 mb-2"><div class="detail-field"><label>Buyer Name</label><p>@(Model.BuyerName ?? "—")</p></div></div>
                    <div class="col-md-6 mb-2"><div class="detail-field"><label>Father Name</label><p>@(Model.BuyerFatherName ?? "—")</p></div></div>
                    <div class="col-md-6 mb-2"><div class="detail-field"><label>CNIC</label><p>@(Model.BuyerCNIC ?? "—")</p></div></div>
                    <div class="col-md-6 mb-2"><div class="detail-field"><label>Passport Number</label><p>@(Model.BuyerPassportNo ?? "—")</p></div></div>
                    <div class="col-md-6 mb-2"><div class="detail-field"><label>Contact</label><p>@(Model.BuyerContact ?? "—")</p></div></div>
                    <div class="col-12 mb-2"><div class="detail-field"><label>Address</label><p>@(Model.BuyerAddress ?? "—")</p></div></div>
                    <div class="col-md-6 mb-2"><div class="detail-field"><label>City</label><p>@(Model.BuyerCity ?? "—")</p></div></div>
                    <div class="col-md-6 mb-2"><div class="detail-field"><label>Country</label><p>@(Model.BuyerCountry ?? "—")</p></div></div>
                </div>
            </div>
            <div class="tab-pane fade" id="payment" role="tabpanel">
                <div class="row">
                    <div class="col-md-6 mb-2"><div class="detail-field"><label>Transfer Fee Due</label><p>@(Model.TransferFeeDue?.ToString("N2") ?? "—")</p></div></div>
                    <div class="col-md-6 mb-2"><div class="detail-field"><label>Transfer Fee Paid</label><p>@(Model.TransferFeePaid?.ToString("N2") ?? "—")</p></div></div>
                    <div class="col-md-6 mb-2"><div class="detail-field"><label>Payment Date</label><p>@(Model.PaymentDate?.ToString("MMM dd, yyyy") ?? "—")</p></div></div>
                    <div class="col-md-6 mb-2"><div class="detail-field"><label>Payment Mode</label><p>@(Model.PaymentMode ?? "—")</p></div></div>
                    <div class="col-md-6 mb-2"><div class="detail-field"><label>Challan No</label><p>@(Model.PaymentChallanNo ?? "—")</p></div></div>
                </div>
            </div>
            <div class="tab-pane fade" id="comments" role="tabpanel">
                <div class="mb-2"><div class="detail-field"><label>Details</label><p>@(Model.Details ?? "—")</p></div></div>
                <div class="mb-2"><div class="detail-field"><label>CRO Comments</label><p>@(Model.CROComments ?? "—")</p></div></div>
                <div class="mb-2"><div class="detail-field"><label>Accounts Comments</label><p>@(Model.AccountsComments ?? "—")</p></div></div>
                <div class="mb-2"><div class="detail-field"><label>Transfer Comments</label><p>@(Model.TransferComments ?? "—")</p></div></div>
            </div>
            <div class="tab-pane fade" id="attachments" role="tabpanel">
                <p class="text-muted small mb-3">Upload documents for Seller or Buyer. Accepted: JPG, PNG, GIF, BMP, PDF. Max 8MB per file.</p>
                <div class="row">
                    <div class="col-md-6 mb-4">
                        <div class="card h-100" style="border-color: rgb(104, 167, 226);">
                            <div class="card-header text-white" style="background: linear-gradient(135deg, rgb(104, 167, 226) 0%, rgb(72, 123, 165) 100%);">
                                <h6 class="mb-0"><i class="fas fa-user-tag me-2"></i>Seller Attachments</h6>
                            </div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <label class="form-label">Upload file</label>
                                    <input type="file" id="sellerFile" class="form-control form-control-sm" accept=".jpg,.jpeg,.png,.gif,.bmp,.pdf" />
                                    <input type="text" id="sellerDescription" class="form-control form-control-sm mt-1" placeholder="Description (optional)" />
                                    <button type="button" class="btn btn-sm text-white mt-2" style="background: linear-gradient(135deg, rgb(104, 167, 226) 0%, rgb(72, 123, 165) 100%);" id="uploadSellerBtn">
                                        <i class="fas fa-upload me-1"></i>Upload
                                    </button>
                                </div>
                                <div id="sellerAttachmentsList" class="transfer-att-list"></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 mb-4">
                        <div class="card h-100" style="border-color: rgb(104, 167, 226);">
                            <div class="card-header text-white" style="background: linear-gradient(135deg, rgb(104, 167, 226) 0%, rgb(72, 123, 165) 100%);">
                                <h6 class="mb-0"><i class="fas fa-user-plus me-2"></i>Buyer Attachments</h6>
                            </div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <label class="form-label">Upload file</label>
                                    <input type="file" id="buyerFile" class="form-control form-control-sm" accept=".jpg,.jpeg,.png,.gif,.bmp,.pdf" />
                                    <input type="text" id="buyerDescription" class="form-control form-control-sm mt-1" placeholder="Description (optional)" />
                                    <button type="button" class="btn btn-sm text-white mt-2" style="background: linear-gradient(135deg, rgb(104, 167, 226) 0%, rgb(72, 123, 165) 100%);" id="uploadBuyerBtn">
                                        <i class="fas fa-upload me-1"></i>Upload
                                    </button>
                                </div>
                                <div id="buyerAttachmentsList" class="transfer-att-list"></div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="row mt-3">
                    <div class="col-12">
                        <hr class="my-3" />
                        <h6 class="mb-2"><i class="fas fa-fingerprint me-2"></i>Biometric (fingerprint)</h6>
                    </div>
                    <div class="col-md-6 mb-2">
                        <div class="detail-field">
                            <label class="small">Seller biometric</label>
                            <p class="mb-0"><span class="badge @(string.IsNullOrEmpty(Model.SellerBiometric) ? "bg-secondary" : "bg-success")">@(string.IsNullOrEmpty(Model.SellerBiometric) ? "Not captured" : "Stored")</span></p>
                        </div>
                    </div>
                    <div class="col-md-6 mb-2">
                        <div class="detail-field">
                            <label class="small">Buyer biometric</label>
                            <p class="mb-0"><span class="badge @(string.IsNullOrEmpty(Model.BuyerBiometric) ? "bg-secondary" : "bg-success")">@(string.IsNullOrEmpty(Model.BuyerBiometric) ? "Not captured" : "Stored")</span></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .customer-tabs { border-bottom: 2px solid rgb(72, 123, 165); background: linear-gradient(135deg, #f8f9fa 0%, #e8eef5 100%); padding: 0.5rem 1rem 0; }
    .customer-tabs .nav-link { border: none; color: var(--text-secondary); font-weight: 500; }
    .customer-tabs .nav-link.active { color: rgb(72, 123, 165); border-bottom: 2px solid rgb(72, 123, 165); background: transparent; }
    .detail-field label { font-weight: 600; color: var(--text-secondary); margin-bottom: 0.25rem; }
    .detail-field p { margin: 0; }
    .transfer-att-list .att-item { display: flex; justify-content: space-between; align-items: center; padding: 6px 0; border-bottom: 1px solid #eee; }
    .transfer-att-list .att-item:last-child { border-bottom: none; }
</style>

@section Scripts {
<script>
(function() {
    var transferId = '@Model.TransferID';
    var token = document.querySelector('input[name="__RequestVerificationToken"]');
    function getToken() { return token ? token.value : ''; }

    function loadAttachments() {
        $.ajax({
            url: '@Url.Action("GetAttachments", "Transfer")',
            method: 'GET',
            data: { transferId: transferId },
            success: function(res) {
                if (res.success && res.attachments) {
                    renderList('sellerAttachmentsList', res.attachments.filter(function(a) { return a.attachmentType === 'Seller'; }));
                    renderList('buyerAttachmentsList', res.attachments.filter(function(a) { return a.attachmentType === 'Buyer'; }));
                }
            }
        });
    }

    function renderList(containerId, items) {
        var $c = $('#' + containerId);
        $c.empty();
        if (!items || items.length === 0) {
            $c.html('<p class="text-muted mb-0 small"><i class="fas fa-inbox me-1"></i>No attachments</p>');
            return;
        }
        items.forEach(function(a) {
            var isImg = a.fileType && a.fileType.indexOf('image') === 0;
            var isPdf = a.fileType && a.fileType.indexOf('pdf') >= 0;
            var icon = isImg ? 'fa-image' : (isPdf ? 'fa-file-pdf text-danger' : 'fa-file');
            var row = '<div class="att-item">' +
                '<span><i class="fas ' + icon + ' me-2"></i>' + (a.fileName || 'File') + '</span>' +
                '<span>' +
                '<a href="' + a.filePath + '" target="_blank" class="btn btn-sm btn-outline-primary me-1"><i class="fas fa-eye"></i></a>' +
                '<button type="button" class="btn btn-sm btn-outline-danger delete-att" data-id="' + a.attachmentID + '"><i class="fas fa-trash"></i></button>' +
                '</span></div>';
            $c.append(row);
        });
        $c.find('.delete-att').on('click', function() {
            var id = $(this).data('id');
            if (!confirm('Delete this attachment?')) return;
            $.post('@Url.Action("DeleteAttachment", "Transfer")', { __RequestVerificationToken: getToken(), attachmentId: id })
                .done(function(r) { if (r.success) loadAttachments(); else alert(r.message); })
                .fail(function() { alert('Error deleting'); });
        });
    }

    function upload(type, fileInputId, descId, btnId) {
        var fileInput = document.getElementById(fileInputId);
        var descInput = document.getElementById(descId);
        var btn = document.getElementById(btnId);
        if (!fileInput || !fileInput.files || !fileInput.files[0]) {
            alert('Please select a file.');
            return;
        }
        var fd = new FormData();
        fd.append('transferId', transferId);
        fd.append('file', fileInput.files[0]);
        fd.append('attachmentType', type);
        fd.append('description', descInput ? descInput.value : '');
        fd.append('__RequestVerificationToken', getToken());
        $(btn).prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-1"></i>Uploading...');
        $.ajax({
            url: '@Url.Action("UploadAttachment", "Transfer")',
            method: 'POST',
            data: fd,
            processData: false,
            contentType: false,
            success: function(r) {
                if (r.success) {
                    fileInput.value = '';
                    if (descInput) descInput.value = '';
                    loadAttachments();
                } else alert(r.message || 'Upload failed');
                $(btn).prop('disabled', false).html('<i class="fas fa-upload me-1"></i>Upload');
            },
            error: function() {
                alert('Upload failed.');
                $(btn).prop('disabled', false).html('<i class="fas fa-upload me-1"></i>Upload');
            }
        });
    }

    $('#attachments-tab').on('shown.bs.tab', function() { loadAttachments(); });
    if ($('#attachments-tab').hasClass('active')) loadAttachments();

    $('#uploadSellerBtn').on('click', function() { upload('Seller', 'sellerFile', 'sellerDescription', 'uploadSellerBtn'); });
    $('#uploadBuyerBtn').on('click', function() { upload('Buyer', 'buyerFile', 'buyerDescription', 'uploadBuyerBtn'); });
})();
</script>
}
