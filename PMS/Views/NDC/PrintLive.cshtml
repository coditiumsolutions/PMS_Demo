@model PMS.Models.NDC

@{
    Layout = null;
    ViewData["Title"] = "No Dues Certificate - " + Model.NDCID;
    var orgName = "ZKB";
    var orgSubName = "Property Management System";
    var appNo = Model.NDCID;
    var regNo = Model.CustomerID ?? "—";
    var ndcType = string.IsNullOrWhiteSpace(Model.NDCType) ? "NDC" : Model.NDCType;
    var remainingDues = Math.Max(Model.RemainingDues ?? 0m, 0m);
    var transferFeeDue = Math.Max(Model.TransferFeeAmount ?? 0m, 0m);
    var totalOutstanding = remainingDues + transferFeeDue;
    var hasAnyDue = totalOutstanding > 0m;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Juba Smart City PMS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/juba-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
</head>
<body>

<!-- Print/Download Controls -->
<div class="d-flex justify-content-between align-items-center mb-3 no-print">
    <h3 class="mb-0"><i class="fas fa-certificate me-2"></i>No Dues Certificate</h3>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-secondary btn-sm" onclick="window.print()"><i class="fas fa-print me-1"></i>Print</button>
    </div>
</div>

<div class="a4-container">
    <div id="ndc-root">
        <!-- Header Section (reference style) -->
        <div class="a4-header">
            <div class="header-grid">
                <div class="header-logo-wrap">
                    <img src="~/images/logo.jpeg" alt="Organization Logo" class="a4-logo" />
                </div>
                <div class="header-center">
                    <div class="org-name">@orgName</div>
                    <div class="org-subname">@orgSubName</div>
                    <div class="statement-title">Statement of NDC</div>
                </div>
                <div class="header-meta">
                    <div><strong>Type:</strong> @ndcType</div>
                    <div><strong>Registration No.:</strong> @regNo</div>
                    <div><strong>Application No.:</strong> @appNo</div>
                </div>
            </div>
            <div class="header-secondary mt-2">
                <div><strong>Expiry Date:</strong> @(Model.NDCExpiryDate?.ToString("MMM dd, yyyy") ?? "—")</div>
                <div><strong>Initiating Office:</strong> @(Model.Customer?.City ?? "Head Office")</div>
            </div>
        </div>

        <!-- NDC & Customer Information -->
        <div class="a4-section">
            <p class="certificate-paragraph">
                The details of dues till date against registration no. <strong>@(Model.CustomerID ?? "—")</strong>
                for customer/applicant <strong>@(Model.Customer?.FullName ?? "—")</strong> under plan
                <strong>@(Model.Customer?.PaymentPlan?.PlanName ?? "—")</strong> in project
                <strong>@(Model.Customer?.PaymentPlan?.Project?.ProjectName ?? "—")</strong> are as follows:
            </p>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.Title))
        {
            <div class="a4-section">
                <div class="a4-section-title">Title / Reference</div>
                <div class="a4-info-block" style="margin-bottom: 0;">
                    <div class="a4-info-value">@Model.Title</div>
                </div>
            </div>
        }

        @if (hasAnyDue)
        {
            <div class="a4-section">
                <div class="a4-section-title">Dues Summary</div>
                <table class="a4-table">
                    <thead>
                        <tr>
                            <th class="text-start">Particulars</th>
                            <th class="text-end">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (remainingDues > 0m)
                        {
                            <tr>
                                <td class="text-start">Remaining Installment Dues</td>
                                <td class="text-end">@remainingDues.ToString("N0")</td>
                            </tr>
                        }
                        <tr>
                            <td class="text-start">Transfer Fee (Due)</td>
                            <td class="text-end">@transferFeeDue.ToString("N0")</td>
                        </tr>
                        <tr>
                            <td class="text-start"><strong>Total Dues Payable</strong></td>
                            <td class="text-end"><strong>@totalOutstanding.ToString("N0")</strong></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.Comments))
        {
            <div class="a4-section">
                <div class="a4-section-title">Comments</div>
                <div class="a4-info-block" style="margin-bottom: 0;">
                    <div class="a4-info-value">@Model.Comments</div>
                </div>
            </div>
        }

        @{
            var ndcAttachments = ViewBag.NdcAttachments as List<PMS.Models.Attachment> ?? new List<PMS.Models.Attachment>();
        }
        @if (ndcAttachments.Count > 0)
        {
            <div class="a4-section">
                <div class="a4-section-title">Attachments</div>
                <table class="a4-table">
                    <thead>
                        <tr>
                            <th class="text-start">File</th>
                            <th class="text-start">Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var att in ndcAttachments)
                        {
                            <tr>
                                <td class="text-start">@(att.FileName ?? "Attachment")</td>
                                <td class="text-start">@(string.IsNullOrWhiteSpace(att.Description) ? "—" : att.Description)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <div class="a4-footer">
            <div>This is a system generated statement and does not require a signature.</div>
            <div style="margin-top: 10px;">
                <strong>@orgName - @orgSubName</strong><br>
                Generated on: @DateTime.Now.ToString("MMMM dd, yyyy at hh:mm tt")
            </div>
        </div>
    </div>
</div>

<style>
    .a4-container { width: 210mm; min-height: 297mm; margin: 0 auto; padding: 15mm; background: white; box-shadow: 0 0 10px rgba(0,0,0,0.1); font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; overflow: hidden; }
    .a4-header { border-bottom: 2px solid #333; padding-bottom: 10px; margin-bottom: 12px; }
    .header-grid { display: grid; grid-template-columns: 100px 1fr 210px; align-items: center; gap: 10px; }
    .header-logo-wrap { display: flex; align-items: center; justify-content: center; }
    .header-center { text-align: center; }
    .org-name { font-size: 24px; font-weight: 800; color: #111; line-height: 1.1; }
    .org-subname { font-size: 16px; font-weight: 700; color: #111; line-height: 1.15; margin-top: 1px; }
    .statement-title { font-size: 20px; font-weight: 800; margin-top: 6px; }
    .header-meta { font-size: 12px; line-height: 1.35; }
    .header-secondary { font-size: 12px; display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-left: 110px; }
    .certificate-paragraph { font-size: 14px; line-height: 1.45; margin: 0; }
    .a4-section { margin-bottom: 12px; }
    .a4-section-title { font-size: 13px; font-weight: bold; color: #333; margin-bottom: 8px; padding-bottom: 3px; border-bottom: 1px solid #ddd; }
    .a4-info-block { background: #f8f9fa; padding: 10px; border-radius: 5px; border-left: 4px solid #007bff; }
    .a4-info-value { color: #333; }
    .a4-table { width: 100%; border-collapse: collapse; font-size: 9px; margin-bottom: 10px; }
    .a4-table th { background: #f8f9fa; border: 1px solid #ddd; padding: 4px 3px; font-weight: bold; text-align: center; font-size: 9px; }
    .a4-table td { border: 1px solid #ddd; padding: 4px 3px; text-align: center; font-size: 9px; }
    .a4-table .text-start { text-align: left; }
    .a4-table .text-end { text-align: right; }
    .a4-footer { margin-top: 10px; padding-top: 8px; border-top: 1px solid #ddd; font-size: 9px; color: #666; text-align: center; }
    .a4-logo { max-width: 84px; height: auto; }
    @@media (max-width: 992px) { .header-grid { grid-template-columns: 1fr; } .header-secondary { margin-left: 0; grid-template-columns: 1fr; } .header-center { text-align: left; } }
    @@media print { @@page { size: A4; margin: 0; } body { margin: 0; padding: 0; background: white; } .a4-container { width: 210mm; min-height: 297mm; margin: 0; padding: 12mm; box-shadow: none; page-break-after: avoid; page-break-inside: avoid; overflow: hidden; } .no-print { display: none !important; } .a4-section { page-break-inside: avoid; margin-bottom: 8px; } .a4-header { margin-bottom: 8px; padding-bottom: 8px; } .a4-footer { margin-top: 8px; padding-top: 5px; } }
    @@media screen { body { background: #f5f5f5; padding: 20px; } .a4-container { margin: 20px auto; } }
</style>

</body>
</html>
