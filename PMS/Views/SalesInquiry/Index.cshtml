@section Scripts {
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/dataTables.bootstrap5.min.js"></script>
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/dataTables.bootstrap5.min.css" />

    <script>
        $(document).ready(function () {
            $('#inquiriesTable').DataTable({
                "order": [[4, "desc"]], // Sort by date descending (Date column is now at index 4)
                "pageLength": 25,
                "language": {
                    "search": "Search inquiries:",
                    "lengthMenu": "Show _MENU_ inquiries per page",
                    "info": "Showing _START_ to _END_ of _TOTAL_ inquiries",
                    "infoEmpty": "No inquiries found",
                    "infoFiltered": "(filtered from _MAX_ total inquiries)"
                }
            });

            // Remove any existing backdrops
            $('.modal-backdrop').remove();

            // Ensure Bootstrap 5 modals have no backdrop and stay above UI (same as Users page)
            $('.modal').on('show.bs.modal', function(e) {
                // Remove any existing backdrops
                $('.modal-backdrop').remove();
                // Ensure instance exists and set backdrop to false
                var modalInstance = bootstrap.Modal.getOrCreateInstance(this, { backdrop: false });
                if (modalInstance && modalInstance._config) {
                    modalInstance._config.backdrop = false;
                }
            });

            // Remove backdrops on shown/hidden as a safeguard
            $('.modal').on('shown.bs.modal hidden.bs.modal', function() {
                $('.modal-backdrop').remove();
            });
        });

        function deleteInquiry(inquiryId) {
            if (confirm('Are you sure you want to delete this inquiry?\n\nThis action cannot be undone.')) {
                document.getElementById('deleteInquiryId').value = inquiryId;
                document.getElementById('deleteForm').submit();
            }
        }

        function markContacted(inquiryId, method) {
            // Set timeout to allow the contact action to trigger first
            setTimeout(function() {
                document.getElementById('contactedInquiryId').value = inquiryId;
                document.getElementById('contactedMethod').value = method;
                document.getElementById('contactedForm').submit();
            }, 500);
        }
    </script>
}

