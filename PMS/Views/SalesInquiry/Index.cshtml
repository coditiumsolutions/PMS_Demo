@model IEnumerable<PMS.Models.PropertyInquiry>

@{
    ViewData["Title"] = "Sales Inquiries";
    var selectedStatus = ViewBag.SelectedStatus as string ?? "All";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div class="d-flex gap-2 align-items-center">
        <div class="btn-group">
            <button type="button" class="btn btn-primary dropdown-toggle" data-bs-toggle="dropdown">
                <i class="fas fa-plus me-2"></i>New Inquiry
            </button>
            <ul class="dropdown-menu">
                <li><a class="dropdown-item" href="#" onclick="showNewInquiryModal()">
                    <i class="fas fa-envelope me-2"></i>Property Inquiry
                </a></li>
            </ul>
        </div>
        <a asp-action="PerformanceReport" class="btn btn-outline-primary">
            <i class="fas fa-chart-line me-2"></i>Performance Report
        </a>
    </div>
</div>

<!-- Filter Buttons -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <label class="fw-bold me-2">Filter by Status:</label>
            <a asp-action="Index" asp-route-status="All" 
               class="btn btn-sm @(selectedStatus == "All" ? "btn-primary" : "btn-outline-primary")">
                <i class="fas fa-list me-1"></i>All
            </a>
            <a asp-action="Index" asp-route-status="New" 
               class="btn btn-sm @(selectedStatus == "New" ? "btn-info" : "btn-outline-info")">
                <i class="fas fa-star me-1"></i>New
            </a>
            <a asp-action="Index" asp-route-status="Contacted" 
               class="btn btn-sm @(selectedStatus == "Contacted" ? "btn-warning" : "btn-outline-warning")">
                <i class="fas fa-phone me-1"></i>Contacted
            </a>
            <a asp-action="Index" asp-route-status="Follow-up" 
               class="btn btn-sm @(selectedStatus == "Follow-up" ? "btn-secondary" : "btn-outline-secondary")">
                <i class="fas fa-clock me-1"></i>Follow-up
            </a>
            <a asp-action="Index" asp-route-status="Converted" 
               class="btn btn-sm @(selectedStatus == "Converted" ? "btn-success" : "btn-outline-success")">
                <i class="fas fa-check-circle me-1"></i>Converted
            </a>
            <a asp-action="Index" asp-route-status="Closed" 
               class="btn btn-sm @(selectedStatus == "Closed" ? "btn-danger" : "btn-outline-danger")">
                <i class="fas fa-times-circle me-1"></i>Closed
            </a>
        </div>
    </div>
</div>

<!-- Summary Cards -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="avatar-sm rounded-circle bg-primary bg-soft text-primary">
                            <i class="fas fa-envelope font-size-24"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="mb-1 text-muted">Total Inquiries</h6>
                        <h4 class="mb-0">@ViewBag.TotalInquiries</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="avatar-sm rounded-circle bg-info bg-soft text-info">
                            <i class="fas fa-star font-size-24"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="mb-1 text-muted">New Leads</h6>
                        <h4 class="mb-0">@ViewBag.NewInquiries</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="avatar-sm rounded-circle bg-warning bg-soft text-warning">
                            <i class="fas fa-phone font-size-24"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="mb-1 text-muted">Contacted</h6>
                        <h4 class="mb-0">@ViewBag.ContactedInquiries</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="avatar-sm rounded-circle bg-success bg-soft text-success">
                            <i class="fas fa-check-circle font-size-24"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="mb-1 text-muted">Converted</h6>
                        <h4 class="mb-0">@ViewBag.ConvertedInquiries</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Inquiries Table -->
<div class="card border-0 shadow-sm">
    <div class="card-header" style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);">
        <h5 class="mb-0 text-white">
            <i class="fas fa-list me-2"></i>All Inquiries (@selectedStatus)
        </h5>
    </div>
    <div class="card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table id="inquiriesTable" class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Manage</th>
                            <th>Contact Actions</th>
                            <th>Status</th>
                            <th>ID</th>
                            <th>Date</th>
                            <th>Customer Name</th>
                            <th>Phone</th>
                            <th>Email</th>
                            <th>Type</th>
                            <th>Message</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var inquiry in Model)
                        {
                            <tr class="@(inquiry.Status == "New" ? "table-warning" : "")">
                                <!-- Manage Column -->
                                <td>
                                    <div class="btn-group" role="group">
                                        <button type="button" 
                                                class="btn btn-sm btn-outline-info" 
                                                data-bs-toggle="modal" 
                                                data-bs-target="#detailsModal@(inquiry.InquiryID)"
                                                title="View Details">
                                            <i class="fas fa-eye"></i>
                                        </button>
                                        @if (ViewBag.CanEdit == true)
                                        {
                                        <button type="button" 
                                                class="btn btn-sm btn-outline-primary" 
                                                data-bs-toggle="modal" 
                                                data-bs-target="#statusModal@(inquiry.InquiryID)"
                                                title="Update Status">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        }
                                        @if (ViewBag.CanDelete == true)
                                        {
                                        <button type="button" 
                                                class="btn btn-sm btn-outline-danger" 
                                                onclick="deleteInquiry(@inquiry.InquiryID)"
                                                title="Delete">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                        }
                                    </div>
                                </td>
                                <!-- Contact Actions Column -->
                                <td>
                                    <div class="btn-group-vertical btn-group-sm" role="group">
                                        <!-- Call Button -->
                                        <a href="tel:@inquiry.PhoneNumber" 
                                           class="btn btn-sm btn-success mb-1"
                                           onclick="markContacted(@inquiry.InquiryID, 'Call')"
                                           title="Call Customer">
                                            <i class="fas fa-phone me-1"></i>Call
                                        </a>
                                        <!-- WhatsApp Button -->
                                        <a href="https://wa.me/@inquiry.PhoneNumber.Replace("+", "").Replace("-", "").Replace(" ", "")" 
                                           target="_blank"
                                           class="btn btn-sm btn-success mb-1"
                                           onclick="markContacted(@inquiry.InquiryID, 'WhatsApp')"
                                           title="WhatsApp">
                                            <i class="fab fa-whatsapp me-1"></i>WhatsApp
                                        </a>
                                        <!-- Email Button -->
                                        @if (!string.IsNullOrEmpty(inquiry.EmailAddress))
                                        {
                                            <a href="mailto:@inquiry.EmailAddress?subject=Re: Property Inquiry - JUBA Smart City" 
                                               class="btn btn-sm btn-primary"
                                               onclick="markContacted(@inquiry.InquiryID, 'Email')"
                                               title="Send Email">
                                                <i class="fas fa-envelope me-1"></i>Email
                                            </a>
                                        }
                                    </div>
                                </td>
                                <!-- Status Column -->
                                <td>
                                    @if (inquiry.Status == "New")
                                    {
                                        <span class="badge bg-info">
                                            <i class="fas fa-star me-1"></i>@inquiry.Status
                                        </span>
                                    }
                                    else if (inquiry.Status == "Contacted")
                                    {
                                        <span class="badge bg-warning">
                                            <i class="fas fa-phone me-1"></i>@inquiry.Status
                                        </span>
                                    }
                                    else if (inquiry.Status == "Follow-up")
                                    {
                                        <span class="badge bg-secondary">
                                            <i class="fas fa-clock me-1"></i>@inquiry.Status
                                        </span>
                                    }
                                    else if (inquiry.Status == "Converted")
                                    {
                                        <span class="badge bg-success">
                                            <i class="fas fa-check-circle me-1"></i>@inquiry.Status
                                        </span>
                                    }
                                    else if (inquiry.Status == "Closed")
                                    {
                                        <span class="badge bg-danger">
                                            <i class="fas fa-times-circle me-1"></i>@inquiry.Status
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@inquiry.Status</span>
                                    }
                                </td>
                                <!-- ID Column -->
                                <td><code>#@inquiry.InquiryID</code></td>
                                <!-- Date Column -->
                                <td>
                                    <small>
                                        <i class="fas fa-calendar-alt text-muted me-1"></i>
                                        @inquiry.SubmittedAt.ToString("MMM dd, yyyy")
                                        <br>
                                        <i class="fas fa-clock text-muted me-1"></i>
                                        @inquiry.SubmittedAt.ToString("hh:mm tt")
                                    </small>
                                </td>
                                <!-- Customer Name Column -->
                                <td>
                                    <strong>@inquiry.FullName</strong>
                                    @if (inquiry.IsContacted)
                                    {
                                        <br><small class="text-success"><i class="fas fa-check-circle me-1"></i>Contacted</small>
                                    }
                                </td>
                                <!-- Phone Column -->
                                <td>
                                    <a href="tel:@inquiry.PhoneNumber" class="text-decoration-none">
                                        <i class="fas fa-phone text-primary me-1"></i>@inquiry.PhoneNumber
                                    </a>
                                </td>
                                <!-- Email Column -->
                                <td>
                                    @if (!string.IsNullOrEmpty(inquiry.EmailAddress))
                                    {
                                        <a href="mailto:@inquiry.EmailAddress" class="text-decoration-none">
                                            <i class="fas fa-envelope text-primary me-1"></i>@inquiry.EmailAddress
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <!-- Type Column -->
                                <td>
                                    @if (!string.IsNullOrEmpty(inquiry.InquiryType))
                                    {
                                        <span class="badge bg-info">@inquiry.InquiryType</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">General</span>
                                    }
                                </td>
                                <!-- Message Column (Last) -->
                                <td>
                                    @if (!string.IsNullOrEmpty(inquiry.Message))
                                    {
                                        <div style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                            @inquiry.Message
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-inbox fa-4x mb-3 text-muted"></i>
                <h5 class="text-muted">No Inquiries Found!</h5>
                <p class="text-muted">Website inquiries will appear here when customers submit the form.</p>
            </div>
        }
    </div>
</div>

<!-- Inquiry Detail Modals -->
@foreach (var inquiry in Model)
{
    <!-- Details Modal -->
    <div class="modal fade" id="detailsModal@(inquiry.InquiryID)" tabindex="-1" aria-labelledby="detailsModalLabel@(inquiry.InquiryID)" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header" style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);">
                    <h5 class="modal-title text-white" id="detailsModalLabel@(inquiry.InquiryID)">
                        <i class="fas fa-envelope-open-text me-2"></i>Inquiry Details - #@inquiry.InquiryID
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="text-muted small">Full Name</label>
                            <p class="mb-0 fw-bold">@inquiry.FullName</p>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small">Phone Number</label>
                            <p class="mb-0">
                                <a href="tel:@inquiry.PhoneNumber" class="text-decoration-none">
                                    <i class="fas fa-phone text-success me-1"></i>@inquiry.PhoneNumber
                                </a>
                            </p>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small">Email Address</label>
                            <p class="mb-0">
                                @if (!string.IsNullOrEmpty(inquiry.EmailAddress))
                                {
                                    <a href="mailto:@inquiry.EmailAddress" class="text-decoration-none">
                                        <i class="fas fa-envelope text-primary me-1"></i>@inquiry.EmailAddress
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted">Not provided</span>
                                }
                            </p>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small">Inquiry Type</label>
                            <p class="mb-0">
                                <span class="badge bg-info">@(inquiry.InquiryType ?? "General")</span>
                            </p>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small">Submitted Date</label>
                            <p class="mb-0">@inquiry.SubmittedAt.ToString("MMMM dd, yyyy hh:mm tt")</p>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small">Status</label>
                            <p class="mb-0">
                                @if (inquiry.Status == "New")
                                {
                                    <span class="badge bg-info">@inquiry.Status</span>
                                }
                                else if (inquiry.Status == "Converted")
                                {
                                    <span class="badge bg-success">@inquiry.Status</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning">@inquiry.Status</span>
                                }
                            </p>
                        </div>
                        @if (!string.IsNullOrEmpty(inquiry.AssignedTo))
                        {
                            <div class="col-md-6">
                                <label class="text-muted small">Assigned To</label>
                                <p class="mb-0"><i class="fas fa-user-tie me-1"></i>@inquiry.AssignedTo</p>
                            </div>
                        }
                        @if (inquiry.FollowUpDate.HasValue)
                        {
                            <div class="col-md-6">
                                <label class="text-muted small">Follow-up Date</label>
                                <p class="mb-0 text-warning">
                                    <i class="fas fa-calendar-check me-1"></i>
                                    @inquiry.FollowUpDate.Value.ToString("MMMM dd, yyyy")
                                </p>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(inquiry.IPAddress))
                        {
                            <div class="col-md-6">
                                <label class="text-muted small">IP Address</label>
                                <p class="mb-0"><code>@inquiry.IPAddress</code></p>
                            </div>
                        }
                        <div class="col-12">
                            <label class="text-muted small">Message</label>
                            <div class="alert alert-light mb-0">
                                @(inquiry.Message ?? "No message provided")
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(inquiry.Notes))
                        {
                            <div class="col-12">
                                <label class="text-muted small">Internal Notes</label>
                                <div class="alert alert-info mb-0">
                                    @Html.Raw(inquiry.Notes.Replace("\n", "<br>"))
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <a href="tel:@inquiry.PhoneNumber" class="btn btn-success">
                        <i class="fas fa-phone me-1"></i>Call Now
                    </a>
                    <a href="https://wa.me/@inquiry.PhoneNumber.Replace("+", "").Replace("-", "").Replace(" ", "")" 
                       target="_blank" class="btn btn-success">
                        <i class="fab fa-whatsapp me-1"></i>WhatsApp
                    </a>
                    @if (!string.IsNullOrEmpty(inquiry.EmailAddress))
                    {
                        <a href="mailto:@inquiry.EmailAddress" class="btn btn-primary">
                            <i class="fas fa-envelope me-1"></i>Email
                        </a>
                    }
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Status Update Modal -->
    <div class="modal fade" id="statusModal@(inquiry.InquiryID)" tabindex="-1" aria-labelledby="statusModalLabel@(inquiry.InquiryID)" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered modal-fullscreen-sm-down sales-inquiry-edit-modal">
            <div class="modal-content">
                <div class="modal-header" style="background: var(--primary);">
                    <h6 class="modal-title text-white" id="statusModalLabel@(inquiry.InquiryID)">
                        <i class="fas fa-edit me-2"></i>Update Inquiry - @inquiry.FullName
                    </h6>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <!-- Status Update Form -->
                    <form asp-action="UpdateStatus" method="post" class="mb-3">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="inquiryId" value="@inquiry.InquiryID" />
                        
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Update Status</label>
                            <select name="status" class="form-select" required>
                                <option value="New" selected="@(inquiry.Status == "New")">New</option>
                                <option value="Contacted" selected="@(inquiry.Status == "Contacted")">Contacted</option>
                                <option value="Follow-up" selected="@(inquiry.Status == "Follow-up")">Follow-up</option>
                                <option value="Converted" selected="@(inquiry.Status == "Converted")">Converted to Customer</option>
                                <option value="Closed" selected="@(inquiry.Status == "Closed")">Closed</option>
                            </select>
                        </div>
                        
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="fas fa-save me-1"></i>Update Status
                        </button>
                    </form>

                    <hr>

                    <!-- Add Notes Form -->
                    <form asp-action="AddNotes" method="post" class="mb-3">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="inquiryId" value="@inquiry.InquiryID" />
                        
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Add Notes</label>
                            <textarea name="notes" class="form-control" rows="3" 
                                      placeholder="Enter follow-up notes, customer feedback, etc."></textarea>
                        </div>
                        
                        <button type="submit" class="btn btn-outline-primary w-100">
                            <i class="fas fa-comment-medical me-1"></i>Add Notes
                        </button>
                    </form>

                    <hr>

                    <!-- Assign To Form -->
                    <form asp-action="AssignTo" method="post" class="mb-3">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="inquiryId" value="@inquiry.InquiryID" />
                        
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Assign To Sales Agent</label>
                            <select name="assignedTo" class="form-select">
                                <option value="">-- Unassigned --</option>
                                @{
                                    var usersList = ViewBag.Users as IEnumerable<string> ?? Enumerable.Empty<string>();
                                    foreach (var name in usersList)
                                    {
                                        if (name == inquiry.AssignedTo)
                                        {
                                            <option value="@name" selected>@name</option>
                                        }
                                        else
                                        {
                                            <option value="@name">@name</option>
                                        }
                                    }
                                }
                            </select>
                        </div>
                        
                        <button type="submit" class="btn btn-outline-secondary w-100">
                            <i class="fas fa-user-tie me-1"></i>Assign
                        </button>
                    </form>

                    <hr>

                    <!-- Set Follow-up Date Form -->
                    <form asp-action="SetFollowUp" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="inquiryId" value="@inquiry.InquiryID" />
                        
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Set Follow-up Date</label>
                            <input type="date" name="followUpDate" class="form-control" 
                                   value="@inquiry.FollowUpDate?.ToString("yyyy-MM-dd")" 
                                   min="@DateTime.Today.ToString("yyyy-MM-dd")">
                        </div>
                        
                        <button type="submit" class="btn btn-outline-warning w-100">
                            <i class="fas fa-calendar-check me-1"></i>Set Follow-up
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

<!-- Delete Form (Hidden) -->
<form id="deleteForm" asp-action="Delete" method="post" style="display: none;">
    @Html.AntiForgeryToken()
    <input type="hidden" id="deleteInquiryId" name="inquiryId" />
</form>

<!-- Mark Contacted Form (Hidden) -->
<form id="contactedForm" asp-action="MarkAsContacted" method="post" style="display: none;">
    @Html.AntiForgeryToken()
    <input type="hidden" id="contactedInquiryId" name="inquiryId" />
    <input type="hidden" id="contactedMethod" name="method" />
</form>

<style>
    .avatar-sm {
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .bg-soft {
        background-color: rgba(var(--bs-primary-rgb), 0.1) !important;
    }

    .bg-info.bg-soft {
        background-color: rgba(13, 202, 240, 0.1) !important;
    }

    .bg-warning.bg-soft {
        background-color: rgba(255, 193, 7, 0.1) !important;
    }

    .bg-success.bg-soft {
        background-color: rgba(25, 135, 84, 0.1) !important;
    }

    .font-size-24 {
        font-size: 24px;
    }

    code {
        background: rgba(156, 106, 222, 0.1);
        color: #9C6ADE;
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
    }

    .table-warning {
        background-color: rgba(255, 193, 7, 0.1) !important;
    }

    .btn-group-vertical .btn {
        font-size: 11px;
        padding: 4px 10px;
    }

    /* Inquiry Modals - No Backdrop (same as Users page) */
    .modal-backdrop {
        display: none !important;
    }

    body.modal-open .modal-backdrop {
        display: none !important;
    }

    /* Disable global dim overlay from layout on this page */
    body.modal-open::before {
        display: none !important;
        background: transparent !important;
    }

    /* Force transparent background for all modals on this page */
    .modal {
        background: transparent !important;
        /* Safety: ensure modal overlays sidebar */
        z-index: 10050 !important;
    }

    .modal.show {
        background: transparent !important;
    }

    /* Dark theme styling for inquiry modals */
