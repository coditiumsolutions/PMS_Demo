@model List<PMS.Models.SalesAgentPerformanceViewModel>
@{
    ViewData["Title"] = "Sales Agent Performance Report";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">
        <i class="fas fa-chart-line me-2"></i>Sales Agent Performance Report
    </h2>
    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Back to Inquiries
        </a>
        <button type="button" onclick="window.print()" class="btn btn-outline-primary">
            <i class="fas fa-print me-2"></i>Print
        </button>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header" style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);">
        <h5 class="mb-0 text-white">
            <i class="fas fa-user-tie me-2"></i>Inquiry counts by Sales Agent
        </h5>
    </div>
    <div class="card-body">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table id="performanceTable" class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Sales Agent</th>
                            <th>Total Assigned</th>
                            <th class="text-info">New</th>
                            <th class="text-warning">Contacted</th>
                            <th class="text-secondary">Follow-up</th>
                            <th class="text-success">Converted</th>
                            <th class="text-danger">Closed</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@(string.IsNullOrEmpty(row.AgentName) ? "(Unassigned)" : row.AgentName)</strong>
                                </td>
                                <td><span class="badge bg-primary">@row.Total</span></td>
                                <td>@row.New</td>
                                <td>@row.Contacted</td>
                                <td>@row.FollowUp</td>
                                <td>@row.Converted</td>
                                <td>@row.Closed</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted mb-0">No inquiry data to display.</p>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            if ($.fn.DataTable && $('#performanceTable tbody tr').length > 0) {
                $('#performanceTable').DataTable({
                    pageLength: 25,
                    order: [[ 1, "desc" ]]
                });
            }
        });
    </script>
}
