@model AccBankAccount
@{
    ViewData["Title"] = "New bank account";
    var heads = ViewBag.PostingHeads as IEnumerable<AccAccountHead> ?? Array.Empty<AccAccountHead>();
}
<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="AccountHeadID" class="form-label">GL ledger (posting account)</label>
            <select asp-for="AccountHeadID" class="form-select ams-ledger-select" required data-placeholder="Search GL ledger…" data-allow-clear="false">
                <option value="">— Select —</option>
                @foreach (var h in heads)
                {
                    <option value="@h.AccountHeadID">@h.AccountCode — @h.AccountName</option>
                }
            </select>
            <span asp-validation-for="AccountHeadID" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Currency" class="form-label"></label>
            <input asp-for="Currency" class="form-control" maxlength="10" />
        </div>
        <div class="col-md-6">
            <label asp-for="BankName" class="form-label"></label>
            <input asp-for="BankName" class="form-control" maxlength="150" required />
        </div>
        <div class="col-md-6">
            <label asp-for="BranchName" class="form-label"></label>
            <input asp-for="BranchName" class="form-control" maxlength="150" />
        </div>
        <div class="col-md-4">
            <label asp-for="BranchCode" class="form-label"></label>
            <input asp-for="BranchCode" class="form-control" maxlength="20" />
        </div>
        <div class="col-md-8">
            <label asp-for="AccountTitle" class="form-label"></label>
            <input asp-for="AccountTitle" class="form-control" maxlength="200" required />
        </div>
        <div class="col-md-4">
            <label asp-for="AccountNumber" class="form-label"></label>
            <input asp-for="AccountNumber" class="form-control" maxlength="50" required />
        </div>
        <div class="col-md-4">
            <label asp-for="IBAN" class="form-label"></label>
            <input asp-for="IBAN" class="form-control" maxlength="34" />
        </div>
        <div class="col-md-4">
            <label asp-for="AccountType" class="form-label"></label>
            <input asp-for="AccountType" class="form-control" maxlength="30" placeholder="e.g. Current" />
        </div>
        <div class="col-md-4">
            <label asp-for="OpeningBalance" class="form-label"></label>
            <input asp-for="OpeningBalance" class="form-control" type="number" step="0.01" />
        </div>
        <div class="col-md-4">
            <label asp-for="OpeningDate" class="form-label"></label>
            <input asp-for="OpeningDate" class="form-control" type="date" />
        </div>
        <div class="col-md-4 d-flex align-items-end">
            <div class="form-check">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label">Active</label>
            </div>
        </div>
    </div>
    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
