@model List<AccBankAccount>
@{
    ViewData["Title"] = "Bank accounts";
}
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <partial name="_AmsExportCsv" model="@("BankAccounts")" />

    <p class="mb-0 text-muted small">Link each bank account to a posting GL ledger for vouchers in later steps.</p>
    <div class="btn-group">
        @if (ViewBag.CanCreate == true)
        {
            <a class="btn btn-primary btn-sm" asp-action="Create"><i class="fas fa-plus me-1"></i>New bank account</a>
        }
        <a class="btn btn-outline-secondary btn-sm" asp-controller="AmsCoa" asp-action="Index">Chart of accounts</a>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-sm table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Bank</th>
                <th>Title / number</th>
                <th>GL code</th>
                <th>Currency</th>
                <th class="text-end">Opening</th>
                <th>Active</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var b in Model)
            {
                <tr>
                    <td>@b.BankName</td>
                    <td>@b.AccountTitle<br /><span class="text-muted small">@b.AccountNumber</span></td>
                    <td>@(b.AccountHead?.AccountCode ?? "—")</td>
                    <td>@b.Currency</td>
                    <td class="text-end">@b.OpeningBalance.ToString("N2")</td>
                    <td>@(b.IsActive ? "Yes" : "No")</td>
                    <td class="text-nowrap">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="ChequeBooks" asp-route-bankAccountId="@b.BankAccountID">Cheque books</a>
                        <a class="btn btn-sm btn-outline-secondary" asp-action="ChequeRegisters" asp-route-bankAccountId="@b.BankAccountID">Cheques</a>
                        @if (ViewBag.CanEdit == true)
                        {
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@b.BankAccountID">Edit</a>
                        }
                        @if (ViewBag.CanDelete == true)
                        {
                            ViewData["AmsDeleteEntity"] = "bankaccount";
                            ViewData["AmsDeleteId"] = b.BankAccountID;
                            <partial name="_AmsDeleteButton" />
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
@if (!Model.Any())
{
    <p class="text-muted">No bank accounts yet. Create one and pick a posting account from the COA.</p>
}
