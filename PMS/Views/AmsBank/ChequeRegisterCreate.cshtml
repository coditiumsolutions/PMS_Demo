@model AccChequeRegister
@{
    ViewData["Title"] = "New cheque (register)";
    var bankId = (int)ViewBag.BankAccountId;
    var label = ViewBag.BankLabel as string ?? "";
    var books = ViewBag.ChequeBooks as IEnumerable<AccChequeBook> ?? Array.Empty<AccChequeBook>();
}
<p class="text-muted small mb-3">@label</p>
<form asp-action="ChequeRegisterCreate" asp-route-bankAccountId="@bankId" method="post">
    @Html.AntiForgeryToken()
    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="ChequeBookID" class="form-label">Cheque book (optional)</label>
            <select asp-for="ChequeBookID" class="form-select">
                <option value="">— None —</option>
                @foreach (var b in books)
                {
                    if (Model.ChequeBookID == b.ChequeBookID)
                    {
                        <option value="@b.ChequeBookID" selected="selected">@b.SeriesFrom–@b.SeriesTo (@b.IssuedDate.ToString("yyyy-MM-dd"))</option>
                    }
                    else
                    {
                        <option value="@b.ChequeBookID">@b.SeriesFrom–@b.SeriesTo (@b.IssuedDate.ToString("yyyy-MM-dd"))</option>
                    }
                }
            </select>
            <span asp-validation-for="ChequeBookID" class="text-danger"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="ChequeNo" class="form-label"></label>
            <input asp-for="ChequeNo" class="form-control" maxlength="30" required />
        </div>
        <div class="col-md-3">
            <label asp-for="ChequeType" class="form-label"></label>
            <select asp-for="ChequeType" class="form-select">
                <option value="Payment">Payment</option>
                <option value="Receipt">Receipt</option>
            </select>
        </div>
        <div class="col-md-4">
            <label asp-for="ChequeDate" class="form-label"></label>
            <input asp-for="ChequeDate" class="form-control" type="date" required />
        </div>
        <div class="col-md-4">
            <label asp-for="EntryDate" class="form-label"></label>
            <input asp-for="EntryDate" class="form-control" type="date" required />
        </div>
        <div class="col-md-4">
            <label asp-for="Amount" class="form-label"></label>
            <input asp-for="Amount" class="form-control" type="number" step="0.01" min="0.01" required />
            <span asp-validation-for="Amount" class="text-danger"></span>
        </div>
        <div class="col-md-4 d-flex align-items-end">
            <div class="form-check">
                <input asp-for="IsPostDated" class="form-check-input" />
                <label asp-for="IsPostDated" class="form-check-label">Post-dated</label>
            </div>
        </div>
        <div class="col-md-8">
            <label asp-for="PayableTo" class="form-label"></label>
            <input asp-for="PayableTo" class="form-control" maxlength="200" />
        </div>
        <div class="col-md-12">
            <label asp-for="ReceivedFrom" class="form-label"></label>
            <input asp-for="ReceivedFrom" class="form-control" maxlength="200" />
        </div>
        <div class="col-12">
            <label asp-for="Remarks" class="form-label"></label>
            <textarea asp-for="Remarks" class="form-control" rows="2" maxlength="500"></textarea>
        </div>
    </div>
    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="ChequeRegisters" asp-route-bankAccountId="@bankId" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
