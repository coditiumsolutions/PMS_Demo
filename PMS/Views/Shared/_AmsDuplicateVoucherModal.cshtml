@{
    var duplicateNo = ViewBag.DuplicateVoucherNo as string;
}
@if (!string.IsNullOrWhiteSpace(duplicateNo))
{
    <div class="modal fade" id="duplicateVoucherModal" tabindex="-1" aria-labelledby="duplicateVoucherModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title" id="duplicateVoucherModalLabel">@PMS.Utilities.AmsVoucherNumberHelper.DuplicateVoucherTitle</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-0">@PMS.Utilities.AmsVoucherNumberHelper.DuplicateMessage(duplicateNo)</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-primary" data-bs-dismiss="modal">OK</button>
                </div>
            </div>
        </div>
    </div>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var el = document.getElementById('duplicateVoucherModal');
            if (el) new bootstrap.Modal(el).show();
        });
    </script>
}
