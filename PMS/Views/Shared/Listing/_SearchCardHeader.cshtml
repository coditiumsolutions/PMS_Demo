@{
    var collapseId = ViewData["SearchCollapseId"] as string ?? "pmsSearchFiltersCollapse";
}

<div class="card-header pms-search-card-header d-flex justify-content-between align-items-center">
    <h6 class="mb-0">
        <i class="bi bi-funnel-fill me-2" aria-hidden="true"></i>Search Filters
    </h6>
    <button class="btn btn-sm btn-outline-secondary"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#@collapseId"
            aria-expanded="true"
            aria-controls="@collapseId"
            title="Toggle search filters">
        <i class="bi bi-chevron-up" aria-hidden="true"></i>
    </button>
</div>
