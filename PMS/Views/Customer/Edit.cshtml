@model PMS.Models.Customer

@{
    ViewData["Title"] = "Edit Customer";
}

<div class="pms-form-page">
    <div class="pms-form-header">
        <div class="pms-form-header-text">
            <h1>Edit Customer</h1>
            <p>Manage customer information, next of kin, allotments, joint owners, and document attachments.</p>
            <div class="pms-form-header-meta">Customer ID: <code>@Model.CustomerID</code></div>
        </div>
        <div class="pms-form-header-actions">
            <button type="submit" form="customerEditForm" class="btn btn-primary">
                <i class="bi bi-check-lg me-1" aria-hidden="true"></i>Save Changes
            </button>
            <a asp-action="Details" asp-route-id="@Model.CustomerID" class="btn btn-outline-secondary">
                <i class="bi bi-eye me-1" aria-hidden="true"></i>View Details
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-x-lg me-1" aria-hidden="true"></i>Cancel
            </a>
        </div>
    </div>

    <div class="card pms-saas-form-card pms-saas-form">
        <div class="card-header border-0">
            <ul class="nav pms-form-tabs customer-tabs" id="customerTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="personal-tab" data-bs-toggle="tab" data-bs-target="#personal" type="button" role="tab" aria-controls="personal" aria-selected="true">
                        <i class="bi bi-person-vcard" aria-hidden="true"></i>Personal Info
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="nominee-tab" data-bs-toggle="tab" data-bs-target="#nominee" type="button" role="tab" aria-controls="nominee" aria-selected="false">
                        <i class="bi bi-shield-check" aria-hidden="true"></i>Next of Kin
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="allotments-tab" data-bs-toggle="tab" data-bs-target="#allotments" type="button" role="tab" aria-controls="allotments" aria-selected="false">
                        <i class="bi bi-building" aria-hidden="true"></i>Allotments
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="jointowners-tab" data-bs-toggle="tab" data-bs-target="#jointowners" type="button" role="tab" aria-controls="jointowners" aria-selected="false">
                        <i class="bi bi-people" aria-hidden="true"></i>Joint Owners
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="attachments-tab" data-bs-toggle="tab" data-bs-target="#attachments" type="button" role="tab" aria-controls="attachments" aria-selected="false">
                        <i class="bi bi-paperclip" aria-hidden="true"></i>Attachments
                    </button>
                </li>
            </ul>
        </div>
        <div class="card-body pms-saas-form-body">
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-warning alert-dismissible fade show" role="alert">
                        @TempData["ErrorMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form id="customerEditForm" asp-action="Edit" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="CustomerID" />
                    <input type="hidden" asp-for="CreatedAt" />
                    <input type="hidden" asp-for="NomineeNICDocumentPath" />
                    <input type="hidden" asp-for="NomineePicturePath" />
                    
                    <div class="tab-content" id="customerTabContent">
                        <!-- Personal Info Tab (Personal + Contact) -->
                        <div class="tab-pane fade show active" id="personal" role="tabpanel" aria-labelledby="personal-tab">
                            <div class="row g-3 pms-form-fields-row">
                                <!-- Personal Information -->
                                <div class="col-12 col-lg-6 pms-form-section">
                                    <h6 class="pms-form-section-title"><i class="fas fa-user me-2"></i>Personal Information</h6>
                                    
                                    <div class="mb-3">
                                        <label asp-for="FullName" class="form-label">Full Name *</label>
                                        <input asp-for="FullName" id="FullName" class="form-control" required />
                                        <span asp-validation-for="FullName" class="text-danger"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="FatherName" class="form-label">S/D/W/O</label>
                                        <input asp-for="FatherName" class="form-control" />
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="CNIC" class="form-label">National ID (CNIC)</label>
                                        <input asp-for="CNIC" id="CNIC" class="form-control" placeholder="XXXXX-XXXXXXX-X" maxlength="15" />
                                        <small class="text-muted">Format: 5 digits, hyphen, 7 digits, hyphen, 1 digit. Required if no Passport.</small>
                                        <span id="cnicValidationError" class="text-danger small d-none"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="PassportNo" class="form-label">Passport Number</label>
                                        <input asp-for="PassportNo" id="PassportNo" class="form-control" placeholder="Min 5 characters if no CNIC" />
                                        <small class="text-muted">Provide at least 5 characters if not providing CNIC.</small>
                                        <span id="passportValidationError" class="text-danger small d-none"></span>
                                    </div>
                                    <div id="cnicPassportRuleError" class="alert alert-warning small py-2 d-none" role="alert">
                                        <i class="fas fa-exclamation-triangle me-1"></i><span id="cnicPassportRuleErrorText"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="DOB" class="form-label">Date of Birth</label>
                                        <input type="text" id="DOBDisplay" class="form-control" value="@(Model.DOB?.ToString("dd-MM-yyyy") ?? "01-01-1990")" placeholder="DD-MM-YYYY" />
                                        <input asp-for="DOB" type="hidden" id="DOB" value="@(Model.DOB?.ToString("yyyy-MM-dd") ?? "")" />
                                        <small class="text-muted">Format: DD-MM-YYYY (e.g. 31-12-1990).</small>
                                        <span id="dobValidationError" class="text-danger small d-none"></span>
                                        <span asp-validation-for="DOB" class="text-danger"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="Gender" class="form-label">Gender</label>
                                        <select asp-for="Gender" class="form-select">
                                            <option value="">Select Gender</option>
                                            <option value="Male">Male</option>
                                            <option value="Female">Female</option>
                                            <option value="Other">Other</option>
                                        </select>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="Nationality" class="form-label">Nationality</label>
                                        <input asp-for="Nationality" class="form-control" list="nationalityList-customer-edit" autocomplete="off" placeholder="Select from list or type a value" />
                                        <datalist id="nationalityList-customer-edit">
                                            @if (ViewBag.Nationalities != null)
                                            {
                                                foreach (var nationality in ViewBag.Nationalities)
                                                {
                                                    <option value="@nationality"></option>
                                                }
                                            }
                                        </datalist>
                                        <small class="text-muted">Suggestions from configuration; you may enter any nationality.</small>
                                        <span asp-validation-for="Nationality" class="text-danger"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="Status" class="form-label">Status</label>
                                        <select asp-for="Status" class="form-select">
                                            <option value="Pending">Pending</option>
                                            <option value="Active">Active</option>
                                            <option value="Inactive">Inactive</option>
                                            <option value="Blocked">Blocked</option>
                                            <option value="Marked for Deletion">Marked for Deletion</option>
                                            <option value="Suspended">Suspended</option>
                                            <option value="Cancelled">Cancelled</option>
                                            <option value="Refunded">Refunded</option>
                                        </select>
                                        <small class="text-muted">New customers start as Pending; use the customer list to activate when ready.</small>
                                    </div>
                                </div>

                                <!-- Contact Information -->
                                <div class="col-12 col-lg-6 pms-form-section">
                                    <h6 class="pms-form-section-title"><i class="fas fa-phone me-2"></i>Contact Information</h6>
                                    
                                    <div class="mb-3">
                                        <label asp-for="Email" class="form-label">Email Address</label>
                                        <input asp-for="Email" type="email" class="form-control" />
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="Phone" class="form-label">Phone (landline / primary contact) *</label>
                                        <input asp-for="Phone" id="Phone" class="form-control" required />
                                        <span asp-validation-for="Phone" class="text-danger"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="MobileNo" class="form-label">Mobile *</label>
                                        <input asp-for="MobileNo" id="MobileNo" class="form-control" required />
                                        <span asp-validation-for="MobileNo" class="text-danger"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="MobileNo2" class="form-label">Mobile 2</label>
                                        <input asp-for="MobileNo2" id="MobileNo2" class="form-control" />
                                        <span asp-validation-for="MobileNo2" class="text-danger"></span>
                                        <small class="form-text text-muted">Optional. Must differ from Phone and Mobile.</small>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="City" class="form-label">City *</label>
                                        <input asp-for="City" class="form-control" list="cityOptions" placeholder="Select or type city" required />
                                        <datalist id="cityOptions">
                                            @if (ViewBag.Cities != null)
                                            {
                                                @foreach (var city in ViewBag.Cities)
                                                {
                                                    <option value="@city"></option>
                                                }
                                            }
                                        </datalist>
                                        <span asp-validation-for="City" class="text-danger"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="Country" class="form-label">Country *</label>
                                        <input asp-for="Country" class="form-control" list="countryOptions" placeholder="Select or type country" required />
                                        <datalist id="countryOptions">
                                            @if (ViewBag.Countries != null)
                                            {
                                                @foreach (var country in ViewBag.Countries)
                                                {
                                                    <option value="@country"></option>
                                                }
                                            }
                                        </datalist>
                                        <span asp-validation-for="Country" class="text-danger"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="MailingAddress" class="form-label">Mailing Address *</label>
                                        <textarea asp-for="MailingAddress" class="form-control" rows="2" required></textarea>
                                        <span asp-validation-for="MailingAddress" class="text-danger"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="PermanentAddress" class="form-label">Permanent Address</label>
                                        <textarea asp-for="PermanentAddress" class="form-control" rows="2"></textarea>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Next of Kin Info Tab -->
                        <div class="tab-pane fade" id="nominee" role="tabpanel" aria-labelledby="nominee-tab">
                            <div class="row g-3 pms-form-fields-row">
                                <div class="col-12 col-lg-6 pms-form-section">
                                    <h6 class="pms-form-section-title"><i class="fas fa-user-friends me-2"></i>Next of Kin Information</h6>
                                    
                                    <div class="mb-3">
                                        <label asp-for="NomineeName" class="form-label">Next of Kin Name</label>
                                        <input asp-for="NomineeName" class="form-control" />
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="NomineeID" class="form-label">Next of Kin ID / National ID</label>
                                        <input asp-for="NomineeID" class="form-control" />
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="NomineeRelation" class="form-label">Relationship</label>
                                        <select asp-for="NomineeRelation" class="form-select">
                                            <option value="">Select Relationship</option>
                                            <option value="Father">Father</option>
                                            <option value="Mother">Mother</option>
                                            <option value="Son">Son</option>
                                            <option value="Daughter">Daughter</option>
                                            <option value="Spouse">Spouse</option>
                                            <option value="Brother">Brother</option>
                                            <option value="Sister">Sister</option>
                                            <option value="Other">Other</option>
                                        </select>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">Next of Kin NIC Document</label>
                                        @if (!string.IsNullOrEmpty(Model.NomineeNICDocumentPath))
                                        {
                                            <div class="mb-2">
                                                <a href="@Model.NomineeNICDocumentPath" target="_blank" class="btn btn-sm btn-outline-primary">
                                                    <i class="fas fa-eye me-1"></i>View Current NIC Document
                                                </a>
                                            </div>
                                        }
                                        <input type="file" name="nomineeNICUpload" class="form-control" accept="image/*,.pdf" />
                                        <small class="text-muted">Uploading a file will replace the current document. Accepted formats: JPG, PNG, GIF, BMP, PDF. Max size: 8MB.</small>
                                        <span asp-validation-for="NomineeNICDocumentPath" class="text-danger"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">Next of Kin Picture</label>
                                        @if (!string.IsNullOrEmpty(Model.NomineePicturePath))
                                        {
                                            <div class="mb-2">
                                                <a href="@Model.NomineePicturePath" target="_blank" class="btn btn-sm btn-outline-primary">
                                                    <i class="fas fa-eye me-1"></i>View Current Picture
                                                </a>
                                            </div>
                                        }
                                        <input type="file" name="nomineePictureUpload" class="form-control" accept="image/*" />
                                        <small class="text-muted">Uploading a file will replace the current picture. Accepted formats: JPG, PNG, GIF, BMP. Max size: 8MB.</small>
                                        <span asp-validation-for="NomineePicturePath" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-12 col-lg-6 pms-form-section">
                                    <div class="alert alert-info">
                                        <i class="fas fa-info-circle me-2"></i>
                                        <strong>Next of Kin Information</strong>
                                        <p class="mb-0 mt-2">The next of kin is the person who will have rights in case of any unforeseen circumstances.</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Property Allotments Tab -->
                        <div class="tab-pane fade" id="allotments" role="tabpanel" aria-labelledby="allotments-tab">
                            <div class="row g-3 mb-4">
                                <div class="col-12 col-md-6 col-xl-3">
                                        <label asp-for="ProjectID" class="form-label">Project *</label>
                                        <select asp-for="ProjectID" id="ProjectID" class="form-select" required>
                                            <option value="">Select Project</option>
                                            @if (ViewBag.Projects != null)
                                            {
                                                @foreach (var project in ViewBag.Projects)
                                                {
                                                    <option value="@project.ProjectID">@project.ProjectName (@project.Prefix)</option>
                                                }
                                            }
                                        </select>
                                        <span asp-validation-for="ProjectID" class="text-danger"></span>
                                </div>
                                <div class="col-12 col-md-6 col-xl-3">
                                    <label asp-for="RegisteredSize" class="form-label">Registered Size</label>
                                    <input asp-for="RegisteredSize" id="RegisteredSize" class="form-control" type="number" step="0.01" inputmode="decimal" placeholder="Enter size" />
                                    <datalist id="RegisteredSizeOptions"></datalist>
                                    <small class="text-muted">Sizes are suggested from selected project, or type your own value.</small>
                                </div>
                                <div class="col-12 col-md-6 col-xl-3">
                                    <label class="form-label">Is Dealer Registered?</label>
                                    <div class="d-flex gap-3 mb-2">
                                        <div class="form-check">
                                            <input class="form-check-input" type="radio" name="IsDealerRegistered" id="dealerRegYes" value="1" @(Model?.IsDealerRegistered != 0 ? "checked" : null)>
                                            <label class="form-check-label" for="dealerRegYes">Yes</label>
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="radio" name="IsDealerRegistered" id="dealerRegNo" value="0" @(Model?.IsDealerRegistered == 0 ? "checked" : null)>
                                            <label class="form-check-label" for="dealerRegNo">No</label>
                                        </div>
                                    </div>
                                    <div id="dealerDropdownWrap">
                                        <label asp-for="DealerID" class="form-label">Select Dealer</label>
                                        <select asp-for="DealerID" id="DealerID" class="form-select">
                                            <option value="">Select Dealer</option>
                                            @if (ViewBag.Dealers != null)
                                            {
                                                @foreach (var dealer in ViewBag.Dealers)
                                                {
                                                    <option value="@dealer.DealerID">@dealer.DealershipName</option>
                                                }
                                            }
                                        </select>
                                        <span asp-validation-for="DealerID" class="text-danger"></span>
                                    </div>
                                    <div id="dealerNameWrap" style="display:none;">
                                        <label asp-for="DealerName" class="form-label">Dealer Name</label>
                                        <input asp-for="DealerName" id="DealerName" class="form-control" placeholder="Enter dealer name manually" maxlength="200" />
                                        <span asp-validation-for="DealerName" class="text-danger"></span>
                                    </div>
                                </div>
                                    </div>

                            <div class="row g-3 mb-4">
                                <div class="col-12 col-md-6 col-xl-3">
                                        <label asp-for="PlanID" class="form-label">Payment Plan</label>
                                        <select asp-for="PlanID" class="form-select">
                                            <option value="">Select Payment Plan</option>
                                            @if (ViewBag.PaymentPlans != null)
                                            {
                                                @foreach (var plan in ViewBag.PaymentPlans)
                                                {
                                                    <option value="@plan.PlanID">@plan.PlanName - PKR @plan.TotalAmount.ToString("N0")</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                <div class="col-12 col-md-6 col-xl-3">
                                        <label asp-for="SubProject" class="form-label">Sub Project</label>
                                        <select asp-for="SubProject" id="SubProject" class="form-select">
                                            @if (!string.IsNullOrWhiteSpace(Model.SubProject))
                                            {
                                                <option value="@Model.SubProject" selected>@Model.SubProject</option>
                                            }
                                            else
                                            {
                                                <option value="">@(string.IsNullOrEmpty(Model.ProjectID) ? "Select Project first" : "Select Sub Project")</option>
                                            }
                                        </select>
                                        <small class="text-muted">Sub projects are loaded from the selected project (same as Create).</small>
                                    </div>
                                <div class="col-12 col-md-6 col-xl-3">
                                    <div class="alert alert-info mb-0 h-100 d-flex align-items-center">
                                        <i class="fas fa-info-circle me-2"></i>
                                        <strong>Allotment is managed from the Allotment module</strong> (workflow).
                                    </div>
                                </div>
                                </div>

                            <div class="mb-4">
                                        <label asp-for="AdditionalInfo" class="form-label">Additional Notes</label>
                                <textarea asp-for="AdditionalInfo" class="form-control" rows="4" placeholder="Enter any additional information about the customer..."></textarea>
                        </div>

                            @if (Model.Allotments != null && Model.Allotments.Any())
                            {
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead>
                                        <tr>
                                            <th>Allotment ID</th>
                                            <th>Plot No</th>
                                            <th>Block</th>
                                            <th>Size</th>
                                            <th>Type</th>
                                            <th>Date</th>
                                            <th>Status</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var allotment in Model.Allotments)
                                        {
                                            <tr>
                                                <td><code>@allotment.AllotmentID</code></td>
                                                <td>@allotment.Property?.PlotNo</td>
                                                <td>@allotment.Property?.Block</td>
                                                <td>@allotment.Property?.Size</td>
                                                <td>@allotment.AllottmentType</td>
                                                <td>@allotment.AllotmentDate.ToString("MMM dd, yyyy")</td>
                                                <td>
                                                    @if (allotment.WorkFlowStatus == "Approved")
                                                    {
                                                        <span class="badge bg-success">@allotment.WorkFlowStatus</span>
                                                    }
                                                    else if (allotment.WorkFlowStatus == "Pending" || allotment.WorkFlowStatus == "Pending Approval")
                                                    {
                                                        <span class="badge bg-warning">@allotment.WorkFlowStatus</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-primary">@allotment.WorkFlowStatus</span>
                                                    }
                                                </td>
                                                <td>
                                                    <div class="btn-group" role="group">
                                                        <a asp-controller="Allotment" asp-action="Details" asp-route-id="@allotment.AllotmentID" 
                                                           class="btn btn-sm btn-outline-info" title="View Allotment" onclick="event.stopPropagation();">
                                                            <i class="fas fa-eye"></i>
                                                        </a>
                                                        @if (allotment.WorkFlowStatus == "Pending" || allotment.WorkFlowStatus == "Pending Approval")
                                                        {
                                                            <a asp-controller="Allotment" asp-action="Details" asp-route-id="@allotment.AllotmentID" 
                                                               class="btn btn-sm btn-outline-primary" title="Edit Allotment" onclick="event.stopPropagation();">
                                                                <i class="fas fa-edit"></i>
                                                            </a>
                                                        }
                                                        else
                                                        {
                                                           <a href="@Url.Action("UnAllot", "Allotment")" 
                                                               class="btn btn-sm btn-outline-danger" title="Un-Allot Property" onclick="event.stopPropagation();">
                                                                <i class="fas fa-undo"></i>
                                                            </a>
                                                        }
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                                <div class="alert alert-info">
                                    <i class="fas fa-info-circle me-2"></i>
                                    <strong>No allotment found.</strong> Create a new allotment from the <em>Allotment</em> module.
                                </div>
                            }
                        </div>

                        <!-- Joint Owners Tab -->
                        <div class="tab-pane fade" id="jointowners" role="tabpanel" aria-labelledby="jointowners-tab">
                            <div class="row g-3 pms-form-fields-row">
                                <div class="col-12 col-md-6 col-xl-6">
                                    <label class="form-label">Joint Owner Name *</label>
                                    <input type="text" id="jointOwnerName" class="form-control" placeholder="Enter joint owner name" />
                                    <small class="text-muted">Letters, spaces, dots and hyphens only.</small>
                                </div>
                                <div class="col-12 col-md-6 col-xl-3">
                                    <label class="form-label">Son /D/W/o</label>
                                    <input type="text" id="jointOwnerFatherName" class="form-control" placeholder="Enter father name" />
                                </div>
                                <div class="col-12 col-md-6 col-xl-3">
                                    <label class="form-label">CNIC *</label>
                                    <input type="text" id="jointOwnerCNIC" class="form-control" placeholder="XXXXX-XXXXXXX-X" maxlength="15" />
                                </div>
                                <div class="col-12 col-md-6 col-xl-3">
                                    <label class="form-label">Contact *</label>
                                    <input type="text" id="jointOwnerContact" class="form-control" placeholder="03XXXXXXXXX" />
                                    <small class="text-muted">Must be 11 to 13 digits.</small>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Address</label>
                                    <input type="text" id="jointOwnerAddress" class="form-control" placeholder="Address" />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Percentage</label>
                                    <input type="number" id="jointOwnerPercentage" class="form-control" min="0" max="100" step="0.01" placeholder="e.g. 50" />
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label">Details</label>
                                    <textarea id="jointOwnerDetails" class="form-control" rows="2" placeholder="Any additional details"></textarea>
                                </div>
                                <div class="col-md-12">
                                    <button type="button" class="btn btn-primary" onclick="addJointOwnerFromTab()">
                                        <i class="fas fa-plus me-2"></i>Add Joint Owner
                                    </button>
                                </div>
                            </div>
                            <hr />
                            <div class="table-responsive">
                                <table class="table table-sm table-hover" id="jointOwnersTable">
                                    <thead>
                                        <tr>
                                            <th>Name</th>
                                            <th>Son /D/W/o</th>
                                            <th>CNIC</th>
                                            <th>Contact</th>
                                            <th>Percentage</th>
                                            <th>Address</th>
                                            <th>Created</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td colspan="7" class="text-muted text-center">Loading joint owners...</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <!-- Attachments Tab -->
                        <div class="tab-pane fade" id="attachments" role="tabpanel" aria-labelledby="attachments-tab">
                            <div class="row">
                                <div class="col-12">
                                    <h6 class="pms-form-section-title"><i class="fas fa-paperclip me-2"></i>Customer Attachments</h6>
                                    
                                    <!-- Customer Picture Section -->
                                    <div class="card mb-4" style="border-color: var(--primary);">
                                        <div class="card-header text-white" style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);">
                                            <h6 class="mb-0"><i class="fas fa-user-circle me-2"></i>Customer Picture</h6>
                                        </div>
                                        <div class="card-body">
                                            <div class="row">
                                                <div class="col-md-4">
                                                    <div id="customerPicturePreview" class="text-center mb-3">
                                                        <img id="customerPictureImg" src="" alt="Customer Picture" class="img-thumbnail" style="max-width: 200px; max-height: 200px; display: none;" />
                                                        <div id="customerPicturePlaceholder" class="text-muted">
                                                            <i class="fas fa-user-circle fa-5x"></i>
                                                            <p class="mt-2">No picture uploaded</p>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-8">
                                                    <div class="mb-3">
                                                        <label class="form-label">Upload Customer Picture</label>
                                                        <input type="file" id="customerPictureFile" class="form-control" accept="image/*" />
                                                        <small class="text-muted">Only image files (JPG, PNG, GIF, BMP). Max size: 8MB</small>
                                                    </div>
                                                    <button type="button" class="btn text-white" style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);" onclick="uploadAttachment('CustomerPicture', 'customerPictureFile')">
                                                        <i class="fas fa-upload me-2"></i>Upload Picture
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- ID Card Section -->
                                    <div class="card mb-4" style="border-color: var(--primary);">
                                        <div class="card-header text-white" style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);">
                                            <h6 class="mb-0"><i class="fas fa-id-card me-2"></i>Customer ID Card</h6>
                                        </div>
                                        <div class="card-body">
                                            <div class="row">
                                                <div class="col-md-4">
                                                    <div id="idCardPreview" class="text-center mb-3">
                                                        <img id="idCardImg" src="" alt="ID Card" class="img-thumbnail" style="max-width: 200px; max-height: 200px; display: none;" />
                                                        <div id="idCardPlaceholder" class="text-muted">
                                                            <i class="fas fa-id-card fa-5x"></i>
                                                            <p class="mt-2">No ID card uploaded</p>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-8">
                                                    <div class="mb-3">
                                                        <label class="form-label">Upload ID Card</label>
                                                        <input type="file" id="idCardFile" class="form-control" accept="image/*,.pdf" multiple />
                                                        <small class="text-muted">Image files (JPG, PNG, GIF, BMP) or PDF. Max size: 8MB each. You can upload multiple files (e.g., front and back).</small>
                                                    </div>
                                                    <button type="button" class="btn text-white" style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);" onclick="uploadAttachment('IDCard', 'idCardFile')">
                                                        <i class="fas fa-upload me-2"></i>Upload ID Card
                                                    </button>
                                                    <div id="idCardFilesContainer" class="row mt-3"></div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Other Attachments Section -->
                                    <div class="card mb-4" style="border-color: var(--primary);">
                                        <div class="card-header text-white" style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);">
                                            <h6 class="mb-0"><i class="fas fa-folder-open me-2"></i>Other Attachments</h6>
                                        </div>
                                        <div class="card-body">
                                            <div class="mb-3">
                                                <label class="form-label">Upload Additional Attachment</label>
                                                <div class="row">
                                                    <div class="col-md-6">
                                                        <input type="file" id="otherAttachmentFile" class="form-control" accept="image/*,.pdf" />
                                                        <small class="text-muted">Image files or PDF. Max size: 8MB</small>
                                                    </div>
                                                    <div class="col-md-4">
                                                        <input type="text" id="otherAttachmentDescription" class="form-control" placeholder="Description (optional)" />
                                                    </div>
                                                    <div class="col-md-2">
                                                        <button type="button" class="btn text-white w-100" style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);" onclick="uploadAttachment('Other', 'otherAttachmentFile', 'otherAttachmentDescription')">
                                                            <i class="fas fa-upload me-2"></i>Upload
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- Attachments List -->
                                            <div id="attachmentsList" class="mt-4">
                                                <h6 class="pms-form-section-title">Uploaded Attachments</h6>
                                                <div id="attachmentsContainer" class="row">
                                                    <div class="col-12 text-center text-muted py-3">
                                                        <i class="fas fa-spinner fa-spin fa-2x mb-2"></i>
                                                        <p>Loading attachments...</p>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="pms-form-actions-inline d-none d-md-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1" aria-hidden="true"></i>Save Changes
                        </button>
                        <a asp-action="Details" asp-route-id="@Model.CustomerID" class="btn btn-outline-secondary">
                            <i class="bi bi-eye me-1" aria-hidden="true"></i>View Details
                        </a>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-x-lg me-1" aria-hidden="true"></i>Cancel
                        </a>
                    </div>
                </form>
        </div>
    </div>

    <div class="pms-form-footer-sticky">
        <div class="pms-form-footer-inner">
            <button type="submit" form="customerEditForm" class="btn btn-primary">
                <i class="bi bi-check-lg me-1" aria-hidden="true"></i>Save Changes
            </button>
            <a asp-action="Details" asp-route-id="@Model.CustomerID" class="btn btn-outline-secondary d-none d-sm-inline-flex">
                <i class="bi bi-eye me-1" aria-hidden="true"></i>View Details
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-x-lg me-1" aria-hidden="true"></i>Cancel
            </a>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        var initialTab = '@(ViewBag.InitialTab ?? "personal")';

        // FullName: letters, spaces, dots, hyphens only
        document.getElementById('FullName').addEventListener('input', function () {
            this.value = this.value.replace(/[^a-zA-Z\s\.\-]/g, '');
        });
        // Phone: digits and + only
        ['Phone', 'MobileNo', 'MobileNo2'].forEach(function (id) {
            var el = document.getElementById(id);
            if (el) el.addEventListener('input', function () {
                this.value = this.value.replace(/[^0-9\+]/g, '');
            });
        });

        $(document).ready(function() {
            // Load Registered Size options from selected project (same as Registration module)
            function normalizeSizeValue(value) {
                return (value || '').toString().trim().toLowerCase();
            }

            function normalizeDropdownValue(value) {
                return (value || '').toString().trim().toLowerCase();
            }

            function loadSubProjects(projectId, selectedValue) {
                var $subProjectSelect = $('#SubProject');
                var desiredValue = (selectedValue || $subProjectSelect.val() || '').toString().trim();
                $subProjectSelect.html('<option value="">Select Sub Project</option>').prop('disabled', !projectId);
                if (!projectId) {
                    $subProjectSelect.html('<option value="">Select Project first</option>');
                    return;
                }

                $.get('@Url.Action("GetProjectSubProjects", "Customer")', { projectId: projectId })
                    .done(function(arr) {
                        var desiredValueNormalized = normalizeDropdownValue(desiredValue);
                        var matched = false;

                        $(arr).each(function() {
                            var itemValue = (this && this.name) ? this.name.toString() : (this || '').toString();
                            var itemPrefix = (this && this.prefix) ? this.prefix.toString() : '';
                            var opt = $('<option></option>').val(itemValue).text(itemPrefix ? (itemValue + ' (' + itemPrefix + ')') : itemValue);
                            if (!matched && normalizeDropdownValue(itemValue) === desiredValueNormalized) {
                                opt.prop('selected', true);
                                matched = true;
                            }
                            $subProjectSelect.append(opt);
                        });

                        if (!matched && desiredValue) {
                            $subProjectSelect.append(
                                $('<option></option>')
                                    .val(desiredValue)
                                    .text(desiredValue + ' (current)')
                                    .prop('selected', true)
                            );
                        }
                    })
                    .fail(function() {
                        $subProjectSelect.html('<option value="">Could not load sub projects</option>');
                    });
            }

            function loadSizesForProject(projectId, selectValue) {
                var $sizeInput = $('#RegisteredSize');
                var $sizeOptions = $('#RegisteredSizeOptions');
                var desiredValue = (selectValue || $sizeInput.val() || '').toString().trim();
                $sizeInput.prop('disabled', !projectId);
                $sizeOptions.empty();
                if (projectId) {
                    $.get('@Url.Action("GetProjectSizes", "Customer")', { projectId: projectId })
                        .done(function(arr) {
                            $(arr).each(function() {
                                var itemValue = (this || '').toString();
                                $sizeOptions.append($('<option></option>').val(itemValue));
                            });
                            if (desiredValue) $sizeInput.val(desiredValue);
                        });
                } else {
                    $sizeInput.val('');
                }
            }
            var currentSize = '@(Model.RegisteredSize ?? "")';
            var currentSubProject = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SubProject ?? ""));
            var currentProjectId = $('#ProjectID').val();
            if (currentProjectId) {
                loadSizesForProject(currentProjectId, currentSize);
                loadSubProjects(currentProjectId, currentSubProject);
            } else {
                $('#RegisteredSize').prop('disabled', true);
                $('#SubProject').html('<option value="">Select Project first</option>').prop('disabled', true);
            }

            $('#ProjectID').on('change', function() {
                loadSizesForProject($(this).val(), '');
                loadSubProjects($(this).val(), '');
            });

            function toggleDealerFields() {
                var isYes = $('#dealerRegYes').is(':checked');
                $('#dealerDropdownWrap').toggle(isYes);
                $('#dealerNameWrap').toggle(!isYes);
                if (isYes) { $('#DealerName').val(''); } else { $('#DealerID').val(''); }
            }
            $('#dealerRegYes, #dealerRegNo').on('change', toggleDealerFields);
            toggleDealerFields();

            $('form').on('submit', function() {
                if ($('#dealerRegYes').is(':checked')) {
                    $('#DealerName').val('');
                } else {
                    $('#DealerID').val('');
                }
            });

            // CNIC/Passport rule: either CNIC format 5-7-1 or Passport min 5 chars
            function validateCnicOrPassport() {
                var cnic = ($('#CNIC').val() || '').trim();
                var passport = ($('#PassportNo').val() || '').trim();
                var cnicRegex = /^\d{5}-\d{7}-\d$/;
                var cnicValid = cnicRegex.test(cnic);
                var passportValid = passport.length >= 5;
                $('#CNIC').removeClass('is-invalid');
                $('#PassportNo').removeClass('is-invalid');
                $('#cnicValidationError, #passportValidationError').addClass('d-none').text('');
                $('#cnicPassportRuleError').addClass('d-none');
                if (cnicValid || passportValid) return true;
                $('#cnicPassportRuleError').removeClass('d-none');
                $('#cnicPassportRuleErrorText').text('Either National ID (CNIC) in format XXXXX-XXXXXXX-X or Passport Number (min 5 characters) is required.');
                if (cnic && !cnicValid) {
                    $('#CNIC').addClass('is-invalid');
                    $('#cnicValidationError').removeClass('d-none').text('CNIC must be XXXXX-XXXXXXX-X (5-7-1 digits).');
                }
                if (passport && passport.length > 0 && passport.length < 5) {
                    $('#PassportNo').addClass('is-invalid');
                    $('#passportValidationError').removeClass('d-none').text('Passport must be at least 5 characters.');
                }
                if (!cnic && !passport) {
                    $('#CNIC').addClass('is-invalid');
                    $('#PassportNo').addClass('is-invalid');
                }
                return false;
            }
            $('#CNIC').on('input blur', function() {
                this.value = formatCnicValue(this.value);
            });
            $('#CNIC, #PassportNo').on('input blur', function() {
                var cnic = ($('#CNIC').val() || '').trim();
                var passport = ($('#PassportNo').val() || '').trim();
                if (cnic || passport) {
                    var cnicValid = /^\d{5}-\d{7}-\d$/.test(cnic);
                    var passportValid = passport.length >= 5;
                    if (cnicValid || passportValid) {
                        $('#CNIC, #PassportNo').removeClass('is-invalid');
                        $('#cnicValidationError, #passportValidationError, #cnicPassportRuleError').addClass('d-none').text('');
                    }
                }
            });
            $('#customerEditForm').on('submit', function(e) {
                if (!validateCnicOrPassport()) {
                    e.preventDefault();
                    $('#personal-tab').tab('show');
                    $('html, body').animate({ scrollTop: $('#CNIC').offset().top - 20 }, 300);
                    return false;
                }
                if (!syncDobForSubmit(true)) {
                    e.preventDefault();
                    $('#personal-tab').tab('show');
                    $('html, body').animate({ scrollTop: $('#DOBDisplay').offset().top - 20 }, 300);
                    return false;
                }
            });
            function parseDobDisplay(value) {
                var parts = (value || '').trim().split('-');
                if (parts.length !== 3) return null;
                var dd = parseInt(parts[0], 10);
                var mm = parseInt(parts[1], 10);
                var yyyy = parseInt(parts[2], 10);
                if (!dd || !mm || !yyyy || yyyy < 1900 || mm < 1 || mm > 12 || dd < 1 || dd > 31) return null;
                var dt = new Date(yyyy, mm - 1, dd);
                if (dt.getFullYear() !== yyyy || dt.getMonth() !== (mm - 1) || dt.getDate() !== dd) return null;
                return { dd: dd, mm: mm, yyyy: yyyy };
            }
            function formatIsoDate(parts) {
                var dd = String(parts.dd).padStart(2, '0');
                var mm = String(parts.mm).padStart(2, '0');
                return String(parts.yyyy) + '-' + mm + '-' + dd;
            }
            function syncDobForSubmit(showError) {
                var display = ($('#DOBDisplay').val() || '').trim();
                if (!display) {
                    $('#DOB').val('');
                    $('#DOBDisplay').removeClass('is-invalid');
                    $('#dobValidationError').addClass('d-none').text('');
                    return true;
                }
                var parsed = parseDobDisplay(display);
                if (!parsed) {
                    if (showError !== false) {
                        $('#DOBDisplay').addClass('is-invalid');
                        $('#dobValidationError').text('Please enter Date of Birth in DD-MM-YYYY format.').removeClass('d-none');
                    }
                    return false;
                }
                $('#DOB').val(formatIsoDate(parsed));
                $('#DOBDisplay').removeClass('is-invalid');
                $('#dobValidationError').addClass('d-none').text('');
                return true;
            }
            $('#DOBDisplay').on('change blur', function() { syncDobForSubmit(true); });

            // Property selection (allotment) has moved to Allotment module workflow.

            // Load attachments when attachments tab is shown
            $('#attachments-tab').on('shown.bs.tab', function() {
                loadAttachments();
            });
            $('#jointowners-tab').on('shown.bs.tab', function() {
                loadJointOwners();
            });

            // Open requested initial tab once (used by post-create redirect to Edit).
            if (initialTab === 'attachments') {
                var attachmentsTrigger = document.getElementById('attachments-tab');
                if (attachmentsTrigger) {
                    var attachmentTab = new bootstrap.Tab(attachmentsTrigger);
                    attachmentTab.show();
                    // Remove one-time query flag from URL so refresh keeps normal behavior.
                    if (window.history && window.history.replaceState) {
                        var cleanUrl = window.location.origin + window.location.pathname;
                        window.history.replaceState({}, document.title, cleanUrl);
                    }
                }
            }

            // Load attachments on page load if tab is active
            if ($('#attachments-tab').hasClass('active')) {
                loadAttachments();
            }
            if ($('#jointowners-tab').hasClass('active')) {
                loadJointOwners();
            }
        });

        var customerId = '@Model.CustomerID';
        function normalizeDigits(value) {
            return (value || '').replace(/\D/g, '');
        }
        function formatCnicValue(value) {
            var raw = normalizeDigits(value);
            if (raw.length <= 5) return raw;
            if (raw.length <= 12) return raw.slice(0, 5) + '-' + raw.slice(5);
            return raw.slice(0, 5) + '-' + raw.slice(5, 12) + '-' + raw.slice(12, 13);
        }
        function validateJointOwnerInputs() {
            var name = ($('#jointOwnerName').val() || '').trim();
            var cnic = ($('#jointOwnerCNIC').val() || '').trim();
            var contact = ($('#jointOwnerContact').val() || '').trim();
            var nameOk = /^[a-zA-Z\s\.\-]+$/.test(name);
            var cnicOk = /^\d{5}-\d{7}-\d$/.test(cnic);
            var contactDigits = normalizeDigits(contact);
            var contactOk = contactDigits.length >= 11 && contactDigits.length <= 13;
            $('#jointOwnerName, #jointOwnerCNIC, #jointOwnerContact').removeClass('is-invalid');
            if (!name || !nameOk) {
                $('#jointOwnerName').addClass('is-invalid');
                return { isValid: false, message: 'Joint owner name is required and must contain letters only.' };
            }
            if (!cnicOk) {
                $('#jointOwnerCNIC').addClass('is-invalid');
                return { isValid: false, message: 'CNIC is required in XXXXX-XXXXXXX-X format.' };
            }
            if (!contactOk) {
                $('#jointOwnerContact').addClass('is-invalid');
                return { isValid: false, message: 'Contact number is required and must be between 11 and 13 digits.' };
            }
            return { isValid: true };
        }

        function loadJointOwners() {
            $.ajax({
                url: '@Url.Action("GetJointOwners", "Customer")',
                method: 'GET',
                data: { customerId: customerId },
                success: function(response) {
                    var tbody = $('#jointOwnersTable tbody');
                    tbody.empty();
                    if (!response.success) {
                        tbody.html('<tr><td colspan="7" class="text-danger text-center">' + (response.message || 'Failed to load joint owners.') + '</td></tr>');
                        return;
                    }
                    if (!response.jointOwners || response.jointOwners.length === 0) {
                        tbody.html('<tr><td colspan="7" class="text-muted text-center">No joint owners added yet.</td></tr>');
                        return;
                    }
                    response.jointOwners.forEach(function(item) {
                        tbody.append('<tr>' +
                            '<td>' + (item.jointOwnerName || '—') + '</td>' +
                            '<td>' + (item.fatherName || '—') + '</td>' +
                            '<td>' + (item.cnic || '—') + '</td>' +
                            '<td>' + (item.contact || '—') + '</td>' +
                            '<td>' + (item.percentage != null ? item.percentage : '—') + '</td>' +
                            '<td>' + (item.address || '—') + '</td>' +
                            '<td>' + (item.createdAt || '—') + '</td>' +
                        '</tr>');
                    });
                },
                error: function() {
                    $('#jointOwnersTable tbody').html('<tr><td colspan="7" class="text-danger text-center">Error loading joint owners.</td></tr>');
                }
            });
        }

        function addJointOwnerFromTab() {
            var jointOwnerValidation = validateJointOwnerInputs();
            if (!jointOwnerValidation.isValid) {
                alert(jointOwnerValidation.message);
                return;
            }
            var token = $('#customerEditForm input[name="__RequestVerificationToken"]').val();
            $.ajax({
                url: '@Url.Action("AddJointOwner", "Customer")',
                method: 'POST',
                data: {
                    __RequestVerificationToken: token,
                    customerId: customerId,
                    jointOwnerName: $('#jointOwnerName').val(),
                    fatherName: $('#jointOwnerFatherName').val(),
                    cnic: $('#jointOwnerCNIC').val(),
                    contact: $('#jointOwnerContact').val(),
                    address: $('#jointOwnerAddress').val(),
                    percentage: $('#jointOwnerPercentage').val(),
                    details: $('#jointOwnerDetails').val()
                },
                success: function(response) {
                    if (!response.success) {
                        alert(response.message || 'Unable to add joint owner.');
                        return;
                    }
                    $('#jointOwnerName, #jointOwnerFatherName, #jointOwnerCNIC, #jointOwnerContact, #jointOwnerAddress, #jointOwnerPercentage, #jointOwnerDetails').val('');
                    loadJointOwners();
                },
                error: function() {
                    alert('Error while adding joint owner.');
                }
            });
        }
        $('#jointOwnerName').on('input', function() {
            this.value = this.value.replace(/[^a-zA-Z\s\.\-]/g, '');
        });
        $('#jointOwnerFatherName').on('input', function() {
            this.value = this.value.replace(/[^a-zA-Z\s\.\-]/g, '');
        });
        $('#jointOwnerContact').on('input', function() {
            this.value = this.value.replace(/[^0-9]/g, '');
        });
        $('#jointOwnerCNIC').on('input', function() {
            this.value = formatCnicValue(this.value);
        });

        // Load attachments
        function loadAttachments() {
            $.ajax({
                url: '@Url.Action("GetAttachments", "Customer")',
                method: 'GET',
                data: { customerId: customerId },
                success: function(response) {
                    if (response.success) {
                        displayAttachments(response.attachments);
                    } else {
                        $('#attachmentsContainer').html('<div class="col-12 text-center text-muted py-3"><p>' + (response.message || 'Error loading attachments') + '</p></div>');
                    }
                },
                error: function() {
                    $('#attachmentsContainer').html('<div class="col-12 text-center text-muted py-3"><p>Error loading attachments</p></div>');
                }
            });
        }

        // Display attachments
        function displayAttachments(attachments) {
            var container = $('#attachmentsContainer');
            container.empty();

            if (attachments.length === 0) {
                container.html('<div class="col-12 text-center text-muted py-3"><i class="fas fa-inbox fa-2x mb-2"></i><p>No attachments uploaded yet</p></div>');
                return;
            }

            // Separate attachments by type
            var customerPicture = attachments.find(a => a.attachmentType === 'CustomerPicture');
            var idCards = attachments.filter(a => a.attachmentType === 'IDCard');
            var otherAttachments = attachments.filter(a => a.attachmentType === 'Other');

            // Display Customer Picture
            if (customerPicture) {
                $('#customerPictureImg').attr('src', customerPicture.filePath).show();
                $('#customerPicturePlaceholder').hide();
            } else {
                $('#customerPictureImg').hide();
                $('#customerPicturePlaceholder').show();
            }

            // Display ID Cards (multiple supported)
            var idCardContainer = $('#idCardFilesContainer');
            idCardContainer.empty();
            var primaryIdCard = idCards.length > 0 ? idCards[0] : null;
            if (primaryIdCard) {
                if (primaryIdCard.fileType && primaryIdCard.fileType.includes('pdf')) {
                    $('#idCardImg').hide();
                    $('#idCardPlaceholder').html('<i class="fas fa-file-pdf fa-5x"></i><p class="mt-2">PDF Document</p>').show();
                } else {
                    $('#idCardImg').attr('src', primaryIdCard.filePath).show();
                    $('#idCardPlaceholder').hide();
                }

                idCards.forEach(function(idCard) {
                    var isImage = idCard.fileType && idCard.fileType.startsWith('image/');
                    var isPdf = idCard.fileType && idCard.fileType.includes('pdf');
                    var idCardHtml = '<div class="col-md-6 mb-3">' +
                        '<div class="card h-100">' +
                        '<div class="card-body text-center">';

                    if (isImage) {
                        idCardHtml += '<img src="' + idCard.filePath + '" class="img-thumbnail mb-2" style="max-width: 100%; max-height: 180px;" />';
                    } else if (isPdf) {
                        idCardHtml += '<i class="fas fa-file-pdf fa-4x text-danger mb-2"></i>';
                    } else {
                        idCardHtml += '<i class="fas fa-file fa-4x text-muted mb-2"></i>';
                    }

                    idCardHtml += '<h6 class="card-title">' + (idCard.fileName || 'ID Card') + '</h6>' +
                        '<p class="card-text small text-muted">' +
                        (idCard.fileSize ? formatFileSize(idCard.fileSize) : '') +
                        ' • ' + idCard.uploadedAt + '</p>' +
                        '<div class="btn-group" role="group">' +
                        '<a href="' + idCard.filePath + '" target="_blank" class="btn btn-sm btn-outline-primary">' +
                        '<i class="fas fa-eye me-1"></i>View</a>' +
                        '<button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteAttachment(\'' + idCard.attachmentID + '\')">' +
                        '<i class="fas fa-trash me-1"></i>Delete</button>' +
                        '</div>' +
                        '</div></div></div>';
                    idCardContainer.append(idCardHtml);
                });
            } else {
                $('#idCardImg').hide();
                $('#idCardPlaceholder').html('<i class="fas fa-id-card fa-5x"></i><p class="mt-2">No ID card uploaded</p>').show();
                idCardContainer.append('<div class="col-12 text-center text-muted py-2"><p class="mb-0">No ID card files uploaded yet</p></div>');
            }

            // Display Other Attachments
            if (otherAttachments.length > 0) {
                otherAttachments.forEach(function(attachment) {
                    var isImage = attachment.fileType && attachment.fileType.startsWith('image/');
                    var isPdf = attachment.fileType && attachment.fileType.includes('pdf');
                    
                    var cardHtml = '<div class="col-md-4 mb-3">' +
                        '<div class="card h-100">' +
                        '<div class="card-body text-center">';
                    
                    if (isImage) {
                        cardHtml += '<img src="' + attachment.filePath + '" class="img-thumbnail mb-2" style="max-width: 100%; max-height: 200px;" />';
                    } else if (isPdf) {
                        cardHtml += '<i class="fas fa-file-pdf fa-4x text-danger mb-2"></i>';
                    } else {
                        cardHtml += '<i class="fas fa-file fa-4x text-muted mb-2"></i>';
                    }
                    
                    cardHtml += '<h6 class="card-title">' + (attachment.fileName || 'Attachment') + '</h6>';
                    
                    if (attachment.description) {
                        cardHtml += '<p class="card-text text-muted small">' + attachment.description + '</p>';
                    }
                    
                    cardHtml += '<p class="card-text small text-muted">' + 
                        (attachment.fileSize ? formatFileSize(attachment.fileSize) : '') + 
                        ' • ' + attachment.uploadedAt + '</p>' +
                        '<div class="btn-group" role="group">' +
                        '<a href="' + attachment.filePath + '" target="_blank" class="btn btn-sm btn-outline-primary">' +
                        '<i class="fas fa-eye me-1"></i>View</a>' +
                        '<button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteAttachment(\'' + attachment.attachmentID + '\')">' +
                        '<i class="fas fa-trash me-1"></i>Delete</button>' +
                        '</div>' +
                        '</div></div></div>';
                    
                    container.append(cardHtml);
                });
            } else {
                container.append('<div class="col-12 text-center text-muted py-3"><p>No other attachments</p></div>');
            }
        }

        // Upload attachment
        function uploadSingleAttachment(file, attachmentType, description) {
            var formData = new FormData();
            formData.append('customerId', customerId);
            formData.append('file', file);
            formData.append('attachmentType', attachmentType);
            formData.append('description', description || '');

            return new Promise(function(resolve, reject) {
                $.ajax({
                    url: '@Url.Action("UploadAttachment", "Customer")',
                    method: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function(response) {
                        resolve(response);
                    },
                    error: function(xhr) {
                        reject(xhr);
                    }
                });
            });
        }

        function uploadAttachment(attachmentType, fileInputId, descriptionInputId) {
            var fileInput = $('#' + fileInputId)[0];
            var selectedFiles = Array.from(fileInput.files || []);
            if (selectedFiles.length === 0) {
                alert('Please select a file to upload');
                return;
            }
            if (attachmentType !== 'IDCard' && selectedFiles.length > 1) {
                alert('Please select only one file for this attachment type.');
                return;
            }
            var description = descriptionInputId ? $('#' + descriptionInputId).val() : '';
            var filesToUpload = attachmentType === 'IDCard' ? selectedFiles : [selectedFiles[0]];
            var uploadRequests = filesToUpload.map(function(file) {
                return uploadSingleAttachment(file, attachmentType, description);
            });

            Promise.all(uploadRequests)
                .then(function(results) {
                    var failed = results.filter(function(r) { return !r.success; });
                    if (failed.length > 0) {
                        var firstError = failed[0] && failed[0].message ? failed[0].message : 'Some files could not be uploaded.';
                        alert('Error: ' + firstError);
                        return;
                    }

                    if (attachmentType === 'IDCard' && filesToUpload.length > 1) {
                        alert(filesToUpload.length + ' ID card files uploaded successfully.');
                    } else {
                        alert((results[0] && results[0].message) ? results[0].message : 'File uploaded successfully.');
                    }

                    fileInput.value = '';
                    if (descriptionInputId) {
                        $('#' + descriptionInputId).val('');
                    }
                    loadAttachments();
                })
                .catch(function(xhr) {
                    var err = xhr && xhr.responseJSON && xhr.responseJSON.message
                        ? xhr.responseJSON.message
                        : 'An error occurred while uploading the file';
                    alert('Error: ' + err);
                });
        }

        // Delete attachment
        function deleteAttachment(attachmentId) {
            if (!confirm('Are you sure you want to delete this attachment?')) {
                return;
            }

            $.ajax({
                url: '@Url.Action("DeleteAttachment", "Customer")',
                method: 'POST',
                data: { attachmentId: attachmentId },
                success: function(response) {
                    if (response.success) {
                        alert(response.message);
                        loadAttachments();
                    } else {
                        alert('Error: ' + response.message);
                    }
                },
                error: function() {
                    alert('An error occurred while deleting the attachment');
                }
            });
        }

        // Format file size
        function formatFileSize(bytes) {
            if (bytes === 0) return '0 Bytes';
            var k = 1024;
            var sizes = ['Bytes', 'KB', 'MB', 'GB'];
            var i = Math.floor(Math.log(bytes) / Math.log(k));
            return Math.round(bytes / Math.pow(k, i) * 100) / 100 + ' ' + sizes[i];
        }

        // (intentionally removed loadProperties() and selectedPropertyEdit handlers)
    </script>
}
