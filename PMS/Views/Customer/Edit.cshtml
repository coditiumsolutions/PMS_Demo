@model PMS.Models.Customer

@{
    ViewData["Title"] = "Edit Customer";
}

<div class="row">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2></h2>
            <div>
                <a asp-action="Details" asp-route-id="@Model.CustomerID" class="btn btn-outline-info me-2">
                    <i class="fas fa-eye me-2"></i>View Details
                </a>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Back to List
                </a>
            </div>
        </div>

        <div class="card">
            <div class="card-header p-0">
                <ul class="nav nav-tabs customer-tabs" id="customerTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="personal-tab" data-bs-toggle="tab" data-bs-target="#personal" type="button" role="tab" aria-controls="personal" aria-selected="true">
                            <i class="fas fa-user-circle me-2"></i>Personal Info
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="nominee-tab" data-bs-toggle="tab" data-bs-target="#nominee" type="button" role="tab" aria-controls="nominee" aria-selected="false">
                            <i class="fas fa-user-shield me-2"></i>Next of Kin Info
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="registration-tab" data-bs-toggle="tab" data-bs-target="#registration" type="button" role="tab" aria-controls="registration" aria-selected="false">
                            <i class="fas fa-file-contract me-2"></i>Registration Info
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="allotments-tab" data-bs-toggle="tab" data-bs-target="#allotments" type="button" role="tab" aria-controls="allotments" aria-selected="false">
                            <i class="fas fa-building me-2"></i>Allotments
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="attachments-tab" data-bs-toggle="tab" data-bs-target="#attachments" type="button" role="tab" aria-controls="attachments" aria-selected="false">
                            <i class="fas fa-paperclip me-2"></i>Attachments
                        </button>
                    </li>
                </ul>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="CustomerID" />
                    <input type="hidden" asp-for="CreatedAt" />
                    <input type="hidden" asp-for="NomineeNICDocumentPath" />
                    <input type="hidden" asp-for="NomineePicturePath" />
                    
                    <div class="tab-content" id="customerTabContent">
                        <!-- Personal Info Tab (Personal + Contact) -->
                        <div class="tab-pane fade show active" id="personal" role="tabpanel" aria-labelledby="personal-tab">
                            <div class="row">
                                <!-- Personal Information -->
                                <div class="col-md-6">
                                    <h6 class="mb-3"><i class="fas fa-user me-2"></i>Personal Information</h6>
                                    
                                    <div class="mb-3">
                                        <label asp-for="FullName" class="form-label">Full Name *</label>
                                        <input asp-for="FullName" class="form-control" required />
                                        <span asp-validation-for="FullName" class="text-danger"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="FatherName" class="form-label">Father's Name</label>
                                        <input asp-for="FatherName" class="form-control" />
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="CNIC" class="form-label">National ID</label>
                                        <input asp-for="CNIC" class="form-control" placeholder="XXXXX-XXXXXXX-X" />
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="PassportNo" class="form-label">Passport Number</label>
                                        <input asp-for="PassportNo" class="form-control" />
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="DOB" class="form-label">Date of Birth</label>
                                        <input asp-for="DOB" type="date" class="form-control" />
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="Gender" class="form-label">Gender</label>
                                        <select asp-for="Gender" class="form-select">
                                            <option value="">Select Gender</option>
                                            <option value="Male">Male</option>
                                            <option value="Female">Female</option>
                                            <option value="Other">Other</option>
                                        </select>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="Nationality" class="form-label">Nationality</label>
                                        <select asp-for="Nationality" class="form-select">
                                            <option value="">Select Nationality</option>
                                            @if (ViewBag.Nationalities != null)
                                            {
                                                foreach (var nationality in ViewBag.Nationalities)
                                                {
                                                    <option value="@nationality">@nationality</option>
                                                }
                                            }
                                        </select>
                                        <span asp-validation-for="Nationality" class="text-danger"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="Status" class="form-label">Status</label>
                                        <select asp-for="Status" class="form-select">
                                            <option value="Active">Active</option>
                                            <option value="Inactive">Inactive</option>
                                            <option value="Suspended">Suspended</option>
                                            <option value="Cancelled">Cancelled</option>
                                        </select>
                                    </div>
                                </div>

                                <!-- Contact Information -->
                                <div class="col-md-6">
                                    <h6 class="mb-3"><i class="fas fa-phone me-2"></i>Contact Information</h6>
                                    
                                    <div class="mb-3">
                                        <label asp-for="Email" class="form-label">Email Address</label>
                                        <input asp-for="Email" type="email" class="form-control" />
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="Phone" class="form-label">Phone Number *</label>
                                        <input asp-for="Phone" class="form-control" required />
                                        <span asp-validation-for="Phone" class="text-danger"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="City" class="form-label">City</label>
                                        <select asp-for="City" class="form-select">
                                            <option value="">Select City</option>
                                            @if (ViewBag.Cities != null)
                                            {
                                                @foreach (var city in ViewBag.Cities)
                                                {
                                                    <option value="@city">@city</option>
                                                }
                                            }
                                        </select>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="Country" class="form-label">Country</label>
                                        <select asp-for="Country" class="form-select">
                                            <option value="">Select Country</option>
                                            @if (ViewBag.Countries != null)
                                            {
                                                @foreach (var country in ViewBag.Countries)
                                                {
                                                    <option value="@country">@country</option>
                                                }
                                            }
                                        </select>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="MailingAddress" class="form-label">Mailing Address</label>
                                        <textarea asp-for="MailingAddress" class="form-control" rows="2"></textarea>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="PermanentAddress" class="form-label">Permanent Address</label>
                                        <textarea asp-for="PermanentAddress" class="form-control" rows="2"></textarea>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Next of Kin Info Tab -->
                        <div class="tab-pane fade" id="nominee" role="tabpanel" aria-labelledby="nominee-tab">
                            <div class="row">
                                <div class="col-md-6">
                                    <h6 class="mb-3"><i class="fas fa-user-friends me-2"></i>Next of Kin Information</h6>
                                    
                                    <div class="mb-3">
                                        <label asp-for="NomineeName" class="form-label">Next of Kin Name</label>
                                        <input asp-for="NomineeName" class="form-control" />
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="NomineeID" class="form-label">Next of Kin ID / National ID</label>
                                        <input asp-for="NomineeID" class="form-control" />
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="NomineeRelation" class="form-label">Relationship</label>
                                        <select asp-for="NomineeRelation" class="form-select">
                                            <option value="">Select Relationship</option>
                                            <option value="Father">Father</option>
                                            <option value="Mother">Mother</option>
                                            <option value="Son">Son</option>
                                            <option value="Daughter">Daughter</option>
                                            <option value="Spouse">Spouse</option>
                                            <option value="Brother">Brother</option>
                                            <option value="Sister">Sister</option>
                                            <option value="Other">Other</option>
                                        </select>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">Next of Kin NIC Document</label>
                                        @if (!string.IsNullOrEmpty(Model.NomineeNICDocumentPath))
                                        {
                                            <div class="mb-2">
                                                <a href="@Model.NomineeNICDocumentPath" target="_blank" class="btn btn-sm btn-outline-primary">
                                                    <i class="fas fa-eye me-1"></i>View Current NIC Document
                                                </a>
                                            </div>
                                        }
                                        <input type="file" name="nomineeNICUpload" class="form-control" accept="image/*,.pdf" />
                                        <small class="text-muted">Uploading a file will replace the current document. Accepted formats: JPG, PNG, GIF, BMP, PDF. Max size: 8MB.</small>
                                        <span asp-validation-for="NomineeNICDocumentPath" class="text-danger"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">Next of Kin Picture</label>
                                        @if (!string.IsNullOrEmpty(Model.NomineePicturePath))
                                        {
                                            <div class="mb-2">
                                                <a href="@Model.NomineePicturePath" target="_blank" class="btn btn-sm btn-outline-primary">
                                                    <i class="fas fa-eye me-1"></i>View Current Picture
                                                </a>
                                            </div>
                                        }
                                        <input type="file" name="nomineePictureUpload" class="form-control" accept="image/*" />
                                        <small class="text-muted">Uploading a file will replace the current picture. Accepted formats: JPG, PNG, GIF, BMP. Max size: 8MB.</small>
                                        <span asp-validation-for="NomineePicturePath" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="alert alert-info">
                                        <i class="fas fa-info-circle me-2"></i>
                                        <strong>Next of Kin Information</strong>
                                        <p class="mb-0 mt-2">The next of kin is the person who will have rights in case of any unforeseen circumstances.</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Registration Info Tab -->
                        <div class="tab-pane fade" id="registration" role="tabpanel" aria-labelledby="registration-tab">
                            <div class="row">
                                <div class="col-md-6">
                                    <h6 class="mb-3"><i class="fas fa-file-alt me-2"></i>Registration Details</h6>
                                    
                                    <div class="mb-3">
                                        <label asp-for="RegID" class="form-label">Registration</label>
                                        <select asp-for="RegID" class="form-select">
                                            <option value="">Select Registration</option>
                                            @if (ViewBag.Registrations != null)
                                            {
                                                @foreach (var reg in ViewBag.Registrations)
                                                {
                                                    <option value="@reg.RegID">@reg.FullName - @reg.RegID</option>
                                                }
                                            }
                                        </select>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="ProjectID" class="form-label">Project *</label>
                                        <select asp-for="ProjectID" class="form-select" required>
                                            <option value="">Select Project</option>
                                            @if (ViewBag.Projects != null)
                                            {
                                                @foreach (var project in ViewBag.Projects)
                                                {
                                                    <option value="@project.ProjectID">@project.ProjectName (@project.Prefix)</option>
                                                }
                                            }
                                        </select>
                                        <span asp-validation-for="ProjectID" class="text-danger"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="PlanID" class="form-label">Payment Plan</label>
                                        <select asp-for="PlanID" class="form-select">
                                            <option value="">Select Payment Plan</option>
                                            @if (ViewBag.PaymentPlans != null)
                                            {
                                                @foreach (var plan in ViewBag.PaymentPlans)
                                                {
                                                    <option value="@plan.PlanID">@plan.PlanName - @plan.TotalAmount.ToString("C")</option>
                                                }
                                            }
                                        </select>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="SubProject" class="form-label">Sub Project</label>
                                        <select asp-for="SubProject" class="form-select">
                                            <option value="">Select Sub Project</option>
                                            @if (ViewBag.SubProjects != null)
                                            {
                                                @foreach (var subProject in ViewBag.SubProjects)
                                                {
                                                    <option value="@subProject">@subProject</option>
                                                }
                                            }
                                        </select>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="RegisteredSize" class="form-label">Registered Size</label>
                                        <select asp-for="RegisteredSize" class="form-select">
                                            <option value="">Select Size</option>
                                            @if (ViewBag.Sizes != null)
                                            {
                                                @foreach (var size in ViewBag.Sizes)
                                                {
                                                    <option value="@size">@size</option>
                                                }
                                            }
                                        </select>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="DealerID" class="form-label">Dealer *</label>
                                        <select asp-for="DealerID" class="form-select" required>
                                            <option value="">Select Dealer</option>
                                            @if (ViewBag.Dealers != null)
                                            {
                                                @foreach (var dealer in ViewBag.Dealers)
                                                {
                                                    <option value="@dealer.DealerID">@dealer.DealershipName</option>
                                                }
                                            }
                                        </select>
                                        <span asp-validation-for="DealerID" class="text-danger"></span>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <h6 class="mb-3"><i class="fas fa-sticky-note me-2"></i>Additional Information</h6>

                                    <div class="mb-3">
                                        <label asp-for="AdditionalInfo" class="form-label">Additional Notes</label>
                                        <textarea asp-for="AdditionalInfo" class="form-control" rows="6" placeholder="Enter any additional information about the customer..."></textarea>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Property Allotments Tab -->
                        <div class="tab-pane fade" id="allotments" role="tabpanel" aria-labelledby="allotments-tab">
                            @if (Model.Allotments != null && Model.Allotments.Any())
                            {
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead>
                                        <tr>
                                            <th>Allotment ID</th>
                                            <th>Plot No</th>
                                            <th>Block</th>
                                            <th>Size</th>
                                            <th>Type</th>
                                            <th>Date</th>
                                            <th>Status</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var allotment in Model.Allotments)
                                        {
                                            <tr>
                                                <td><code>@allotment.AllotmentID</code></td>
                                                <td>@allotment.Property?.PlotNo</td>
                                                <td>@allotment.Property?.Block</td>
                                                <td>@allotment.Property?.Size</td>
                                                <td>@allotment.AllottmentType</td>
                                                <td>@allotment.AllotmentDate.ToString("MMM dd, yyyy")</td>
                                                <td>
                                                    @if (allotment.WorkFlowStatus == "Approved")
                                                    {
                                                        <span class="badge bg-success">@allotment.WorkFlowStatus</span>
                                                    }
                                                    else if (allotment.WorkFlowStatus == "Pending" || allotment.WorkFlowStatus == "Pending Approval")
                                                    {
                                                        <span class="badge bg-warning">@allotment.WorkFlowStatus</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-primary">@allotment.WorkFlowStatus</span>
                                                    }
                                                </td>
                                                <td>
                                                    <div class="btn-group" role="group">
                                                        <a asp-controller="Allotment" asp-action="Details" asp-route-id="@allotment.AllotmentID" 
                                                           class="btn btn-sm btn-outline-info" title="View Allotment" onclick="event.stopPropagation();">
                                                            <i class="fas fa-eye"></i>
                                                        </a>
                                                        @if (allotment.WorkFlowStatus == "Pending" || allotment.WorkFlowStatus == "Pending Approval")
                                                        {
                                                            <a asp-controller="Allotment" asp-action="Details" asp-route-id="@allotment.AllotmentID" 
                                                               class="btn btn-sm btn-outline-primary" title="Edit Allotment" onclick="event.stopPropagation();">
                                                                <i class="fas fa-edit"></i>
                                                            </a>
                                                        }
                                                        else
                                                        {
                                                           <a href="@Url.Action("UnAllot", "Allotment")" 
                                                               class="btn btn-sm btn-outline-danger" title="Un-Allot Property" onclick="event.stopPropagation();">
                                                                <i class="fas fa-undo"></i>
                                                            </a>
                                                        }
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div id="noAllotmentSection">
                                <div class="alert alert-info mb-4">
                                    <i class="fas fa-info-circle me-2"></i>
                                    <strong>No Allotment Found</strong><br>
                                    This customer does not have a property allotted yet. You can start the allotment process below.
                                </div>

                                @if (string.IsNullOrEmpty(Model.ProjectID) || string.IsNullOrEmpty(Model.RegisteredSize))
                                {
                                    <div class="alert alert-warning">
                                        <i class="fas fa-exclamation-triangle me-2"></i>
                                        <strong>Cannot Create Allotment:</strong>
                                        @if (string.IsNullOrEmpty(Model.ProjectID))
                                        {
                                            <p>Customer must have a Project assigned.</p>
                                        }
                                        @if (string.IsNullOrEmpty(Model.RegisteredSize))
                                        {
                                            <p>Customer must have a Registered Size set.</p>
                                        }
                                        <p class="mb-0 mt-2">
                                            <small>Please set the required information in the Registration Info tab above and save the customer first.</small>
                                        </p>
                                    </div>
                                }
                                else
                                {
                                    <div class="card border-primary">
                                        <div class="card-header bg-primary text-white">
                                            <h5 class="mb-0">
                                                <i class="fas fa-plus-circle me-2"></i>Start Allotment Process
                                            </h5>
                                        </div>
                                        <div class="card-body">
                                            <form id="createAllotmentForm">
                                                <input type="hidden" id="customerID" value="@Model.CustomerID" />
                                                <input type="hidden" id="projectID" value="@Model.ProjectID" />
                                                <input type="hidden" id="registeredSize" value="@Model.RegisteredSize" />

                                                <div class="row">
                                                    <div class="col-md-6 mb-3">
                                                        <label class="form-label">
                                                            <i class="fas fa-building me-2"></i>Customer Project
                                                        </label>
                                                        <input type="text" class="form-control" value="@(Model.Project?.ProjectName ?? "N/A")" readonly />
                                                        <small class="text-muted">Properties will be filtered by this project</small>
                                                    </div>
                                                    <div class="col-md-6 mb-3">
                                                        <label class="form-label">
                                                            <i class="fas fa-ruler-combined me-2"></i>Registered Size
                                                        </label>
                                                        <input type="text" class="form-control" value="@Model.RegisteredSize" readonly />
                                                        <small class="text-muted">Properties will be filtered by this size</small>
                                                    </div>
                                                    <div class="col-md-6 mb-3">
                                                        <label class="form-label">
                                                            <i class="fas fa-tag me-2"></i>Allotment Type <span class="text-danger">*</span>
                                                        </label>
                                                        <select id="allotmentType" class="form-select" required>
                                                            <option value="">Select Type</option>
                                                            @if (ViewBag.AllotmentTypes != null)
                                                            {
                                                                @foreach (var type in ViewBag.AllotmentTypes)
                                                                {
                                                                    <option value="@type">@type</option>
                                                                }
                                                            }
                                                            else
                                                            {
                                                                <option value="Regular">Regular</option>
                                                                <option value="Transfer">Transfer</option>
                                                                <option value="Balloting">Balloting</option>
                                                                <option value="Special">Special</option>
                                                            }
                                                        </select>
                                                    </div>
                                                    <div class="col-md-6 mb-3">
                                                        <label class="form-label">
                                                            <i class="fas fa-home me-2"></i>Select Property <span class="text-danger">*</span>
                                                        </label>
                                                        <select id="propertyID" class="form-select" required>
                                                            <option value="">Loading properties...</option>
                                                        </select>
                                                        <small class="text-muted">Only available properties matching project and size are shown</small>
                                                    </div>
                                                    <div class="col-md-12 mb-3">
                                                        <label class="form-label">
                                                            <i class="fas fa-comment me-2"></i>Comments
                                                        </label>
                                                        <textarea id="comments" class="form-control" rows="3" placeholder="Enter any comments or notes..."></textarea>
                                                    </div>
                                                    <div class="col-md-12">
                                                        <button type="submit" class="btn btn-success">
                                                            <i class="fas fa-check me-2"></i>Create Allotment
                                                        </button>
                                                        <button type="button" class="btn btn-secondary" onclick="loadProperties()">
                                                            <i class="fas fa-redo me-2"></i>Refresh Properties List
                                                        </button>
                                                    </div>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                }
                            </div>
                            }
                        </div>

                        <!-- Attachments Tab -->
                        <div class="tab-pane fade" id="attachments" role="tabpanel" aria-labelledby="attachments-tab">
                            <div class="row">
                                <div class="col-12">
                                    <h6 class="mb-3"><i class="fas fa-paperclip me-2"></i>Customer Attachments</h6>
                                    
                                    <!-- Customer Picture Section -->
                                    <div class="card mb-4" style="border-color: rgb(104, 167, 226);">
                                        <div class="card-header text-white" style="background: linear-gradient(135deg, rgb(104, 167, 226) 0%, rgb(72, 123, 165) 100%);">
                                            <h6 class="mb-0"><i class="fas fa-user-circle me-2"></i>Customer Picture</h6>
                                        </div>
                                        <div class="card-body">
                                            <div class="row">
                                                <div class="col-md-4">
                                                    <div id="customerPicturePreview" class="text-center mb-3">
                                                        <img id="customerPictureImg" src="" alt="Customer Picture" class="img-thumbnail" style="max-width: 200px; max-height: 200px; display: none;" />
                                                        <div id="customerPicturePlaceholder" class="text-muted">
                                                            <i class="fas fa-user-circle fa-5x"></i>
                                                            <p class="mt-2">No picture uploaded</p>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-8">
                                                    <div class="mb-3">
                                                        <label class="form-label">Upload Customer Picture</label>
                                                        <input type="file" id="customerPictureFile" class="form-control" accept="image/*" />
                                                        <small class="text-muted">Only image files (JPG, PNG, GIF, BMP). Max size: 8MB</small>
                                                    </div>
                                                    <button type="button" class="btn text-white" style="background: linear-gradient(135deg, rgb(104, 167, 226) 0%, rgb(72, 123, 165) 100%);" onclick="uploadAttachment('CustomerPicture', 'customerPictureFile')">
                                                        <i class="fas fa-upload me-2"></i>Upload Picture
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- ID Card Section -->
                                    <div class="card mb-4" style="border-color: rgb(104, 167, 226);">
                                        <div class="card-header text-white" style="background: linear-gradient(135deg, rgb(104, 167, 226) 0%, rgb(72, 123, 165) 100%);">
                                            <h6 class="mb-0"><i class="fas fa-id-card me-2"></i>Customer ID Card</h6>
                                        </div>
                                        <div class="card-body">
                                            <div class="row">
                                                <div class="col-md-4">
                                                    <div id="idCardPreview" class="text-center mb-3">
                                                        <img id="idCardImg" src="" alt="ID Card" class="img-thumbnail" style="max-width: 200px; max-height: 200px; display: none;" />
                                                        <div id="idCardPlaceholder" class="text-muted">
                                                            <i class="fas fa-id-card fa-5x"></i>
                                                            <p class="mt-2">No ID card uploaded</p>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-8">
                                                    <div class="mb-3">
                                                        <label class="form-label">Upload ID Card</label>
                                                        <input type="file" id="idCardFile" class="form-control" accept="image/*,.pdf" />
                                                        <small class="text-muted">Image files (JPG, PNG, GIF, BMP) or PDF. Max size: 8MB</small>
                                                    </div>
                                                    <button type="button" class="btn text-white" style="background: linear-gradient(135deg, rgb(104, 167, 226) 0%, rgb(72, 123, 165) 100%);" onclick="uploadAttachment('IDCard', 'idCardFile')">
                                                        <i class="fas fa-upload me-2"></i>Upload ID Card
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Other Attachments Section -->
                                    <div class="card mb-4" style="border-color: rgb(104, 167, 226);">
                                        <div class="card-header text-white" style="background: linear-gradient(135deg, rgb(104, 167, 226) 0%, rgb(72, 123, 165) 100%);">
                                            <h6 class="mb-0"><i class="fas fa-folder-open me-2"></i>Other Attachments</h6>
                                        </div>
                                        <div class="card-body">
                                            <div class="mb-3">
                                                <label class="form-label">Upload Additional Attachment</label>
                                                <div class="row">
                                                    <div class="col-md-6">
                                                        <input type="file" id="otherAttachmentFile" class="form-control" accept="image/*,.pdf" />
                                                        <small class="text-muted">Image files or PDF. Max size: 8MB</small>
                                                    </div>
                                                    <div class="col-md-4">
                                                        <input type="text" id="otherAttachmentDescription" class="form-control" placeholder="Description (optional)" />
                                                    </div>
                                                    <div class="col-md-2">
                                                        <button type="button" class="btn text-white w-100" style="background: linear-gradient(135deg, rgb(104, 167, 226) 0%, rgb(72, 123, 165) 100%);" onclick="uploadAttachment('Other', 'otherAttachmentFile', 'otherAttachmentDescription')">
                                                            <i class="fas fa-upload me-2"></i>Upload
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- Attachments List -->
                                            <div id="attachmentsList" class="mt-4">
                                                <h6 class="mb-3">Uploaded Attachments</h6>
                                                <div id="attachmentsContainer" class="row">
                                                    <div class="col-12 text-center text-muted py-3">
                                                        <i class="fas fa-spinner fa-spin fa-2x mb-2"></i>
                                                        <p>Loading attachments...</p>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Form Actions -->
                    <div class="row mt-4">
                        <div class="col-12">
                            <hr>
                            <div class="d-flex justify-content-end">
                                <button type="submit" class="btn btn-primary me-2">
                                    <i class="fas fa-save me-2"></i>Save Changes
                                </button>
                                <a asp-action="Details" asp-route-id="@Model.CustomerID" class="btn btn-outline-info me-2">
                                    <i class="fas fa-eye me-2"></i>View Details
                                </a>
                                <a asp-action="Index" class="btn btn-secondary">
                                    <i class="fas fa-times me-2"></i>Cancel
                                </a>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    /* Tab Styling */
    .customer-tabs {
        border-bottom: 2px solid #6f42c1;
        background: linear-gradient(135deg, #f8f9fa 0%, #f3f0ff 100%);
        padding: 0.5rem 1rem 0;
    }

    .customer-tabs .nav-link {
        color: #666;
        font-weight: 600;
        border: none;
        border-bottom: 3px solid transparent;
        padding: 0.75rem 1.25rem;
        transition: all 0.3s ease;
        font-size: 14px;
    }

    .customer-tabs .nav-link:hover {
        color: #6f42c1;
        background: rgba(111, 66, 193, 0.05);
        border-bottom-color: #9370db;
    }

    .customer-tabs .nav-link.active {
        color: #6f42c1;
        background: white;
        border-bottom-color: #6f42c1;
        font-weight: 700;
    }

    .customer-tabs .nav-link i {
        font-size: 13px;
    }

    /* Tab Content */
    .tab-content {
        padding-top: 1rem;
    }

    .tab-content .tab-pane {
        display: none;
    }

    .tab-content .tab-pane.show.active {
        display: block;
    }

    /* Section Headers within Tabs */
    .tab-pane h6 {
        color: #6f42c1;
        font-weight: 700;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid #e8dcff;
    }

    /* Responsive Tabs */
    @@media (max-width: 768px) {
        .customer-tabs .nav-link {
            padding: 0.5rem 0.75rem;
            font-size: 12px;
        }

        .customer-tabs .nav-link i {
            display: none;
        }
    }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        $(document).ready(function() {
            // Load properties when tab is shown
            $('#allotments-tab').on('shown.bs.tab', function() {
                loadProperties();
            });

            // Handle form submission
            $('#createAllotmentForm').on('submit', function(e) {
                e.preventDefault();
                
                var customerID = $('#customerID').val();
                var propertyID = $('#propertyID').val();
                var allotmentType = $('#allotmentType').val();
                var comments = $('#comments').val();

                if (!propertyID || !allotmentType) {
                    alert('Please select both Property and Allotment Type');
                    return;
                }

                // Show loading
                var submitBtn = $(this).find('button[type="submit"]');
                var originalText = submitBtn.html();
                submitBtn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-2"></i>Creating...');

                $.ajax({
                    url: '@Url.Action("CreateAllotmentFromCustomer", "Allotment")',
                    method: 'POST',
                    data: {
                        customerID: customerID,
                        propertyID: propertyID,
                        allotmentType: allotmentType,
                        comments: comments
                    },
                    success: function(response) {
                        if (response.success) {
                            alert(response.message);
                            window.location.reload();
                        } else {
                            alert('Error: ' + response.message);
                            submitBtn.prop('disabled', false).html(originalText);
                        }
                    },
                    error: function(xhr, status, error) {
                        var errorMessage = 'An error occurred while creating the allotment';
                        if (xhr.responseJSON && xhr.responseJSON.message) {
                            errorMessage = xhr.responseJSON.message;
                        } else if (xhr.responseText) {
                            try {
                                var response = JSON.parse(xhr.responseText);
                                if (response.message) {
                                    errorMessage = response.message;
                                }
                            } catch (e) {
                                errorMessage = 'HTTP Error ' + xhr.status + ': ' + error;
                            }
                        }
                        alert('Error: ' + errorMessage);
                        console.error('Allotment creation error:', xhr, status, error);
                        submitBtn.prop('disabled', false).html(originalText);
                    }
                });
            });

            // Load attachments when attachments tab is shown
            $('#attachments-tab').on('shown.bs.tab', function() {
                loadAttachments();
            });

            // Load attachments on page load if tab is active
            if ($('#attachments-tab').hasClass('active')) {
                loadAttachments();
            }
        });

        var customerId = '@Model.CustomerID';

        // Load attachments
        function loadAttachments() {
            $.ajax({
                url: '@Url.Action("GetAttachments", "Customer")',
                method: 'GET',
                data: { customerId: customerId },
                success: function(response) {
                    if (response.success) {
                        displayAttachments(response.attachments);
                    } else {
                        $('#attachmentsContainer').html('<div class="col-12 text-center text-muted py-3"><p>' + (response.message || 'Error loading attachments') + '</p></div>');
                    }
                },
                error: function() {
                    $('#attachmentsContainer').html('<div class="col-12 text-center text-muted py-3"><p>Error loading attachments</p></div>');
                }
            });
        }

        // Display attachments
        function displayAttachments(attachments) {
            var container = $('#attachmentsContainer');
            container.empty();

            if (attachments.length === 0) {
                container.html('<div class="col-12 text-center text-muted py-3"><i class="fas fa-inbox fa-2x mb-2"></i><p>No attachments uploaded yet</p></div>');
                return;
            }

            // Separate attachments by type
            var customerPicture = attachments.find(a => a.attachmentType === 'CustomerPicture');
            var idCard = attachments.find(a => a.attachmentType === 'IDCard');
            var otherAttachments = attachments.filter(a => a.attachmentType === 'Other');

            // Display Customer Picture
            if (customerPicture) {
                $('#customerPictureImg').attr('src', customerPicture.filePath).show();
                $('#customerPicturePlaceholder').hide();
            } else {
                $('#customerPictureImg').hide();
                $('#customerPicturePlaceholder').show();
            }

            // Display ID Card
            if (idCard) {
                if (idCard.fileType && idCard.fileType.includes('pdf')) {
                    $('#idCardImg').hide();
                    $('#idCardPlaceholder').html('<i class="fas fa-file-pdf fa-5x"></i><p class="mt-2">PDF Document</p>').show();
                } else {
                    $('#idCardImg').attr('src', idCard.filePath).show();
                    $('#idCardPlaceholder').hide();
                }
            } else {
                $('#idCardImg').hide();
                $('#idCardPlaceholder').html('<i class="fas fa-id-card fa-5x"></i><p class="mt-2">No ID card uploaded</p>').show();
            }

            // Display Other Attachments
            if (otherAttachments.length > 0) {
                otherAttachments.forEach(function(attachment) {
                    var isImage = attachment.fileType && attachment.fileType.startsWith('image/');
                    var isPdf = attachment.fileType && attachment.fileType.includes('pdf');
                    
                    var cardHtml = '<div class="col-md-4 mb-3">' +
                        '<div class="card h-100">' +
                        '<div class="card-body text-center">';
                    
                    if (isImage) {
                        cardHtml += '<img src="' + attachment.filePath + '" class="img-thumbnail mb-2" style="max-width: 100%; max-height: 200px;" />';
                    } else if (isPdf) {
                        cardHtml += '<i class="fas fa-file-pdf fa-4x text-danger mb-2"></i>';
                    } else {
                        cardHtml += '<i class="fas fa-file fa-4x text-muted mb-2"></i>';
                    }
                    
                    cardHtml += '<h6 class="card-title">' + (attachment.fileName || 'Attachment') + '</h6>';
                    
                    if (attachment.description) {
                        cardHtml += '<p class="card-text text-muted small">' + attachment.description + '</p>';
                    }
                    
                    cardHtml += '<p class="card-text small text-muted">' + 
                        (attachment.fileSize ? formatFileSize(attachment.fileSize) : '') + 
                        ' • ' + attachment.uploadedAt + '</p>' +
                        '<div class="btn-group" role="group">' +
                        '<a href="' + attachment.filePath + '" target="_blank" class="btn btn-sm btn-outline-primary">' +
                        '<i class="fas fa-eye me-1"></i>View</a>' +
                        '<button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteAttachment(\'' + attachment.attachmentID + '\')">' +
                        '<i class="fas fa-trash me-1"></i>Delete</button>' +
                        '</div>' +
                        '</div></div></div>';
                    
                    container.append(cardHtml);
                });
            } else {
                container.append('<div class="col-12 text-center text-muted py-3"><p>No other attachments</p></div>');
            }
        }

        // Upload attachment
        function uploadAttachment(attachmentType, fileInputId, descriptionInputId) {
            var fileInput = $('#' + fileInputId)[0];
            var file = fileInput.files[0];

            if (!file) {
                alert('Please select a file to upload');
                return;
            }

            var formData = new FormData();
            formData.append('customerId', customerId);
            formData.append('file', file);
            formData.append('attachmentType', attachmentType);
            
            if (descriptionInputId) {
                var description = $('#' + descriptionInputId).val();
                formData.append('description', description);
            }

            $.ajax({
                url: '@Url.Action("UploadAttachment", "Customer")',
                method: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                success: function(response) {
                    if (response.success) {
                        alert(response.message);
                        // Clear file input
                        fileInput.value = '';
                        if (descriptionInputId) {
                            $('#' + descriptionInputId).val('');
                        }
                        // Reload attachments
                        loadAttachments();
                    } else {
                        alert('Error: ' + response.message);
                    }
                },
                error: function() {
                    alert('An error occurred while uploading the file');
                }
            });
        }

        // Delete attachment
        function deleteAttachment(attachmentId) {
            if (!confirm('Are you sure you want to delete this attachment?')) {
                return;
            }

            $.ajax({
                url: '@Url.Action("DeleteAttachment", "Customer")',
                method: 'POST',
                data: { attachmentId: attachmentId },
                success: function(response) {
                    if (response.success) {
                        alert(response.message);
                        loadAttachments();
                    } else {
                        alert('Error: ' + response.message);
                    }
                },
                error: function() {
                    alert('An error occurred while deleting the attachment');
                }
            });
        }

        // Format file size
        function formatFileSize(bytes) {
            if (bytes === 0) return '0 Bytes';
            var k = 1024;
            var sizes = ['Bytes', 'KB', 'MB', 'GB'];
            var i = Math.floor(Math.log(bytes) / Math.log(k));
            return Math.round(bytes / Math.pow(k, i) * 100) / 100 + ' ' + sizes[i];
        }

        function loadProperties() {
            var customerID = $('#customerID').val();
            if (!customerID) return;

            var propertySelect = $('#propertyID');
            propertySelect.html('<option value="">Loading properties...</option>');

            $.ajax({
                url: '@Url.Action("GetAvailablePropertiesForCustomer", "Customer")',
                method: 'POST',
                data: { customerID: customerID },
                success: function(response) {
                    if (response.success && response.properties.length > 0) {
                        propertySelect.html('<option value="">Select a Property</option>');
                        $.each(response.properties, function(index, property) {
                            var optionText = property.plotNo;
                            if (property.block) optionText += ' - Block ' + property.block;
                            if (property.street) optionText += ' - ' + property.street;
                            optionText += ' (' + property.size + ')';
                            
                            propertySelect.append(
                                $('<option></option>')
                                    .attr('value', property.propertyID)
                                    .text(optionText)
                            );
                        });
                    } else {
                        var message = response.message || 'No available properties found';
                        propertySelect.html('<option value="">' + message + '</option>');
                    }
                },
                error: function() {
                    propertySelect.html('<option value="">Error loading properties</option>');
                }
            });
        }
    </script>
}
