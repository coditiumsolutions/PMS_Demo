@model PMS.Models.Customer

@{
    ViewData["Title"] = "Add New Customer";
}

<div class="row">
    <div class="col-12">
        <!-- Customer Wizard Form -->
        <form asp-action="Create" method="post" id="customerWizardForm" enctype="multipart/form-data">
            <input type="hidden" id="currentStepHidden" name="currentStep" value="3" />

            <div class="card">
                <div class="card-header" style="background: linear-gradient(135deg, rgb(104, 167, 226) 0%, rgb(72, 123, 165) 100%);">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 text-white">
                            <i class="fas fa-user-plus me-2"></i>Create New Customer
                        </h5>
                        <div class="text-white">
                            <span id="wizardStepIndicator">Step 1 of 3</span>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-warning alert-dismissible fade show" role="alert">
                            @TempData["ErrorMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <!-- Wizard Progress Bar -->
                    <div class="mb-4">
                        <div class="progress" style="height: 30px;">
                            <div class="progress-bar progress-bar-striped progress-bar-animated" 
                                 role="progressbar" 
                                 id="wizardProgress" 
                                 style="width: 33.33%; background: linear-gradient(135deg, rgb(104, 167, 226) 0%, rgb(72, 123, 165) 100%);">
                                <strong>Step 1: Personal Info</strong>
                            </div>
                        </div>
                    </div>

                    <!-- Wizard Steps -->
                    <div id="wizardSteps">
                        <!-- Step 1: Personal Info -->
                        <div class="wizard-step" id="step1" data-step="1">
                            <h5 class="mb-4" style="color: rgb(104, 167, 226);">
                                <i class="fas fa-user-circle me-2"></i>Step 1: Personal Information
                            </h5>
                            <!-- Registration Search -->
                            <div class="card mb-4 border-primary">
                                <div class="card-header bg-light">
                                    <h6 class="mb-0"><i class="fas fa-file-alt me-2"></i>Link to Registration (optional)</h6>
                                </div>
                                <div class="card-body">
                                    <div class="row align-items-end">
                                        <div class="col-md-4">
                                            <label for="registrationSearchInput" class="form-label">Registration ID</label>
                                            <input type="text" id="registrationSearchInput" class="form-control" placeholder="e.g. REG0000001" />
                                        </div>
                                        <div class="col-md-4">
                                            <button type="button" id="btnSearchRegistration" class="btn btn-outline-primary">
                                                <i class="fas fa-search me-1"></i>Search Registration
                                            </button>
                                        </div>
                                        <div class="col-md-4">
                                            <span id="registrationSearchMessage" class="text-muted small"></span>
                                        </div>
                                    </div>
                                    <input type="hidden" asp-for="RegID" id="RegID" />
                                </div>
                            </div>
                            <div class="row">
                                <!-- Personal Information -->
                                <div class="col-md-6">
                                    <h6 class="mb-3"><i class="fas fa-user me-2"></i>Personal Information</h6>
                                    
                                    <div class="mb-3">
                                        <label asp-for="FullName" class="form-label">Full Name *</label>
                                        <input asp-for="FullName" class="form-control" id="FullName" required />
                                        <span asp-validation-for="FullName" class="text-danger"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="FatherName" class="form-label">Father's Name</label>
                                        <input asp-for="FatherName" class="form-control" />
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="CNIC" class="form-label">National ID (CNIC)</label>
                                        <input asp-for="CNIC" id="CNIC" class="form-control" placeholder="XXXXX-XXXXXXX-X" />
                                        <small class="text-muted">Required format: 5 digits, hyphen, 7 digits, hyphen, 1 digit (e.g. 11111-1111111-1).</small>
                                        <span id="cnicValidationError" class="text-danger small d-none"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="PassportNo" class="form-label">Passport Number</label>
                                        <input asp-for="PassportNo" id="PassportNo" class="form-control" placeholder="Min 5 characters if no CNIC" />
                                        <small class="text-muted">Provide at least 5 characters if not providing CNIC.</small>
                                        <span id="passportValidationError" class="text-danger small d-none"></span>
                                    </div>
                                    <div id="cnicPassportRuleError" class="alert alert-warning small py-2 d-none" role="alert">
                                        <i class="fas fa-exclamation-triangle me-1"></i><span id="cnicPassportRuleErrorText"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="DOB" class="form-label">Date of Birth</label>
                                        <input asp-for="DOB" type="date" id="DOB" class="form-control" value="1990-01-01"
                                               max="@(DateTime.Today.AddYears(-16).ToString("yyyy-MM-dd"))"
                                               title="Must be at least 16 years ago" />
                                        <small class="text-muted">Default: 01/01/1990. Must be at least 16 years old.</small>
                                        <span id="dobValidationError" class="text-danger small d-none"></span>
                                        <span asp-validation-for="DOB" class="text-danger"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="Gender" class="form-label">Gender</label>
                                        <select asp-for="Gender" class="form-select">
                                            <option value="">Select Gender</option>
                                            <option value="Male">Male</option>
                                            <option value="Female">Female</option>
                                            <option value="Other">Other</option>
                                        </select>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="Nationality" class="form-label">Nationality</label>
                                        <select asp-for="Nationality" class="form-select">
                                            <option value="">Select Nationality</option>
                                            @if (ViewBag.Nationalities != null)
                                            {
                                                foreach (var nationality in ViewBag.Nationalities)
                                                {
                                                    <option value="@nationality">@nationality</option>
                                                }
                                            }
                                        </select>
                                        <span asp-validation-for="Nationality" class="text-danger"></span>
                                    </div>
                                </div>

                                <!-- Contact Information -->
                                <div class="col-md-6">
                                    <h6 class="mb-3"><i class="fas fa-phone me-2"></i>Contact Information</h6>
                                    
                                    <div class="mb-3">
                                        <label asp-for="Email" class="form-label">Email Address</label>
                                        <input asp-for="Email" id="Email" type="email" class="form-control" />
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="Phone" class="form-label">Phone (landline / primary contact) *</label>
                                        <input asp-for="Phone" id="Phone" class="form-control" required />
                                        <span asp-validation-for="Phone" class="text-danger"></span>
                                        <span id="phoneValidationError" class="text-danger small d-none"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="MobileNo" class="form-label">Mobile *</label>
                                        <input asp-for="MobileNo" id="MobileNo" class="form-control" required />
                                        <span asp-validation-for="MobileNo" class="text-danger"></span>
                                        <span id="mobileValidationError" class="text-danger small d-none"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="MobileNo2" class="form-label">Mobile 2</label>
                                        <input asp-for="MobileNo2" id="MobileNo2" class="form-control" />
                                        <span asp-validation-for="MobileNo2" class="text-danger"></span>
                                        <small class="form-text text-muted">Optional. Must differ from Phone and Mobile.</small>
                                        <span id="mobile2ValidationError" class="text-danger small d-none"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="City" class="form-label">City *</label>
                                        <select asp-for="City" class="form-select" required>
                                            <option value="">Select City</option>
                                            @if (ViewBag.Cities != null)
                                            {
                                                @foreach (var city in ViewBag.Cities)
                                                {
                                                    <option value="@city">@city</option>
                                                }
                                            }
                                        </select>
                                        <span asp-validation-for="City" class="text-danger"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="Country" class="form-label">Country *</label>
                                        <select asp-for="Country" class="form-select" required>
                                            <option value="">Select Country</option>
                                            @if (ViewBag.Countries != null)
                                            {
                                                @foreach (var country in ViewBag.Countries)
                                                {
                                                    <option value="@country">@country</option>
                                                }
                                            }
                                        </select>
                                        <span asp-validation-for="Country" class="text-danger"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="MailingAddress" class="form-label">Mailing Address *</label>
                                        <textarea asp-for="MailingAddress" class="form-control" rows="2" required></textarea>
                                        <span asp-validation-for="MailingAddress" class="text-danger"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="PermanentAddress" class="form-label">Permanent Address</label>
                                        <textarea asp-for="PermanentAddress" class="form-control" rows="2"></textarea>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Step 2: Next of Kin Info -->
                        <div class="wizard-step" id="step2" data-step="2" style="display: none;">
                            <h5 class="mb-4" style="color: rgb(104, 167, 226);">
                                <i class="fas fa-user-shield me-2"></i>Step 2: Next of Kin Information
                            </h5>
                            <div class="row">
                                <div class="col-md-6">
                                    <h6 class="mb-3"><i class="fas fa-user-friends me-2"></i>Next of Kin Information</h6>
                                    
                                    <div class="mb-3">
                                        <label asp-for="NomineeName" class="form-label">Next of Kin Name</label>
                                        <input asp-for="NomineeName" class="form-control" />
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="NomineeID" class="form-label">Next of Kin ID / National ID</label>
                                        <input asp-for="NomineeID" class="form-control" />
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="NomineeRelation" class="form-label">Relationship</label>
                                        <select asp-for="NomineeRelation" class="form-select">
                                            <option value="">Select Relationship</option>
                                            <option value="Father">Father</option>
                                            <option value="Mother">Mother</option>
                                            <option value="Son">Son</option>
                                            <option value="Daughter">Daughter</option>
                                            <option value="Spouse">Spouse</option>
                                            <option value="Brother">Brother</option>
                                            <option value="Sister">Sister</option>
                                            <option value="Other">Other</option>
                                        </select>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">Next of Kin NIC Document</label>
                                        <input type="file" name="nomineeNICUpload" class="form-control" accept="image/*,.pdf" />
                                        <small class="text-muted">Accepted formats: JPG, PNG, GIF, BMP, PDF. Max size: 8MB.</small>
                                        <span asp-validation-for="NomineeNICDocumentPath" class="text-danger"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">Next of Kin Picture</label>
                                        <input type="file" name="nomineePictureUpload" class="form-control" accept="image/*" />
                                        <small class="text-muted">Accepted formats: JPG, PNG, GIF, BMP. Max size: 8MB.</small>
                                        <span asp-validation-for="NomineePicturePath" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="alert alert-info">
                                        <i class="fas fa-info-circle me-2"></i>
                                        <strong>Next of Kin Information</strong>
                                        <p class="mb-0 mt-2">Please provide the details of the person who will be the next of kin for this customer. This person will have rights in case of any unforeseen circumstances.</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Step 3: Payment Plan Info -->
                        <div class="wizard-step" id="step3" data-step="3" style="display: none;">
                            <h5 class="mb-4" style="color: rgb(104, 167, 226);">
                                <i class="fas fa-file-contract me-2"></i>Step 3: Payment Plan Information
                            </h5>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label asp-for="ProjectID" class="form-label">Project *</label>
                                        <select asp-for="ProjectID" id="projectIDSelect" class="form-select" required>
                                            <option value="">Select Project</option>
                                            @if (ViewBag.Projects != null)
                                            {
                                                @foreach (var project in ViewBag.Projects)
                                                {
                                                    <option value="@project.ProjectID" data-project-prefix="@(project.Prefix ?? "")">@project.ProjectName (@project.Prefix)</option>
                                                }
                                            }
                                        </select>
                                        <span asp-validation-for="ProjectID" class="text-danger"></span>
                                        <small class="text-muted">The project prefix will be used to generate the Customer ID</small>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="PlanID" class="form-label">Payment Plan *</label>
                                        <select asp-for="PlanID" id="planIDSelect" class="form-select" required>
                                            <option value="">Select Payment Plan</option>
                                            @if (ViewBag.PaymentPlans != null)
                                            {
                                                @foreach (var plan in ViewBag.PaymentPlans)
                                                {
                                                    <option value="@plan.PlanID" data-project-prefix="@(plan.Project?.Prefix ?? "")">@plan.PlanName - PKR @plan.TotalAmount.ToString("N0")</option>
                                                }
                                            }
                                        </select>
                                        <span asp-validation-for="PlanID" class="text-danger"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="SubProject" class="form-label">Sub Project *</label>
                                        <select asp-for="SubProject" id="SubProject" class="form-select" required disabled>
                                            @if (!string.IsNullOrWhiteSpace(Model?.SubProject))
                                            {
                                                <option value="@Model.SubProject" selected>@Model.SubProject</option>
                                            }
                                            else
                                            {
                                                <option value="">Select Project first</option>
                                            }
                                        </select>
                                        <span asp-validation-for="SubProject" class="text-danger"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="RegisteredSize" class="form-label">Registered Size *</label>
                                        <select asp-for="RegisteredSize" id="RegisteredSize" class="form-select" required disabled>
                                            <option value="">Select Project first</option>
                                        </select>
                                        <small class="text-muted">Sizes are loaded from the selected project.</small>
                                        <span asp-validation-for="RegisteredSize" class="text-danger"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">Is Dealer Registered?</label>
                                        <div class="d-flex gap-3">
                                            <div class="form-check">
                                                <input class="form-check-input" type="radio" name="IsDealerRegistered" id="dealerRegYes" value="1" @(Model?.IsDealerRegistered != 0 ? "checked" : null)>
                                                <label class="form-check-label" for="dealerRegYes">Yes</label>
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input" type="radio" name="IsDealerRegistered" id="dealerRegNo" value="0" @(Model?.IsDealerRegistered == 0 ? "checked" : null)>
                                                <label class="form-check-label" for="dealerRegNo">No</label>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="mb-3" id="dealerDropdownWrap">
                                        <label asp-for="DealerID" class="form-label">Select Dealer *</label>
                                        <select asp-for="DealerID" id="DealerID" class="form-select">
                                            <option value="">Select Dealer</option>
                                            @if (ViewBag.Dealers != null)
                                            {
                                                @foreach (var dealer in ViewBag.Dealers)
                                                {
                                                    <option value="@dealer.DealerID">@dealer.DealershipName</option>
                                                }
                                            }
                                        </select>
                                        <span asp-validation-for="DealerID" class="text-danger"></span>
                                    </div>
                                    <div class="mb-3" id="dealerNameWrap" style="display:none;">
                                        <label asp-for="DealerName" class="form-label">Dealer Name *</label>
                                        <input asp-for="DealerName" id="DealerName" class="form-control" placeholder="Enter dealer name manually" maxlength="200" />
                                        <span asp-validation-for="DealerName" class="text-danger"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label for="selectedPropertySelect" class="form-label">Available Properties</label>
                                        <select id="selectedPropertySelect" name="SelectedPropertyID" class="form-select" data-selected="@ViewBag.SelectedPropertyID">
                                            <option value="">Select project, size, and dealer to view available properties</option>
                                        </select>
                                        <small id="availablePropertyHelp" class="text-muted">Properties are filtered by the selected project, size, and dealer.</small>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <h6 class="mb-3"><i class="fas fa-sticky-note me-2"></i>Additional Information</h6>

                                    <div class="mb-3">
                                        <label asp-for="AdditionalInfo" class="form-label">Additional Notes</label>
                                        <textarea asp-for="AdditionalInfo" class="form-control" rows="6" placeholder="Enter any additional information about the customer..."></textarea>
                                    </div>

                                    <!-- Preview Customer ID -->
                                    <div class="alert alert-info">
                                        <h6 class="alert-heading"><i class="fas fa-id-badge me-2"></i>Customer ID Preview</h6>
                                        <p class="mb-0">
                                            <strong>Customer ID will be:</strong><br>
                                            <span id="customerIDPreview" class="badge bg-secondary" style="font-size: 14px;">Select Project to preview</span>
                                        </p>
                                        <small class="text-muted">Format: [Project Prefix][Sequential Number] (e.g., JSC0001)</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Wizard Navigation Buttons -->
                    <div class="row mt-4">
                        <div class="col-12">
                            <hr>
                            <div class="d-flex justify-content-between">
                                <button type="button" id="prevBtn" class="btn btn-secondary" style="display: none;" onclick="previousStep()">
                                    <i class="fas fa-arrow-left me-2"></i>Previous
                                </button>
                                <div class="ms-auto">
                                    <button type="button" id="nextBtn" class="btn text-white" style="background: linear-gradient(135deg, rgb(104, 167, 226) 0%, rgb(72, 123, 165) 100%);" onclick="nextStep()">
                                        Next <i class="fas fa-arrow-right ms-2"></i>
                                    </button>
                                    <button type="submit" id="createBtn" class="btn text-white" style="background: linear-gradient(135deg, rgb(104, 167, 226) 0%, rgb(72, 123, 165) 100%); display: none;">
                                        <i class="fas fa-save me-2"></i>Create Customer
                                    </button>
                                    <a asp-action="Index" class="btn btn-secondary">
                                        <i class="fas fa-times me-2"></i>Cancel
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<style>
    /* Compact Card Spacing */
    .card-body {
        padding: 8px 12px !important;
    }

    .card-header {
        padding: 8px 12px !important;
    }


    /* Wizard Step Styling */
    .wizard-step {
        min-height: 400px;
    }

    .wizard-step h5 {
        font-weight: 700;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid rgba(104, 167, 226, 0.3);
    }

    /* Progress Bar */
    .progress {
        border-radius: 10px;
        overflow: hidden;
    }

    .progress-bar {
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 600;
    }

    /* Section Headers within Steps */
    .wizard-step h6 {
        color: rgb(104, 167, 226);
        font-weight: 700;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid rgba(104, 167, 226, 0.2);
    }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        // FullName: letters, spaces, dots, hyphens only
        document.getElementById('FullName').addEventListener('input', function () {
            this.value = this.value.replace(/[^a-zA-Z\s\.\-]/g, '');
        });
        // Phone / Mobile: digits and + only
        ['Phone', 'MobileNo', 'MobileNo2'].forEach(function (id) {
            var el = document.getElementById(id);
            if (el) el.addEventListener('input', function () {
                this.value = this.value.replace(/[^0-9\+]/g, '');
            });
        });

        let currentStep = 1;
        const totalSteps = 3;

        // Wizard Navigation Functions
        function updateWizardUI() {
            // Show/hide steps
            $('.wizard-step').hide();
            $('#step' + currentStep).show();

            // Update progress bar
            var progress = (currentStep / totalSteps) * 100;
            $('#wizardProgress').css('width', progress + '%');
            
            var stepText = '';
            if (currentStep === 1) {
                stepText = 'Step 1: Personal Info';
            } else if (currentStep === 2) {
                stepText = 'Step 2: Next of Kin Info';
            } else if (currentStep === 3) {
                stepText = 'Step 3: Payment Plan Info';
            }
            $('#wizardProgress').html('<strong>' + stepText + '</strong>');

            // Update step indicator
            $('#wizardStepIndicator').text('Step ' + currentStep + ' of ' + totalSteps);

            // Show/hide navigation buttons
            if (currentStep === 1) {
                $('#prevBtn').hide();
                $('#nextBtn').show();
                $('#createBtn').hide();
            } else if (currentStep === totalSteps) {
                $('#prevBtn').show();
                $('#nextBtn').hide();
                $('#createBtn').show();
            } else {
                $('#prevBtn').show();
                $('#nextBtn').show();
                $('#createBtn').hide();
            }
        }

        function nextStep() {
            // Step 1: enforce identity/contact rules before allowing Next
            if (currentStep === 1) {
                if (!validateStep1IdentityAndMobile()) {
                    $('html, body').animate({ scrollTop: $('#step1').offset().top - 20 }, 300);
                    return;
                }
                if (!validateStep1Dob()) {
                    $('html, body').animate({ scrollTop: $('#DOB').offset().top - 20 }, 300);
                    return;
                }
                if (!validateStep1ContactRules()) {
                    $('html, body').animate({ scrollTop: $('#Phone').offset().top - 20 }, 300);
                    return;
                }
            }

            // Validate current step
            var currentStepElement = $('#step' + currentStep);
            var form = currentStepElement.closest('form')[0];
            
            // Get all required fields in current step
            var requiredFields = currentStepElement.find('[required]');
            var isValid = true;
            
            requiredFields.each(function() {
                if (!$(this).val()) {
                    isValid = false;
                    $(this).addClass('is-invalid');
                } else {
                    $(this).removeClass('is-invalid');
                }
            });

            if (!isValid) {
                alert('Please fill all required fields before proceeding.');
                return;
            }

            if (currentStep < totalSteps) {
                currentStep++;
                updateWizardUI();
                
                // Scroll to top
                $('html, body').animate({
                    scrollTop: $('.card').offset().top - 100
                }, 300);
            }
        }

        function previousStep() {
            if (currentStep > 1) {
                currentStep--;
                updateWizardUI();
                
                // Scroll to top
                $('html, body').animate({
                    scrollTop: $('.card').offset().top - 100
                }, 300);
            }
        }

        function normalizeDropdownValue(value) {
            return (value || '').toString().trim().toLowerCase();
        }

        function loadSizes(projectId, selectedValue) {
            var $sizeSelect = $('#RegisteredSize');
            var desiredValue = (selectedValue || $sizeSelect.val() || '').toString().trim();
            $sizeSelect.html('<option value="">Select Size</option>').prop('disabled', !projectId);
            if (!projectId) {
                return;
            }

            $.get('@Url.Action("GetProjectSizes", "Customer")', { projectId: projectId })
                .done(function(arr) {
                    var desiredValueNormalized = normalizeDropdownValue(desiredValue);
                    var matched = false;
                    $(arr).each(function() {
                        var itemValue = (this || '').toString();
                        var opt = $('<option></option>').val(itemValue).text(itemValue);
                        if (!matched && normalizeDropdownValue(itemValue) === desiredValueNormalized) {
                            opt.prop('selected', true);
                            matched = true;
                        }
                        $sizeSelect.append(opt);
                    });

                    // Keep posted value visible if not currently present in project size list.
                    if (!matched && desiredValue) {
                        $sizeSelect.append(
                            $('<option></option>')
                                .val(desiredValue)
                                .text(desiredValue + ' (current)')
                                .prop('selected', true)
                        );
                    }
                    loadAvailablePropertiesPreview();
                })
                .fail(function() {
                    $sizeSelect.html('<option value="">Could not load sizes</option>');
                });
        }

        function loadSubProjects(projectId, selectedValue) {
            var $subProjectSelect = $('#SubProject');
            var desiredValue = (selectedValue || $subProjectSelect.val() || '').toString().trim();
            $subProjectSelect.html('<option value="">Select Sub Project</option>').prop('disabled', !projectId);
            if (!projectId) {
                return;
            }

            $.get('@Url.Action("GetProjectSubProjects", "Customer")', { projectId: projectId })
                .done(function(arr) {
                    var desiredValueNormalized = normalizeDropdownValue(desiredValue);
                    var matched = false;

                    $(arr).each(function() {
                        var itemValue = (this || '').toString();
                        var opt = $('<option></option>').val(itemValue).text(itemValue);
                        if (!matched && normalizeDropdownValue(itemValue) === desiredValueNormalized) {
                            opt.prop('selected', true);
                            matched = true;
                        }
                        $subProjectSelect.append(opt);
                    });

                    // Keep the posted value visible if it isn't currently in project's subproject list.
                    if (!matched && desiredValue) {
                        $subProjectSelect.append(
                            $('<option></option>')
                                .val(desiredValue)
                                .text(desiredValue + ' (current)')
                                .prop('selected', true)
                        );
                    }
                })
                .fail(function() {
                    $subProjectSelect.html('<option value="">Could not load sub projects</option>');
                });
        }

        var currentProjectId = $('#projectIDSelect').val();
        var currentRegisteredSize = '@(Model?.RegisteredSize ?? "")';
        var currentSubProject = '@(Model?.SubProject ?? "")';
        if (currentProjectId) {
            loadSizes(currentProjectId, currentRegisteredSize);
            loadSubProjects(currentProjectId, currentSubProject);
        }

        $('#projectIDSelect').on('change', function() {
            var selectedProjectId = $(this).val();
            loadSizes(selectedProjectId, '');
            loadSubProjects(selectedProjectId, '');
        });

        // Update Customer ID Preview when Project is selected
        $('#projectIDSelect').on('change', function() {
            var selectedOption = $(this).find('option:selected');
            var projectPrefix = selectedOption.data('project-prefix');
            
            if (projectPrefix) {
                // Show preview (actual number will be generated on server)
                $('#customerIDPreview').text(projectPrefix + 'XXXXX').removeClass('bg-secondary').addClass('bg-primary');
            } else {
                $('#customerIDPreview').text('Select Project to preview').removeClass('bg-primary').addClass('bg-secondary');
            }
        });

        // Registration Search - pre-fill from registration
        $('#btnSearchRegistration').on('click', function() {
            var regID = $('#registrationSearchInput').val().trim();
            var $msg = $('#registrationSearchMessage');
            $msg.removeClass('text-success text-danger').text('');
            $('#RegID').val('');
            if (!regID) {
                $msg.addClass('text-danger').text('Please enter a Registration ID.');
                return;
            }
            $.post('@Url.Action("SearchRegistration", "Customer")', { regID: regID, __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() })
                .done(function(data) {
                    if (data.success && data.registration) {
                        var r = data.registration;
                        $('#RegID').val(r.regID);
                        $('#FullName').val(r.fullName || '');
                        $('#CNIC').val(r.cnic || '');
                        $('#Phone').val(r.phone || '');
                        $('#Email').val(r.email || '');

                        if (r.projectID) {
                            $('#projectIDSelect').val(r.projectID);
                            loadSizes(r.projectID, r.size || '');
                            loadSubProjects(r.projectID, r.subProject || '');
                        }

                        $msg.addClass('text-success').text('Registration found. Details pre-filled.');
                    } else {
                        $msg.addClass('text-danger').text(data.message || 'Registration not found.');
                    }
                })
                .fail(function() {
                    $msg.addClass('text-danger').text('Search failed. Please try again.');
                });
        });

        // Also update preview when Payment Plan is selected (as fallback if Project not selected)
        $('#planIDSelect').on('change', function() {
            // Only update if ProjectID is not selected
            if (!$('#projectIDSelect').val()) {
                var selectedOption = $(this).find('option:selected');
                var projectPrefix = selectedOption.data('project-prefix');
                
                if (projectPrefix) {
                    // Show preview (actual number will be generated on server)
                    $('#customerIDPreview').text(projectPrefix + 'XXXXX').removeClass('bg-secondary').addClass('bg-primary');
                } else {
                    $('#customerIDPreview').text('Select Project or Payment Plan to preview').removeClass('bg-primary').addClass('bg-secondary');
                }
            }
        });

        function toggleDealerFields() {
            var isYes = $('#dealerRegYes').is(':checked');
            $('#dealerDropdownWrap').toggle(isYes);
            $('#dealerNameWrap').toggle(!isYes);
            if (isYes) { $('#DealerName').val(''); } else { $('#DealerID').val(''); }
            loadAvailablePropertiesPreview();
        }
        $('#dealerRegYes, #dealerRegNo').on('change', toggleDealerFields);
        toggleDealerFields();

        $('form').on('submit', function() {
            if ($('#dealerRegYes').is(':checked')) {
                $('#DealerName').val('');
            } else {
                $('#DealerID').val('');
            }
        });

        $('#projectIDSelect, #RegisteredSize, #DealerID').on('change', loadAvailablePropertiesPreview);
        $('#selectedPropertySelect').on('change', function() {
            $(this).data('selected', $(this).val());
        });

        function loadAvailablePropertiesPreview() {
            var propertySelect = $('#selectedPropertySelect');
            var helpText = $('#availablePropertyHelp');

            if (!propertySelect.length) {
                return;
            }

            var projectId = $('#projectIDSelect').val();
            var registeredSize = $('#RegisteredSize').val();
            var dealerId = $('#dealerRegYes').is(':checked') ? $('#DealerID').val() : null;

            if (!projectId || !registeredSize) {
                propertySelect.html('<option value="">Select project and size to view available properties</option>');
                propertySelect.data('selected', '');
                helpText.removeClass('text-danger').addClass('text-muted').text('Properties are filtered by the selected project, size, and dealer.');
                return;
            }

            propertySelect.html('<option value="">Loading properties...</option>');
            helpText.removeClass('text-danger').addClass('text-muted').text('Loading properties for the selected project, size, and dealer...');

            $.ajax({
                url: '@Url.Action("GetAvailablePropertiesByProject", "Customer")',
                method: 'GET',
                data: {
                    projectId: projectId,
                    registeredSize: registeredSize,
                    dealerId: dealerId || ''
                },
                success: function(response) {
                    if (response.success && response.properties && response.properties.length > 0) {
                        propertySelect.html('<option value="">Select a Property</option>');
                        $.each(response.properties, function(index, property) {
                            var optionText = property.plotNo;
                            if (property.block) optionText += ' - Block ' + property.block;
                            if (property.street) optionText += ' - ' + property.street;
                            optionText += ' (' + property.size + ')';
                            propertySelect.append(
                                $('<option></option>')
                                    .attr('value', property.propertyID)
                                    .text(optionText)
                            );
                        });

                        var preselected = propertySelect.data('selected');
                        if (preselected) {
                            propertySelect.val(preselected);
                        }
                        propertySelect.data('selected', propertySelect.val());

                        var projectName = response.projectName ? response.projectName : 'selected project';
                        helpText.removeClass('text-danger').addClass('text-muted').text('Showing ' + response.properties.length + ' properties for ' + projectName + ' (' + response.registeredSize + '). Dealer filter applied if selected.');
                    } else {
                        var message = response.message || 'No available properties found for the selected project, size, and dealer.';
                        propertySelect.html('<option value="">' + message + '</option>');
                        propertySelect.data('selected', '');
                        helpText.removeClass('text-muted').addClass('text-danger').text(message);
                    }
                },
                error: function() {
                    var message = 'Could not load available properties. Please try again.';
                    propertySelect.html('<option value="">' + message + '</option>');
                    propertySelect.data('selected', '');
                    helpText.removeClass('text-muted').addClass('text-danger').text(message);
                }
            });
        }

        // Step 1 identity + mobile rules:
        // CNIC is required with XXXXX-XXXXXXX-X format.
        // Mobile is required and must be 11-13 digits.
        // Mobile 2 is optional but when provided must be 11-13 digits.
        function validateStep1IdentityAndMobile(showAlert) {
            if (showAlert === undefined) showAlert = true;
            var cnic = ($('#CNIC').val() || '').trim();
            var phoneRaw = ($('#Phone').val() || '').trim();
            var mobileRaw = ($('#MobileNo').val() || '').trim();
            var mobile2Raw = ($('#MobileNo2').val() || '').trim();
            var cnicRegex = /^\d{5}-\d{7}-\d$/;
            var phoneDigits = normalizePhoneDigits(phoneRaw);
            var mobileDigits = normalizePhoneDigits(mobileRaw);
            var mobile2Digits = normalizePhoneDigits(mobile2Raw);
            var cnicValid = cnicRegex.test(cnic);
            var phoneValid = !!phoneRaw;
            var mobileValid = /^\d+$/.test(mobileRaw) && mobileDigits.length >= 11 && mobileDigits.length <= 13;
            var mobile2Valid = !mobile2Raw || (/^\d+$/.test(mobile2Raw) && mobile2Digits.length >= 11 && mobile2Digits.length <= 13);
            $('#CNIC').removeClass('is-invalid');
            $('#Phone').removeClass('is-invalid');
            $('#MobileNo').removeClass('is-invalid');
            $('#MobileNo2').removeClass('is-invalid');
            $('#cnicValidationError').addClass('d-none').text('');
            $('#phoneValidationError').addClass('d-none').text('');
            $('#mobileValidationError').addClass('d-none').text('');
            $('#mobile2ValidationError').addClass('d-none').text('');
            $('#cnicPassportRuleError').addClass('d-none');
            if (!cnicValid) {
                $('#CNIC').addClass('is-invalid');
                $('#cnicValidationError').removeClass('d-none').text('CNIC is required in XXXXX-XXXXXXX-X format.');
                $('#cnicPassportRuleError').removeClass('d-none');
                $('#cnicPassportRuleErrorText').text('Please enter a valid CNIC in format XXXXX-XXXXXXX-X.');
                return false;
            }
            if (!phoneValid) {
                $('#Phone').addClass('is-invalid');
                $('#phoneValidationError').removeClass('d-none').text('Phone is required.');
                if (showAlert) alert('Phone is required.');
                return false;
            }
            if (!mobileValid) {
                $('#MobileNo').addClass('is-invalid');
                $('#mobileValidationError').removeClass('d-none').text('Mobile must contain only digits (11 to 13 digits).');
                if (showAlert) alert('Mobile is required and must contain only digits (11 to 13 digits).');
                return false;
            }
            if (!mobile2Valid) {
                $('#MobileNo2').addClass('is-invalid');
                $('#mobile2ValidationError').removeClass('d-none').text('Mobile 2 must contain only digits (11 to 13 digits).');
                if (showAlert) alert('Mobile 2 must contain only digits (11 to 13 digits).');
                return false;
            }
            return true;
        }

        $('#CNIC').on('input blur', function() {
            var cnic = ($('#CNIC').val() || '').trim();
            var cnicValid = /^\d{5}-\d{7}-\d$/.test(cnic);
            if (cnicValid) {
                $('#CNIC').removeClass('is-invalid');
                $('#cnicValidationError, #cnicPassportRuleError').addClass('d-none').text('');
            }
        });

        $('#MobileNo, #MobileNo2').on('input blur', function() {
            var id = $(this).attr('id');
            var raw = ($(this).val() || '').trim();
            var digits = normalizePhoneDigits(raw);
            var valid = !raw || (/^\d+$/.test(raw) && digits.length >= 11 && digits.length <= 13);
            if (id === 'MobileNo') {
                valid = /^\d+$/.test(raw) && digits.length >= 11 && digits.length <= 13;
            }
            if (valid) {
                $(this).removeClass('is-invalid');
            }
        });

        function normalizePhoneDigits(value) {
            return (value || '').toString().replace(/\D/g, '');
        }

        function validateStep1ContactRules(showAlert) {
            if (showAlert === undefined) showAlert = true;
            var phone = normalizePhoneDigits($('#Phone').val());
            var mobile = normalizePhoneDigits($('#MobileNo').val());
            var mobile2 = normalizePhoneDigits($('#MobileNo2').val());
            $('#Phone, #MobileNo, #MobileNo2').removeClass('is-invalid');
            $('#phoneValidationError').addClass('d-none').text('');
            $('#mobileValidationError').addClass('d-none').text('');
            $('#mobile2ValidationError').addClass('d-none').text('');

            if (phone && mobile && phone === mobile) {
                $('#Phone, #MobileNo').addClass('is-invalid');
                $('#phoneValidationError').removeClass('d-none').text('Phone must be different from Mobile.');
                $('#mobileValidationError').removeClass('d-none').text('Mobile must be different from Phone.');
                if (showAlert) alert('Phone and Mobile must be different numbers.');
                return false;
            }
            if (mobile2) {
                if (phone && mobile2 === phone) {
                    $('#Phone, #MobileNo2').addClass('is-invalid');
                    $('#phoneValidationError').removeClass('d-none').text('Phone must be different from Mobile 2.');
                    $('#mobile2ValidationError').removeClass('d-none').text('Mobile 2 must be different from Phone.');
                    if (showAlert) alert('Mobile 2 must be different from Phone.');
                    return false;
                }
                if (mobile && mobile2 === mobile) {
                    $('#MobileNo, #MobileNo2').addClass('is-invalid');
                    $('#mobileValidationError').removeClass('d-none').text('Mobile must be different from Mobile 2.');
                    $('#mobile2ValidationError').removeClass('d-none').text('Mobile 2 must be different from Mobile.');
                    if (showAlert) alert('Mobile 2 must be different from Mobile.');
                    return false;
                }
            }
            return true;
        }

        function validateStep1Field(fieldId) {
            var $field = $('#' + fieldId);
            if (!$field.length) return true;
            var value = ($field.val() || '').toString().trim();

            if (fieldId === 'CNIC' || fieldId === 'Phone' || fieldId === 'MobileNo' || fieldId === 'MobileNo2') {
                var identityOk = validateStep1IdentityAndMobile(false);
                var contactOk = validateStep1ContactRules(false);
                return identityOk && contactOk;
            }

            if (fieldId === 'DOB') {
                return validateStep1Dob();
            }

            if (fieldId === 'PassportNo') {
                return validateCnicPassportPair();
            }

            if (fieldId === 'Email') {
                if (!value) {
                    $field.removeClass('is-invalid');
                    return true;
                }
                var emailValid = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(value);
                $field.toggleClass('is-invalid', !emailValid);
                return emailValid;
            }

            if ($field.prop('required')) {
                var ok = !!value;
                $field.toggleClass('is-invalid', !ok);
                return ok;
            }

            return true;
        }

        function validateCnicPassportPair() {
            var cnic = ($('#CNIC').val() || '').trim();
            var passport = ($('#PassportNo').val() || '').trim();
            var cnicValid = /^\d{5}-\d{7}-\d$/.test(cnic);
            var passportValid = passport.length >= 3;

            $('#PassportNo').removeClass('is-invalid');
            $('#passportValidationError').addClass('d-none').text('');
            if (passport && !/^[a-zA-Z0-9]+$/.test(passport)) {
                $('#PassportNo').addClass('is-invalid');
                $('#passportValidationError').removeClass('d-none').text('Passport must be alphanumeric only.');
                return false;
            }

            if (!cnicValid && !passportValid) {
                $('#CNIC, #PassportNo').addClass('is-invalid');
                $('#cnicPassportRuleError').removeClass('d-none');
                $('#cnicPassportRuleErrorText').text('Either valid CNIC or Passport Number (min 3 chars) is required.');
                return false;
            }

            $('#cnicPassportRuleError').addClass('d-none');
            return true;
        }

        function validateStep1Dob() {
            var dobVal = $('#DOB').val();
            if (!dobVal) return true;
            var maxDob = new Date();
            maxDob.setFullYear(maxDob.getFullYear() - 16);
            var dob = new Date(dobVal);
            if (dob > maxDob) {
                $('#DOB').addClass('is-invalid');
                $('#dobValidationError').text('Date of Birth must be at least 16 years ago.').removeClass('d-none');
                return false;
            }
            $('#DOB').removeClass('is-invalid');
            $('#dobValidationError').addClass('d-none').text('');
            return true;
        }

        // Form submission handler
        $('#customerWizardForm').on('submit', function(e) {
            // Only validate if we're on step 3 (final step)
            if (currentStep !== 3) {
                e.preventDefault();
                alert('Please complete all steps before submitting.');
                currentStep = 3;
                updateWizardUI();
                return false;
            }
            
            // Validate required fields in final step only (Step 1/2 are validated on their own step transitions).
            var step3Element = $('#step3');
            var isValid = true;
            var invalidFields = [];
            var requiredFields = step3Element.find('[required]');

            requiredFields.each(function() {
                var field = $(this);
                var value = field.val();
                var fieldName = field.attr('name') || field.attr('id') || 'field';

                if (field.is('select')) {
                    if (!value || value === '' || value === null) {
                        isValid = false;
                        field.addClass('is-invalid');
                        invalidFields.push(fieldName);
                    } else {
                        field.removeClass('is-invalid');
                    }
                } else {
                    if (!value || value.trim() === '') {
                        isValid = false;
                        field.addClass('is-invalid');
                        invalidFields.push(fieldName);
                    } else {
                        field.removeClass('is-invalid');
                    }
                }
            });
            
            if (!isValid) {
                e.preventDefault();
                var message = 'Please fill all required fields before submitting.';
                if (invalidFields.length > 0) {
                    var maxFields = 5;
                    var fieldsToShow = invalidFields.length > maxFields ? maxFields : invalidFields.length;
                    var fieldsList = [];
                    for (var i = 0; i < fieldsToShow; i++) {
                        fieldsList.push(invalidFields[i]);
                    }
                    message += '\n\nMissing fields: ' + fieldsList.join(', ');
                    if (invalidFields.length > maxFields) {
                        message += ' and ' + (invalidFields.length - maxFields) + ' more...';
                    }
                }
                alert(message);
                $('html, body').animate({ scrollTop: $('#step3').offset().top - 100 }, 300);
                return false;
            }
            
            // If validation passes, allow form submission
            // Show loading state
            $('#createBtn').prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-2"></i>Creating...');
            return true;
        });

        // Initialize wizard
        $(document).ready(function() {
            // Default DOB to 01/01/1990 if empty (Create form)
            var dobInput = document.getElementById('DOB');
            if (dobInput && !dobInput.value) {
                dobInput.value = '1990-01-01';
            }
            $('#DOB').on('change input', function() {
                var d = $(this).val();
                if (d) {
                    var maxDob = new Date(); maxDob.setFullYear(maxDob.getFullYear() - 16);
                    if (new Date(d) <= maxDob) {
                        $(this).removeClass('is-invalid');
                        $('#dobValidationError').addClass('d-none').text('');
                    }
                }
            });
            // Check if we're returning from a validation error (ModelState has errors)
            var serverErrorKeys = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                ViewData.ModelState
                    .Where(x => x.Value != null && x.Value.Errors.Count > 0)
                    .Select(x => x.Key)
                    .ToList()
            ));
            if (Array.isArray(serverErrorKeys) && serverErrorKeys.length > 0) {
                var step1Fields = ['FullName', 'FatherName', 'CNIC', 'PassportNo', 'DOB', 'Gender', 'Nationality', 'Phone', 'MobileNo', 'MobileNo2', 'Email', 'City', 'Country', 'MailingAddress', 'PermanentAddress', 'RegID'];
                var step2Fields = ['NomineeName', 'NomineeID', 'NomineeRelation', 'NomineeNICDocumentPath', 'NomineePicturePath'];
                var step3Fields = ['ProjectID', 'PlanID', 'SubProject', 'RegisteredSize', 'DealerID', 'DealerName', 'AdditionalInfo'];

                var targetStep = 3;
                if (serverErrorKeys.some(function (k) { return step1Fields.indexOf(k) >= 0; })) {
                    targetStep = 1;
                } else if (serverErrorKeys.some(function (k) { return step2Fields.indexOf(k) >= 0; })) {
                    targetStep = 2;
                } else if (serverErrorKeys.some(function (k) { return step3Fields.indexOf(k) >= 0; })) {
                    targetStep = 3;
                }
                currentStep = targetStep;
            }
            updateWizardUI();
            loadAvailablePropertiesPreview();

            // Live field-level validation on leave/change for Step 1 fields
            var step1FieldIds = ['FullName', 'CNIC', 'PassportNo', 'DOB', 'Phone', 'MobileNo', 'MobileNo2', 'Email', 'City', 'Country', 'MailingAddress'];
            step1FieldIds.forEach(function(fieldId) {
                var $field = $('#' + fieldId);
                if (!$field.length) return;

                var eventName = $field.is('select') ? 'change' : 'blur';
                $field.on(eventName, function() {
                    validateStep1Field(fieldId);
                });
            });
        });
    </script>
}
