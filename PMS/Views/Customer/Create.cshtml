@model PMS.Models.Customer

@{
    ViewData["Title"] = "Add New Customer";
}

<div class="row">
    <div class="col-12">
        <!-- Customer Wizard Form -->
        <form asp-action="Create" method="post" id="customerWizardForm" enctype="multipart/form-data">
            <input type="hidden" id="currentStepHidden" name="currentStep" value="3" />

            <div class="card">
                <div class="card-header" style="background: linear-gradient(135deg, rgb(104, 167, 226) 0%, rgb(72, 123, 165) 100%);">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 text-white">
                            <i class="fas fa-user-plus me-2"></i>Create New Customer
                        </h5>
                        <div class="text-white">
                            <span id="wizardStepIndicator">Step 1 of 3</span>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-warning alert-dismissible fade show" role="alert">
                            @TempData["ErrorMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <!-- Wizard Progress Bar -->
                    <div class="mb-4">
                        <div class="progress" style="height: 30px;">
                            <div class="progress-bar progress-bar-striped progress-bar-animated" 
                                 role="progressbar" 
                                 id="wizardProgress" 
                                 style="width: 33.33%; background: linear-gradient(135deg, rgb(104, 167, 226) 0%, rgb(72, 123, 165) 100%);">
                                <strong>Step 1: Personal Info</strong>
                            </div>
                        </div>
                    </div>

                    <!-- Wizard Steps -->
                    <div id="wizardSteps">
                        <!-- Step 1: Personal Info -->
                        <div class="wizard-step" id="step1" data-step="1">
                            <h5 class="mb-4" style="color: rgb(104, 167, 226);">
                                <i class="fas fa-user-circle me-2"></i>Step 1: Personal Information
                            </h5>
                            <div class="row">
                                <!-- Personal Information -->
                                <div class="col-md-6"
                                    <h6 class="mb-3"><i class="fas fa-user me-2"></i>Personal Information</h6>
                                    
                                    <div class="mb-3">
                                        <label asp-for="FullName" class="form-label">Full Name *</label>
                                        <input asp-for="FullName" class="form-control" required />
                                        <span asp-validation-for="FullName" class="text-danger"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="FatherName" class="form-label">Father's Name</label>
                                        <input asp-for="FatherName" class="form-control" />
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="CNIC" class="form-label">National ID</label>
                                        <input asp-for="CNIC" class="form-control" placeholder="XXXXX-XXXXXXX-X" />
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="PassportNo" class="form-label">Passport Number</label>
                                        <input asp-for="PassportNo" class="form-control" />
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="DOB" class="form-label">Date of Birth</label>
                                        <input asp-for="DOB" type="date" class="form-control" />
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="Gender" class="form-label">Gender</label>
                                        <select asp-for="Gender" class="form-select">
                                            <option value="">Select Gender</option>
                                            <option value="Male">Male</option>
                                            <option value="Female">Female</option>
                                            <option value="Other">Other</option>
                                        </select>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="Nationality" class="form-label">Nationality</label>
                                        <select asp-for="Nationality" class="form-select">
                                            <option value="">Select Nationality</option>
                                            @if (ViewBag.Nationalities != null)
                                            {
                                                foreach (var nationality in ViewBag.Nationalities)
                                                {
                                                    <option value="@nationality">@nationality</option>
                                                }
                                            }
                                        </select>
                                        <span asp-validation-for="Nationality" class="text-danger"></span>
                                    </div>
                                </div>

                                <!-- Contact Information -->
                                <div class="col-md-6">
                                    <h6 class="mb-3"><i class="fas fa-phone me-2"></i>Contact Information</h6>
                                    
                                    <div class="mb-3">
                                        <label asp-for="Email" class="form-label">Email Address</label>
                                        <input asp-for="Email" type="email" class="form-control" />
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="Phone" class="form-label">Phone Number *</label>
                                        <input asp-for="Phone" class="form-control" required />
                                        <span asp-validation-for="Phone" class="text-danger"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="City" class="form-label">City</label>
                                        <select asp-for="City" class="form-select">
                                            <option value="">Select City</option>
                                            @if (ViewBag.Cities != null)
                                            {
                                                @foreach (var city in ViewBag.Cities)
                                                {
                                                    <option value="@city">@city</option>
                                                }
                                            }
                                        </select>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="Country" class="form-label">Country</label>
                                        <select asp-for="Country" class="form-select">
                                            <option value="">Select Country</option>
                                            @if (ViewBag.Countries != null)
                                            {
                                                @foreach (var country in ViewBag.Countries)
                                                {
                                                    <option value="@country">@country</option>
                                                }
                                            }
                                        </select>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="MailingAddress" class="form-label">Mailing Address</label>
                                        <textarea asp-for="MailingAddress" class="form-control" rows="2"></textarea>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="PermanentAddress" class="form-label">Permanent Address</label>
                                        <textarea asp-for="PermanentAddress" class="form-control" rows="2"></textarea>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Step 2: Next of Kin Info -->
                        <div class="wizard-step" id="step2" data-step="2" style="display: none;">
                            <h5 class="mb-4" style="color: rgb(104, 167, 226);">
                                <i class="fas fa-user-shield me-2"></i>Step 2: Next of Kin Information
                            </h5>
                            <div class="row">
                                <div class="col-md-6">
                                    <h6 class="mb-3"><i class="fas fa-user-friends me-2"></i>Next of Kin Information</h6>
                                    
                                    <div class="mb-3">
                                        <label asp-for="NomineeName" class="form-label">Next of Kin Name</label>
                                        <input asp-for="NomineeName" class="form-control" />
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="NomineeID" class="form-label">Next of Kin ID / National ID</label>
                                        <input asp-for="NomineeID" class="form-control" />
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="NomineeRelation" class="form-label">Relationship</label>
                                        <select asp-for="NomineeRelation" class="form-select">
                                            <option value="">Select Relationship</option>
                                            <option value="Father">Father</option>
                                            <option value="Mother">Mother</option>
                                            <option value="Son">Son</option>
                                            <option value="Daughter">Daughter</option>
                                            <option value="Spouse">Spouse</option>
                                            <option value="Brother">Brother</option>
                                            <option value="Sister">Sister</option>
                                            <option value="Other">Other</option>
                                        </select>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">Next of Kin NIC Document</label>
                                        <input type="file" name="nomineeNICUpload" class="form-control" accept="image/*,.pdf" />
                                        <small class="text-muted">Accepted formats: JPG, PNG, GIF, BMP, PDF. Max size: 8MB.</small>
                                        <span asp-validation-for="NomineeNICDocumentPath" class="text-danger"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">Next of Kin Picture</label>
                                        <input type="file" name="nomineePictureUpload" class="form-control" accept="image/*" />
                                        <small class="text-muted">Accepted formats: JPG, PNG, GIF, BMP. Max size: 8MB.</small>
                                        <span asp-validation-for="NomineePicturePath" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="alert alert-info">
                                        <i class="fas fa-info-circle me-2"></i>
                                        <strong>Next of Kin Information</strong>
                                        <p class="mb-0 mt-2">Please provide the details of the person who will be the next of kin for this customer. This person will have rights in case of any unforeseen circumstances.</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Step 3: Payment Plan Info -->
                        <div class="wizard-step" id="step3" data-step="3" style="display: none;">
                            <h5 class="mb-4" style="color: rgb(104, 167, 226);">
                                <i class="fas fa-file-contract me-2"></i>Step 3: Payment Plan Information
                            </h5>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label asp-for="ProjectID" class="form-label">Project *</label>
                                        <select asp-for="ProjectID" id="projectIDSelect" class="form-select" required>
                                            <option value="">Select Project</option>
                                            @if (ViewBag.Projects != null)
                                            {
                                                @foreach (var project in ViewBag.Projects)
                                                {
                                                    <option value="@project.ProjectID" data-project-prefix="@(project.Prefix ?? "")">@project.ProjectName (@project.Prefix)</option>
                                                }
                                            }
                                        </select>
                                        <span asp-validation-for="ProjectID" class="text-danger"></span>
                                        <small class="text-muted">The project prefix will be used to generate the Customer ID</small>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="PlanID" class="form-label">Payment Plan *</label>
                                        <select asp-for="PlanID" id="planIDSelect" class="form-select" required>
                                            <option value="">Select Payment Plan</option>
                                            @if (ViewBag.PaymentPlans != null)
                                            {
                                                @foreach (var plan in ViewBag.PaymentPlans)
                                                {
                                                    <option value="@plan.PlanID" data-project-prefix="@(plan.Project?.Prefix ?? "")">@plan.PlanName - @plan.TotalAmount.ToString("C")</option>
                                                }
                                            }
                                        </select>
                                        <span asp-validation-for="PlanID" class="text-danger"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="SubProject" class="form-label">Sub Project *</label>
                                        <select asp-for="SubProject" class="form-select" required>
                                            <option value="">Select Sub Project</option>
                                            @if (ViewBag.SubProjects != null)
                                            {
                                                @foreach (var subProject in ViewBag.SubProjects)
                                                {
                                                    <option value="@subProject">@subProject</option>
                                                }
                                            }
                                        </select>
                                        <span asp-validation-for="SubProject" class="text-danger"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="RegisteredSize" class="form-label">Registered Size *</label>
                                        <select asp-for="RegisteredSize" id="RegisteredSize" class="form-select" required>
                                            <option value="">Select Size</option>
                                            @if (ViewBag.Sizes != null)
                                            {
                                                @foreach (var size in ViewBag.Sizes)
                                                {
                                                    <option value="@size">@size</option>
                                                }
                                            }
                                        </select>
                                        <span asp-validation-for="RegisteredSize" class="text-danger"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="DealerID" class="form-label">Dealer *</label>
                                        <select asp-for="DealerID" id="DealerID" class="form-select" required>
                                            <option value="">Select Dealer</option>
                                            @if (ViewBag.Dealers != null)
                                            {
                                                @foreach (var dealer in ViewBag.Dealers)
                                                {
                                                    <option value="@dealer.DealerID">@dealer.DealershipName</option>
                                                }
                                            }
                                        </select>
                                        <span asp-validation-for="DealerID" class="text-danger"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label for="selectedPropertySelect" class="form-label">Available Properties</label>
                                        <select id="selectedPropertySelect" name="SelectedPropertyID" class="form-select" data-selected="@ViewBag.SelectedPropertyID">
                                            <option value="">Select project, size, and dealer to view available properties</option>
                                        </select>
                                        <small id="availablePropertyHelp" class="text-muted">Properties are filtered by the selected project, size, and dealer.</small>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <h6 class="mb-3"><i class="fas fa-sticky-note me-2"></i>Additional Information</h6>

                                    <div class="mb-3">
                                        <label asp-for="AdditionalInfo" class="form-label">Additional Notes</label>
                                        <textarea asp-for="AdditionalInfo" class="form-control" rows="6" placeholder="Enter any additional information about the customer..."></textarea>
                                    </div>

                                    <!-- Preview Customer ID -->
                                    <div class="alert alert-info">
                                        <h6 class="alert-heading"><i class="fas fa-id-badge me-2"></i>Customer ID Preview</h6>
                                        <p class="mb-0">
                                            <strong>Customer ID will be:</strong><br>
                                            <span id="customerIDPreview" class="badge bg-secondary" style="font-size: 14px;">Select Project to preview</span>
                                        </p>
                                        <small class="text-muted">Format: [Project Prefix][Sequential Number] (e.g., JSC0001)</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Wizard Navigation Buttons -->
                    <div class="row mt-4">
                        <div class="col-12">
                            <hr>
                            <div class="d-flex justify-content-between">
                                <button type="button" id="prevBtn" class="btn btn-secondary" style="display: none;" onclick="previousStep()">
                                    <i class="fas fa-arrow-left me-2"></i>Previous
                                </button>
                                <div class="ms-auto">
                                    <button type="button" id="nextBtn" class="btn text-white" style="background: linear-gradient(135deg, rgb(104, 167, 226) 0%, rgb(72, 123, 165) 100%);" onclick="nextStep()">
                                        Next <i class="fas fa-arrow-right ms-2"></i>
                                    </button>
                                    <button type="submit" id="createBtn" class="btn text-white" style="background: linear-gradient(135deg, rgb(104, 167, 226) 0%, rgb(72, 123, 165) 100%); display: none;">
                                        <i class="fas fa-save me-2"></i>Create Customer
                                    </button>
                                    <a asp-action="Index" class="btn btn-secondary">
                                        <i class="fas fa-times me-2"></i>Cancel
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<style>
    /* Compact Card Spacing */
    .card-body {
        padding: 8px 12px !important;
    }

    .card-header {
        padding: 8px 12px !important;
    }


    /* Wizard Step Styling */
    .wizard-step {
        min-height: 400px;
    }

    .wizard-step h5 {
        font-weight: 700;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid rgba(104, 167, 226, 0.3);
    }

    /* Progress Bar */
    .progress {
        border-radius: 10px;
        overflow: hidden;
    }

    .progress-bar {
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 600;
    }

    /* Section Headers within Steps */
    .wizard-step h6 {
        color: rgb(104, 167, 226);
        font-weight: 700;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid rgba(104, 167, 226, 0.2);
    }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        let currentStep = 1;
        const totalSteps = 3;

        // Wizard Navigation Functions
        function updateWizardUI() {
            // Show/hide steps
            $('.wizard-step').hide();
            $('#step' + currentStep).show();

            // Update progress bar
            var progress = (currentStep / totalSteps) * 100;
            $('#wizardProgress').css('width', progress + '%');
            
            var stepText = '';
            if (currentStep === 1) {
                stepText = 'Step 1: Personal Info';
            } else if (currentStep === 2) {
                stepText = 'Step 2: Next of Kin Info';
            } else if (currentStep === 3) {
                stepText = 'Step 3: Payment Plan Info';
            }
            $('#wizardProgress').html('<strong>' + stepText + '</strong>');

            // Update step indicator
            $('#wizardStepIndicator').text('Step ' + currentStep + ' of ' + totalSteps);

            // Show/hide navigation buttons
            if (currentStep === 1) {
                $('#prevBtn').hide();
                $('#nextBtn').show();
                $('#createBtn').hide();
            } else if (currentStep === totalSteps) {
                $('#prevBtn').show();
                $('#nextBtn').hide();
                $('#createBtn').show();
            } else {
                $('#prevBtn').show();
                $('#nextBtn').show();
                $('#createBtn').hide();
            }
        }

        function nextStep() {
            // Validate current step
            var currentStepElement = $('#step' + currentStep);
            var form = currentStepElement.closest('form')[0];
            
            // Get all required fields in current step
            var requiredFields = currentStepElement.find('[required]');
            var isValid = true;
            
            requiredFields.each(function() {
                if (!$(this).val()) {
                    isValid = false;
                    $(this).addClass('is-invalid');
                } else {
                    $(this).removeClass('is-invalid');
                }
            });

            if (!isValid) {
                alert('Please fill all required fields before proceeding.');
                return;
            }

            if (currentStep < totalSteps) {
                currentStep++;
                updateWizardUI();
                
                // Scroll to top
                $('html, body').animate({
                    scrollTop: $('.card').offset().top - 100
                }, 300);
            }
        }

        function previousStep() {
            if (currentStep > 1) {
                currentStep--;
                updateWizardUI();
                
                // Scroll to top
                $('html, body').animate({
                    scrollTop: $('.card').offset().top - 100
                }, 300);
            }
        }

        // Update Customer ID Preview when Project is selected
        $('#projectIDSelect').on('change', function() {
            var selectedOption = $(this).find('option:selected');
            var projectPrefix = selectedOption.data('project-prefix');
            
            if (projectPrefix) {
                // Show preview (actual number will be generated on server)
                $('#customerIDPreview').text(projectPrefix + 'XXXXX').removeClass('bg-secondary').addClass('bg-primary');
            } else {
                $('#customerIDPreview').text('Select Project to preview').removeClass('bg-primary').addClass('bg-secondary');
            }
        });

        // Also update preview when Payment Plan is selected (as fallback if Project not selected)
        $('#planIDSelect').on('change', function() {
            // Only update if ProjectID is not selected
            if (!$('#projectIDSelect').val()) {
                var selectedOption = $(this).find('option:selected');
                var projectPrefix = selectedOption.data('project-prefix');
                
                if (projectPrefix) {
                    // Show preview (actual number will be generated on server)
                    $('#customerIDPreview').text(projectPrefix + 'XXXXX').removeClass('bg-secondary').addClass('bg-primary');
                } else {
                    $('#customerIDPreview').text('Select Project or Payment Plan to preview').removeClass('bg-primary').addClass('bg-secondary');
                }
            }
        });

        $('#projectIDSelect, #RegisteredSize, #DealerID').on('change', loadAvailablePropertiesPreview);
        $('#selectedPropertySelect').on('change', function() {
            $(this).data('selected', $(this).val());
        });

        function loadAvailablePropertiesPreview() {
            var propertySelect = $('#selectedPropertySelect');
            var helpText = $('#availablePropertyHelp');

            if (!propertySelect.length) {
                return;
            }

            var projectId = $('#projectIDSelect').val();
            var registeredSize = $('#RegisteredSize').val();
            var dealerId = $('#DealerID').val();

            if (!projectId || !registeredSize || !dealerId) {
                propertySelect.html('<option value="">Select project, size, and dealer to view available properties</option>');
                propertySelect.data('selected', '');
                helpText.removeClass('text-danger').addClass('text-muted').text('Properties are filtered by the selected project, size, and dealer.');
                return;
            }

            propertySelect.html('<option value="">Loading properties...</option>');
            helpText.removeClass('text-danger').addClass('text-muted').text('Loading properties for the selected project, size, and dealer...');

            $.ajax({
                url: '@Url.Action("GetAvailablePropertiesByProject", "Customer")',
                method: 'GET',
                data: {
                    projectId: projectId,
                    registeredSize: registeredSize,
                    dealerId: dealerId || ''
                },
                success: function(response) {
                    if (response.success && response.properties && response.properties.length > 0) {
                        propertySelect.html('<option value="">Select a Property</option>');
                        $.each(response.properties, function(index, property) {
                            var optionText = property.plotNo;
                            if (property.block) optionText += ' - Block ' + property.block;
                            if (property.street) optionText += ' - ' + property.street;
                            optionText += ' (' + property.size + ')';
                            propertySelect.append(
                                $('<option></option>')
                                    .attr('value', property.propertyID)
                                    .text(optionText)
                            );
                        });

                        var preselected = propertySelect.data('selected');
                        if (preselected) {
                            propertySelect.val(preselected);
                        }
                        propertySelect.data('selected', propertySelect.val());

                        var projectName = response.projectName ? response.projectName : 'selected project';
                        helpText.removeClass('text-danger').addClass('text-muted').text('Showing ' + response.properties.length + ' properties for ' + projectName + ' (' + response.registeredSize + '). Dealer filter applied if selected.');
                    } else {
                        var message = response.message || 'No available properties found for the selected project, size, and dealer.';
                        propertySelect.html('<option value="">' + message + '</option>');
                        propertySelect.data('selected', '');
                        helpText.removeClass('text-muted').addClass('text-danger').text(message);
                    }
                },
                error: function() {
                    var message = 'Could not load available properties. Please try again.';
                    propertySelect.html('<option value="">' + message + '</option>');
                    propertySelect.data('selected', '');
                    helpText.removeClass('text-muted').addClass('text-danger').text(message);
                }
            });
        }

        // Form submission handler
        $('#customerWizardForm').on('submit', function(e) {
            // Only validate if we're on step 3 (final step)
            if (currentStep !== 3) {
                e.preventDefault();
                alert('Please complete all steps before submitting.');
                currentStep = 3;
                updateWizardUI();
                return false;
            }
            
            // Validate all required fields in all steps
            var isValid = true;
            var firstInvalidStep = null;
            var invalidFields = [];
            
            for (var step = 1; step <= totalSteps; step++) {
                var stepElement = $('#step' + step);
                var requiredFields = stepElement.find('[required]');
                
                requiredFields.each(function() {
                    var field = $(this);
                    var value = field.val();
                    var fieldName = field.attr('name') || field.attr('id') || 'field';
                    
                    // Check if it's a select and has a value
                    if (field.is('select')) {
                        if (!value || value === '' || value === null) {
                            isValid = false;
                            field.addClass('is-invalid');
                            invalidFields.push(fieldName);
                            if (firstInvalidStep === null) {
                                firstInvalidStep = step;
                            }
                        } else {
                            field.removeClass('is-invalid');
                        }
                    } else if (field.is('input[type="email"]')) {
                        // Email validation - simple check without complex regex to avoid Razor parsing issues
                        function isValidEmail(email) {
                            if (!email || email.trim() === '') return false;
                            var trimmed = email.trim();
                            var atSymbol = String.fromCharCode(64); // @@ symbol
                            var atIndex = trimmed.indexOf(atSymbol);
                            if (atIndex <= 0 || atIndex >= trimmed.length - 1) return false;
                            var dotIndex = trimmed.lastIndexOf('.');
                            if (dotIndex <= atIndex || dotIndex >= trimmed.length - 1) return false;
                            return true;
                        }
                        
                        if (field.attr('required')) {
                            if (!value || value.trim() === '' || !isValidEmail(value)) {
                                isValid = false;
                                field.addClass('is-invalid');
                                invalidFields.push(fieldName);
                                if (firstInvalidStep === null) {
                                    firstInvalidStep = step;
                                }
                            } else {
                                field.removeClass('is-invalid');
                            }
                        } else if (value && value.trim() !== '') {
                            // If email is provided but not required, validate format
                            if (!isValidEmail(value)) {
                                isValid = false;
                                field.addClass('is-invalid');
                                invalidFields.push(fieldName);
                                if (firstInvalidStep === null) {
                                    firstInvalidStep = step;
                                }
                            } else {
                                field.removeClass('is-invalid');
                            }
                        } else {
                            field.removeClass('is-invalid');
                        }
                    } else {
                        // For input fields
                        if (!value || value.trim() === '') {
                            isValid = false;
                            field.addClass('is-invalid');
                            invalidFields.push(fieldName);
                            if (firstInvalidStep === null) {
                                firstInvalidStep = step;
                            }
                        } else {
                            field.removeClass('is-invalid');
                        }
                    }
                });
            }
            
            if (!isValid) {
                e.preventDefault();
                var message = 'Please fill all required fields before submitting.';
                if (invalidFields.length > 0) {
                    var maxFields = 5;
                    var fieldsToShow = invalidFields.length > maxFields ? maxFields : invalidFields.length;
                    var fieldsList = [];
                    for (var i = 0; i < fieldsToShow; i++) {
                        fieldsList.push(invalidFields[i]);
                    }
                    message += '\n\nMissing fields: ' + fieldsList.join(', ');
                    if (invalidFields.length > maxFields) {
                        message += ' and ' + (invalidFields.length - maxFields) + ' more...';
                    }
                }
                alert(message);
                
                // Navigate to first invalid step
                if (firstInvalidStep !== null) {
                    currentStep = firstInvalidStep;
                    updateWizardUI();
                    $('html, body').animate({
                        scrollTop: $('.card').offset().top - 100
                    }, 300);
                }
                return false;
            }
            
            // If validation passes, allow form submission
            // Show loading state
            $('#createBtn').prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-2"></i>Creating...');
            return true;
        });

        // Initialize wizard
        $(document).ready(function() {
            // Check if we're returning from a validation error (ModelState has errors)
            @if (!ViewData.ModelState.IsValid)
            {
                <text>
                // If there are validation errors, show step 3 (Payment Plan Info)
                currentStep = 3;
                </text>
            }
            updateWizardUI();
            loadAvailablePropertiesPreview();
        });
    </script>
}
