@model PMS.Models.Customer

@{
	Layout = null;
    ViewData["Title"] = "Account Statement";
    var plan = Model.PaymentPlan;
    var schedules = plan?.PaymentSchedules?.OrderBy(ps => ps.InstallmentNo ?? int.MaxValue).ToList() ?? new List<PMS.Models.PaymentSchedule>();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Juba Smart City PMS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/juba-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
</head>
<body>

<!-- Print/Download Controls -->
<div class="d-flex justify-content-between align-items-center mb-3 no-print">
    <h3 class="mb-0"><i class="fas fa-file-invoice-dollar me-2"></i>Account Statement</h3>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-secondary btn-sm" onclick="window.print()"><i class="fas fa-print me-1"></i>Print</button>
        <a class="btn btn-outline-primary btn-sm" href="#" onclick="downloadPDF(event)"><i class="fas fa-file-pdf me-1"></i>Download PDF</a>
    </div>
</div>

<div class="a4-container">
    <div id="statement-root">
        <!-- Header Section -->
        <div class="a4-header text-center">
            <img src="~/images/logo.jpeg" alt="JUBA Smart City Logo" class="a4-logo" />
            <div class="a4-title">Account Statement</div>
            <div class="a4-subtitle">JUBA Smart City Property Management System</div>
            <div class="a4-subtitle">Generated on: @DateTime.Now.ToString("MMMM dd, yyyy")</div>
        </div>

        <!-- Customer and Plot Information -->
        <div class="a4-section">
            <div class="a4-info-grid">
                <div class="a4-info-block">
                    <h6>Customer Information</h6>
                    <div class="a4-info-row">
                        <span class="a4-info-label">Customer ID:</span>
                        <span class="a4-info-value"><code>@Model.CustomerID</code></span>
                    </div>
                    <div class="a4-info-row">
                        <span class="a4-info-label">Customer Name:</span>
                        <span class="a4-info-value">@Model.FullName</span>
                    </div>
                    <div class="a4-info-row">
                        <span class="a4-info-label">Address:</span>
                        <span class="a4-info-value">@(Model.MailingAddress ?? Model.PermanentAddress ?? "-")</span>
                    </div>
                    <div class="a4-info-row">
                        <span class="a4-info-label">Mobile:</span>
                        <span class="a4-info-value">@Model.Phone</span>
                    </div>
                </div>
                <div class="a4-info-block">
                    <h6>Plot / Plan Information</h6>
                    @{
                        var property = Model.Allotments?.FirstOrDefault()?.Property;
                    }
                    <div class="a4-info-row">
                        <span class="a4-info-label">Plot:</span>
                        <span class="a4-info-value">@(property != null ? ($"{property.PlotNo}, Block {property.Block}{(string.IsNullOrWhiteSpace(property.Street) ? string.Empty : ", Street " + property.Street)}") : "-")</span>
                    </div>
                    <div class="a4-info-row">
                        <span class="a4-info-label">Size:</span>
                        <span class="a4-info-value">@(property?.Size ?? Model.RegisteredSize ?? "-")</span>
                    </div>
                    <div class="a4-info-row">
                        <span class="a4-info-label">Plan:</span>
                        <span class="a4-info-value">@(plan?.PlanName ?? "-")</span>
                    </div>
                    <div class="a4-info-row">
                        <span class="a4-info-label">Total Amount:</span>
                        <span class="a4-info-value">@(plan != null ? plan.TotalAmount.ToString("N0") + " SSP" : "-")</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Surcharge Policy Information -->
        <div class="a4-section">


        <!-- Payment Schedule Table -->
        <div class="a4-section">
            <div class="a4-section-title">Payment Schedule</div>
            <table class="a4-table">
                <thead>
                    <tr>
                        <th class="text-start">Account Head</th>
                        <th>Installment No</th>
                        <th>Due Date</th>
                        <th class="text-end">Due Amount</th>
                        <th class="text-end">Amount Due</th>
                        <th class="text-end">Amount Paid</th>
                        <th>Paid On</th>
                        <th class="text-start">Payment DS/Instrument No</th>
                        <th class="text-end">Surcharge (Daily)</th>
                    </tr>
                </thead>
                <tbody>
                @{
                    decimal totalDueAmount = 0m;
                    decimal totalAmountDue = 0m;
                    decimal totalAmountPaid = 0m;
                    decimal totalSurcharge = 0m;
                }
                @foreach (var sch in schedules)
                {
                    var payments = sch.Payments?.OrderBy(p => p.PaymentDate).ToList() ?? new List<PMS.Models.Payment>();
                    var amountPaid = payments.Sum(p => p.Amount);
                    var amountDue = Math.Max(0m, sch.Amount - amountPaid);
                    
                    // Calculate daily surcharge from DueDate until fully paid or today
                    decimal surcharge = 0m;
                    if (sch.SurchargeApplied)
                    {
                        var dueDate = sch.DueDate.Date;
                        var today = DateTime.Now.Date;
                        var endDate = today; // Default to today if not fully paid
                        
                        // If fully paid, calculate surcharge only until the last payment date
                        if (amountPaid >= sch.Amount && payments.Any())
                        {
                            endDate = payments.Last().PaymentDate.Date;
                        }
                        
                        // Calculate days overdue (only if past due date)
                        if (endDate > dueDate)
                        {
                            var daysOverdue = (int)(endDate - dueDate).TotalDays;
                            
                            // Calculate surcharge: Use original due amount (sch.Amount) for fully paid installments,
                            // or remaining amount due for partially paid installments
                            // SurchargeRate format: 
                            //   - Old records: stored as percentage (e.g., 0.05 = 0.05%, need to divide by 100)
                            //   - New records: stored as decimal (e.g., 0.0005 = 0.05%, use directly)
                            // Check if value > 1 to determine format (old percentage format vs new decimal format)
                            var dailySurchargeRate = sch.SurchargeRate > 1m 
                                ? sch.SurchargeRate / 100m  // Old format: 0.05 → 0.0005
                                : sch.SurchargeRate;        // New format: 0.0005 → 0.0005
                            // Daily surcharge = Amount × daily rate × Days Overdue
                            // Example: 100,000 × 0.0005 = 50 per day, × 3 days = 150
                            
                            // Use original amount for surcharge calculation (not remaining amount due)
                            // This ensures late payments are charged surcharge even if now fully paid
                            var amountForSurcharge = amountPaid >= sch.Amount ? sch.Amount : amountDue;
                            var dailySurchargeAmount = amountForSurcharge * dailySurchargeRate; // Amount × 0.0005 per day
                            surcharge = Math.Round(dailySurchargeAmount * daysOverdue, 2);
                        }
                    }

                    totalDueAmount += sch.Amount;
                    totalAmountDue += amountDue;
                    totalAmountPaid += amountPaid;
                    totalSurcharge += surcharge;
                    
                    // Calculate days overdue for display (for both unpaid and late-paid installments)
                    var daysOverdueDisplay = 0;
                    var dueDateDisplay = sch.DueDate.Date;
                    var endDateDisplay = amountPaid >= sch.Amount && payments.Any() 
                        ? payments.Last().PaymentDate.Date 
                        : DateTime.Now.Date;
                    
                    if (endDateDisplay > dueDateDisplay)
                    {
                        daysOverdueDisplay = (int)(endDateDisplay - dueDateDisplay).TotalDays;
                    }

                    <tr>
                        <td class="text-start">Installment</td>
                        <td>@(sch.InstallmentNo?.ToString() ?? "N/A")</td>
                        <td>
                            @sch.DueDate.ToString("MMM dd, yyyy")
                            @if (daysOverdueDisplay > 0)
                            {
                                <br /><small class="text-danger">(@daysOverdueDisplay day@(daysOverdueDisplay != 1 ? "s" : "") overdue)</small>
                            }
                        </td>
                        <td class="text-end">@($"{sch.Amount:N0}")</td>
                        <td class="text-end">@($"{amountDue:N0}")</td>
                        <td class="text-end">@($"{amountPaid:N0}")</td>
                        <td>@(payments.LastOrDefault()?.PaymentDate.ToString("MMM dd, yyyy") ?? "-")</td>
                        <td class="text-start">@(payments.LastOrDefault()?.ReferenceNo ?? "-")</td>
                        <td class="text-end">
                            @($"{surcharge:N0}")
                            @if (sch.SurchargeApplied && daysOverdueDisplay > 0)
                            {
                                // Determine format and calculate display values
                                var isOldFormat = sch.SurchargeRate > 1m;
                                var dailyRatePercent = isOldFormat ? sch.SurchargeRate : sch.SurchargeRate * 100m;
                                var dailyRateDecimal = isOldFormat ? sch.SurchargeRate / 100m : sch.SurchargeRate;
                                var amountForDisplay = amountPaid >= sch.Amount ? sch.Amount : amountDue;
                                var dailySurchargeAmount = amountForDisplay * dailyRateDecimal;
                                <br /><small class="text-muted">(@($"{dailyRatePercent:N2}")% daily = @($"{dailySurchargeAmount:N0}") per day × @daysOverdueDisplay day@(daysOverdueDisplay != 1 ? "s" : ""))</small>
                            }
                        </td>
                    </tr>
                }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="3" class="text-end">Totals</td>
                        <td class="text-end">@($"{totalDueAmount:N0}")</td>
                        <td class="text-end">@($"{totalAmountDue:N0}")</td>
                        <td class="text-end">@($"{totalAmountPaid:N0}")</td>
                        <td></td>
                        <td></td>
                        <td class="text-end">@($"{totalSurcharge:N0}")</td>
                    </tr>
                </tfoot>
            </table>
        </div>

        <!-- Footer -->
        <div class="a4-footer">
            <div>This is a system generated report and does not require a signature.</div>
            <div style="margin-top: 10px;">
                <strong>JUBA Smart City Property Management System</strong><br>
                Generated on: @DateTime.Now.ToString("MMMM dd, yyyy at hh:mm tt")
            </div>
        </div>
    </div>
</div>

<script>
    function downloadPDF(e) {
        e.preventDefault();
        window.print();
    }
</script>

<style>
    /* A4 Paper Size Styling */
    .a4-container {
        width: 210mm;
        height: 297mm;
        margin: 0 auto;
        padding: 15mm;
        background: white;
        box-shadow: 0 0 10px rgba(0,0,0,0.1);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        overflow: hidden;
    }

    .a4-header {
        border-bottom: 2px solid #333;
        padding-bottom: 10px;
        margin-bottom: 12px;
    }

    .a4-title {
        font-size: 20px;
        font-weight: bold;
        color: #333;
        margin-bottom: 5px;
    }

    .a4-subtitle {
        font-size: 11px;
        color: #666;
        margin-bottom: 3px;
    }

    .a4-section {
        margin-bottom: 12px;
    }

    .a4-section-title {
        font-size: 13px;
        font-weight: bold;
        color: #333;
        margin-bottom: 8px;
        padding-bottom: 3px;
        border-bottom: 1px solid #ddd;
    }

    .a4-info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
        margin-bottom: 12px;
    }

    .a4-info-block {
        background: #f8f9fa;
        padding: 10px;
        border-radius: 5px;
        border-left: 4px solid #007bff;
    }

    .a4-info-block h6 {
        font-size: 11px;
        font-weight: bold;
        margin-bottom: 6px;
        color: #333;
    }

    .a4-info-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 3px;
        font-size: 10px;
    }

    .a4-info-label {
        font-weight: 600;
        color: #555;
    }

    .a4-info-value {
        color: #333;
    }

    .a4-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 9px;
        margin-bottom: 10px;
    }

    .a4-table th {
        background: #f8f9fa;
        border: 1px solid #ddd;
        padding: 4px 3px;
        font-weight: bold;
        text-align: center;
        font-size: 9px;
    }

    .a4-table td {
        border: 1px solid #ddd;
        padding: 4px 3px;
        text-align: center;
        font-size: 9px;
    }

    .a4-table .text-start {
        text-align: left;
    }

    .a4-table .text-end {
        text-align: right;
    }

    .a4-table tfoot td {
        background: #f8f9fa;
        font-weight: bold;
        border-top: 2px solid #333;
    }

    .a4-footer {
        margin-top: 10px;
        padding-top: 8px;
        border-top: 1px solid #ddd;
        font-size: 9px;
        color: #666;
        text-align: center;
    }

    .a4-logo {
        max-width: 120px;
        height: auto;
        margin-bottom: 10px;
    }

    /* Print Styles */
    @@media print {
        @@page {
            size: A4;
            margin: 0;
        }
        
        body {
            margin: 0;
            padding: 0;
            background: white;
        }
        
        .a4-container {
            width: 210mm;
            height: 297mm;
            margin: 0;
            padding: 12mm;
            box-shadow: none;
            page-break-after: avoid;
            page-break-inside: avoid;
            overflow: hidden;
        }
        
        .no-print {
            display: none !important;
        }
        
        .a4-table {
            page-break-inside: avoid;
            font-size: 8px;
        }
        
        .a4-table th,
        .a4-table td {
            padding: 3px 2px;
            font-size: 8px;
        }
        
        .a4-section {
            page-break-inside: avoid;
            margin-bottom: 8px;
        }
        
        .a4-header {
            margin-bottom: 8px;
            padding-bottom: 8px;
        }
        
        .a4-footer {
            margin-top: 8px;
            padding-top: 5px;
        }
        
        /* Prevent page breaks */
        .a4-info-grid {
            page-break-inside: avoid;
        }
    }

    /* Screen Styles */
    @@media screen {
        body {
            background: #f5f5f5;
            padding: 20px;
        }
        
        .a4-container {
            margin: 20px auto;
        }
    }
</style>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
