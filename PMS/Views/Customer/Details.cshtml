<style>
    /* Tab Styling */
    .customer-tabs {
        border-bottom: 2px solid #6f42c1;
        background: linear-gradient(135deg, #f8f9fa 0%, #f3f0ff 100%);
        padding: 0.5rem 1rem 0;
    }

    .customer-tabs .nav-link {
        color: #666;
        font-weight: 600;
        border: none;
        border-bottom: 3px solid transparent;
        padding: 0.75rem 1.25rem;
        transition: all 0.3s ease;
        font-size: 14px;
    }

    .customer-tabs .nav-link:hover {
        color: #6f42c1;
        background: rgba(111, 66, 193, 0.05);
        border-bottom-color: #9370db;
    }

    .customer-tabs .nav-link.active {
        color: #6f42c1;
        background: white;
        border-bottom-color: #6f42c1;
        font-weight: 700;
    }

    .customer-tabs .nav-link i {
        font-size: 13px;
    }

    /* Tab Content */
    .tab-content {
        padding-top: 1rem;
    }

    /* Detail Fields */
    .detail-field {
        padding: 8px 10px;
        background: linear-gradient(135deg, #f8f9fa 0%, var(--gold-tint) 100%);
        border-radius: 6px;
        transition: all 0.3s ease;
    }

    .detail-field:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 15px rgba(11, 148, 68, 0.1);
    }

    .detail-field label {
        display: block;
        margin-bottom: 3px;
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #666;
        font-weight: 600;
    }

    .detail-field p {
        font-size: 14px;
        color: var(--text-dark);
        margin-bottom: 0;
        font-weight: 500;
    }

    code {
        background: var(--light-green);
        color: var(--primary-green);
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 13px;
        font-weight: 600;
    }

    /* Section Headers within Tabs */
    .tab-pane h6 {
        color: #6f42c1;
        font-weight: 700;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid #e8dcff;
    }

