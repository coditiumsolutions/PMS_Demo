        cursor: pointer;
    }

    .activity-log-row:hover {
        background-color: rgba(111, 66, 193, 0.08);
    }

    /* Responsive Tabs */
    @@media (max-width: 768px) {
        .customer-tabs .nav-link {
            padding: 0.5rem 0.75rem;
            font-size: 12px;
        }

        .customer-tabs .nav-link i {
            display: none;
        }
