@model PMS.Models.Customer

@{
    ViewData["Title"] = "Customer Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div class="d-flex align-items-center gap-4">
        <!-- <h2 class="mb-0">
            <i class="fas fa-user me-2"></i>Customer Details
        </h2> -->
        <div class="d-flex align-items-center gap-3 ms-4">
            <div class="badge bg-light text-dark px-3 py-2" style="font-size: 14px;">
                <i class="fas fa-calendar-check me-2" style="color: #6f42c1;"></i>
                <strong>Member Since:</strong> @Model.CreatedAt.ToString("MMMM yyyy")
                <span class="text-muted ms-2">(@((DateTime.Now - Model.CreatedAt).Days) days)</span>
            </div>
        </div>
    </div>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.CustomerID" class="btn btn-primary me-2">
            <i class="fas fa-edit me-2"></i>Edit
        </a>
        <a asp-action="AccountStatement" asp-route-id="@Model.CustomerID" target="_blank" class="btn btn-outline-info me-2">
            <i class="fas fa-file-invoice-dollar me-2"></i>Account Statement
        </a>
        @if (Model.Allotments != null && Model.Allotments.Any())
        {
            <a asp-action="AllotmentLetter" asp-route-id="@Model.CustomerID" target="_blank" class="btn btn-outline-info me-2">
                <i class="fas fa-file-signature me-2"></i>Allotment Letter
            </a>
        }
        <a asp-action="Index" class="btn btn-outline-primary">
            <i class="fas fa-arrow-left me-2"></i>Back to List
        </a>
    </div>
</div>

<div class="row">
    <!-- Main Content with Tabs -->
    <div class="col-12">
        <div class="card">
            <div class="card-header p-0">
                <ul class="nav nav-tabs customer-tabs" id="customerTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="personal-tab" data-bs-toggle="tab" data-bs-target="#personal" type="button" role="tab" aria-controls="personal" aria-selected="true">
                            <i class="fas fa-user-circle me-2"></i>Personal Info
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="contact-tab" data-bs-toggle="tab" data-bs-target="#contact" type="button" role="tab" aria-controls="contact" aria-selected="false">
                            <i class="fas fa-address-book me-2"></i>Contact Info
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="nominee-tab" data-bs-toggle="tab" data-bs-target="#nominee" type="button" role="tab" aria-controls="nominee" aria-selected="false">
                            <i class="fas fa-user-shield me-2"></i>Next of Kin
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="registration-tab" data-bs-toggle="tab" data-bs-target="#registration" type="button" role="tab" aria-controls="registration" aria-selected="false">
                            <i class="fas fa-file-contract me-2"></i>Registration & Plan
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="allotments-tab" data-bs-toggle="tab" data-bs-target="#allotments" type="button" role="tab" aria-controls="allotments" aria-selected="false">
                            <i class="fas fa-building me-2"></i>Allotments
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="activity-tab" data-bs-toggle="tab" data-bs-target="#activity" type="button" role="tab" aria-controls="activity" aria-selected="false">
                            <i class="fas fa-history me-2"></i>Activity
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="transfers-tab" data-bs-toggle="tab" data-bs-target="#transfers" type="button" role="tab" aria-controls="transfers" aria-selected="false">
                            <i class="fas fa-exchange-alt me-2"></i>Transfers
                            @if (Model.Transfers != null && Model.Transfers.Any())
                            {
                                <span class="badge bg-warning rounded-pill ms-1">@Model.Transfers.Count</span>
                            }
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="jointowners-tab" data-bs-toggle="tab" data-bs-target="#jointowners" type="button" role="tab" aria-controls="jointowners" aria-selected="false">
                            <i class="fas fa-users me-2"></i>JointOwners
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="attachments-tab" data-bs-toggle="tab" data-bs-target="#attachments" type="button" role="tab" aria-controls="attachments" aria-selected="false">
                            <i class="fas fa-paperclip me-2"></i>Attachments
                        </button>
                    </li>
                </ul>
            </div>
            <div class="card-body">
                <div class="tab-content" id="customerTabContent">
                    <!-- Personal Information Tab -->
                    <div class="tab-pane fade show active" id="personal" role="tabpanel" aria-labelledby="personal-tab">
                <div class="row">
                    <div class="col-md-6 mb-2">
                        <div class="detail-field">
                            <label><i class="fas fa-id-badge me-2"></i>Customer ID</label>
                            <p><code>@Model.CustomerID</code></p>
                        </div>
                    </div>
                    <div class="col-md-6 mb-2">
                        <div class="detail-field">
                            <label><i class="fas fa-toggle-on me-2"></i>Status</label>
                            <p>
                                <span class="badge @(Model.Status == "Active" ? "bg-success" : "bg-warning")">
                                    @Model.Status
                                </span>
                            </p>
                        </div>
                    </div>
                    <div class="col-md-6 mb-2">
                        <div class="detail-field">
                            <label><i class="fas fa-user me-2"></i>Full Name</label>
                            <p>@Model.FullName</p>
                        </div>
                    </div>
                    <div class="col-md-6 mb-2">
                        <div class="detail-field">
                            <label><i class="fas fa-user-friends me-2"></i>Father Name</label>
                            <p>@Model.FatherName</p>
                        </div>
                    </div>
                    <div class="col-md-6 mb-2">
                        <div class="detail-field">
                            <label><i class="fas fa-id-card me-2"></i>National ID</label>
                            <p>@Model.CNIC</p>
                        </div>
                    </div>
                    <div class="col-md-6 mb-2">
                        <div class="detail-field">
                            <label><i class="fas fa-passport me-2"></i>Passport No</label>
                            <p>@(Model.PassportNo ?? "N/A")</p>
                        </div>
                    </div>
                    <div class="col-md-6 mb-2">
                        <div class="detail-field">
                            <label><i class="fas fa-birthday-cake me-2"></i>Date of Birth</label>
                            <p>@(Model.DOB?.ToString("dd-MM-yyyy") ?? "N/A")</p>
                        </div>
                    </div>
                    <div class="col-md-6 mb-2">
                        <div class="detail-field">
                            <label><i class="fas fa-venus-mars me-2"></i>Gender</label>
                            <p>@Model.Gender</p>
                        </div>
                    </div>
                </div>
                    </div>

                    <!-- Contact Information Tab -->
                    <div class="tab-pane fade" id="contact" role="tabpanel" aria-labelledby="contact-tab">
                <div class="row">
                    <div class="col-md-6 mb-2">
                        <div class="detail-field">
                            <label><i class="fas fa-phone me-2"></i>Phone</label>
                            <p>@Model.Phone</p>
                        </div>
                    </div>
                    <div class="col-md-6 mb-2">
                        <div class="detail-field">
                            <label><i class="fas fa-mobile-alt me-2"></i>Mobile</label>
                            <p>@Model.MobileNo</p>
                        </div>
                    </div>
                    <div class="col-md-6 mb-2">
                        <div class="detail-field">
                            <label><i class="fas fa-mobile-alt me-2"></i>Mobile 2</label>
                            <p>@(string.IsNullOrWhiteSpace(Model.MobileNo2) ? "—" : Model.MobileNo2)</p>
                        </div>
                    </div>
                    <div class="col-md-6 mb-2">
                        <div class="detail-field">
                            <label><i class="fas fa-envelope me-2"></i>Email</label>
                            <p>@Model.Email</p>
                        </div>
                    </div>
                    <div class="col-md-6 mb-2">
                        <div class="detail-field">
                            <label><i class="fas fa-city me-2"></i>City</label>
                            <p>@Model.City</p>
                        </div>
                    </div>
                    <div class="col-md-6 mb-2">
                        <div class="detail-field">
                            <label><i class="fas fa-globe me-2"></i>Country</label>
                            <p>@Model.Country</p>
                        </div>
                    </div>
                    <div class="col-md-12 mb-2">
                        <div class="detail-field">
                            <label><i class="fas fa-map-marker-alt me-2"></i>Mailing Address</label>
                            <p>@Model.MailingAddress</p>
                        </div>
                    </div>
                    <div class="col-md-12 mb-2">
                        <div class="detail-field">
                            <label><i class="fas fa-home me-2"></i>Permanent Address</label>
                            <p>@Model.PermanentAddress</p>
                        </div>
                    </div>
                </div>
                    </div>

                    <!-- Next of Kin Information Tab -->
                    <div class="tab-pane fade" id="nominee" role="tabpanel" aria-labelledby="nominee-tab">
                <div class="row">
                    <div class="col-md-4 mb-2">
                        <div class="detail-field">
                            <label><i class="fas fa-user me-2"></i>Next of Kin Name</label>
                            <p>@(Model.NomineeName ?? "N/A")</p>
                        </div>
                    </div>
                    <div class="col-md-4 mb-2">
                        <div class="detail-field">
                            <label><i class="fas fa-id-card me-2"></i>Next of Kin ID</label>
                            <p>@(Model.NomineeID ?? "N/A")</p>
                        </div>
                    </div>
                    <div class="col-md-4 mb-2">
                        <div class="detail-field">
                            <label><i class="fas fa-heart me-2"></i>Relation</label>
                            <p>@(Model.NomineeRelation ?? "N/A")</p>
                        </div>
                    </div>
                </div>
                    </div>

                    <!-- Registration & Plan Tab -->
                    <div class="tab-pane fade" id="registration" role="tabpanel" aria-labelledby="registration-tab">
                        <div class="row">
                            <!-- Registration Information -->
                            @if (Model.Registration != null)
                            {
                                <div class="col-md-12 mb-3">
                                    <h6 class="mb-3"><i class="fas fa-file-alt me-2"></i>Registration Information</h6>
                                    <div class="row">
                                        <div class="col-md-4 mb-2">
                                            <div class="detail-field">
                                                <label><i class="fas fa-tag me-2"></i>Registration ID</label>
                                                <p><code>@Model.Registration.RegID</code></p>
                                            </div>
                                        </div>
                                        <div class="col-md-4 mb-2">
                                            <div class="detail-field">
                                                <label><i class="fas fa-calendar me-2"></i>Registered On</label>
                                                <p>@Model.Registration.CreatedAt.ToString("MMM dd, yyyy")</p>
                                            </div>
                                        </div>
                                        <div class="col-md-4 mb-2">
                                            <div class="detail-field">
                                                <label><i class="fas fa-info-circle me-2"></i>Status</label>
                                                <p>
                                                    <span class="badge bg-success">@Model.Registration.Status</span>
                                                </p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }

                            <!-- Payment Plan Information -->
                            @if (Model.PaymentPlan != null)
                            {
                                <div class="col-md-12 mb-3">
                                    <h6 class="mb-3"><i class="fas fa-credit-card me-2"></i>Payment Plan</h6>
                                    <div class="row">
                                        <div class="col-md-6 mb-2">
                                            <div class="detail-field">
                                                <label><i class="fas fa-tag me-2"></i>Plan Name</label>
                                                <p>@Model.PaymentPlan.PlanName</p>
                                            </div>
                                        </div>
                                        <div class="col-md-6 mb-2">
                                            <div class="detail-field">
                                                <label><i class="fas fa-money-bill-wave me-2"></i>Total Amount</label>
                                                <p><strong style="color: var(--primary-green); font-size: 1.3rem;">@Model.PaymentPlan.TotalAmount.ToString("N2") PKR</strong></p>
                                            </div>
                                        </div>
                                        <div class="col-md-4 mb-2">
                                            <div class="detail-field">
                                                <label><i class="fas fa-clock me-2"></i>Duration</label>
                                                <p>@(Model.PaymentPlan.DurationMonths?.ToString() ?? "N/A") Months</p>
                                            </div>
                                        </div>
                                        <div class="col-md-4 mb-2">
                                            <div class="detail-field">
                                                <label><i class="fas fa-calendar-alt me-2"></i>Frequency</label>
                                                <p>@Model.PaymentPlan.Frequency</p>
                                            </div>
                                        </div>
                                        @if (Model.PaymentPlan.PaymentSchedules != null && Model.PaymentPlan.PaymentSchedules.Any())
                                        {
                                            var totalPaid = Model.PaymentPlan.PaymentSchedules
                                                .SelectMany(ps => ps.Payments ?? new List<PMS.Models.Payment>())
                                                .Where(p => p.Status == "Completed")
                                                .Sum(p => p.Amount);
                                            var totalDue = Model.PaymentPlan.TotalAmount;
                                            var percentage = totalDue > 0 ? (totalPaid / totalDue) * 100 : 0;

                                            <div class="col-md-4 mb-2">
                                                <div class="detail-field">
                                                    <label><i class="fas fa-chart-line me-2"></i>Payment Progress</label>
                                                    <div class="progress" style="height: 20px;">
                                                        <div class="progress-bar" role="progressbar" 
                                                             style="width: @percentage%; background: linear-gradient(135deg, var(--primary-green) 0%, var(--accent-gold) 100%);"
                                                             aria-valuenow="@percentage" aria-valuemin="0" aria-valuemax="100">
                                                            @percentage.ToString("N1")%
                                                        </div>
                                                    </div>
                                                    <small class="text-muted mt-1 d-block">
                                                        @totalPaid.ToString("N2") / @totalDue.ToString("N2") PKR
                                                    </small>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }

                            <!-- Project Information -->
                            <div class="col-md-12 @(!string.IsNullOrEmpty(Model.AdditionalInfo) ? "mb-3" : "")">
                                <h6 class="mb-3"><i class="fas fa-project-diagram me-2"></i>Project Details</h6>
                                <div class="row">
                                    <div class="col-md-6 mb-2">
                                        <div class="detail-field">
                                            <label><i class="fas fa-building me-2"></i>Sub Project</label>
                                            <p>@(Model.SubProject ?? "N/A")</p>
                                        </div>
                                    </div>
                                    <div class="col-md-6 mb-2">
                                        <div class="detail-field">
                                            <label><i class="fas fa-ruler-combined me-2"></i>Registered Size</label>
                                            <p>@(Model.RegisteredSize ?? "N/A")</p>
                                        </div>
                                    </div>
                                    <div class="col-md-6 mb-2">
                                        <div class="detail-field">
                                            <label><i class="fas fa-store me-2"></i>Dealer</label>
                                            <p>
                                                @if (Model.IsDealerRegistered == 0 && !string.IsNullOrWhiteSpace(Model.DealerName))
                                                {
                                                    @Model.DealerName <span class="badge bg-secondary ms-1">Not Registered</span>
                                                }
                                                else if (Model.Dealer != null)
                                                {
                                                    @Model.Dealer.DealershipName <span class="badge bg-success ms-1">Registered</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">N/A</span>
                                                }
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Additional Information -->
                            @if (!string.IsNullOrEmpty(Model.AdditionalInfo))
                            {
                                <div class="col-md-12">
                                    <h6 class="mb-3"><i class="fas fa-sticky-note me-2"></i>Additional Notes</h6>
                                    <div class="alert alert-info mb-0">
                                        <p class="mb-0">@Model.AdditionalInfo</p>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Property Allotments Tab -->
                    <div class="tab-pane fade" id="allotments" role="tabpanel" aria-labelledby="allotments-tab">
                @if (Model.Allotments != null && Model.Allotments.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Allotment ID</th>
                                    <th>Plot No</th>
                                    <th>Block</th>
                                    <th>Size</th>
                                    <th>Type</th>
                                    <th>Date</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var allotment in Model.Allotments)
                                {
                                    <tr>
                                        <td><code>@allotment.AllotmentID</code></td>
                                        <td>@allotment.Property?.PlotNo</td>
                                        <td>@allotment.Property?.Block</td>
                                        <td>@allotment.Property?.Size</td>
                                        <td>@allotment.AllottmentType</td>
                                        <td>@allotment.AllotmentDate.ToString("MMM dd, yyyy")</td>
                                        <td>
                                            @if (allotment.WorkFlowStatus == "Approved")
                                            {
                                                <span class="badge bg-success">@allotment.WorkFlowStatus</span>
                                            }
                                            else if (allotment.WorkFlowStatus == "Pending" || allotment.WorkFlowStatus == "Pending Approval")
                                            {
                                                <span class="badge bg-warning">@allotment.WorkFlowStatus</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-primary">@allotment.WorkFlowStatus</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="btn-group" role="group">
                                                <a asp-controller="Allotment" asp-action="Details" asp-route-id="@allotment.AllotmentID" 
                                                   class="btn btn-sm btn-outline-info" title="View Allotment" onclick="event.stopPropagation();">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                                @if (allotment.WorkFlowStatus == "Pending" || allotment.WorkFlowStatus == "Pending Approval")
                                                {
                                                    <a asp-controller="Allotment" asp-action="Details" asp-route-id="@allotment.AllotmentID" 
                                                       class="btn btn-sm btn-outline-primary" title="Edit Allotment" onclick="event.stopPropagation();">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                }
                                                else
                                                {
                                                    <a href="@Url.Action("UnAllot", "Allotment")" 
                                                       class="btn btn-sm btn-outline-danger" title="Un-Allot Property" onclick="event.stopPropagation();">
                                                        <i class="fas fa-undo"></i>
                                                    </a>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div id="noAllotmentSection">
                        <div class="alert alert-info mb-4">
                            <i class="fas fa-info-circle me-2"></i>
                            <strong>No Allotment Found</strong><br>
                            This customer does not have a property allotted yet. You can start the allotment process below.
                        </div>

                        @if (Model.PaymentPlan == null || string.IsNullOrEmpty(Model.PaymentPlan.ProjectID) || string.IsNullOrEmpty(Model.RegisteredSize))
                        {
                            <div class="alert alert-warning">
                                <i class="fas fa-exclamation-triangle me-2"></i>
                                <strong>Cannot Create Allotment:</strong>
                                @if (Model.PaymentPlan == null || string.IsNullOrEmpty(Model.PaymentPlan.ProjectID))
                                {
                                    <p>Customer must have a Payment Plan with an assigned Project.</p>
                                }
                                @if (string.IsNullOrEmpty(Model.RegisteredSize))
                                {
                                    <p>Customer must have a Registered Size set.</p>
                                }
                                <a asp-action="Edit" asp-route-id="@Model.CustomerID" class="btn btn-sm btn-primary mt-2">
                                    <i class="fas fa-edit me-2"></i>Edit Customer to Set Required Information
                                </a>
                            </div>
                        }
                        else
                        {
                            <div class="card border-primary">
                                <div class="card-header bg-primary text-white">
                                    <h5 class="mb-0">
                                        <i class="fas fa-plus-circle me-2"></i>Start Allotment Process
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <form id="createAllotmentForm">
                                        <input type="hidden" id="customerID" value="@Model.CustomerID" />
                                        <input type="hidden" id="projectID" value="@Model.PaymentPlan.ProjectID" />
                                        <input type="hidden" id="registeredSize" value="@Model.RegisteredSize" />

                                        <div class="row">
                                            <div class="col-md-6 mb-3">
                                                <label class="form-label">
                                                    <i class="fas fa-building me-2"></i>Customer Project
                                                </label>
                                                <input type="text" class="form-control" value="@(Model.PaymentPlan.Project?.ProjectName ?? "N/A")" readonly />
                                                <small class="text-muted">Properties will be filtered by this project</small>
                                            </div>
                                            <div class="col-md-6 mb-3">
                                                <label class="form-label">
                                                    <i class="fas fa-ruler-combined me-2"></i>Registered Size
                                                </label>
                                                <input type="text" class="form-control" value="@Model.RegisteredSize" readonly />
                                                <small class="text-muted">Properties will be filtered by this size</small>
                                            </div>
                                            <div class="col-md-6 mb-3">
                                                <label class="form-label">
                                                    <i class="fas fa-tag me-2"></i>Allotment Type <span class="text-danger">*</span>
                                                </label>
                                                <select id="allotmentType" class="form-select" required>
                                                    <option value="">Select Type</option>
                                                    <option value="Regular">Regular</option>
                                                    <option value="Transfer">Transfer</option>
                                                    <option value="Balloting">Balloting</option>
                                                    <option value="Special">Special</option>
                                                </select>
                                            </div>
                                            <div class="col-md-6 mb-3">
                                                <label class="form-label">
                                                    <i class="fas fa-home me-2"></i>Select Property <span class="text-danger">*</span>
                                                </label>
                                                <select id="propertyID" class="form-select" required>
                                                    <option value="">Loading properties...</option>
                                                </select>
                                                <small class="text-muted">Only available properties matching project and size are shown</small>
                                            </div>
                                            <div class="col-md-12 mb-3">
                                                <label class="form-label">
                                                    <i class="fas fa-comment me-2"></i>Comments
                                                </label>
                                                <textarea id="comments" class="form-control" rows="3" placeholder="Enter any comments or notes..."></textarea>
                                            </div>
                                            <div class="col-md-12">
                                                <button type="submit" class="btn btn-success">
                                                    <i class="fas fa-check me-2"></i>Create Allotment
                                                </button>
                                                <button type="button" class="btn btn-secondary" onclick="loadProperties()">
                                                    <i class="fas fa-redo me-2"></i>Refresh Properties List
                                                </button>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>
                }
                    </div>

                    <!-- Activity History Tab (ActivityLog where RefID = CustomerID) -->
                    <div class="tab-pane fade" id="activity" role="tabpanel" aria-labelledby="activity-tab">
                @{
                    var activityLogs = ViewBag.ActivityLogs as IEnumerable<PMS.Models.ActivityLog>;
                }
                @if (activityLogs != null && activityLogs.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>User</th>
                                    <th>Action</th>
                                    <th>Ref Type</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var log in activityLogs)
                                {
                                    <tr class="activity-log-row js-activity-log-row"
                                        data-created-at="@log.CreatedAt.ToString("MMM dd, yyyy HH:mm")"
                                        data-user="@(log.User?.FullName ?? log.UserID ?? "—")"
                                        data-action="@(log.Action ?? "—")"
                                        data-ref-type="@(log.RefType ?? "—")"
                                        data-ref-id="@(log.RefID ?? "—")"
                                        data-details="@(log.Details ?? "")">
                                        <td class="text-muted small">@log.CreatedAt.ToString("MMM dd, yyyy HH:mm")</td>
                                        <td>@(log.User?.FullName ?? log.UserID ?? "—")</td>
                                        <td>
                                            <i class="fas fa-circle-notch me-2" style="font-size: 8px;"></i>
                                            @(log.Action ?? "—")
                                        </td>
                                        <td><span class="badge bg-secondary">@(log.RefType ?? "—")</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center text-muted py-3">
                        <i class="fas fa-inbox fa-2x mb-2 d-block"></i>
                        <p class="mb-0">No activity logs found for this customer.</p>
                    </div>
                }
                    </div>

                    <!-- Transfers Tab -->
                    <div class="tab-pane fade" id="transfers" role="tabpanel" aria-labelledby="transfers-tab">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="mb-0"><i class="fas fa-exchange-alt me-2"></i>Ownership Transfers</h6>
                            <a asp-controller="Transfer" asp-action="Create" asp-route-customerId="@Model.CustomerID" class="btn btn-sm btn-primary">
                                <i class="fas fa-plus me-1"></i>New Transfer
                            </a>
                        </div>
                        @if (Model.Transfers != null && Model.Transfers.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead>
                                        <tr>
                                            <th>Transfer ID</th>
                                            <th>Seller</th>
                                            <th>Buyer</th>
                                            <th>Workflow</th>
                                            <th>Created</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var t in Model.Transfers.OrderByDescending(t => t.CreatedAt))
                                        {
                                            <tr>
                                                <td><code>@t.TransferID</code></td>
                                                <td>@(t.SellerName ?? "—")</td>
                                                <td>@(t.BuyerName ?? "—")</td>
                                                <td>
                                                    @if (t.WorkFlowStatus == "Approved")
                                                    { <span class="badge bg-success">@t.WorkFlowStatus</span> }
                                                    else
                                                    { <span class="badge bg-warning">@(t.WorkFlowStatus ?? "—")</span> }
                                                </td>
                                                <td>@t.CreatedAt.ToString("MMM dd, yyyy")</td>
                                                <td>
                                                    <a asp-controller="Transfer" asp-action="Details" asp-route-id="@t.TransferID" class="btn btn-sm btn-outline-info">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                    @if (t.WorkFlowStatus != "Approved")
                                                    {
                                                        <a asp-controller="Transfer" asp-action="Edit" asp-route-id="@t.TransferID" class="btn btn-sm btn-outline-primary">
                                                            <i class="fas fa-edit"></i>
                                                        </a>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info mb-0">
                                <i class="fas fa-info-circle me-2"></i>No transfers for this customer file. <a asp-controller="Transfer" asp-action="Create" asp-route-customerId="@Model.CustomerID">Start a transfer</a>.
                            </div>
                        }
                    </div>

                    <!-- Joint Owners Tab -->
                    <div class="tab-pane fade" id="jointowners" role="tabpanel" aria-labelledby="jointowners-tab">
                        @Html.AntiForgeryToken()
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Joint Owner Name *</label>
                                <input type="text" id="jointOwnerName" class="form-control" placeholder="Enter joint owner name" />
                                <small class="text-muted">Letters, spaces, dots and hyphens only.</small>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Son /D/W/o</label>
                                <input type="text" id="jointOwnerFatherName" class="form-control" placeholder="Enter father name" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">CNIC *</label>
                                <input type="text" id="jointOwnerCNIC" class="form-control" placeholder="XXXXX-XXXXXXX-X" maxlength="15" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Contact *</label>
                                <input type="text" id="jointOwnerContact" class="form-control" placeholder="03XXXXXXXXX" />
                                <small class="text-muted">Must be 11 to 13 digits.</small>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Address</label>
                                <input type="text" id="jointOwnerAddress" class="form-control" placeholder="Address" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Percentage</label>
                                <input type="number" id="jointOwnerPercentage" class="form-control" min="0" max="100" step="0.01" placeholder="e.g. 50" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Details</label>
                                <textarea id="jointOwnerDetails" class="form-control" rows="2" placeholder="Any additional details"></textarea>
                            </div>
                            <div class="col-md-12">
                                <button type="button" class="btn btn-primary" onclick="addJointOwnerFromDetails()">
                                    <i class="fas fa-plus me-2"></i>Add Joint Owner
                                </button>
                            </div>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-sm table-hover" id="jointOwnersTable">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th>Son /D/W/o</th>
                                        <th>CNIC</th>
                                        <th>Contact</th>
                                        <th>Percentage</th>
                                        <th>Address</th>
                                        <th>Created</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td colspan="7" class="text-muted text-center">Loading joint owners...</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Attachments Tab -->
                    <div class="tab-pane fade" id="attachments" role="tabpanel" aria-labelledby="attachments-tab">
                        <div class="row">
                            <div class="col-12">
                                <h6 class="mb-3"><i class="fas fa-paperclip me-2"></i>Customer Attachments</h6>
                                
                                <!-- Customer Picture Section -->
                                <div class="card mb-4" style="border-color: rgb(104, 167, 226);">
                                    <div class="card-header text-white" style="background: linear-gradient(135deg, rgb(104, 167, 226) 0%, rgb(72, 123, 165) 100%);">
                                        <h6 class="mb-0"><i class="fas fa-user-circle me-2"></i>Customer Picture</h6>
                                    </div>
                                    <div class="card-body">
                                        <div class="text-center" id="customerPicturePreview">
                                            <img id="customerPictureImg" src="" alt="Customer Picture" class="img-thumbnail" style="max-width: 300px; max-height: 300px; display: none;" />
                                            <div id="customerPicturePlaceholder" class="text-muted">
                                                <i class="fas fa-user-circle fa-5x"></i>
                                                <p class="mt-2">No picture uploaded</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- ID Card Section -->
                                <div class="card mb-4" style="border-color: rgb(104, 167, 226);">
                                    <div class="card-header text-white" style="background: linear-gradient(135deg, rgb(104, 167, 226) 0%, rgb(72, 123, 165) 100%);">
                                        <h6 class="mb-0"><i class="fas fa-id-card me-2"></i>Customer ID Card</h6>
                                    </div>
                                    <div class="card-body">
                                        <div class="text-center" id="idCardPreview">
                                            <img id="idCardImg" src="" alt="ID Card" class="img-thumbnail" style="max-width: 300px; max-height: 300px; display: none;" />
                                            <div id="idCardPlaceholder" class="text-muted">
                                                <i class="fas fa-id-card fa-5x"></i>
                                                <p class="mt-2">No ID card uploaded</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Other Attachments Section -->
                                <div class="card mb-4" style="border-color: rgb(104, 167, 226);">
                                    <div class="card-header text-white" style="background: linear-gradient(135deg, rgb(104, 167, 226) 0%, rgb(72, 123, 165) 100%);">
                                        <h6 class="mb-0"><i class="fas fa-folder-open me-2"></i>Other Attachments</h6>
                                    </div>
                                    <div class="card-body">
                                        <div id="attachmentsList">
                                            <h6 class="mb-3">Uploaded Attachments</h6>
                                            <div id="attachmentsContainer" class="row">
                                                <div class="col-12 text-center text-muted py-3">
                                                    <i class="fas fa-spinner fa-spin fa-2x mb-2"></i>
                                                    <p>Loading attachments...</p>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="activityLogDetailsModal" tabindex="-1" aria-labelledby="activityLogDetailsModalLabel" aria-hidden="true" data-bs-backdrop="false">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="activityLogDetailsModalLabel">
                    <i class="fas fa-file-alt me-2"></i>Log Details
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label text-muted small mb-1">Date</label>
                        <div class="form-control bg-light" id="logModalDate">—</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-muted small mb-1">User</label>
                        <div class="form-control bg-light" id="logModalUser">—</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-muted small mb-1">Action</label>
                        <div class="form-control bg-light" id="logModalAction">—</div>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label text-muted small mb-1">Ref Type</label>
                        <div class="form-control bg-light" id="logModalRefType">—</div>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label text-muted small mb-1">Ref ID</label>
                        <div class="form-control bg-light" id="logModalRefId">—</div>
