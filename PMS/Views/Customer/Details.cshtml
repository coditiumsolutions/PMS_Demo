@model PMS.Models.Customer

@{
    ViewData["Title"] = "Customer Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div class="d-flex align-items-center gap-4">
        <!-- <h2 class="mb-0">
            <i class="fas fa-user me-2"></i>Customer Details
        </h2> -->
        <div class="d-flex align-items-center gap-3 ms-4">
            <div class="badge bg-light text-dark px-3 py-2" style="font-size: 14px;">
                <i class="fas fa-calendar-check me-2" style="color: #6f42c1;"></i>
                <strong>Member Since:</strong> @Model.CreatedAt.ToString("MMMM yyyy")
                <span class="text-muted ms-2">(@((DateTime.Now - Model.CreatedAt).Days) days)</span>
            </div>
        </div>
    </div>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.CustomerID" class="btn btn-primary me-2">
            <i class="fas fa-edit me-2"></i>Edit
        </a>
        <a asp-action="Index" class="btn btn-outline-primary">
            <i class="fas fa-arrow-left me-2"></i>Back to List
        </a>
    </div>
</div>

<div class="row">
    <!-- Main Content with Tabs -->
    <div class="col-12">
        <div class="card">
            <div class="card-header p-0">
                <ul class="nav nav-tabs customer-tabs" id="customerTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="personal-tab" data-bs-toggle="tab" data-bs-target="#personal" type="button" role="tab" aria-controls="personal" aria-selected="true">
                            <i class="fas fa-user-circle me-2"></i>Personal Info
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="contact-tab" data-bs-toggle="tab" data-bs-target="#contact" type="button" role="tab" aria-controls="contact" aria-selected="false">
                            <i class="fas fa-address-book me-2"></i>Contact Info
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="nominee-tab" data-bs-toggle="tab" data-bs-target="#nominee" type="button" role="tab" aria-controls="nominee" aria-selected="false">
                            <i class="fas fa-user-shield me-2"></i>Nominee
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="registration-tab" data-bs-toggle="tab" data-bs-target="#registration" type="button" role="tab" aria-controls="registration" aria-selected="false">
                            <i class="fas fa-file-contract me-2"></i>Registration & Plan
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="allotments-tab" data-bs-toggle="tab" data-bs-target="#allotments" type="button" role="tab" aria-controls="allotments" aria-selected="false">
                            <i class="fas fa-building me-2"></i>Allotments
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="activity-tab" data-bs-toggle="tab" data-bs-target="#activity" type="button" role="tab" aria-controls="activity" aria-selected="false">
                            <i class="fas fa-history me-2"></i>Activity
                        </button>
                    </li>
                </ul>
            </div>
            <div class="card-body">
                <div class="tab-content" id="customerTabContent">
                    <!-- Personal Information Tab -->
                    <div class="tab-pane fade show active" id="personal" role="tabpanel" aria-labelledby="personal-tab">
                <div class="row">
                    <div class="col-md-6 mb-2">
                        <div class="detail-field">
                            <label><i class="fas fa-id-badge me-2"></i>Customer ID</label>
                            <p><code>@Model.CustomerID</code></p>
                        </div>
                    </div>
                    <div class="col-md-6 mb-2">
                        <div class="detail-field">
                            <label><i class="fas fa-toggle-on me-2"></i>Status</label>
                            <p>
                                <span class="badge @(Model.Status == "Active" ? "bg-success" : "bg-warning")">
                                    @Model.Status
                                </span>
                            </p>
                        </div>
                    </div>
                    <div class="col-md-6 mb-2">
                        <div class="detail-field">
                            <label><i class="fas fa-user me-2"></i>Full Name</label>
                            <p>@Model.FullName</p>
                        </div>
                    </div>
                    <div class="col-md-6 mb-2">
                        <div class="detail-field">
                            <label><i class="fas fa-user-friends me-2"></i>Father Name</label>
                            <p>@Model.FatherName</p>
                        </div>
                    </div>
                    <div class="col-md-6 mb-2">
                        <div class="detail-field">
                            <label><i class="fas fa-id-card me-2"></i>CNIC</label>
                            <p>@Model.CNIC</p>
                        </div>
                    </div>
                    <div class="col-md-6 mb-2">
                        <div class="detail-field">
                            <label><i class="fas fa-passport me-2"></i>Passport No</label>
                            <p>@(Model.PassportNo ?? "N/A")</p>
                        </div>
                    </div>
                    <div class="col-md-6 mb-2">
                        <div class="detail-field">
                            <label><i class="fas fa-birthday-cake me-2"></i>Date of Birth</label>
                            <p>@(Model.DOB?.ToString("MMMM dd, yyyy") ?? "N/A")</p>
                        </div>
                    </div>
                    <div class="col-md-6 mb-2">
                        <div class="detail-field">
                            <label><i class="fas fa-venus-mars me-2"></i>Gender</label>
                            <p>@Model.Gender</p>
                        </div>
                    </div>
                </div>
                    </div>

                    <!-- Contact Information Tab -->
                    <div class="tab-pane fade" id="contact" role="tabpanel" aria-labelledby="contact-tab">
                <div class="row">
                    <div class="col-md-6 mb-2">
                        <div class="detail-field">
                            <label><i class="fas fa-phone me-2"></i>Phone</label>
                            <p>@Model.Phone</p>
                        </div>
                    </div>
                    <div class="col-md-6 mb-2">
                        <div class="detail-field">
                            <label><i class="fas fa-envelope me-2"></i>Email</label>
                            <p>@Model.Email</p>
                        </div>
                    </div>
                    <div class="col-md-6 mb-2">
                        <div class="detail-field">
                            <label><i class="fas fa-city me-2"></i>City</label>
                            <p>@Model.City</p>
                        </div>
                    </div>
                    <div class="col-md-6 mb-2">
                        <div class="detail-field">
                            <label><i class="fas fa-globe me-2"></i>Country</label>
                            <p>@Model.Country</p>
                        </div>
                    </div>
                    <div class="col-md-12 mb-2">
                        <div class="detail-field">
                            <label><i class="fas fa-map-marker-alt me-2"></i>Mailing Address</label>
                            <p>@Model.MailingAddress</p>
                        </div>
                    </div>
                    <div class="col-md-12 mb-2">
                        <div class="detail-field">
                            <label><i class="fas fa-home me-2"></i>Permanent Address</label>
                            <p>@Model.PermanentAddress</p>
                        </div>
                    </div>
                </div>
                    </div>

                    <!-- Nominee Information Tab -->
                    <div class="tab-pane fade" id="nominee" role="tabpanel" aria-labelledby="nominee-tab">
                <div class="row">
                    <div class="col-md-4 mb-2">
                        <div class="detail-field">
                            <label><i class="fas fa-user me-2"></i>Nominee Name</label>
                            <p>@(Model.NomineeName ?? "N/A")</p>
                        </div>
                    </div>
                    <div class="col-md-4 mb-2">
                        <div class="detail-field">
                            <label><i class="fas fa-id-card me-2"></i>Nominee ID</label>
                            <p>@(Model.NomineeID ?? "N/A")</p>
                        </div>
                    </div>
                    <div class="col-md-4 mb-2">
                        <div class="detail-field">
                            <label><i class="fas fa-heart me-2"></i>Relation</label>
                            <p>@(Model.NomineeRelation ?? "N/A")</p>
                        </div>
                    </div>
                </div>
                    </div>

                    <!-- Registration & Plan Tab -->
                    <div class="tab-pane fade" id="registration" role="tabpanel" aria-labelledby="registration-tab">
                        <div class="row">
                            <!-- Registration Information -->
                            @if (Model.Registration != null)
                            {
                                <div class="col-md-12 mb-3">
                                    <h6 class="mb-3"><i class="fas fa-file-alt me-2"></i>Registration Information</h6>
                                    <div class="row">
                                        <div class="col-md-4 mb-2">
                                            <div class="detail-field">
                                                <label><i class="fas fa-tag me-2"></i>Registration ID</label>
                                                <p><code>@Model.Registration.RegID</code></p>
                                            </div>
                                        </div>
                                        <div class="col-md-4 mb-2">
                                            <div class="detail-field">
                                                <label><i class="fas fa-calendar me-2"></i>Registered On</label>
                                                <p>@Model.Registration.CreatedAt.ToString("MMM dd, yyyy")</p>
                                            </div>
                                        </div>
                                        <div class="col-md-4 mb-2">
                                            <div class="detail-field">
                                                <label><i class="fas fa-info-circle me-2"></i>Status</label>
                                                <p>
                                                    <span class="badge bg-success">@Model.Registration.Status</span>
                                                </p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }

                            <!-- Payment Plan Information -->
                            @if (Model.PaymentPlan != null)
                            {
                                <div class="col-md-12 mb-3">
                                    <h6 class="mb-3"><i class="fas fa-credit-card me-2"></i>Payment Plan</h6>
                                    <div class="row">
                                        <div class="col-md-6 mb-2">
                                            <div class="detail-field">
                                                <label><i class="fas fa-tag me-2"></i>Plan Name</label>
                                                <p>@Model.PaymentPlan.PlanName</p>
                                            </div>
                                        </div>
                                        <div class="col-md-6 mb-2">
                                            <div class="detail-field">
                                                <label><i class="fas fa-money-bill-wave me-2"></i>Total Amount</label>
                                                <p><strong style="color: var(--primary-green); font-size: 1.3rem;">@Model.PaymentPlan.TotalAmount.ToString("N2") SSP</strong></p>
                                            </div>
                                        </div>
                                        <div class="col-md-4 mb-2">
                                            <div class="detail-field">
                                                <label><i class="fas fa-clock me-2"></i>Duration</label>
                                                <p>@Model.PaymentPlan.DurationMonths Months</p>
                                            </div>
                                        </div>
                                        <div class="col-md-4 mb-2">
                                            <div class="detail-field">
                                                <label><i class="fas fa-calendar-alt me-2"></i>Frequency</label>
                                                <p>@Model.PaymentPlan.Frequency</p>
                                            </div>
                                        </div>
                                        @if (Model.PaymentPlan.PaymentSchedules != null && Model.PaymentPlan.PaymentSchedules.Any())
                                        {
                                            var totalPaid = Model.PaymentPlan.PaymentSchedules
                                                .SelectMany(ps => ps.Payments ?? new List<PMS.Models.Payment>())
                                                .Where(p => p.Status == "Completed")
                                                .Sum(p => p.Amount);
                                            var totalDue = Model.PaymentPlan.TotalAmount;
                                            var percentage = totalDue > 0 ? (totalPaid / totalDue) * 100 : 0;

                                            <div class="col-md-4 mb-2">
                                                <div class="detail-field">
                                                    <label><i class="fas fa-chart-line me-2"></i>Payment Progress</label>
                                                    <div class="progress" style="height: 20px;">
                                                        <div class="progress-bar" role="progressbar" 
                                                             style="width: @percentage%; background: linear-gradient(135deg, var(--primary-green) 0%, var(--accent-gold) 100%);"
                                                             aria-valuenow="@percentage" aria-valuemin="0" aria-valuemax="100">
                                                            @percentage.ToString("N1")%
                                                        </div>
                                                    </div>
                                                    <small class="text-muted mt-1 d-block">
                                                        @totalPaid.ToString("N2") / @totalDue.ToString("N2") SSP
                                                    </small>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }

                            <!-- Project Information -->
                            <div class="col-md-12 @(!string.IsNullOrEmpty(Model.AdditionalInfo) ? "mb-3" : "")">
                                <h6 class="mb-3"><i class="fas fa-project-diagram me-2"></i>Project Details</h6>
                                <div class="row">
                                    <div class="col-md-6 mb-2">
                                        <div class="detail-field">
                                            <label><i class="fas fa-building me-2"></i>Sub Project</label>
                                            <p>@(Model.SubProject ?? "N/A")</p>
                                        </div>
                                    </div>
                                    <div class="col-md-6 mb-2">
                                        <div class="detail-field">
                                            <label><i class="fas fa-ruler-combined me-2"></i>Registered Size</label>
                                            <p>@(Model.RegisteredSize ?? "N/A")</p>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Additional Information -->
                            @if (!string.IsNullOrEmpty(Model.AdditionalInfo))
                            {
                                <div class="col-md-12">
                                    <h6 class="mb-3"><i class="fas fa-sticky-note me-2"></i>Additional Notes</h6>
                                    <div class="alert alert-info mb-0">
                                        <p class="mb-0">@Model.AdditionalInfo</p>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Property Allotments Tab -->
                    <div class="tab-pane fade" id="allotments" role="tabpanel" aria-labelledby="allotments-tab">
                @if (Model.Allotments != null && Model.Allotments.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Allotment ID</th>
                                    <th>Plot No</th>
                                    <th>Block</th>
                                    <th>Size</th>
                                    <th>Type</th>
                                    <th>Date</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var allotment in Model.Allotments)
                                {
                                    <tr>
                                        <td><code>@allotment.AllotmentID</code></td>
                                        <td>@allotment.Property?.PlotNo</td>
                                        <td>@allotment.Property?.Block</td>
                                        <td>@allotment.Property?.Size</td>
                                        <td>@allotment.AllottmentType</td>
                                        <td>@allotment.AllotmentDate.ToString("MMM dd, yyyy")</td>
                                        <td>
                                            <span class="badge bg-primary">@allotment.WorkFlowStatus</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center text-muted py-3">
                        <i class="fas fa-inbox fa-2x mb-2 d-block"></i>
                        <p class="mb-0">No property allotments found.</p>
                    </div>
                }
                    </div>

                    <!-- Activity History Tab -->
                    <div class="tab-pane fade" id="activity" role="tabpanel" aria-labelledby="activity-tab">
                @if (Model.CustomerLogs != null && Model.CustomerLogs.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Action</th>
                                    <th>Remarks</th>
                                    <th>Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var log in Model.CustomerLogs.OrderByDescending(l => l.CreatedAt).Take(10))
                                {
                                    <tr>
                                        <td>
                                            <i class="fas fa-circle-notch me-2" style="font-size: 8px;"></i>
                                            @log.Action
                                        </td>
                                        <td>@log.Remarks</td>
                                        <td class="text-muted small">@log.CreatedAt.ToString("MMM dd, yyyy hh:mm tt")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center text-muted py-3">
                        <i class="fas fa-inbox fa-2x mb-2 d-block"></i>
                        <p class="mb-0">No activity logs found.</p>
                    </div>
                }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Tab Styling */
    .customer-tabs {
        border-bottom: 2px solid #6f42c1;
        background: linear-gradient(135deg, #f8f9fa 0%, #f3f0ff 100%);
        padding: 0.5rem 1rem 0;
    }

    .customer-tabs .nav-link {
        color: #666;
        font-weight: 600;
        border: none;
        border-bottom: 3px solid transparent;
        padding: 0.75rem 1.25rem;
        transition: all 0.3s ease;
        font-size: 14px;
    }

    .customer-tabs .nav-link:hover {
        color: #6f42c1;
        background: rgba(111, 66, 193, 0.05);
        border-bottom-color: #9370db;
    }

    .customer-tabs .nav-link.active {
        color: #6f42c1;
        background: white;
        border-bottom-color: #6f42c1;
        font-weight: 700;
    }

    .customer-tabs .nav-link i {
        font-size: 13px;
    }

    /* Tab Content */
    .tab-content {
        padding-top: 1rem;
    }

    /* Detail Fields */
    .detail-field {
        padding: 8px 10px;
        background: linear-gradient(135deg, #f8f9fa 0%, var(--gold-tint) 100%);
        border-radius: 6px;
        transition: all 0.3s ease;
    }

    .detail-field:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 15px rgba(11, 148, 68, 0.1);
    }

    .detail-field label {
        display: block;
        margin-bottom: 3px;
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #666;
        font-weight: 600;
    }

    .detail-field p {
        font-size: 14px;
        color: var(--text-dark);
        margin-bottom: 0;
        font-weight: 500;
    }

    code {
        background: var(--light-green);
        color: var(--primary-green);
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 13px;
        font-weight: 600;
    }

    /* Section Headers within Tabs */
    .tab-pane h6 {
        color: #6f42c1;
        font-weight: 700;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid #e8dcff;
    }

    /* Responsive Tabs */
    @@media (max-width: 768px) {
        .customer-tabs .nav-link {
            padding: 0.5rem 0.75rem;
            font-size: 12px;
        }

        .customer-tabs .nav-link i {
            display: none;
        }
    }
</style>

