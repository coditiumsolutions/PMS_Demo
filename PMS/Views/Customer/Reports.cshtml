@{
    ViewData["Title"] = "Customer Reports";
    var summary = ViewBag.Summary as PMS.Models.CustomerReportsSummary;
    var allottedPerProject = ViewBag.AllottedPerProject as IList<PMS.Models.AllottedPerProjectReportItem> ?? new List<PMS.Models.AllottedPerProjectReportItem>();
    var byStatusPerProject = ViewBag.ByStatusPerProject as IList<PMS.Models.CustomersByStatusPerProjectItem> ?? new List<PMS.Models.CustomersByStatusPerProjectItem>();
    var newCustomersPerMonth = ViewBag.NewCustomersPerMonth as IList<PMS.Models.NewCustomersPerMonthItem> ?? new List<PMS.Models.NewCustomersPerMonthItem>();
    var byCity = ViewBag.ByCity as IList<PMS.Models.CustomersByCityItem> ?? new List<PMS.Models.CustomersByCityItem>();
    var bySize = ViewBag.BySize as IList<PMS.Models.CustomersBySizeItem> ?? new List<PMS.Models.CustomersBySizeItem>();
    var customersWithoutPaymentPlanAllocated = (int?)ViewBag.CustomersWithoutPaymentPlanAllocated ?? 0;
    var customersWithMissingAllocatedPaymentPlan = (int?)ViewBag.CustomersWithMissingAllocatedPaymentPlan ?? 0;
    var customersWithoutProjectAllocated = (int?)ViewBag.CustomersWithoutProjectAllocated ?? 0;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-chart-bar me-2"></i>Customer Reports</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-2"></i>Back to Customers
    </a>
</div>

@if (summary != null)
{
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-primary h-100">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase small">Total Customers</h6>
                    <h3 class="mb-0">@summary.TotalCustomers</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-success h-100">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase small">Allotted</h6>
                    <h3 class="mb-0 text-success">@summary.TotalAllotted</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-warning h-100">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase small">Not Allotted</h6>
                    <h3 class="mb-0 text-warning">@summary.TotalNotAllotted</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-secondary h-100">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase small">Active / Inactive</h6>
                    <h3 class="mb-0">@summary.ActiveCustomers <small class="text-muted">/ @summary.InactiveCustomers</small></h3>
                </div>
            </div>
        </div>
    </div>
}

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-danger h-100">
            <div class="card-body">
                <h6 class="text-muted text-uppercase small">Without Payment Plan Allocated</h6>
                <h3 class="mb-0 text-danger">@customersWithoutPaymentPlanAllocated</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-warning h-100">
            <div class="card-body">
                <h6 class="text-muted text-uppercase small">Allocated Plan Not Found</h6>
                <h3 class="mb-0 text-warning">@customersWithMissingAllocatedPaymentPlan</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-info h-100">
            <div class="card-body">
                <h6 class="text-muted text-uppercase small">Without Project Allocated</h6>
                <h3 class="mb-0 text-info">@customersWithoutProjectAllocated</h3>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- 1. Allotted Vs Not Allotted per Project -->
    <div class="col-12">
        <div class="card">
            <div class="card-header bg-light d-flex align-items-center">
                <i class="fas fa-building me-2 text-primary"></i>
                <h5 class="mb-0">1. Allotted vs Not Allotted per Project</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Project</th>
                                <th class="text-end">Allotted</th>
                                <th class="text-end">Not Allotted</th>
                                <th class="text-end">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in allottedPerProject)
                            {
                                <tr>
                                    <td><strong>@(row.ProjectName ?? row.ProjectID)</strong></td>
                                    <td class="text-end"><span class="badge bg-success">@row.Allotted</span></td>
                                    <td class="text-end"><span class="badge bg-warning text-dark">@row.NotAllotted</span></td>
                                    <td class="text-end">@row.Total</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                @if (!allottedPerProject.Any())
                {
                    <p class="text-muted p-3 mb-0">No project data.</p>
                }
            </div>
        </div>
    </div>

    <!-- 2. Customers per Project grouped by Status -->
    <div class="col-12">
        <div class="card">
            <div class="card-header bg-light d-flex align-items-center">
                <i class="fas fa-tags me-2 text-primary"></i>
                <h5 class="mb-0">2. Customers per Project by Status</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Project</th>
                                <th>Status</th>
                                <th class="text-end">Count</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in byStatusPerProject)
                            {
                                <tr>
                                    <td>@(row.ProjectName ?? row.ProjectID)</td>
                                    <td><span class="badge @(row.Status == "Active" ? "bg-success" : "bg-secondary")">@row.Status</span></td>
                                    <td class="text-end">@row.Count</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                @if (!byStatusPerProject.Any())
                {
                    <p class="text-muted p-3 mb-0">No data.</p>
                }
            </div>
        </div>
    </div>

    <!-- 3. New Customers each month -->
    <div class="col-12 col-lg-6">
        <div class="card h-100">
            <div class="card-header bg-light d-flex align-items-center">
                <i class="fas fa-calendar-alt me-2 text-primary"></i>
                <h5 class="mb-0">3. New Customers per Month</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Month</th>
                                <th class="text-end">New Customers</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in newCustomersPerMonth.Take(18))
                            {
                                <tr>
                                    <td>@row.YearMonthLabel</td>
                                    <td class="text-end">@row.Count</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                @if (!newCustomersPerMonth.Any())
                {
                    <p class="text-muted p-3 mb-0">No data for last 24 months.</p>
                }
            </div>
        </div>
    </div>

    <!-- 4. Customers by City -->
    <div class="col-12 col-lg-6">
        <div class="card h-100">
            <div class="card-header bg-light d-flex align-items-center">
                <i class="fas fa-city me-2 text-primary"></i>
                <h5 class="mb-0">4. Customers by City (Top 20)</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>City</th>
                                <th class="text-end">Count</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in byCity)
                            {
                                <tr>
                                    <td>@(row.City ?? "-")</td>
                                    <td class="text-end">@row.Count</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                @if (!byCity.Any())
                {
                    <p class="text-muted p-3 mb-0">No data.</p>
                }
            </div>
        </div>
    </div>

    <!-- 5. Customers by Registered Size -->
    <div class="col-12 col-lg-6">
        <div class="card h-100">
            <div class="card-header bg-light d-flex align-items-center">
                <i class="fas fa-ruler-combined me-2 text-primary"></i>
                <h5 class="mb-0">5. Customers by Registered Size</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Size</th>
                                <th class="text-end">Count</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in bySize)
                            {
                                <tr>
                                    <td>@(row.Size ?? "-")</td>
                                    <td class="text-end">@row.Count</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                @if (!bySize.Any())
                {
                    <p class="text-muted p-3 mb-0">No data.</p>
                }
            </div>
        </div>
    </div>

    <!-- 6. Quick links to other reports -->
    <div class="col-12 col-lg-6">
        <div class="card h-100">
            <div class="card-header bg-light d-flex align-items-center">
                <i class="fas fa-link me-2 text-primary"></i>
                <h5 class="mb-0">More Reports</h5>
            </div>
            <div class="card-body">
                <ul class="list-unstyled mb-0">
                    <li class="mb-2">
                        <a asp-controller="Reports" asp-action="Defaulters" class="text-decoration-none">
                            <i class="fas fa-exclamation-triangle text-warning me-2"></i>Defaulters (Overdue Payments)
                        </a>
                    </li>
                    <li class="mb-2">
                        <a asp-controller="Reports" asp-action="NotAllotted" class="text-decoration-none">
                            <i class="fas fa-user-times text-secondary me-2"></i>Not Allotted Customers
                        </a>
                    </li>
                    <li class="mb-0">
                        <a asp-action="ByProject" class="text-decoration-none">
                            <i class="fas fa-layer-group text-primary me-2"></i>Customers By Project (with sizes)
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>
