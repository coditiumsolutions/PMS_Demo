@model IEnumerable<PMS.Models.Customer>

@{
    ViewData["Title"] = "Search Customers";
    var recordCount = Model?.Count() ?? 0;
    ViewData["ListingTitle"] = "Customers";
    ViewData["ListingDescription"] = "Manage all customer records";
    ViewData["ListingCountText"] = recordCount + " Record" + (recordCount == 1 ? "" : "s");
    ViewData["ListingRecordCount"] = recordCount;
    ViewData["ListingAddUrl"] = ViewBag.CanCreate == true ? Url.Action("Create") : null;
    ViewData["ListingAddText"] = "Add New";
    ViewData["SearchCollapseId"] = "customerSearchCollapse";

    var pendingCount = ViewBag.PendingCustomersCount;
    ViewData["ListingExtraActions"] =
        "<a href=\"" + Url.Action("ByProject") + "\" class=\"btn btn-outline-primary btn-sm\">" +
        "<i class=\"bi bi-layers me-1\" aria-hidden=\"true\"></i>By Project</a>" +
        "<a href=\"" + Url.Action("Index", new { statusFilter = "Pending" }) + "\" class=\"btn btn-outline-warning btn-sm\">" +
        "<i class=\"bi bi-clock me-1\" aria-hidden=\"true\"></i>Pending " +
        "<span class=\"badge bg-warning text-dark ms-1\">" + pendingCount + "</span></a>" +
        "<a href=\"" + Url.Action("UpdateRequests") + "\" class=\"btn btn-outline-secondary btn-sm\">" +
        "<i class=\"bi bi-person-lines-fill me-1\" aria-hidden=\"true\"></i>Update Requests</a>" +
        "<a href=\"" + Url.Action("Reports") + "\" class=\"btn btn-outline-primary btn-sm\">" +
        "<i class=\"bi bi-bar-chart me-1\" aria-hidden=\"true\"></i>Reports</a>" +
        "<a href=\"" + Url.Action("CustomerBlocking") + "\" class=\"btn btn-outline-primary btn-sm\">" +
        "<i class=\"bi bi-slash-circle me-1\" aria-hidden=\"true\"></i>Blocking</a>";

    var showBulkSelection = (ViewBag.StatusFilter as string) == "Pending" && ViewBag.CanEdit == true;
    ViewData["ShowBulkSelection"] = showBulkSelection;
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Search Filters -->
<form method="get" asp-action="Index" class="mb-4">
    <div class="card pms-search-card">
        <partial name="Listing/_SearchCardHeader" />
        <div class="collapse show" id="customerSearchCollapse">
            <div class="card-body">
                <div class="row g-3 pms-search-fields align-items-end">
                    <div class="col-12 col-md-6 col-lg-3 col-search">
                        <div class="form-floating">
                            <select name="projectFilter" id="projectFilter" class="form-select" onchange="this.form.submit()">
                                <option value="All" selected="@(ViewBag.ProjectFilter == "All")">All Projects</option>
                                @if (ViewBag.Projects != null)
                                {
                                    @foreach (var project in ViewBag.Projects)
                                    {
                                        <option value="@project.ProjectID" selected="@(ViewBag.ProjectFilter == project.ProjectID)">
                                            @project.ProjectName
                                        </option>
                                    }
                                }
                            </select>
                            <label for="projectFilter">Filter by Project</label>
                        </div>
                    </div>
                    <div class="col-12 col-md-6 col-lg-3 col-search">
                        <div class="form-floating">
                            <select name="statusFilter" id="statusFilter" class="form-select" onchange="this.form.submit()">
                                <option value="All" selected="@(ViewBag.StatusFilter == "All")">All Status</option>
                                <option value="Active" selected="@(ViewBag.StatusFilter == "Active")">Active</option>
                                <option value="Pending" selected="@(ViewBag.StatusFilter == "Pending")">Pending</option>
                                <option value="Inactive" selected="@(ViewBag.StatusFilter == "Inactive")">Inactive</option>
                                <option value="Marked for Deletion" selected="@(ViewBag.StatusFilter == "Marked for Deletion")">Marked for Deletion</option>
                            </select>
                            <label for="statusFilter">Filter by Status</label>
                        </div>
                    </div>
                    <div class="col-12 col-md-6 col-lg-3 col-search">
                        <div class="form-floating">
                            <input type="text"
                                   name="searchTerm"
                                   id="searchTerm"
                                   class="form-control"
                                   placeholder="Search"
                                   value="@ViewBag.SearchTerm" />
                            <label for="searchTerm">Search by ID, FormNo, Name, National ID, Email</label>
                        </div>
                    </div>
                    <div class="col-12 col-md-6 col-lg-3 col-search">
                        <div class="d-flex justify-content-end gap-2 pms-search-actions border-0 mt-0 pt-0">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-search me-1" aria-hidden="true"></i>Search
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-counterclockwise me-1" aria-hidden="true"></i>Clear
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

@if (showBulkSelection)
{
    <form asp-action="BulkUpdatePendingCustomers" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="projectFilter" value="@ViewBag.ProjectFilter" />
        <input type="hidden" name="searchTerm" value="@ViewBag.SearchTerm" />

        <div class="card pms-search-card mb-3">
            <div class="card-body">
                <div class="d-flex flex-wrap align-items-center gap-2">
                    <span class="fw-bold">Pending Customer Actions:</span>
                    <select name="bulkAction" id="bulkAction" class="form-select form-select-sm" style="width: 240px;" required>
                        <option value="">Select Action</option>
                        <option value="Activate">Make Active</option>
                        <option value="MarkForDeletion">Mark for Deletion</option>
                    </select>
                    <button type="submit" class="btn btn-warning btn-sm" id="applyBulkActionBtn" disabled>
                        <i class="fas fa-check-double me-1"></i>Apply to Selected
                    </button>
                    <small class="text-muted">Select customers below, choose action, and enter comments.</small>
                </div>
                <div class="mt-2">
                    <label for="bulkActionComments" class="form-label fw-bold mb-1">Comments <span class="text-danger">*</span></label>
                    <textarea id="bulkActionComments"
                              name="comments"
                              class="form-control form-control-sm"
                              rows="2"
                              maxlength="1000"
                              placeholder="Enter reason/comments for this status change"
                              required></textarea>
                </div>
            </div>
        </div>

        <div class="card pms-grid-card pms-saas-grid">
            <div class="card-body">
                <partial name="Listing/_GridToolbar" />
                <partial name="_CustomerDataGrid" model="Model" />
            </div>
        </div>
    </form>
}
else
{
    <div class="card pms-grid-card pms-saas-grid">
        <div class="card-body">
            <partial name="Listing/_GridToolbar" />
            <partial name="_CustomerDataGrid" model="Model" />
        </div>
    </div>
}

@section Scripts {
    <script>
        $(document).ready(function() {
            var showBulkSelection = @showBulkSelection.ToString().ToLowerInvariant();
            var createdDateColumnIndex = showBulkSelection ? 7 : 6;
            var actionsColumnIndex = showBulkSelection ? 8 : 7;

            if ($('#customersTable').length) {
                $('#customersTable').DataTable({
                    "pageLength": 25,
                    "order": [[ createdDateColumnIndex, "desc" ]],
                    "columnDefs": [
                        { "orderable": false, "targets": actionsColumnIndex }
                    ]
                });
            }

            if (showBulkSelection) {
                var $selectAll = $('#selectAllPendingCustomers');
                var $rowChecks = $('.pending-customer-checkbox');
                var $applyBtn = $('#applyBulkActionBtn');
                var $bulkAction = $('#bulkAction');
                var $comments = $('#bulkActionComments');

                function refreshBulkButtonState() {
                    var anyChecked = $('.pending-customer-checkbox:checked').length > 0;
                    var hasAction = ($bulkAction.val() || '').trim().length > 0;
                    var hasComments = ($comments.val() || '').trim().length > 0;
                    $applyBtn.prop('disabled', !(anyChecked && hasAction && hasComments));
                }

                $selectAll.on('change', function() {
                    $rowChecks.prop('checked', this.checked);
                    refreshBulkButtonState();
                });

                $(document).on('change', '.pending-customer-checkbox', function() {
                    var total = $rowChecks.length;
                    var checked = $('.pending-customer-checkbox:checked').length;
                    $selectAll.prop('checked', total > 0 && total === checked);
                    refreshBulkButtonState();
                });

                $bulkAction.on('change', refreshBulkButtonState);
                $comments.on('input', refreshBulkButtonState);

                refreshBulkButtonState();
            }
        });
    </script>
}
