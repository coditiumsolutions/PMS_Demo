@model IEnumerable<PMS.Models.Customer>

@{
    ViewData["Title"] = "Search Customers";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>
    <!-- <i class="fas fa-users me-2"></i>Customers -->
    </h2>
    <div class="btn-group" role="group">
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Add New Customer
        </a>
        <a asp-action="ByProject" class="btn btn-outline-primary">
            <i class="fas fa-layer-group me-2"></i>Customers By Project
        </a>
    </div>
</div>

<!-- Filters -->
<form method="get" asp-action="Index" class="mb-4">
    <div class="card">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label fw-bold">Filter by Project</label>
                    <select name="projectFilter" class="form-select form-select-sm" onchange="this.form.submit()">
                        <option value="All" selected="@(ViewBag.ProjectFilter == "All")">All Projects</option>
                        @if (ViewBag.Projects != null)
                        {
                            @foreach (var project in ViewBag.Projects)
                            {
                                <option value="@project.ProjectID" selected="@(ViewBag.ProjectFilter == project.ProjectID)">
                                    @project.ProjectName
                                </option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">Filter by Status</label>
                    <select name="statusFilter" class="form-select form-select-sm" onchange="this.form.submit()">
                        <option value="All" selected="@(ViewBag.StatusFilter == "All")">All Status</option>
                        <option value="Active" selected="@(ViewBag.StatusFilter == "Active")">Active</option>
                        <option value="Inactive" selected="@(ViewBag.StatusFilter == "Inactive")">Inactive</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">Search</label>
                    <input type="text" name="searchTerm" class="form-control form-control-sm" 
                           placeholder="Search by ID, Name, CNIC, Phone, Email..." 
                           value="@ViewBag.SearchTerm" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">&nbsp;</label>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-sm">
                            <i class="fas fa-search me-2"></i>Search
                        </button>
                        <a asp-action="Index" class="btn btn-secondary btn-sm">
                            <i class="fas fa-times me-2"></i>Clear
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover" id="customersTable">
                <thead class="table-dark">
                    <tr>
                        <th>Customer ID</th>
                        <th>Full Name</th>
                        <th>Project</th>
                        <th>Phone</th>
                        <th>City</th>
                        <th>Status</th>
                        <th>Created Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var customer in Model)
                    {
                        <tr>
                            <td>
                                <span class="badge bg-secondary">@customer.CustomerID</span>
                            </td>
                            <td>
                                <strong>@customer.FullName</strong>
                                @if (!string.IsNullOrEmpty(customer.FatherName))
                                {
                                    <br><small class="text-muted">S/O @customer.FatherName</small>
                                }
                            </td>
                            <td>
                                @if (customer.PaymentPlan?.Project != null)
                                {
                                    <span class="badge bg-info">@customer.PaymentPlan.Project.ProjectName</span>
                                }
                                else
                                {
                                    <span class="text-muted">No Project</span>
                                }
                            </td>
                            <td>@customer.Phone</td>
                            <td>@customer.City</td>
                            <td>
                                <span class="badge @(customer.Status == "Active" ? "bg-success" : "bg-warning")">
                                    @customer.Status
                                </span>
                            </td>
                            <td>@customer.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a asp-action="Details" asp-route-id="@customer.CustomerID" 
                                       class="btn btn-sm btn-outline-info" title="View Details">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@customer.CustomerID" 
                                       class="btn btn-sm btn-outline-primary" title="Edit">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@customer.CustomerID" 
                                       class="btn btn-sm btn-outline-danger" title="Delete">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#customersTable').DataTable({
                "pageLength": 25,
                "order": [[ 6, "desc" ]], // Created Date is now column 6
                "columnDefs": [
                    { "orderable": false, "targets": 7 } // Actions column is now column 7
                ]
            });
        });
    </script>
}
