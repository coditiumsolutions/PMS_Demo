@model IEnumerable<PMS.Models.Customer>
@{
    var showBulkSelection = ViewData["ShowBulkSelection"] as bool? == true;
}

@if (Model != null && Model.Any())
{
    <div class="table-responsive pms-saas-table-wrap">
        <table class="table pms-saas-table" id="customersTable">
            <thead>
                <tr>
                    @if (showBulkSelection)
                    {
                        <th class="pms-saas-th-check">
                            <input type="checkbox" id="selectAllPendingCustomers" class="pms-saas-checkbox" title="Select all" aria-label="Select all customers" />
                        </th>
                    }
                    <th>Customer ID</th>
                    <th>Full Name</th>
                    <th>Project</th>
                    <th>Allotment Status</th>
                    <th>PlanPlan</th>
                    <th>Status</th>
                    <th>Created Date</th>
                    <th class="pms-saas-th-actions">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var customer in Model)
                {
                    var projectName = customer.PaymentPlan?.Project?.ProjectName
                        ?? customer.Project?.ProjectName;
                    var planName = customer.PaymentPlan?.PlanName;
                    var planId = customer.PlanID;
                    var custStatus = customer.Status ?? "Active";
                    var fatherLine = !string.IsNullOrEmpty(customer.FatherName)
                        ? "S/O " + customer.FatherName
                        : null;
                    var formLine = !string.IsNullOrWhiteSpace(customer.FormNo)
                        ? "Form No: " + customer.FormNo
                        : null;
                    <tr>
                        @if (showBulkSelection)
                        {
                            <td class="pms-saas-td-check" data-label="Select">
                                <input type="checkbox"
                                       class="pending-customer-checkbox pms-saas-checkbox"
                                       name="selectedCustomerIds"
                                       value="@(customer.CustomerID ?? "")"
                                       aria-label="Select customer @(customer.CustomerID)"
                                       @(string.IsNullOrWhiteSpace(customer.CustomerID) ? "disabled" : "") />
                            </td>
                        }
                        <td data-label="Customer ID">
                            <div class="pms-cell-primary">
                                <span class="pms-cell-primary-title">@(customer.CustomerID ?? "—")</span>
                                <span class="pms-cell-primary-sub">@(formLine ?? "—")</span>
                            </div>
                        </td>
                        <td data-label="Full Name">
                            <div class="pms-cell-primary">
                                <span class="pms-cell-primary-title">@customer.FullName</span>
                                <span class="pms-cell-primary-sub">@(fatherLine ?? "—")</span>
                            </div>
                        </td>
                        <td data-label="Project">
                            @if (!string.IsNullOrWhiteSpace(projectName))
                            {
                                <span class="pms-pill pms-pill--info">@projectName</span>
                            }
                            else
                            {
                                <span class="text-muted small">No project</span>
                            }
                        </td>
                        <td data-label="Allotment Status">
                            @if (customer.Allotments != null && customer.Allotments.Any())
                            {
                                <span class="pms-pill pms-pill--success">Allotted</span>
                            }
                            else
                            {
                                <span class="pms-pill pms-pill--neutral">Not allotted</span>
                            }
                        </td>
                        <td data-label="PlanPlan">
                            @if (!string.IsNullOrWhiteSpace(planName) || !string.IsNullOrWhiteSpace(planId))
                            {
                                <div class="pms-cell-primary">
                                    <span class="pms-cell-primary-title">@(string.IsNullOrWhiteSpace(planName) ? "Unknown plan" : planName)</span>
                                    @if (!string.IsNullOrWhiteSpace(planId))
                                    {
                                        <span class="pms-cell-primary-sub">@planId</span>
                                    }
                                </div>
                            }
                            else
                            {
                                <span class="text-muted small">No plan</span>
                            }
                        </td>
                        <td data-label="Status">
                            @if (custStatus == "Active")
                            { <span class="pms-pill pms-pill--success">@custStatus</span> }
                            else if (custStatus == "Inactive" || custStatus == "Marked for Deletion")
                            { <span class="pms-pill pms-pill--danger">@custStatus</span> }
                            else if (custStatus == "Pending")
                            { <span class="pms-pill pms-pill--warning">@custStatus</span> }
                            else
                            { <span class="pms-pill pms-pill--neutral">@custStatus</span> }
                        </td>
                        <td data-label="Created Date">
                            <span class="text-nowrap">@customer.CreatedAt.ToString("MMM dd, yyyy")</span>
                        </td>
                        <td class="pms-saas-td-actions" data-label="Actions">
                            <div class="pms-row-actions" role="group">
                                <a asp-action="AccountStatement" asp-route-id="@(customer.CustomerID ?? "")" class="btn btn-sm btn-outline-secondary" title="Account Statement">
                                    <i class="bi bi-receipt" aria-hidden="true"></i>
                                </a>
                                @if (ViewBag.CanEdit == true)
                                {
                                    <a asp-action="Edit" asp-route-id="@(customer.CustomerID ?? "")" class="btn btn-sm btn-outline-primary" title="Edit">
                                        <i class="bi bi-pencil-square" aria-hidden="true"></i>
                                    </a>
                                }
                                <a asp-action="Details" asp-route-id="@(customer.CustomerID ?? "")" class="btn btn-sm btn-outline-secondary" title="View">
                                    <i class="bi bi-eye" aria-hidden="true"></i>
                                </a>
                                @if (ViewBag.CanDelete == true)
                                {
                                    <a asp-action="Delete" asp-route-id="@(customer.CustomerID ?? "")"
                                       class="btn btn-sm btn-outline-danger" title="Delete">
                                        <i class="bi bi-trash" aria-hidden="true"></i>
                                    </a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="pms-saas-empty">
        <i class="bi bi-people pms-saas-empty-icon" aria-hidden="true"></i>
        <h5>No Records Found</h5>
        <p>No customers match your current filters. Try adjusting search criteria or add a new customer.</p>
        @if (ViewBag.CanCreate == true)
        {
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg me-1" aria-hidden="true"></i>Add New Customer
            </a>
        }
    </div>
}
