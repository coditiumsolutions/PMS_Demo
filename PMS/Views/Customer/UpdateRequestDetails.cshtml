@model PMS.Models.CustomerUpdateRequest
@{
    ViewData["Title"] = "Update Request Details";
    var isPending = string.Equals(Model.Status, "Pending", StringComparison.OrdinalIgnoreCase);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0"><i class="fas fa-file-alt me-2"></i>Update Request @Model.RequestID</h2>
    <a asp-action="UpdateRequests" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-1"></i>Back
    </a>
</div>

<div class="card mb-3">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-3"><strong>Customer ID:</strong> @Model.CustomerID</div>
            <div class="col-md-3"><strong>Customer:</strong> @(Model.Customer?.FullName ?? "-")</div>
            <div class="col-md-2">
                <strong>Status:</strong>
                <span class="badge @(Model.Status == "Approved" ? "bg-success" : Model.Status == "Rejected" ? "bg-danger" : "bg-warning text-dark")">@Model.Status</span>
            </div>
            <div class="col-md-4"><strong>Requested:</strong> @Model.RequestedAt.ToString("MMM dd, yyyy hh:mm tt")</div>
            <div class="col-md-4"><strong>Requested By:</strong> @(Model.RequestedByUser?.FullName ?? Model.RequestedBy ?? "-")</div>
            <div class="col-md-4"><strong>Approved By:</strong> @(Model.ApprovedByUser?.FullName ?? Model.ApprovedBy ?? "-")</div>
            <div class="col-md-4"><strong>Rejected By:</strong> @(Model.RejectedByUser?.FullName ?? Model.RejectedBy ?? "-")</div>
            <div class="col-12"><strong>Reviewer Comments:</strong> @(string.IsNullOrWhiteSpace(Model.ReviewerComments) ? "-" : Model.ReviewerComments)</div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header"><strong>Field Changes</strong></div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>Field</th>
                        <th>Old Value</th>
                        <th>New Value</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Changes.Any())
                {
                    foreach (var change in Model.Changes.OrderBy(c => c.FieldName))
                    {
                        <tr>
                            <td>@change.FieldName</td>
                            <td>@(string.IsNullOrWhiteSpace(change.OldValue) ? "-" : change.OldValue)</td>
                            <td>@(string.IsNullOrWhiteSpace(change.NewValue) ? "-" : change.NewValue)</td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="3" class="text-center py-3 text-muted">No field changes saved.</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (isPending)
{
    <div class="row g-3">
        <div class="col-md-6">
            <div class="card border-success">
                <div class="card-header bg-success text-white">Approve Request</div>
                <div class="card-body">
                    <form asp-action="ApproveUpdateRequest" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="requestId" value="@Model.RequestID" />
                        <div class="mb-2">
                            <label class="form-label">Comments (optional)</label>
                            <textarea name="reviewerComments" class="form-control" rows="3"></textarea>
                        </div>
                        <button type="submit" class="btn btn-success">
                            <i class="fas fa-check me-1"></i>Approve
                        </button>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">Reject Request</div>
                <div class="card-body">
                    <form asp-action="RejectUpdateRequest" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="requestId" value="@Model.RequestID" />
                        <div class="mb-2">
                            <label class="form-label">Comments (optional)</label>
                            <textarea name="reviewerComments" class="form-control" rows="3"></textarea>
                        </div>
                        <button type="submit" class="btn btn-danger">
                            <i class="fas fa-times me-1"></i>Reject
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}
