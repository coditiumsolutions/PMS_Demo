@model IEnumerable<PMS.Models.Possession>
@{
    ViewData["Title"] = "Possession";
    var approvedStatus = (string?)ViewBag.ApprovedStatus ?? "Approved";
    var declinedStatus = (string?)ViewBag.DeclinedStatus ?? "Declined";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h2 class="mb-0"><i class="fas fa-key me-2"></i>Possession</h2>
    @if (ViewBag.CanCreate == true)
    {
        <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus me-2"></i>New request</a>
    }
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">@TempData["SuccessMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">@TempData["ErrorMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<div class="row g-3 mb-4">
    <div class="col-6 col-md-4">
        <a href="@Url.Action("Index", new { workflowFilter = "Pending" })" class="text-decoration-none">
            <div class="card border-0 h-100" style="background:#fff3cd;">
                <div class="card-body text-center py-3">
                    <div class="small text-muted text-uppercase fw-semibold">Pending</div>
                    <div class="fs-3 fw-bold text-warning">@(ViewBag.PendingCount ?? 0)</div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-6 col-md-4">
        <a href="@Url.Action("Index", new { workflowFilter = approvedStatus })" class="text-decoration-none">
            <div class="card border-0 h-100" style="background:#d4edda;">
                <div class="card-body text-center py-3">
                    <div class="small text-muted text-uppercase fw-semibold">@approvedStatus</div>
                    <div class="fs-3 fw-bold text-success">@(ViewBag.ApprovedCount ?? 0)</div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-6 col-md-4">
        <a href="@Url.Action("Index", new { workflowFilter = declinedStatus })" class="text-decoration-none">
            <div class="card border-0 h-100" style="background:#f8d7da;">
                <div class="card-body text-center py-3">
                    <div class="small text-muted text-uppercase fw-semibold">@declinedStatus</div>
                    <div class="fs-3 fw-bold text-danger">@(ViewBag.DeclinedCount ?? 0)</div>
                </div>
            </div>
        </a>
    </div>
</div>

<form method="get" asp-action="Index" class="mb-4">
    <div class="card">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Status</label>
                    <select name="workflowFilter" class="form-select form-select-sm" onchange="this.form.submit()">
                        <option value="">All</option>
                        @{
                            var wfFilter = ViewBag.WorkflowFilter as string;
                        }
                        @if (wfFilter == "Pending")
                        {
                            <option value="Pending" selected>Pending</option>
                        }
                        else
                        {
                            <option value="Pending">Pending</option>
                        }
                        @foreach (var s in (ViewBag.WorkflowStatuses as List<string> ?? new List<string>()))
                        {
                            if (wfFilter == s)
                            {
                                <option value="@s" selected>@s</option>
                            }
                            else
                            {
                                <option value="@s">@s</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Customer ID</label>
                    <input name="customerFilter" class="form-control form-control-sm" value="@ViewBag.CustomerFilter" placeholder="e.g. CUS0000001" />
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-sm btn-outline-primary"><i class="fas fa-search me-1"></i>Filter</button>
                </div>
            </div>
        </div>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-hover table-sm align-middle">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Customer</th>
                <th>Property</th>
                <th>Status</th>
                <th>Due / Paid</th>
                <th>Date</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                var wf = p.WorkFlowStatus ?? "—";
                var badge = string.Equals(wf, approvedStatus, StringComparison.OrdinalIgnoreCase) ? "bg-success"
                    : string.Equals(wf, declinedStatus, StringComparison.OrdinalIgnoreCase) ? "bg-danger" : "bg-warning text-dark";
                <tr>
                    <td><code>@p.PossessionID</code></td>
                    <td><code>@(p.CustomerID ?? "—")</code></td>
                    <td><code>@(p.PropertyID ?? "—")</code></td>
                    <td><span class="badge @badge">@wf</span></td>
                    <td class="small">@p.PossessionDueCharges.ToString("N0") / @p.PossessionPaidCharges.ToString("N0")</td>
                    <td>@p.PossessionDate.ToString("yyyy-MM-dd")</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@p.PossessionID" class="btn btn-sm btn-outline-primary">View</a>
                        @if (ViewBag.CanEdit == true && !string.Equals(wf, approvedStatus, StringComparison.OrdinalIgnoreCase) && !string.Equals(wf, declinedStatus, StringComparison.OrdinalIgnoreCase))
                        {
                            <a asp-action="Edit" asp-route-id="@p.PossessionID" class="btn btn-sm btn-outline-secondary">Edit</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <p class="text-muted">No possession requests found.</p>
}
