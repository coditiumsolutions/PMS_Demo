@model PMS.Models.Possession
@{
    ViewData["Title"] = "New Possession";
    var initiated = (string?)ViewBag.InitiatedStatus ?? "Initiated";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="fas fa-key me-2"></i>New possession request</h2>
    <a asp-action="Index" class="btn btn-secondary btn-sm"><i class="fas fa-arrow-left me-1"></i>Back</a>
</div>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-danger small mb-3"></div>
    <div class="card mb-3">
        <div class="card-header fw-semibold">Property &amp; customer</div>
        <div class="card-body row g-3">
            <div class="col-md-4">
                <label class="form-label">Property ID <span class="text-danger">*</span></label>
                <input asp-for="PropertyID" class="form-control" maxlength="10" required />
            </div>
            <div class="col-md-4">
                <label class="form-label">Customer ID <span class="text-danger">*</span></label>
                <input asp-for="CustomerID" class="form-control" maxlength="10" required />
            </div>
            <div class="col-md-4">
                <label class="form-label">Possession date</label>
                <input asp-for="PossessionDate" class="form-control" type="date" />
            </div>
        </div>
    </div>
    <div class="card mb-3">
        <div class="card-header fw-semibold">Possession charges &amp; payment</div>
        <div class="card-body row g-3">
            <div class="col-md-4">
                <label class="form-label">Due charges (PKR)</label>
                <input asp-for="PossessionDueCharges" class="form-control" type="number" step="0.01" min="0" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Paid charges (PKR)</label>
                <input asp-for="PossessionPaidCharges" class="form-control" type="number" step="0.01" min="0" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Payment method</label>
                <input asp-for="PaymentMethod" class="form-control" maxlength="100" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Bank name</label>
                <input asp-for="BankName" class="form-control" maxlength="200" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Paid date</label>
                <input asp-for="PaidDate" class="form-control" type="date" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Instrument no.</label>
                <input asp-for="InstrumentNo" class="form-control" maxlength="100" />
            </div>
            <div class="col-12">
                <label class="form-label">Comments</label>
                <textarea asp-for="Comments" class="form-control" rows="2"></textarea>
            </div>
            <div class="col-12">
                <label class="form-label">Remarks</label>
                <textarea asp-for="Remarks" class="form-control" rows="2" maxlength="255"></textarea>
            </div>
        </div>
    </div>
    <div class="card mb-3">
        <div class="card-header fw-semibold">Optional attachment</div>
        <div class="card-body row g-2">
            <div class="col-md-6">
                <input type="file" name="attachment" class="form-control form-control-sm" accept=".jpg,.jpeg,.png,.gif,.bmp,.pdf" />
            </div>
            <div class="col-md-6">
                <input type="text" name="attachmentDescription" class="form-control form-control-sm" placeholder="Description" />
            </div>
            <p class="small text-muted mb-0">Workflow starts as <strong>@initiated</strong>. JPG/PDF etc., max 8MB.</p>
        </div>
    </div>
    <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i>Submit</button>
</form>
