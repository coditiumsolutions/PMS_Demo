@model IEnumerable<PMS.Models.Dealer>

@{
    ViewData["Title"] = "Dealers";
    ViewData["ListingTitle"] = "Dealers List";
    ViewData["ListingRecordCount"] = Model?.Count() ?? 0;
    ViewData["ListingShowAdd"] = false;
    ViewData["ListingExtraActions"] =
        "<a href=\"" + Url.Action("Report") + "\" class=\"btn btn-outline-primary btn-sm\">" +
        "<i class=\"bi bi-bar-chart me-1\" aria-hidden=\"true\"></i>View Report</a>" +
        "<a href=\"" + Url.Action("Create") + "\" class=\"btn btn-primary btn-sm\">" +
        "<i class=\"bi bi-plus-lg me-1\" aria-hidden=\"true\"></i>Create New Dealer</a>";
}

<div class="card pms-grid-card">
    <div class="card-body">
        <partial name="Listing/_GridToolbar" />

        <div class="table-responsive">
            <table class="table table-hover align-middle pms-enterprise-table" id="dealersTable">
                <thead>
                    <tr>
                        <th>Dealer ID</th>
                        <th>Dealership Name</th>
                        <th>Owner Name</th>
                        <th>Mobile No</th>
                        <th>Email</th>
                        <th>Status</th>
                        <th>Membership Type</th>
                        <th>Incentive %</th>
                        <th>Registration Date</th>
                        <th>Customers</th>
                        <th>Properties</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var dealer in Model)
                    {
                        <tr>
                            <td>
                                <span class="badge bg-secondary">@dealer.DealerID</span>
                            </td>
                            <td>
                                <strong class="pms-cell-truncate" title="@dealer.DealershipName">@dealer.DealershipName</strong>
                            </td>
                            <td>@dealer.OwnerName</td>
                            <td>@dealer.MobileNo</td>
                            <td><span class="pms-cell-truncate" title="@dealer.Email">@dealer.Email</span></td>
                            <td>
                                @if (dealer.Status == "Active")
                                { <span class="badge bg-success">@dealer.Status</span> }
                                else if (dealer.Status == "Inactive")
                                { <span class="badge bg-danger">@dealer.Status</span> }
                                else
                                { <span class="badge bg-warning text-dark">@dealer.Status</span> }
                            </td>
                            <td>
                                <span class="badge bg-info">@dealer.MembershipType</span>
                            </td>
                            <td>@dealer.IncentivePercentage%</td>
                            <td>@dealer.RegisterationDate.ToString("MMM dd, yyyy")</td>
                            <td>
                                <span class="badge bg-primary">@(dealer.Customers?.Count ?? 0) Customers</span>
                            </td>
                            <td>
                                <span class="badge bg-success">@(dealer.Properties?.Count ?? 0) Properties</span>
                            </td>
                            <td>
                                <div class="btn-group pms-action-group" role="group">
                                    <a asp-action="Edit" asp-route-id="@dealer.DealerID" class="btn btn-sm btn-outline-primary" title="Edit">
                                        <i class="bi bi-pencil-square" aria-hidden="true"></i>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@dealer.DealerID" class="btn btn-sm btn-outline-secondary" title="Details">
                                        <i class="bi bi-eye" aria-hidden="true"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@dealer.DealerID" class="btn btn-sm btn-outline-danger" title="Delete">
                                        <i class="bi bi-trash" aria-hidden="true"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#dealersTable').DataTable({
                "pageLength": 25,
                "order": [[ 8, "desc" ]],
                "columnDefs": [
                    { "orderable": false, "targets": 11 }
                ]
            });
        });
    </script>
}
