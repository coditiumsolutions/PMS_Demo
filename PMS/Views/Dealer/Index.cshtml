@model IEnumerable<PMS.Models.Dealer>

@{
    ViewData["Title"] = "Dealers";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>
    <!-- <i class="fas fa-store me-2"></i>Dealers -->
    </h2>
    <div class="d-flex gap-2">
        <a asp-action="Report" class="btn btn-premium">
            <i class="fas fa-chart-bar me-2"></i>View Report
        </a>
        <a asp-action="Create" class="btn btn-premium">
            <i class="fas fa-plus me-2"></i>Create New Dealer
        </a>
    </div>
</div>

<div class="card card-premium">
    <div class="card-header card-header-premium">
        <h5 class="mb-0"><i class="fas fa-store me-2"></i>Dealers List</h5>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover" id="dealersTable">
                <thead>
                    <tr>
                        <th>Dealer ID</th>
                        <th>Dealership Name</th>
                        <th>Owner Name</th>
                        <th>Mobile No</th>
                        <th>Email</th>
                        <th>Status</th>
                        <th>Membership Type</th>
                        <th>Registration Date</th>
                        <th>Customers</th>
                        <th>Properties</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var dealer in Model)
                    {
                        <tr>
                            <td>
                                <span class="badge" style="background-color: var(--primary);">@dealer.DealerID</span>
                            </td>
                            <td>
                                <strong>@dealer.DealershipName</strong>
                            </td>
                            <td>@dealer.OwnerName</td>
                            <td>@dealer.MobileNo</td>
                            <td>@dealer.Email</td>
                            <td>
                                <span class="badge @(dealer.Status == "Active" ? "bg-success" : dealer.Status == "Inactive" ? "bg-secondary" : "bg-warning")">
                                    @dealer.Status
                                </span>
                            </td>
                            <td>
                                <span class="badge" style="background-color: var(--accent);">@dealer.MembershipType</span>
                            </td>
                            <td>@dealer.RegisterationDate.ToString("MMM dd, yyyy")</td>
                            <td>
                                <span class="badge" style="background-color: var(--primary);">@(dealer.Customers?.Count ?? 0) Customers</span>
                            </td>
                            <td>
                                <span class="badge bg-success">@(dealer.Properties?.Count ?? 0) Properties</span>
                            </td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a asp-action="Details" asp-route-id="@dealer.DealerID" 
                                       class="btn btn-sm btn-outline-info" title="View Details">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@dealer.DealerID" 
                                       class="btn btn-sm btn-outline-primary" title="Edit">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@dealer.DealerID" 
                                       class="btn btn-sm btn-outline-danger" title="Delete">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#dealersTable').DataTable({
                "pageLength": 25,
                "order": [[ 7, "desc" ]],
                "columnDefs": [
                    { "orderable": false, "targets": 10 }
                ]
            });
        });
    </script>
}
