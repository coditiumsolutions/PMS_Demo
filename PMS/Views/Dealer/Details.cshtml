@model PMS.Models.Dealer

@{
    ViewData["Title"] = "Dealer Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-store me-2"></i></h2>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.DealerID" class="btn btn-outline-primary me-2">
            <i class="fas fa-edit me-2"></i>Edit Dealer
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Back to List
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">Dealership Information</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <dl class="row">
                            <dt class="col-sm-4">Dealer ID:</dt>
                            <dd class="col-sm-8">
                                <span class="badge bg-secondary">@Model.DealerID</span>
                            </dd>

                            <dt class="col-sm-4">Dealership Name:</dt>
                            <dd class="col-sm-8">
                                <strong>@Model.DealershipName</strong>
                            </dd>

                            <dt class="col-sm-4">Status:</dt>
                            <dd class="col-sm-8">
                                <span class="badge @(Model.Status == "Active" ? "bg-success" : Model.Status == "Inactive" ? "bg-secondary" : "bg-warning")">
                                    @Model.Status
                                </span>
                            </dd>

                            <dt class="col-sm-4">Membership Type:</dt>
                            <dd class="col-sm-8">
                                <span class="badge bg-info">@Model.MembershipType</span>
                            </dd>

                            <dt class="col-sm-4">Registration Date:</dt>
                            <dd class="col-sm-8">@Model.RegisterationDate.ToString("MMM dd, yyyy")</dd>
                        </dl>
                    </div>
                    <div class="col-md-6">
                        <dl class="row">
                            <dt class="col-sm-4">Owner Name:</dt>
                            <dd class="col-sm-8">@Model.OwnerName</dd>

                            <dt class="col-sm-4">Owner National Id Card:</dt>
                            <dd class="col-sm-8">@Model.OwnerCNIC</dd>

                            <dt class="col-sm-4">Mobile No:</dt>
                            <dd class="col-sm-8">@Model.MobileNo</dd>

                            <dt class="col-sm-4">Phone Number:</dt>
                            <dd class="col-sm-8">@Model.PhoneNumber</dd>

                            <dt class="col-sm-4">Email:</dt>
                            <dd class="col-sm-8">@Model.Email</dd>

                            <dt class="col-sm-4">Address:</dt>
                            <dd class="col-sm-8">@Model.Address</dd>
                        </dl>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.OwnerDetails))
                {
                    <hr>
                    <h6>Owner Details:</h6>
                    <p class="text-muted">@Model.OwnerDetails</p>
                }

                @if (!string.IsNullOrEmpty(Model.Details))
                {
                    <hr>
                    <h6>Additional Details:</h6>
                    <p class="text-muted">@Model.Details</p>
                }
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">Statistics</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <h6>Total Customers:</h6>
                    <span class="badge bg-primary fs-5">@(Model.Customers?.Count ?? 0) Customers</span>
                </div>
                <div class="mb-3">
                    <h6>Total Properties:</h6>
                    <span class="badge bg-success fs-5">@(Model.Properties?.Count ?? 0) Properties</span>
                </div>
            </div>
        </div>
    </div>
</div>

@if (Model.Customers?.Any() == true)
{
    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Customers</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Customer ID</th>
                                    <th>Full Name</th>
                                    <th>Phone</th>
                                    <th>Email</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var customer in Model.Customers.Take(10))
                                {
                                    <tr>
                                        <td>
                                            <span class="badge bg-secondary">@customer.CustomerID</span>
                                        </td>
                                        <td>@customer.FullName</td>
                                        <td>@customer.Phone</td>
                                        <td>@customer.Email</td>
                                        <td>
                                            <span class="badge @(customer.Status == "Active" ? "bg-success" : "bg-secondary")">
                                                @customer.Status
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        @if (Model.Customers.Count > 10)
                        {
                            <div class="text-center">
                                <small class="text-muted">Showing first 10 of @Model.Customers.Count customers</small>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@if (Model.Properties?.Any() == true)
{
    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Properties</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Property ID</th>
                                    <th>Plot No</th>
                                    <th>Block</th>
                                    <th>Type</th>
                                    <th>Size</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var property in Model.Properties.Take(10))
                                {
                                    <tr>
                                        <td>
                                            <span class="badge bg-secondary">@property.PropertyID</span>
                                        </td>
                                        <td>@property.PlotNo</td>
                                        <td>@property.Block</td>
                                        <td>@property.PropertyType</td>
                                        <td>@property.Size</td>
                                        <td>
                                            <span class="badge @(property.Status == "Available" ? "bg-success" : "bg-primary")">
                                                @property.Status
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        @if (Model.Properties.Count > 10)
                        {
                            <div class="text-center">
                                <small class="text-muted">Showing first 10 of @Model.Properties.Count properties</small>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

