@model PMS.Models.Dealer

@{
    ViewData["Title"] = "Delete Dealer";
}

<div class="row">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="text-danger"><i class="fas fa-exclamation-triangle me-2"></i></h2>
            <a asp-action="Index" class="btn btn-outline-secondary">0
                <i class="fas fa-arrow-left me-2"></i>Back to List
            </a>
        </div>

        <div class="alert alert-warning" role="alert">
            <h4 class="alert-heading">Warning!</h4>
            <p>Are you sure you want to delete this dealer? This action cannot be undone.</p>
            <hr>
            <p class="mb-0">
                This dealer has <strong>@(Model.Customers?.Count ?? 0) customers</strong> and 
                <strong>@(Model.Properties?.Count ?? 0) properties</strong> associated with it.
                Deleting this dealer may affect these relationships.
            </p>
        </div>

        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">Dealer Information</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <dl class="row">
                            <dt class="col-sm-4">Dealer ID:</dt>
                            <dd class="col-sm-8">
                                <span class="badge bg-secondary">@Model.DealerID</span>
                            </dd>

                            <dt class="col-sm-4">Dealership Name:</dt>
                            <dd class="col-sm-8">
                                <strong>@Model.DealershipName</strong>
                            </dd>

                            <dt class="col-sm-4">Owner Name:</dt>
                            <dd class="col-sm-8">@Model.OwnerName</dd>

                            <dt class="col-sm-4">Status:</dt>
                            <dd class="col-sm-8">
                                <span class="badge @(Model.Status == "Active" ? "bg-success" : Model.Status == "Inactive" ? "bg-secondary" : "bg-warning")">
                                    @Model.Status
                                </span>
                            </dd>
                        </dl>
                    </div>
                    <div class="col-md-6">
                        <dl class="row">
                            <dt class="col-sm-4">Registration Date:</dt>
                            <dd class="col-sm-8">@Model.RegisterationDate.ToString("MMM dd, yyyy")</dd>

                            <dt class="col-sm-4">Membership Type:</dt>
                            <dd class="col-sm-8">
                                <span class="badge bg-info">@Model.MembershipType</span>
                            </dd>

                            <dt class="col-sm-4">Mobile No:</dt>
                            <dd class="col-sm-8">@Model.MobileNo</dd>

                            <dt class="col-sm-4">Email:</dt>
                            <dd class="col-sm-8">@Model.Email</dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>

        <form asp-action="Delete" method="post" class="mt-4">
            <input type="hidden" asp-for="DealerID" />
            <div class="d-flex justify-content-end">
                <button type="submit" class="btn btn-danger me-2">
                    <i class="fas fa-trash me-2"></i>Yes, Delete Dealer
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-times me-2"></i>Cancel
                </a>
            </div>
        </form>
    </div>
</div>

