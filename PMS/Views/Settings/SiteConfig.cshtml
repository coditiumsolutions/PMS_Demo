@model PMS.Services.SiteConfig

@{
    ViewData["Title"] = "Site Configuration";
}

<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0">
            <i class="fas fa-cog me-2"></i>Site Configuration
        </h5>
    </div>
    <div class="card-body">
        <form asp-action="SiteConfig" asp-controller="Settings" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="ProjectName" class="form-label">Project Name</label>
                    <input asp-for="ProjectName" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Tagline" class="form-label">Tagline</label>
                    <input asp-for="Tagline" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="WebsiteUrl" class="form-label">Website URL</label>
                    <input asp-for="WebsiteUrl" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Logo</label>
                    <input type="file" name="logo" class="form-control" accept="image/*" />
                    @if (!string.IsNullOrEmpty(Model.LogoPath))
                    {
                        <div class="mt-2">
                            <small class="text-muted d-block mb-1">Current Logo:</small>
                            <img src="@Url.Content(Model.LogoPath)" alt="Logo" style="max-height:60px;" />
                        </div>
                    }
                </div>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-1"></i>Save
                </button>
            </div>
        </form>
    </div>
</div>

