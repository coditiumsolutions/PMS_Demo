@{
    var reportTitle = ViewBag.ReportTitle as string ?? "Requested Report";
    var reportId = ViewBag.ReportId as string ?? string.Empty;
    var reportColumns = ViewBag.ReportColumns as List<string> ?? new List<string>();
    var reportRows = ViewBag.ReportRows as List<List<string>> ?? new List<List<string>>();
    var reportSummary = ViewBag.ReportSummary as Dictionary<string, string> ?? new Dictionary<string, string>();
    var reportDescription = ViewBag.ReportDescription as string ?? string.Empty;
    var filterX = (int?)ViewBag.FilterX ?? 2;
    var fromDate = (DateTime?)ViewBag.FromDate ?? DateTime.Today.AddDays(-30);
    var toDate = (DateTime?)ViewBag.ToDate ?? DateTime.Today;
    ViewData["Title"] = reportTitle;
    ViewData["ListingTitle"] = reportTitle;
    ViewData["ListingDescription"] = reportDescription;
    ViewData["ListingRecordCount"] = reportRows.Count;
    ViewData["ListingShowAdd"] = false;
}

@if (reportId == "defaulter-x-installments")
{
    <form method="get" asp-action="RequestedReport" class="mb-4 pms-listing-page">
        <input type="hidden" name="id" value="@reportId" />
        <input type="hidden" name="title" value="@reportTitle" />
        <div class="pms-listing-search-wrap">
            <div class="row g-2 align-items-end flex-lg-nowrap">
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="pms-compact-field">
                        <label for="filterX" class="form-label">Defaulter Threshold (X Installments)</label>
                        <input type="number" class="form-control" min="1" name="x" id="filterX" value="@filterX" />
                    </div>
                </div>
                <div class="col-12 col-lg-4">
                    <div class="d-flex flex-wrap gap-2 pms-listing-search-actions">
                        <button type="submit" class="btn btn-primary btn-sm flex-grow-1">
                            <i class="bi bi-search me-1" aria-hidden="true"></i>Apply
                        </button>
                        <a asp-action="RequestedReport" asp-route-id="@reportId" asp-route-title="@reportTitle" class="btn btn-outline-secondary btn-sm flex-grow-1">
                            <i class="bi bi-arrow-counterclockwise me-1" aria-hidden="true"></i>Clear
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </form>
}

@if (reportId == "daily-transfer-report")
{
    <form method="get" asp-action="RequestedReport" class="mb-4 pms-listing-page">
        <input type="hidden" name="id" value="@reportId" />
        <input type="hidden" name="title" value="@reportTitle" />
        <div class="pms-listing-search-wrap">
            <div class="row g-2 align-items-end flex-lg-nowrap">
                <div class="col-12 col-md-6 col-lg-3">
                    <div class="pms-compact-field">
                        <label for="fromDate" class="form-label">From Date</label>
                        <input type="date" class="form-control" name="fromDate" id="fromDate" value="@fromDate.ToString("yyyy-MM-dd")" />
                    </div>
                </div>
                <div class="col-12 col-md-6 col-lg-3">
                    <div class="pms-compact-field">
                        <label for="toDate" class="form-label">To Date</label>
                        <input type="date" class="form-control" name="toDate" id="toDate" value="@toDate.ToString("yyyy-MM-dd")" />
                    </div>
                </div>
                <div class="col-12 col-lg-4">
                    <div class="d-flex flex-wrap gap-2 pms-listing-search-actions">
                        <button type="submit" class="btn btn-primary btn-sm flex-grow-1">
                            <i class="bi bi-search me-1" aria-hidden="true"></i>Apply
                        </button>
                        <a asp-action="RequestedReport" asp-route-id="@reportId" asp-route-title="@reportTitle" class="btn btn-outline-secondary btn-sm flex-grow-1">
                            <i class="bi bi-arrow-counterclockwise me-1" aria-hidden="true"></i>Clear
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </form>
}

@if (reportSummary.Any())
{
    <div class="row g-3 mb-4">
        @foreach (var item in reportSummary)
        {
            <div class="col-6 col-md-3">
                <div class="card border-0 h-100" style="background:#f8fafc; border: 1px solid #e2e8f0 !important;">
                    <div class="card-body py-3">
                        <div class="small text-muted text-uppercase fw-semibold">@item.Key</div>
                        <div class="fs-5 fw-bold">@item.Value</div>
                    </div>
                </div>
            </div>
        }
    </div>
}

<div class="card pms-grid-card pms-listing-flat pms-saas-grid pms-listing-page">
    <div class="card-body">
        <partial name="Listing/_GridToolbar" />

        @if (reportColumns.Any() && reportRows.Any())
        {
            <div class="table-responsive pms-saas-table-wrap">
                <table id="requestedReportTable" class="table pms-saas-table">
                    <thead>
                        <tr>
                            @foreach (var col in reportColumns)
                            {
                                <th>@col</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in reportRows)
                        {
                            <tr>
                                @for (var i = 0; i < reportColumns.Count; i++)
                                {
                                    var colName = reportColumns[i];
                                    var cell = i < row.Count ? row[i] : "—";
                                    <td data-label="@colName">@cell</td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-inbox fs-1 mb-3 d-block" aria-hidden="true"></i>
                <p class="mb-0">No records found for this report.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            if ($('#requestedReportTable').length) {
                $('#requestedReportTable').DataTable({
                    pageLength: 25,
                    order: []
                });
            }
        });
    </script>
}
