@model List<PMS.Controllers.BlockedCustomerReportViewModel>

@{
    ViewData["Title"] = "Blocked Customers Report";
}

<!-- Banner with purple gradient -->
<div class="custom-banner mb-4" style="margin-top: 20px;">
    <div style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%); padding: 25px 30px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.1);">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h2 class="text-white mb-1" style="font-weight: 600; text-shadow: 0 2px 4px rgba(0,0,0,0.2);">
                    <i class="fas fa-user-lock me-2"></i>Blocked Customers Report
                </h2>
                <p class="text-white mb-0" style="opacity: 0.95; font-size: 0.95rem;">
                    Customers with inactive or blocked status
                </p>
            </div>
            <div>
                <button onclick="window.print()" class="btn btn-light">
                    <i class="fas fa-print me-2"></i>Print Report
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Summary Cards -->
<div class="row mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="avatar-sm rounded-circle bg-danger bg-soft text-danger">
                            <i class="fas fa-user-lock font-size-24"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="mb-1 text-muted">Total Blocked</h6>
                        <h4 class="mb-0">@Model.Count</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="avatar-sm rounded-circle bg-warning bg-soft text-warning">
                            <i class="fas fa-ban font-size-24"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="mb-1 text-muted">Status Types</h6>
                        <h4 class="mb-0">@Model.Select(c => c.Status).Distinct().Count()</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="avatar-sm rounded-circle bg-info bg-soft text-info">
                            <i class="fas fa-calendar-alt font-size-24"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="mb-1 text-muted">Latest Block</h6>
                        <h4 class="mb-0">@(Model.Any() ? Model.Max(c => c.RegisteredDate).ToString("MMM yyyy") : "N/A")</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Status Breakdown -->
@if (Model.Any())
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header" style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);">
            <h6 class="mb-0 text-white">
                <i class="fas fa-chart-pie me-2"></i>Status Breakdown
            </h6>
        </div>
        <div class="card-body">
            <div class="row">
                @foreach (var statusGroup in Model.GroupBy(c => c.Status))
                {
                    <div class="col-md-3 mb-3">
                        <div class="d-flex align-items-center">
                            <div class="flex-shrink-0">
                                <div class="avatar-xs rounded-circle bg-danger text-white">
                                    <i class="fas fa-times"></i>
                                </div>
                            </div>
                            <div class="flex-grow-1 ms-2">
                                <h6 class="mb-0">@statusGroup.Key</h6>
                                <small class="text-muted">@statusGroup.Count() customers</small>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

<!-- Blocked Customers Table -->
<div class="card border-0 shadow-sm">
    <div class="card-header" style="background: linear-gradient(135deg, #9C6ADE 0%, #C9B3FF 100%);">
        <h5 class="mb-0 text-white">
            <i class="fas fa-list me-2"></i>Blocked Customers Details
        </h5>
    </div>
    <div class="card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table id="blockedCustomersTable" class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Customer ID</th>
                            <th>Customer Name</th>
                            <th>CNIC</th>
                            <th>Phone</th>
                            <th>Email</th>
                            <th>Payment Plan</th>
                            <th>Status</th>
                            <th>City</th>
                            <th>Country</th>
                            <th>Registered Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var customer in Model)
                        {
                            <tr>
                                <td><code>@customer.CustomerID</code></td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-xs rounded-circle bg-danger text-white me-2">
                                            <i class="fas fa-user"></i>
                                        </div>
                                        <strong>@customer.CustomerName</strong>
                                    </div>
                                </td>
                                <td>@customer.CNIC</td>
                                <td>@customer.Phone</td>
                                <td>@customer.Email</td>
                                <td>@customer.PlanName</td>
                                <td>
                                    <span class="badge bg-danger">
                                        <i class="fas fa-ban me-1"></i>@customer.Status
                                    </span>
                                </td>
                                <td>@customer.City</td>
                                <td>@customer.Country</td>
                                <td>
                                    <i class="fas fa-calendar-alt text-muted me-1"></i>
                                    @customer.RegisteredDate.ToString("MMM dd, yyyy")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-check-circle fa-4x mb-3 text-success"></i>
                <h5 class="text-success">No Blocked Customers!</h5>
                <p class="text-muted">All customers are active in the system.</p>
            </div>
        }
    </div>
</div>

<style>
    .avatar-sm {
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .avatar-xs {
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
    }

    .bg-soft {
        background-color: rgba(var(--bs-primary-rgb), 0.1) !important;
    }

    .bg-danger.bg-soft {
        background-color: rgba(220, 53, 69, 0.1) !important;
    }

    .bg-warning.bg-soft {
        background-color: rgba(255, 193, 7, 0.1) !important;
    }

    .bg-info.bg-soft {
        background-color: rgba(13, 202, 240, 0.1) !important;
    }

    .font-size-24 {
        font-size: 24px;
    }

    code {
        background: rgba(156, 106, 222, 0.1);
        color: #9C6ADE;
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
    }

    @@media print {
        .custom-banner button,
        .sidebar,
        .btn {
            display: none !important;
        }
    }
</style>

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/dataTables.bootstrap5.min.js"></script>
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/dataTables.bootstrap5.min.css" />

    <script>
        $(document).ready(function () {
            $('#blockedCustomersTable').DataTable({
                "order": [[9, "desc"]], // Sort by registered date descending
                "pageLength": 25,
                "language": {
                    "search": "Search customers:",
                    "lengthMenu": "Show _MENU_ records per page",
                    "info": "Showing _START_ to _END_ of _TOTAL_ customers",
                    "infoEmpty": "No blocked customers found",
                    "infoFiltered": "(filtered from _MAX_ total records)"
                }
            });
        });
    </script>
}

