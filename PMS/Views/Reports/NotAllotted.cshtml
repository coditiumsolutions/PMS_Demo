@model List<PMS.Controllers.NotAllottedReportViewModel>

@{
    ViewData["Title"] = "Not Allotted Report";
    var filter = ViewBag.Filter as string ?? "All";
}

<!-- Banner with purple gradient -->
<div class="custom-banner mb-4" style="margin-top: 20px;">
    <div style="background: linear-gradient(135deg, #9C6ADE 0%, #E879F9 100%); padding: 25px 30px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.1);">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h2 class="text-white mb-1" style="font-weight: 600; text-shadow: 0 2px 4px rgba(0,0,0,0.2);">
                    <i class="fas fa-user-clock me-2"></i>Not Allotted Customers Report
                </h2>
                <p class="text-white mb-0" style="opacity: 0.95; font-size: 0.95rem;">
                    Customers registered but not yet allotted properties
                </p>
            </div>
            <div>
                <button onclick="window.print()" class="btn btn-light">
                    <i class="fas fa-print me-2"></i>Print Report
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Filter Buttons -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="d-flex align-items-center gap-2">
            <label class="fw-bold me-2">Filter by Payment Status:</label>
            <a asp-action="NotAllotted" asp-route-filter="All" 
               class="btn @(filter == "All" ? "btn-primary" : "btn-outline-primary")">
                <i class="fas fa-list me-1"></i>All
            </a>
            <a asp-action="NotAllotted" asp-route-filter="FullyPaid" 
               class="btn @(filter == "FullyPaid" ? "btn-success" : "btn-outline-success")">
                <i class="fas fa-check-circle me-1"></i>Fully Paid
            </a>
            <a asp-action="NotAllotted" asp-route-filter="Defaulters" 
               class="btn @(filter == "Defaulters" ? "btn-danger" : "btn-outline-danger")">
                <i class="fas fa-exclamation-triangle me-1"></i>Defaulters
            </a>
        </div>
    </div>
</div>

<!-- Summary Cards -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="avatar-sm rounded-circle bg-warning bg-soft text-warning">
                            <i class="fas fa-user-clock font-size-24"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="mb-1 text-muted">Not Allotted</h6>
                        <h4 class="mb-0">@Model.Count</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="avatar-sm rounded-circle bg-success bg-soft text-success">
                            <i class="fas fa-check-double font-size-24"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="mb-1 text-muted">Fully Paid</h6>
                        <h4 class="mb-0">@Model.Count(c => c.PaymentStatus == "Fully Paid")</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="avatar-sm rounded-circle bg-danger bg-soft text-danger">
                            <i class="fas fa-exclamation-triangle font-size-24"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="mb-1 text-muted">Defaulters</h6>
                        <h4 class="mb-0">@Model.Count(c => c.PaymentStatus == "Defaulter")</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="avatar-sm rounded-circle bg-info bg-soft text-info">
                            <i class="fas fa-coins font-size-24"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="mb-1 text-muted">Total Balance (SSP)</h6>
                        <h4 class="mb-0" data-format-number="@Model.Sum(c => c.Balance)">@Model.Sum(c => c.Balance).ToString("N0")</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Not Allotted Table -->
<div class="card border-0 shadow-sm">
    <div class="card-header" style="background: linear-gradient(135deg, #9C6ADE 0%, #C9B3FF 100%);">
        <h5 class="mb-0 text-white">
            <i class="fas fa-list me-2"></i>Not Allotted Customers (@filter)
        </h5>
    </div>
    <div class="card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table id="notAllottedTable" class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Customer ID</th>
                            <th>Customer Name</th>
                            <th>CNIC</th>
                            <th>Phone</th>
                            <th>Email</th>
                            <th>Payment Plan</th>
                            <th>Total Amount</th>
                            <th>Paid</th>
                            <th>Balance</th>
                            <th>Payment Status</th>
                            <th>Registered Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var customer in Model)
                        {
                            <tr>
                                <td><code>@customer.CustomerID</code></td>
                                <td><strong>@customer.CustomerName</strong></td>
                                <td>@customer.CNIC</td>
                                <td>@customer.Phone</td>
                                <td>@customer.Email</td>
                                <td>@customer.PlanName</td>
                                <td><strong><span data-format-number="@customer.TotalAmount">@customer.TotalAmount.ToString("N0")</span> SSP</strong></td>
                                <td><span class="text-success"><span data-format-number="@customer.TotalPaid">@customer.TotalPaid.ToString("N0")</span> SSP</span></td>
                                <td>
                                    @if (customer.Balance > 0)
                                    {
                                        <span class="text-danger fw-bold"><span data-format-number="@customer.Balance">@customer.Balance.ToString("N0")</span> SSP</span>
                                    }
                                    else
                                    {
                                        <span class="text-success fw-bold">0 SSP</span>
                                    }
                                </td>
                                <td>
                                    @if (customer.PaymentStatus == "Fully Paid")
                                    {
                                        <span class="badge bg-success">@customer.PaymentStatus</span>
                                    }
                                    else if (customer.PaymentStatus == "Partial")
                                    {
                                        <span class="badge bg-warning">@customer.PaymentStatus</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">@customer.PaymentStatus</span>
                                    }
                                </td>
                                <td>
                                    <i class="fas fa-calendar-alt text-muted me-1"></i>
                                    @customer.RegisteredDate.ToString("MMM dd, yyyy")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-check-circle fa-4x mb-3 text-success"></i>
                <h5 class="text-success">No Records Found!</h5>
                <p class="text-muted">All customers matching this filter have been allotted properties.</p>
            </div>
        }
    </div>
</div>

<style>
    .avatar-sm {
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .bg-soft {
        background-color: rgba(var(--bs-primary-rgb), 0.1) !important;
    }

    .bg-success.bg-soft {
        background-color: rgba(25, 135, 84, 0.1) !important;
    }

    .bg-danger.bg-soft {
        background-color: rgba(220, 53, 69, 0.1) !important;
    }

    .bg-warning.bg-soft {
        background-color: rgba(255, 193, 7, 0.1) !important;
    }

    .bg-info.bg-soft {
        background-color: rgba(13, 202, 240, 0.1) !important;
    }

    .font-size-24 {
        font-size: 24px;
    }

    code {
        background: rgba(156, 106, 222, 0.1);
        color: #9C6ADE;
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
    }

    @@media print {
        .custom-banner button,
        .sidebar,
        .btn,
        .card:first-child {
            display: none !important;
        }
    }
</style>

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/dataTables.bootstrap5.min.js"></script>
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/dataTables.bootstrap5.min.css" />

    <script>
        $(document).ready(function () {
            $('#notAllottedTable').DataTable({
                "order": [[10, "desc"]], // Sort by registered date descending
                "pageLength": 25,
                "language": {
                    "search": "Search customers:",
                    "lengthMenu": "Show _MENU_ records per page",
                    "info": "Showing _START_ to _END_ of _TOTAL_ customers",
                    "infoEmpty": "No customers found",
                    "infoFiltered": "(filtered from _MAX_ total records)"
                }
            });
        });
    </script>
}

