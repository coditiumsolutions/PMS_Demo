@model PMS.Models.AccountsReceivablesThisMonthViewModel

@{
    ViewData["Title"] = "Receivables This Month";
    var monthName = new DateTime(Model.Year, Model.Month, 1).ToString("MMMM yyyy");
}

<div class="custom-banner mb-4" style="margin-top: 20px;">
    <div style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%); padding: 20px 26px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.1);">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h2 class="text-white mb-1" style="font-weight: 600;">
                    <i class="fas fa-calendar-check me-2"></i>Receivables This Month
                </h2>
                <p class="text-white mb-0" style="opacity: 0.95;">@monthName</p>
            </div>
            <div class="text-white text-end">
                <div class="small" style="opacity:0.9;">Outstanding</div>
                <div class="fw-bold fs-4">@Model.TotalOutstanding.ToString("N0")</div>
            </div>
        </div>
    </div>
</div>

<partial name="_Nav" />

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h6 class="text-muted mb-1">Total Due</h6>
                <h4 class="mb-0">@Model.TotalDue.ToString("N0")</h4>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h6 class="text-muted mb-1">Total Paid</h6>
                <h4 class="mb-0">@Model.TotalPaid.ToString("N0")</h4>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h6 class="text-muted mb-1">Total Outstanding</h6>
                <h4 class="mb-0">@Model.TotalOutstanding.ToString("N0")</h4>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header" style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);">
        <h5 class="mb-0 text-white"><i class="fas fa-list me-2"></i>Outstanding Schedules</h5>
    </div>
    <div class="card-body">
        @if (Model.Items.Any())
        {
            <div class="table-responsive">
                <table id="receivablesTable" class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Customer</th>
                            <th>Project / Plan</th>
                            <th>Installment</th>
                            <th>Due Date</th>
                            <th class="text-end">Due</th>
                            <th class="text-end">Paid</th>
                            <th class="text-end">Outstanding</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var x in Model.Items)
                        {
                            <tr>
                                <td>
                                    <strong>@(x.CustomerName ?? "—")</strong><br />
                                    <small class="text-muted"><code>@(x.CustomerID ?? "—")</code></small>
                                </td>
                                <td>
                                    <div><span class="badge bg-info">@(x.ProjectName ?? "—")</span></div>
                                    <div class="text-muted small">@(x.PlanName ?? "—")</div>
                                </td>
                                <td>
                                    <span class="badge bg-secondary">
                                        #@(x.InstallmentNo?.ToString() ?? "—")
                                    </span>
                                    <div class="text-muted small">@(x.PaymentDescription ?? "—")</div>
                                </td>
                                <td>@x.DueDate.ToString("MMM dd, yyyy")</td>
                                <td class="text-end">@x.AmountDue.ToString("N0")</td>
                                <td class="text-end">@x.AmountPaid.ToString("N0")</td>
                                <td class="text-end"><strong>@x.Outstanding.ToString("N0")</strong></td>
                                <td>
                                    @if (x.IsOverdue)
                                    {
                                        <span class="badge bg-danger">Overdue (@x.DaysPastDue d)</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Due</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-calendar-check fa-4x mb-3 text-muted"></i>
                <h5 class="text-muted">No Outstanding Receivables This Month</h5>
                <p class="text-muted mb-0">All schedules due this month are fully paid.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#receivablesTable').DataTable({
                order: [[6, 'desc']],
                pageLength: 25
            });
        });
    </script>
}

