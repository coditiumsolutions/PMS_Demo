@model PMS.Models.AccountsBankWiseCollectionsViewModel

@{
    ViewData["Title"] = "Bank-wise Collections";
}

<div class="custom-banner mb-4" style="margin-top: 20px;">
    <div style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%); padding: 20px 26px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.1);">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h2 class="text-white mb-1" style="font-weight: 600;">
                    <i class="fas fa-university me-2"></i>Bank-wise Collections
                </h2>
                <p class="text-white mb-0" style="opacity: 0.95;">
                    Date range: @Model.FromDate.ToString("MMM dd, yyyy") to @Model.ToDate.ToString("MMM dd, yyyy")
                </p>
            </div>
            <div class="text-white">
                <div class="small" style="opacity:0.9;">Total Bank Transfer</div>
                <div class="fw-bold fs-4">@Model.TotalBankTransfer.ToString("N0")</div>
            </div>
        </div>
    </div>
</div>

<partial name="_Nav" />

<form method="get" class="mb-3">
    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label fw-bold">From</label>
                    <input type="date" name="fromDate" class="form-control" value="@Model.FromDate.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">To</label>
                    <input type="date" name="toDate" class="form-control" value="@Model.ToDate.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-filter me-2"></i>Apply
                    </button>
                    <a class="btn btn-outline-secondary ms-1" asp-action="BankWiseCollections">
                        <i class="fas fa-times me-2"></i>Reset
                    </a>
                </div>
            </div>
            <div class="text-muted small mt-2">
                Note: “Bank” is inferred from payment Reference/Remarks for payments recorded as <strong>Bank Transfer</strong>.
            </div>
        </div>
    </div>
</form>

<div class="card border-0 shadow-sm">
    <div class="card-header" style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);">
        <h5 class="mb-0 text-white"><i class="fas fa-list me-2"></i>Bank Summary</h5>
    </div>
    <div class="card-body">
        @if (Model.Banks.Any())
        {
            <div class="table-responsive">
                <table id="banksTable" class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Bank (inferred)</th>
                            <th class="text-end">Count</th>
                            <th class="text-end">Total Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var b in Model.Banks)
                        {
                            <tr>
                                <td><span class="badge bg-info">@b.Bank</span></td>
                                <td class="text-end">@b.Count</td>
                                <td class="text-end"><strong>@b.TotalAmount.ToString("N0")</strong></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-university fa-4x mb-3 text-muted"></i>
                <h5 class="text-muted">No Bank Transfer Payments Found</h5>
                <p class="text-muted mb-0">Try expanding the date range.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#banksTable').DataTable({
                order: [[2, 'desc']],
                pageLength: 25
            });
        });
    </script>
}

