@model PMS.Models.AccountsDashboardViewModel

@{
    ViewData["Title"] = "Accounts Management";
}

<div class="custom-banner mb-4" style="margin-top: 20px;">
    <div style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%); padding: 25px 30px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.1);">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h2 class="text-white mb-1" style="font-weight: 600;">
                    <i class="fas fa-calculator me-2"></i>Accounts Management
                </h2>
                <p class="text-white mb-0" style="opacity: 0.95;">
                    Collections & receivables overview (From @Model.PeriodStart.ToString("MMM dd, yyyy") to @Model.PeriodEnd.ToString("MMM dd, yyyy"))
                </p>
            </div>
        </div>
    </div>
</div>

<p class="small text-muted mb-2">
    <a class="btn btn-sm btn-outline-primary" asp-controller="AmsCoa" asp-action="Index"><i class="fas fa-book me-1"></i>Open full accounting</a>
    <span class="ms-2">Chart of accounts, vouchers, ledger, AR/AP, tax, and reconciliation — same access as this page.</span>
</p>

<partial name="_Nav" />

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="avatar-sm rounded-circle bg-success bg-soft text-success">
                            <i class="fas fa-coins font-size-24"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="mb-1 text-muted">Collected Today</h6>
                        <h4 class="mb-0">@Model.TotalCollectedToday.ToString("N0")</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="avatar-sm rounded-circle bg-primary bg-soft text-primary">
                            <i class="fas fa-money-bill-wave font-size-24"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="mb-1 text-muted">Collected This Month</h6>
                        <h4 class="mb-0">@Model.TotalCollectedThisMonth.ToString("N0")</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="avatar-sm rounded-circle bg-warning bg-soft text-warning">
                            <i class="fas fa-calendar-check font-size-24"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="mb-1 text-muted">Receivable This Month</h6>
                        <h4 class="mb-0">@Model.TotalReceivableThisMonth.ToString("N0")</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="avatar-sm rounded-circle bg-danger bg-soft text-danger">
                            <i class="fas fa-exclamation-triangle font-size-24"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="mb-1 text-muted">Overdue Outstanding</h6>
                        <h4 class="mb-0">@Model.TotalOverdueReceivable.ToString("N0")</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header" style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);">
                <h5 class="mb-0 text-white"><i class="fas fa-layer-group me-2"></i>Collections by Method (This Month)</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Method</th>
                                <th class="text-end">Count</th>
                                <th class="text-end">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var m in Model.CollectionsByMethodThisMonth)
                            {
                                <tr>
                                    <td><span class="badge bg-secondary">@m.Method</span></td>
                                    <td class="text-end">@m.Count</td>
                                    <td class="text-end"><strong>@m.TotalAmount.ToString("N0")</strong></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="mt-3">
                    <a class="btn btn-sm btn-outline-primary" asp-action="BankWiseCollections">
                        <i class="fas fa-university me-1"></i>Open Bank-wise Report
                    </a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header" style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);">
                <h5 class="mb-0 text-white"><i class="fas fa-university me-2"></i>Bank-wise Collections (Top)</h5>
            </div>
            <div class="card-body">
                @if (Model.BankWiseCollectionsThisMonth.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Bank (inferred)</th>
                                    <th class="text-end">Count</th>
                                    <th class="text-end">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var b in Model.BankWiseCollectionsThisMonth)
                                {
                                    <tr>
                                        <td><span class="badge bg-info">@b.Bank</span></td>
                                        <td class="text-end">@b.Count</td>
                                        <td class="text-end"><strong>@b.TotalAmount.ToString("N0")</strong></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="text-muted small mt-2">
                        Bank name is inferred from payment reference/remarks for “Bank Transfer” payments.
                    </div>
                }
                else
                {
                    <div class="text-center py-4 text-muted">
                        <i class="fas fa-university fa-3x mb-2"></i>
                        <div>No bank transfer payments found for this month.</div>
                    </div>
                }
                <div class="mt-3">
                    <a class="btn btn-sm btn-outline-primary" asp-action="ReceivablesThisMonth">
                        <i class="fas fa-calendar-check me-1"></i>Open Receivables This Month
                    </a>
                    <a class="btn btn-sm btn-outline-danger ms-1" asp-action="OverdueAging">
                        <i class="fas fa-hourglass-half me-1"></i>Open Overdue Aging
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .avatar-sm {
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .font-size-24 { font-size: 24px; }
    .bg-soft { background-color: rgba(var(--bs-primary-rgb), 0.1) !important; }
</style>

