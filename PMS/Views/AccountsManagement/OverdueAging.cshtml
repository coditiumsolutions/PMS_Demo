@model PMS.Models.AccountsOverdueAgingViewModel

@{
    ViewData["Title"] = "Overdue Aging";
}

<div class="custom-banner mb-4" style="margin-top: 20px;">
    <div style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%); padding: 20px 26px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.1);">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h2 class="text-white mb-1" style="font-weight: 600;">
                    <i class="fas fa-hourglass-half me-2"></i>Overdue Aging
                </h2>
                <p class="text-white mb-0" style="opacity: 0.95;">As of @Model.AsOfDate.ToString("MMM dd, yyyy")</p>
            </div>
            <div class="text-white text-end">
                <div class="small" style="opacity:0.9;">Total Overdue Outstanding</div>
                <div class="fw-bold fs-4">@Model.TotalOutstanding.ToString("N0")</div>
            </div>
        </div>
    </div>
</div>

<partial name="_Nav" />

<div class="row mb-4">
    @foreach (var b in Model.Buckets)
    {
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h6 class="text-muted mb-1">Bucket @b.Bucket</h6>
                    <div class="d-flex justify-content-between">
                        <div class="fw-bold">@b.TotalOutstanding.ToString("N0")</div>
                        <div class="text-muted small">@b.Count items</div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header" style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);">
        <h5 class="mb-0 text-white"><i class="fas fa-list me-2"></i>Top Overdue Items</h5>
    </div>
    <div class="card-body">
        @if (Model.TopOverdueItems.Any())
        {
            <div class="table-responsive">
                <table id="overdueTable" class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Customer</th>
                            <th>Project / Plan</th>
                            <th>Installment</th>
                            <th>Due Date</th>
                            <th class="text-end">Outstanding</th>
                            <th class="text-end">Days Past Due</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var x in Model.TopOverdueItems)
                        {
                            <tr>
                                <td>
                                    <strong>@(x.CustomerName ?? "—")</strong><br />
                                    <small class="text-muted"><code>@(x.CustomerID ?? "—")</code></small>
                                </td>
                                <td>
                                    <div><span class="badge bg-info">@(x.ProjectName ?? "—")</span></div>
                                    <div class="text-muted small">@(x.PlanName ?? "—")</div>
                                </td>
                                <td>
                                    <span class="badge bg-secondary">
                                        #@(x.InstallmentNo?.ToString() ?? "—")
                                    </span>
                                    <div class="text-muted small">@(x.PaymentDescription ?? "—")</div>
                                </td>
                                <td>@x.DueDate.ToString("MMM dd, yyyy")</td>
                                <td class="text-end"><strong>@x.Outstanding.ToString("N0")</strong></td>
                                <td class="text-end"><span class="badge bg-danger">@x.DaysPastDue</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-hourglass-half fa-4x mb-3 text-muted"></i>
                <h5 class="text-muted">No Overdue Items</h5>
                <p class="text-muted mb-0">There are no unpaid schedules past their due date.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#overdueTable').DataTable({
                order: [[4, 'desc']],
                pageLength: 25
            });
        });
    </script>
}

