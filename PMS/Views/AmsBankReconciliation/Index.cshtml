@model List<AccBankReconciliation>
@{
    ViewData["Title"] = "Bank reconciliations";
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success py-2">@TempData["Success"]</div>
}
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <partial name="_AmsExportCsv" model="@("BankReconciliations")" />

    <p class="mb-0 text-muted small">Bank reconciliations: <code>acc.BankReconciliation</code> and lines (voucher line or cheque link).</p>
    @if (ViewBag.CanCreate == true)
    {
        <a class="btn btn-primary btn-sm" asp-action="Create"><i class="fas fa-plus me-1"></i>New reconciliation</a>
    }
</div>
<div class="table-responsive">
    <table class="table table-sm table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Bank</th>
                <th>Period</th>
                <th>Statement</th>
                <th class="text-end">Stmt bal.</th>
                <th class="text-end">Book bal.</th>
                <th class="text-end">Diff.</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model)
            {
                <tr>
                    <td>@(r.BankAccount?.BankName)</td>
                    <td class="small">@(r.Period?.PeriodName)</td>
                    <td>@r.StatementDate.ToString("yyyy-MM-dd")</td>
                    <td class="text-end">@r.BankStatementBalance.ToString("N2")</td>
                    <td class="text-end">@r.BookBalance.ToString("N2")</td>
                    <td class="text-end">@r.Difference.ToString("N2")</td>
                    <td>@r.Status</td>
                    <td>
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@r.ReconciliationID">Lines</a>
                        @if (ViewBag.CanEdit == true)
                        {
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@r.ReconciliationID">Edit</a>
                        }
                        @if (ViewBag.CanDelete == true)
                        {
                            ViewData["AmsDeleteEntity"] = "bankreconciliation";
                            ViewData["AmsDeleteId"] = r.ReconciliationID;
                            <partial name="_AmsDeleteButton" />
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
@if (!Model.Any())
{
    <p class="text-muted">No bank reconciliations yet.</p>
}
