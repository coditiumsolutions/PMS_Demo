@model PMS.Models.User

@{
    ViewData["Title"] = "Edit User";
}

<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>
                <i class="fas fa-user-edit me-2"></i>Edit User
            </h2>
            <a asp-action="Users" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Back to Users
            </a>
        </div>

        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="fas fa-user-circle me-2"></i>User Information
                </h5>
            </div>
            <div class="card-body">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="fas fa-exclamation-circle me-2"></i>
                        @ViewBag.Error
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                <form asp-action="EditUser" method="post">
                    <input type="hidden" asp-for="UserID" />
                    <input type="hidden" asp-for="PasswordHash" />
                    <input type="hidden" asp-for="CreatedAt" />

                    <div class="row">
                        <!-- Personal Information -->
                        <div class="col-md-6">
                            <h6 class="text-primary mb-3">
                                <i class="fas fa-info-circle me-2"></i>Personal Information
                            </h6>

                            <div class="mb-3">
                                <label class="form-label">User ID</label>
                                <input type="text" class="form-control" value="@Model.UserID" disabled />
                                <small class="text-muted">User ID cannot be changed</small>
                            </div>

                            <div class="mb-3">
                                <label asp-for="FullName" class="form-label">Full Name *</label>
                                <input asp-for="FullName" class="form-control" placeholder="Enter full name" required />
                                <span asp-validation-for="FullName" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Email" class="form-label">Email Address *</label>
                                <input asp-for="Email" type="email" class="form-control" placeholder="user@example.com" required />
                                <span asp-validation-for="Email" class="text-danger"></span>
                                <small class="text-muted">This is used for login</small>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Designation" class="form-label">Designation</label>
                                <select asp-for="Designation" class="form-select">
                                    <option value="">Select designation</option>
                                    @if (ViewBag.Designations != null)
                                    {
                                        var designations = (IEnumerable<string>)ViewBag.Designations;
                                        var currentDesignation = Model.Designation;
                                        if (!string.IsNullOrEmpty(currentDesignation) && !designations.Contains(currentDesignation))
                                        {
                                            <option value="@currentDesignation" selected>@currentDesignation</option>
                                        }
                                        @foreach (var d in designations)
                                        {
                                            <option value="@d">@d</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="mb-3">
                                <label asp-for="Department" class="form-label">Department</label>
                                <select asp-for="Department" class="form-select">
                                    <option value="">Select department</option>
                                    @if (ViewBag.Departments != null)
                                    {
                                        var departments = (IEnumerable<string>)ViewBag.Departments;
                                        var currentDepartment = Model.Department;
                                        if (!string.IsNullOrEmpty(currentDepartment) && !departments.Contains(currentDepartment))
                                        {
                                            <option value="@currentDepartment" selected>@currentDepartment</option>
                                        }
                                        @foreach (var d in departments)
                                        {
                                            <option value="@d">@d</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="mb-3">
                                <label asp-for="UserType" class="form-label">User Type</label>
                                <select asp-for="UserType" class="form-select">
                                    <option value="">Select type</option>
                                    <option value="Admin">Admin</option>
                                    <option value="Manager">Manager</option>
                                    <option value="CRO">CRO</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Created Date</label>
                                <input type="text" class="form-control" value="@Model.CreatedAt.ToString("MMMM dd, yyyy hh:mm tt")" disabled />
                            </div>
                        </div>

                        <!-- Role & Status -->
                        <div class="col-md-6">
                            <h6 class="text-primary mb-3">
                                <i class="fas fa-shield-alt me-2"></i>Role & Status
                            </h6>

                            <div class="mb-3">
                                <label asp-for="RoleID" class="form-label">User Role *</label>
                                <select asp-for="RoleID" class="form-select" required id="roleSelect">
                                    <option value="">Select Role</option>
                                    @if (ViewBag.Roles != null)
                                    {
                                        @foreach (var role in ViewBag.Roles)
                                        {
                                            <option value="@role.RoleID" data-permissions="@role.Permissions">
                                                @role.RoleName
                                            </option>
                                        }
                                    }
                                </select>
                                <span asp-validation-for="RoleID" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Role Permissions</label>
                                <style>
                                    .permission-tag { font-weight: 500; }
                                    .permission-tag .fas { color: inherit; }
                                </style>
                                <div id="permissionsDisplay" class="p-3 bg-light rounded" style="min-height: 100px;">
                                    @if (!string.IsNullOrEmpty(Model.Role?.Permissions))
                                    {
                                        <div class="d-flex flex-wrap gap-2 align-items-center">
                                            @foreach (var permission in Model.Role.Permissions.Split(','))
                                            {
                                                var p = permission.Trim();
                                                if (string.IsNullOrEmpty(p)) { continue; }
                                                <span class="badge rounded-pill bg-primary text-white px-3 py-2 d-inline-flex align-items-center gap-2 permission-tag">
                                                    <i class="fas fa-check" aria-hidden="true"></i>
                                                    <span>@p</span>
                                                </span>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <small class="text-muted">Select a role to view permissions</small>
                                    }
                                </div>
                            </div>

                            <div class="mb-3">
                                <div class="form-check form-switch">
                                    <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                                    <label asp-for="IsActive" class="form-check-label">
                                        Active User
                                        <small class="text-muted d-block">Inactive users cannot login</small>
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <hr>
                    <h6 class="text-primary mb-3">
                        <i class="fas fa-lock me-2"></i>Module rights
                    </h6>
                    <p class="text-muted small">No Access = no access; Read = view only; Author = write/create only (cannot edit existing); Edit = Create + Edit + Read; Admin = full CRUD. These will be applied per module later.</p>
                    <div class="table-responsive mb-3">
                        <table class="table table-sm table-bordered">
                            <thead class="table-light">
                                <tr>
                                    <th>Module</th>
                                    <th>Permission</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (ViewBag.ModuleKeys != null)
                                {
                                    var perms = ViewBag.ModulePermissions as Dictionary<string, string> ?? new Dictionary<string, string>();
                                    @foreach (var key in (string[])ViewBag.ModuleKeys)
                                    {
                                        var current = perms.TryGetValue(key, out var p) ? p : "NoAccess";
                                        <tr>
                                            <td>@key</td>
                                            <td>
                                                <select name="ModulePermissions_@key" class="form-select form-select-sm">
                                                    @{
                                                        var permissionOptions = new List<string>();
                                                        if (ViewBag.PermissionOptions != null)
                                                        {
                                                            permissionOptions.AddRange((string[])ViewBag.PermissionOptions);
                                                        }

                                                        if (!permissionOptions.Contains("Author"))
                                                        {
                                                            permissionOptions.Add("Author");
                                                        }
                                                    }
                                                    @foreach (var opt in permissionOptions)
                                                    {
                                                        <option value="@opt" selected="@(opt == current)">@opt</option>
                                                    }
                                                </select>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="row">
                        <div class="col-12">
                            <div class="d-flex justify-content-end">
                                <button type="submit" class="btn btn-primary me-2">
                                    <i class="fas fa-save me-2"></i>Save Changes
                                </button>
                                <a asp-action="Users" class="btn btn-secondary">
                                    <i class="fas fa-times me-2"></i>Cancel
                                </a>
                            </div>
                        </div>
                    </div>
                </form>

                <hr>

                <div class="card mb-3 border-warning">
                    <div class="card-header bg-light">
                        <h6 class="mb-0"><i class="fas fa-key me-2"></i>Reset password</h6>
                    </div>
                    <div class="card-body">
                        @if (TempData["ResetPasswordError"] != null)
                        {
                            <div class="alert alert-danger py-2 small">@TempData["ResetPasswordError"]</div>
                        }
                        <form asp-action="ResetUserPassword" method="post" class="row g-2 align-items-end">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="userId" value="@Model.UserID" />
                            <div class="col-md-4">
                                <label class="form-label small">New password</label>
                                <input type="password" name="newPassword" class="form-control form-control-sm" placeholder="Min 6 characters" minlength="6" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small">Confirm password</label>
                                <input type="password" name="confirmPassword" class="form-control form-control-sm" placeholder="Re-enter password" minlength="6" />
                            </div>
                            <div class="col-md-4">
                                <button type="submit" class="btn btn-warning btn-sm">
                                    <i class="fas fa-key me-1"></i>Reset password
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- User Statistics -->
        <div class="card mt-3">
            <div class="card-header bg-light">
                <h6 class="mb-0">
                    <i class="fas fa-chart-bar me-2"></i>User Statistics
                </h6>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <small class="text-muted">Total Sessions</small>
                        <p class="fw-bold">@Model.UserSessions?.Count ?? 0</p>
                    </div>
                    <div class="col-md-6">
                        <small class="text-muted">Total Activities</small>
                        <p class="fw-bold">@Model.ActivityLogs?.Count ?? 0</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        $(document).ready(function() {
            // Display role permissions
            $('#roleSelect').on('change', function() {
                var selectedOption = $(this).find('option:selected');
                var permissions = selectedOption.data('permissions');
                var permissionsDiv = $('#permissionsDisplay');
                
                if (permissions) {
                    var permissionsList = permissions.split(',').map(function(p) { return p.trim(); }).filter(Boolean);
                    var html = '<div class="d-flex flex-wrap gap-2 align-items-center">';
                    permissionsList.forEach(function(permission) {
                        html += '<span class="badge rounded-pill bg-primary text-white px-3 py-2 d-inline-flex align-items-center gap-2 permission-tag">' +
                                '<i class="fas fa-check" aria-hidden="true"></i>' +
                                '<span>' + permission + '</span>' +
                                '</span>';
                    });
                    html += '</div>';
                    permissionsDiv.html(html);
                } else {
                    permissionsDiv.html('<small class="text-muted">No permissions assigned to this role</small>');
                }
            });
        });
    </script>
}

