@model IEnumerable<PMS.Models.User>

@{
    ViewData["Title"] = "User Management";
    ViewData["HidePageBanner"] = true;
    ViewData["ListingHideTitle"] = true;
    ViewData["ListingRecordCount"] = Model?.Count() ?? 0;
    ViewData["ListingAddUrl"] = Url.Action("CreateUser");
    ViewData["ListingAddText"] = "Add New User";
    ViewData["ListingExtraActions"] =
        "<a href=\"" + Url.Action("Index", "UserMac") + "\" class=\"btn btn-outline-primary btn-sm\">" +
        "<i class=\"bi bi-shield-check me-1\" aria-hidden=\"true\"></i>Manage mTLS Certificates</a>";
    var whitelistCounts = ViewBag.WhitelistCounts as Dictionary<string, int> ?? new Dictionary<string, int>();
    var blockedCounts = ViewBag.BlockedCounts as Dictionary<string, int> ?? new Dictionary<string, int>();
}

<div class="row g-2 mb-3 users-stats-compact">
    <div class="col-6 col-md-3">
        <div class="stats-card">
            <div class="stats-number">@Model.Count()</div>
            <div class="stats-label">Total Users</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stats-card">
            <div class="stats-number">@Model.Count(u => u.IsActive)</div>
            <div class="stats-label">Active Users</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stats-card">
            <div class="stats-number">@Model.Count(u => !u.IsActive)</div>
            <div class="stats-label">Inactive Users</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stats-card">
            <div class="stats-number">@Model.Select(u => u.RoleID).Distinct().Count()</div>
            <div class="stats-label">Total Roles</div>
        </div>
    </div>
</div>

<div class="card pms-grid-card pms-listing-flat pms-saas-grid pms-listing-page">
    <div class="card-body">
        <partial name="Listing/_GridToolbar" />

        <div class="table-responsive pms-saas-table-wrap">
            <table class="table pms-saas-table" id="usersTable">
                <thead>
                    <tr>
                        <th>User ID</th>
                        <th>Full Name</th>
                        <th>Email</th>
                        <th>Designation</th>
                        <th>Department</th>
                        <th>User Type</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Whitelisted Certs</th>
                        <th>Blocked Attempts</th>
                        <th>Created Date</th>
                        <th class="pms-saas-th-actions">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.OrderBy(u => u.FullName))
                    {
                        <tr>
                            <td data-label="User ID"><code>@user.UserID</code></td>
                            <td data-label="Full Name">
                                <strong class="pms-cell-truncate" title="@user.FullName">@user.FullName</strong>
                            </td>
                            <td data-label="Email"><span class="pms-cell-truncate" title="@user.Email">@user.Email</span></td>
                            <td data-label="Designation">@(user.Designation ?? "—")</td>
                            <td data-label="Department">@(user.Department ?? "—")</td>
                            <td data-label="User Type">
                                @if (!string.IsNullOrEmpty(user.UserType))
                                {
                                    <span class="pms-pill pms-pill--info">@user.UserType</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td data-label="Role">
                                @if (user.Role != null)
                                {
                                    <span class="pms-pill pms-pill--info">@user.Role.RoleName</span>
                                }
                                else
                                {
                                    <span class="text-muted">No Role</span>
                                }
                            </td>
                            <td data-label="Status">
                                @if (user.IsActive)
                                {
                                    <span class="pms-pill pms-pill--success">Active</span>
                                }
                                else
                                {
                                    <span class="pms-pill pms-pill--danger">Inactive</span>
                                }
                            </td>
                            <td data-label="Whitelisted Certs">
                                <span class="pms-pill pms-pill--success">@(whitelistCounts.ContainsKey(user.UserID) ? whitelistCounts[user.UserID] : 0)</span>
                            </td>
                            <td data-label="Blocked Attempts">
                                <span class="pms-pill pms-pill--warning">@(blockedCounts.ContainsKey(user.UserID) ? blockedCounts[user.UserID] : 0)</span>
                            </td>
                            <td data-label="Created Date">
                                <span class="text-nowrap">@user.CreatedAt.ToString("MMM dd, yyyy")</span>
                            </td>
                            <td class="pms-saas-td-actions" data-label="Actions">
                                <div class="pms-row-actions" role="group">
                                    <button type="button"
                                            class="btn btn-sm btn-outline-secondary"
                                            data-bs-toggle="modal"
                                            data-bs-target="#userModal@(user.UserID)"
                                            title="View Details">
                                        <i class="bi bi-eye" aria-hidden="true"></i>
                                    </button>
                                    <button type="button"
                                            class="btn btn-sm btn-outline-primary"
                                            onclick="editUser('@user.UserID')"
                                            title="Edit User">
                                        <i class="bi bi-pencil-square" aria-hidden="true"></i>
                                    </button>
                                    <button type="button"
                                            class="btn btn-sm @(user.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                            onclick="toggleUserStatus('@user.UserID', @user.IsActive.ToString().ToLower())"
                                            title="@(user.IsActive ? "Deactivate" : "Activate")">
                                        <i class="bi bi-@(user.IsActive ? "slash-circle" : "check-circle")" aria-hidden="true"></i>
                                    </button>
                                    <a class="btn btn-sm btn-outline-secondary"
                                       asp-controller="UserMac"
                                       asp-action="Index"
                                       asp-route-userId="@user.UserID"
                                       title="Manage mTLS certificates">
                                        <i class="bi bi-shield-check" aria-hidden="true"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>

                        <!-- User Details Modal -->
                        <div class="modal fade" id="userModal@(user.UserID)" tabindex="-1">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <div class="modal-header" style="background: linear-gradient(135deg, var(--primary-green) 0%, #0a7a38 100%);">
                                        <h5 class="modal-title text-white">
                                            <i class="fas fa-user-circle me-2"></i>User Details
                                        </h5>
                                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                    </div>
                                    <div class="modal-body">
                                        <div class="text-center mb-4">
                                            <i class="fas fa-user-circle fa-5x" style="color: var(--primary-green);"></i>
                                        </div>
                                        <div class="row">
                                            <div class="col-12 mb-3">
                                                <label class="text-muted small">User ID</label>
                                                <p><code>@user.UserID</code></p>
                                            </div>
                                            <div class="col-12 mb-3">
                                                <label class="text-muted small">Full Name</label>
                                                <p class="fw-bold">@user.FullName</p>
                                            </div>
                                            <div class="col-12 mb-3">
                                                <label class="text-muted small">Email Address</label>
                                                <p>@user.Email</p>
                                            </div>
                                            <div class="col-6 mb-3">
                                                <label class="text-muted small">Designation</label>
                                                <p>@(user.Designation ?? "—")</p>
                                            </div>
                                            <div class="col-6 mb-3">
                                                <label class="text-muted small">Department</label>
                                                <p>@(user.Department ?? "—")</p>
                                            </div>
                                            <div class="col-6 mb-3">
                                                <label class="text-muted small">User Type</label>
                                                <p>@(user.UserType ?? "—")</p>
                                            </div>
                                            <div class="col-6 mb-3">
                                                <label class="text-muted small">Role</label>
                                                <p>@(user.Role?.RoleName ?? "N/A")</p>
                                            </div>
                                            <div class="col-6 mb-3">
                                                <label class="text-muted small">Status</label>
                                                <p>
                                                    <span class="badge @(user.IsActive ? "bg-success" : "bg-danger")">
                                                        @(user.IsActive ? "Active" : "Inactive")
                                                    </span>
                                                </p>
                                            </div>
                                            <div class="col-12 mb-3">
                                                <label class="text-muted small">Created Date</label>
                                                <p>@user.CreatedAt.ToString("MMMM dd, yyyy hh:mm tt")</p>
                                            </div>
                                            @if (!string.IsNullOrEmpty(user.Role?.Permissions))
                                            {
                                                <div class="col-12">
                                                    <label class="text-muted small">Permissions</label>
                                                    <div class="d-flex flex-wrap gap-1">
                                                        @foreach (var permission in user.Role.Permissions.Split(','))
                                                        {
                                                            <span class="badge bg-primary">
                                                                <i class="fas fa-check me-1"></i>@permission.Trim()
                                                            </span>
                                                        }
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    code {
        background: rgba(156, 106, 222, 0.1);
        color: var(--primary);
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
    }

    .users-stats-compact .stats-card {
        background: var(--surface);
        border-radius: 10px;
        padding: 0.65rem 0.75rem;
        text-align: center;
        box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
        border: 1px solid var(--border);
        min-height: 0;
    }

    .users-stats-compact .stats-number {
        font-family: 'Inter', sans-serif;
        font-size: 1.35rem;
        font-weight: 700;
        color: var(--primary-light);
        margin-bottom: 0.15rem;
        line-height: 1.2;
    }

    .users-stats-compact .stats-label {
        font-size: 10px;
        color: var(--text-secondary);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.35px;
        margin: 0;
        line-height: 1.2;
    }

    .modal-backdrop {
        display: none !important;
    }

    body.modal-open .modal-backdrop {
        display: none !important;
    }

    body.modal-open::before {
        display: none !important;
        background: transparent !important;
    }

    .modal {
        background: transparent !important;
    }

    .modal.show {
        background: transparent !important;
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#usersTable').DataTable({
                pageLength: 25,
                order: [[1, 'asc']],
                columnDefs: [{ orderable: false, targets: 11 }]
            });

            $('.modal-backdrop').remove();

            $('.modal').on('show.bs.modal', function(e) {
                $('.modal-backdrop').remove();
                var modalInstance = bootstrap.Modal.getOrCreateInstance(this, { backdrop: false });
                if (modalInstance && modalInstance._config) {
                    modalInstance._config.backdrop = false;
                }
            });

            $('.modal').on('shown.bs.modal hidden.bs.modal', function() {
                $('.modal-backdrop').remove();
            });
        });

        function editUser(userId) {
            window.location.href = '@Url.Action("EditUser", "Account")/' + userId;
        }

        function toggleUserStatus(userId, isActive) {
            var action = isActive ? 'deactivate' : 'activate';
            if (confirm('Are you sure you want to ' + action + ' this user?')) {
                $.ajax({
                    url: '@Url.Action("ToggleUserStatus", "Account")',
                    type: 'POST',
                    data: { userId: userId },
                    success: function(response) {
                        if (response.success) {
                            alert(response.message);
                            location.reload();
                        } else {
                            alert('Error: ' + response.message);
                        }
                    },
                    error: function() {
                        alert('An error occurred while updating user status.');
                    }
                });
            }
        }
    </script>
}
