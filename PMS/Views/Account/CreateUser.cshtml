@model PMS.Models.User

@{
    ViewData["Title"] = "Create New User";
}

<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <!-- <h2>
                <i class="fas fa-user-plus me-2"></i>Create New User
            </h2> -->
            <a asp-action="Users" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Back to Users
            </a>
        </div>

        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="fas fa-user-circle me-2"></i>User Information
                </h5>
            </div>
            <div class="card-body">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="fas fa-exclamation-circle me-2"></i>
                        @ViewBag.Error
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                <form asp-action="CreateUser" method="post">
                    <div class="row">
                        <!-- Personal Information -->
                        <div class="col-md-6">
                            <h6 class="text-primary mb-3">
                                <i class="fas fa-info-circle me-2"></i>Personal Information
                            </h6>

                            <div class="mb-3">
                                <label asp-for="FullName" class="form-label">Full Name *</label>
                                <input asp-for="FullName" class="form-control" placeholder="Enter full name" required />
                                <span asp-validation-for="FullName" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Email" class="form-label">Email Address *</label>
                                <input asp-for="Email" type="email" class="form-control" placeholder="user@example.com" required />
                                <span asp-validation-for="Email" class="text-danger"></span>
                                <small class="text-muted">This will be used for login</small>
                            </div>

                            <div class="mb-3">
                                <label asp-for="PasswordHash" class="form-label">Password *</label>
                                <input asp-for="PasswordHash" type="password" class="form-control" placeholder="Enter password" required minlength="6" />
                                <span asp-validation-for="PasswordHash" class="text-danger"></span>
                                <small class="text-muted">Minimum 6 characters</small>
                            </div>

                            <div class="mb-3">
                                <label for="ConfirmPassword" class="form-label">Confirm Password *</label>
                                <input type="password" id="ConfirmPassword" class="form-control" placeholder="Re-enter password" required />
                                <small id="passwordMatch" class="text-danger" style="display: none;">Passwords do not match</small>
                            </div>
                        </div>

                        <!-- Role & Status -->
                        <div class="col-md-6">
                            <h6 class="text-primary mb-3">
                                <i class="fas fa-shield-alt me-2"></i>Role & Permissions
                            </h6>

                            <div class="mb-3">
                                <label asp-for="RoleID" class="form-label">User Role *</label>
                                <select asp-for="RoleID" class="form-select" required id="roleSelect">
                                    <option value="">Select Role</option>
                                    @if (ViewBag.Roles != null)
                                    {
                                        @foreach (var role in ViewBag.Roles)
                                        {
                                            <option value="@role.RoleID" data-permissions="@role.Permissions">
                                                @role.RoleName
                                            </option>
                                        }
                                    }
                                </select>
                                <span asp-validation-for="RoleID" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Role Permissions</label>
                                <div id="permissionsDisplay" class="p-3 bg-light rounded" style="min-height: 100px;">
                                    <small class="text-muted">Select a role to view permissions</small>
                                </div>
                            </div>

                            <div class="mb-3">
                                <div class="form-check form-switch">
                                    <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                                    <label asp-for="IsActive" class="form-check-label">
                                        Active User
                                        <small class="text-muted d-block">Inactive users cannot login</small>
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <hr>

                    <div class="alert alert-info">
                        <i class="fas fa-info-circle me-2"></i>
                        <strong>Note:</strong> The user will be able to login immediately after creation using their email and password.
                    </div>

                    <div class="row">
                        <div class="col-12">
                            <div class="d-flex justify-content-end">
                                <button type="submit" class="btn btn-primary me-2" id="submitBtn">
                                    <i class="fas fa-save me-2"></i>Create User
                                </button>
                                <a asp-action="Users" class="btn btn-secondary">
                                    <i class="fas fa-times me-2"></i>Cancel
                                </a>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <!-- Password Requirements Card -->
        <div class="card mt-3">
            <div class="card-body">
                <h6 class="mb-3">
                    <i class="fas fa-lock me-2"></i>Password Requirements
                </h6>
                <ul class="list-unstyled mb-0">
                    <li class="mb-2">
                        <i class="fas fa-check-circle text-success me-2"></i>
                        Minimum 6 characters
                    </li>
                    <li class="mb-2">
                        <i class="fas fa-check-circle text-success me-2"></i>
                        Use a strong, unique password
                    </li>
                    <li>
                        <i class="fas fa-check-circle text-success me-2"></i>
                        Avoid common passwords
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        $(document).ready(function() {
            // Display role permissions
            $('#roleSelect').on('change', function() {
                var selectedOption = $(this).find('option:selected');
                var permissions = selectedOption.data('permissions');
                var permissionsDiv = $('#permissionsDisplay');
                
                if (permissions) {
                    var permissionsList = permissions.split(',');
                    var html = '<div class="d-flex flex-wrap gap-1">';
                    permissionsList.forEach(function(permission) {
                        html += '<span class="badge bg-primary">' +
                                '<i class="fas fa-check-circle me-1"></i>' + 
                                permission.trim() + 
                                '</span>';
                    });
                    html += '</div>';
                    permissionsDiv.html(html);
                } else {
                    permissionsDiv.html('<small class="text-muted">No permissions assigned to this role</small>');
                }
            });

            // Password matching validation
            function checkPasswordMatch() {
                var password = $('#PasswordHash').val();
                var confirmPassword = $('#ConfirmPassword').val();
                var submitBtn = $('#submitBtn');
                var matchMsg = $('#passwordMatch');
                
                if (confirmPassword && password !== confirmPassword) {
                    matchMsg.show();
                    submitBtn.prop('disabled', true);
                } else {
                    matchMsg.hide();
                    submitBtn.prop('disabled', false);
                }
            }

            $('#PasswordHash, #ConfirmPassword').on('keyup', checkPasswordMatch);

            // Form submission validation
            $('form').on('submit', function(e) {
                var password = $('#PasswordHash').val();
                var confirmPassword = $('#ConfirmPassword').val();
                
                if (password !== confirmPassword) {
                    e.preventDefault();
                    alert('Passwords do not match!');
                    return false;
                }
                
                if (password.length < 6) {
                    e.preventDefault();
                    alert('Password must be at least 6 characters long!');
                    return false;
                }
                
                return true;
            });
        });
    </script>
}

