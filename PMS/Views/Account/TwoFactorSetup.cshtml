@{
    Layout = null;
    ViewData["Title"] = "Set up Google Authenticator";
    var qrB64 = ViewBag.QrPngBase64 as string ?? "";
    var secret = ViewBag.ManualSecret as string ?? "";
    var issuer = ViewBag.Issuer as string ?? "PMS";
    var account = ViewBag.Account as string ?? "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
</head>
<body class="bg-light py-4">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-7">
                <div class="card shadow-sm">
                    <div class="card-body p-4">
                        <h1 class="h4 mb-3"><i class="fas fa-mobile-screen-button text-primary me-2"></i>Set up Google Authenticator</h1>
                        <p class="text-muted">Your organization requires an authenticator app. Follow these steps once.</p>

                        <ol class="small mb-4">
                            <li class="mb-2">Install <strong>Google Authenticator</strong> (or Microsoft Authenticator, Authy) on your phone.</li>
                            <li class="mb-2">Tap <strong>Add account</strong> &rarr; <strong>Scan a QR code</strong> and scan the image below.</li>
                            <li class="mb-2">If you cannot scan, choose <strong>Enter a setup key</strong> and use the issuer <code>@issuer</code>, account <code>@account</code>, type <strong>Time-based</strong>, and the secret key below.</li>
                            <li>Enter the <strong>6-digit code</strong> from the app to confirm.</li>
                        </ol>

                        @if (ViewBag.Error != null)
                        {
                            <div class="alert alert-danger">@ViewBag.Error</div>
                        }

                        <div class="row g-4 align-items-start mb-4">
                            <div class="col-md-auto text-center">
                                @if (!string.IsNullOrEmpty(qrB64))
                                {
                                    <img src="data:image/png;base64,@qrB64" alt="QR code" class="img-fluid border rounded" style="max-width:220px;" />
                                }
                            </div>
                            <div class="col-md">
                                <label class="form-label fw-semibold">Manual entry key (Base32)</label>
                                <div class="input-group">
                                    <input type="text" class="form-control font-monospace" id="manualSecret" value="@secret" readonly />
                                    <button type="button" class="btn btn-outline-secondary" onclick="navigator.clipboard.writeText(document.getElementById('manualSecret').value)">Copy</button>
                                </div>
                                <small class="text-muted">Spaces are optional when typing into the app.</small>
                            </div>
                        </div>

                        <form asp-action="TwoFactorSetup" method="post">
                            @Html.AntiForgeryToken()
                            <div class="mb-3">
                                <label class="form-label" for="code">6-digit confirmation code</label>
                                <input type="text" name="code" id="code" class="form-control form-control-lg" inputmode="numeric" maxlength="8" autocomplete="one-time-code" placeholder="000000" required />
                            </div>
                            <button type="submit" class="btn btn-success">Confirm and sign in</button>
                            <a asp-action="TwoFactorCancel" class="btn btn-link">Cancel</a>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
