@model PMS.Models.User

@{
    ViewData["Title"] = "My Profile";
    ViewData["HidePageBanner"] = true;
}

<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="card pms-profile-card">
            <div class="card-body p-3">
                <div class="pms-profile-summary d-flex flex-wrap align-items-center gap-3 mb-3">
                    <div class="pms-profile-avatar flex-shrink-0">
                        <i class="bi bi-person-circle" aria-hidden="true"></i>
                    </div>
                    <div class="flex-grow-1 min-w-0">
                        <div class="d-flex flex-wrap align-items-center gap-2">
                            <h5 class="mb-0 fw-bold">@Model.FullName</h5>
                            @if (!string.IsNullOrEmpty(Model.Role?.RoleName))
                            {
                                <span class="pms-pill pms-pill--info">@Model.Role.RoleName</span>
                            }
                            <span class="pms-pill @(Model.IsActive ? "pms-pill--success" : "pms-pill--danger")">
                                @(Model.IsActive ? "Active" : "Inactive")
                            </span>
                        </div>
                    </div>
                </div>

                <div class="row g-2">
                    <div class="col-md-6">
                        <div class="profile-field">
                            <label class="text-muted small mb-0">User ID</label>
                            <p class="fw-semibold mb-0">@Model.UserID</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="profile-field">
                            <label class="text-muted small mb-0">Email Address</label>
                            <p class="fw-semibold mb-0 text-break">@Model.Email</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="profile-field">
                            <label class="text-muted small mb-0">Role</label>
                            <p class="fw-semibold mb-0">@(Model.Role?.RoleName ?? "—")</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="profile-field">
                            <label class="text-muted small mb-0">Member Since</label>
                            <p class="fw-semibold mb-0">@Model.CreatedAt.ToString("MMMM dd, yyyy")</p>
                        </div>
                    </div>
                </div>

                <div class="pms-profile-permissions mt-3">
                    <div class="small text-muted text-uppercase fw-semibold mb-1">Role Permissions</div>
                    @if (!string.IsNullOrEmpty(Model.Role?.Permissions))
                    {
                        <div class="permissions-list">
                            @foreach (var permission in Model.Role.Permissions.Split(','))
                            {
                                <span class="pms-pill pms-pill--info me-1 mb-1">@permission.Trim()</span>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted small mb-0">No specific permissions assigned.</p>
                    }
                </div>

                <div class="d-flex flex-wrap justify-content-center gap-2 mt-3 pt-2 border-top">
                    <a href="@Url.Action("Index", "Home")" class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-arrow-left me-1" aria-hidden="true"></i>Back to Dashboard
                    </a>
                    <button type="button" class="btn btn-primary btn-sm" onclick="alert('Change password feature coming soon!')">
                        <i class="bi bi-key me-1" aria-hidden="true"></i>Change Password
                    </button>
                </div>
            </div>
        </div>

        <!-- Recent Activity Section -->
        <div class="card mt-3">
            <div class="card-header py-2">
                <h6 class="mb-0">
                    <i class="fas fa-history me-2"></i>
                    Recent Activity
                </h6>
            </div>
            <div class="card-body py-2">
                @if (Model.ActivityLogs != null && Model.ActivityLogs.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover table-sm mb-0">
                            <thead>
                                <tr>
                                    <th>Action</th>
                                    <th>Type</th>
                                    <th>Reference ID</th>
                                    <th>Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var log in Model.ActivityLogs.OrderByDescending(l => l.CreatedAt).Take(10))
                                {
                                    <tr>
                                        <td>
                                            <i class="fas fa-circle-notch me-2" style="font-size: 8px;"></i>
                                            @log.Action
                                        </td>
                                        <td>@log.RefType</td>
                                        <td><code>@log.RefID</code></td>
                                        <td class="text-muted small">@log.CreatedAt.ToString("MMM dd, yyyy hh:mm tt")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center text-muted py-3">
                        <i class="fas fa-inbox fa-2x mb-2 d-block"></i>
                        <p class="small mb-0">No recent activity to display.</p>
                    </div>
                }
            </div>
        </div>

        <!-- Active Sessions -->
        <div class="card mt-3 mb-4">
            <div class="card-header py-2">
                <h6 class="mb-0">
                    <i class="fas fa-desktop me-2"></i>
                    Active Sessions
                </h6>
            </div>
            <div class="card-body py-2">
                @if (Model.UserSessions != null && Model.UserSessions.Any(s => s.LogoutTime == null))
                {
                    <div class="table-responsive">
                        <table class="table table-hover table-sm mb-0">
                            <thead>
                                <tr>
                                    <th>Session ID</th>
                                    <th>Login Time</th>
                                    <th>IP Address</th>
                                    <th>Device</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var session in Model.UserSessions.Where(s => s.LogoutTime == null).OrderByDescending(s => s.LoginTime))
                                {
                                    <tr>
                                        <td><code>@session.SessionID</code></td>
                                        <td>@session.LoginTime.ToString("MMM dd, yyyy hh:mm tt")</td>
                                        <td>@session.IPAddress</td>
                                        <td class="small">@(session.DeviceInfo?.Length > 50 ? session.DeviceInfo.Substring(0, 50) + "..." : session.DeviceInfo)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center text-muted py-3">
                        <i class="fas fa-power-off fa-2x mb-2 d-block"></i>
                        <p class="small mb-0">No active sessions.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .pms-profile-card .pms-profile-avatar {
        font-size: 2.5rem;
        line-height: 1;
        color: var(--primary-green);
    }

    .pms-profile-card .pms-profile-avatar i {
        display: block;
    }

    .pms-profile-card .profile-field {
        padding: 0.5rem 0.65rem;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
    }

    html[data-theme="dark"] .pms-profile-card .profile-field {
        background: rgba(15, 23, 42, 0.5);
        border-color: var(--border, #334155);
    }

    .pms-profile-card .profile-field label {
        display: block;
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.35px;
        line-height: 1.2;
    }

    .pms-profile-card .profile-field p {
        font-size: 0.875rem;
        color: var(--text-primary);
        line-height: 1.3;
    }

    .pms-profile-card .permissions-list {
        display: flex;
        flex-wrap: wrap;
        gap: 0.25rem;
    }

    .pms-profile-card .pms-pill {
        font-size: 0.75rem;
        padding: 0.2rem 0.5rem;
    }

    .pms-profile-card .pms-profile-summary h5 {
        font-size: 1.1rem;
    }

    code {
        background: var(--light-green);
        color: var(--primary-green);
        padding: 2px 6px;
        border-radius: 4px;
        font-size: 11px;
    }
</style>
