@{
    ViewData["Title"] = "Login - Juba Smart City PMS";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #9C6ADE;
            --primary-light: #C9B3FF;
            --text-primary: #1E1E2D;
            --text-secondary: #6B7280;
            --surface: #FFFFFF;
        }

        body {
            background: linear-gradient(135deg, #F9F8FC 0%, #E9E4F0 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', sans-serif;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }
        .login-container {
            background: var(--surface);
            border-radius: 20px;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
            padding: 3rem;
            max-width: 450px;
            width: 100%;
            border: 1px solid rgba(156, 106, 222, 0.1);
        }
        .logo {
            text-align: center;
            margin-bottom: 2.5rem;
        }
        .logo-img {
            max-width: 180px;
            height: auto;
            margin-bottom: 1.5rem;
            filter: drop-shadow(2px 2px 8px rgba(156, 106, 222, 0.2));
            transition: transform 0.2s ease-in-out;
        }
        .logo-img:hover {
            transform: scale(1.05);
        }
        .logo h2 {
            color: var(--primary);
            font-family: 'Inter', sans-serif;
            font-weight: 700;
            font-size: 2rem;
            margin-bottom: 0.5rem;
        }
        .logo p {
            color: var(--text-secondary);
            font-size: 0.9rem;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .form-control {
            border-radius: 12px;
            border: 1px solid var(--border);
            padding: 0.875rem 1rem;
            font-size: 0.95rem;
            transition: all 0.2s ease-in-out;
            background: var(--surface);
        }
        .form-control:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(156, 106, 222, 0.1);
            background: var(--surface);
            outline: none;
        }
        .btn-login {
            background: var(--primary);
            border: none;
            border-radius: 12px;
            padding: 0.875rem 2rem;
            color: white;
            font-weight: 600;
            font-size: 1rem;
            width: 100%;
            transition: all 0.2s ease-in-out;
            box-shadow: 0 4px 12px rgba(156, 106, 222, 0.3);
        }
        .btn-login:hover {
            background: #8a5cc9;
            box-shadow: 0 6px 16px rgba(156, 106, 222, 0.4);
            color: white;
        }
        .alert-danger {
            background: rgba(239, 68, 68, 0.08);
            border: 1px solid rgba(239, 68, 68, 0.2);
            border-radius: 12px;
            color: #dc2626;
            font-weight: 500;
        }
        .form-label {
            color: var(--text-primary);
            font-weight: 600;
            margin-bottom: 0.5rem;
            font-size: 0.9rem;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="login-container">
                    <div class="logo">
                        <img src="~/images/logo.png" alt="JUBA Smart City Logo" class="logo-img" />
                       
                        <p>Property Management System</p>
                    </div>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger" role="alert">
                            @ViewBag.Error
                        </div>
                    }

                    <form method="post">
                        <div class="mb-3">
                            <label for="email" class="form-label">Email Address</label>
                            <input type="email" class="form-control" id="email" name="email" required>
                        </div>
                        <div class="mb-4">
                            <label for="password" class="form-label">Password</label>
                            <input type="password" class="form-control" id="password" name="password" required>
                        </div>
                        <button type="submit" class="btn btn-login">Sign In</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
