@model PMS.Services.SiteConfig

@{
    var projectName = string.IsNullOrWhiteSpace(Model?.ProjectName) ? "PMS" : Model.ProjectName;
    ViewData["Title"] = "Login - " + projectName;
    Layout = null;
    var website = Model?.WebsiteUrl;
    var email = Model?.Email;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="icon" href="~/favicon.ico" type="image/x-icon" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/property-management-theme.css" asp-append-version="true" />
</head>
<body class="pms-login-page">
    <div class="pms-login-shell">
        <!-- Left: Branding background -->
        <section class="pms-login-brand" aria-label="Welcome">
            <div class="pms-login-brand-inner">
                @if (!string.IsNullOrWhiteSpace(website) || !string.IsNullOrWhiteSpace(email))
                {
                    <ul class="pms-login-features">
                        @if (!string.IsNullOrWhiteSpace(website))
                        {
                            <li><i class="bi bi-globe2" aria-hidden="true"></i><span>@website</span></li>
                        }
                        @if (!string.IsNullOrWhiteSpace(email))
                        {
                            <li><i class="bi bi-envelope" aria-hidden="true"></i><span>@email</span></li>
                        }
                    </ul>
                }
            </div>
        </section>

        <!-- Right: Login form -->
        <section class="pms-login-panel" aria-label="Sign in">
            <div class="pms-login-card">
                <h2>Sign in</h2>
                <p class="pms-login-subtitle">Enter your credentials to access your account</p>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger d-flex align-items-start gap-2" role="alert">
                        <i class="bi bi-exclamation-circle-fill flex-shrink-0 mt-1" aria-hidden="true"></i>
                        <span>@ViewBag.Error</span>
                    </div>
                }

                <form method="post" id="loginForm" class="needs-validation" novalidate>
                    @Html.AntiForgeryToken()

                    <div class="form-floating mb-3">
                        <input type="email"
                               class="form-control"
                               id="email"
                               name="email"
                               placeholder="name@company.com"
                               autocomplete="username"
                               required
                               aria-required="true" />
                        <label for="email">Email address</label>
                        <div class="invalid-feedback">Please enter a valid email address.</div>
                    </div>

                    <div class="pms-login-password-wrap mb-1">
                        <div class="form-floating">
                            <input type="password"
                                   class="form-control"
                                   id="password"
                                   name="password"
                                   placeholder="Password"
                                   autocomplete="current-password"
                                   required
                                   aria-required="true" />
                            <label for="password">Password</label>
                            <div class="invalid-feedback">Please enter your password.</div>
                        </div>
                        <button type="button"
                                class="pms-login-toggle-pw"
                                id="togglePassword"
                                aria-label="Show password"
                                aria-pressed="false">
                            <i class="bi bi-eye" id="togglePasswordIcon" aria-hidden="true"></i>
                        </button>
                    </div>

                    <div class="pms-login-options">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="rememberMe" />
                            <label class="form-check-label" for="rememberMe">Remember me</label>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(email))
                        {
                            <a class="pms-login-forgot" href="mailto:@email?subject=@Uri.EscapeDataString($"{projectName} - Password assistance")">Forgot password?</a>
                        }
                        else
                        {
                            <a class="pms-login-forgot" href="#" id="forgotPasswordLink">Forgot password?</a>
                        }
                    </div>

                    <button type="submit" class="pms-btn-login" id="loginSubmitBtn">
                        <span class="btn-text"><i class="bi bi-box-arrow-in-right me-2" aria-hidden="true"></i>Sign in</span>
                        <span class="btn-loading d-none">
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                            Signing in…
                        </span>
                    </button>
                </form>

                <p class="pms-login-secure mb-0">
                    <i class="bi bi-shield-lock me-1" aria-hidden="true"></i>Secure login is enabled.
                </p>
            </div>
        </section>
    </div>

    <footer class="pms-login-footer">
        <span>&copy; @DateTime.Now.Year @projectName. All rights reserved. · Reserved by Coditium Solutions</span>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <script>
        (function () {
            var form = document.getElementById('loginForm');
            var passwordInput = document.getElementById('password');
            var toggleBtn = document.getElementById('togglePassword');
            var toggleIcon = document.getElementById('togglePasswordIcon');
            var submitBtn = document.getElementById('loginSubmitBtn');
            var rememberKey = 'pms-login-remember-email';

            try {
                var savedEmail = localStorage.getItem(rememberKey);
                if (savedEmail) {
                    document.getElementById('email').value = savedEmail;
                    document.getElementById('rememberMe').checked = true;
                }
            } catch (e) { }

            if (toggleBtn && passwordInput) {
                toggleBtn.addEventListener('click', function () {
                    var show = passwordInput.type === 'password';
                    passwordInput.type = show ? 'text' : 'password';
                    toggleIcon.className = show ? 'bi bi-eye-slash' : 'bi bi-eye';
                    toggleBtn.setAttribute('aria-pressed', show ? 'true' : 'false');
                    toggleBtn.setAttribute('aria-label', show ? 'Hide password' : 'Show password');
                });
            }

            var forgotLink = document.getElementById('forgotPasswordLink');
            if (forgotLink) {
                forgotLink.addEventListener('click', function (e) {
                    e.preventDefault();
                    alert('Please contact your system administrator to reset your password.');
                });
            }

            form.addEventListener('submit', function (e) {
                if (!form.checkValidity()) {
                    e.preventDefault();
                    e.stopPropagation();
                    form.classList.add('was-validated');
                    return;
                }

                var remember = document.getElementById('rememberMe').checked;
                var emailVal = document.getElementById('email').value;
                try {
                    if (remember) localStorage.setItem(rememberKey, emailVal);
                    else localStorage.removeItem(rememberKey);
                } catch (err) { }

                submitBtn.disabled = true;
                submitBtn.querySelector('.btn-text').classList.add('d-none');
                submitBtn.querySelector('.btn-loading').classList.remove('d-none');
            });
        })();
    </script>
</body>
</html>
