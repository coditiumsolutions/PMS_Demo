@model IEnumerable<PMS.Models.Registration>

@{
    ViewData["Title"] = "Registrations";
    ViewData["ListingTitle"] = "All Registrations";
    ViewData["ListingRecordCount"] = Model?.Count() ?? 0;
    ViewData["ListingAddUrl"] = ViewBag.CanCreate == true ? Url.Action("Create") : null;
    ViewData["ListingAddText"] = "New Registration";
}

<!-- Search Filters -->
<form method="get" asp-action="Index" class="mb-4 pms-registration-listing">
    <div class="pms-registration-search-wrap pms-listing-search-wrap">
        <div class="row g-2 align-items-end flex-lg-nowrap">
            <div class="col-12 col-lg-5">
                <div class="pms-compact-field pms-select-dropdown">
                    <label for="statusFilter" class="form-label">Filter by Status</label>
                    <select name="statusFilter" id="statusFilter" class="form-select" onchange="this.form.submit()">
                        <option value="All" selected="@(ViewBag.StatusFilter == "All")">All Status</option>
                        <option value="Pending" selected="@(ViewBag.StatusFilter == "Pending")">Pending</option>
                        <option value="Approved" selected="@(ViewBag.StatusFilter == "Approved")">Approved</option>
                        <option value="Rejected" selected="@(ViewBag.StatusFilter == "Rejected")">Rejected</option>
                    </select>
                </div>
            </div>
            <div class="col-12 col-lg-4">
                <div class="pms-compact-field">
                    <label for="searchTerm" class="form-label">Search by ID, Name or Phone No</label>
                    <input type="text"
                           name="searchTerm"
                           id="searchTerm"
                           class="form-control"
                           value="@ViewBag.SearchTerm" />
                </div>
            </div>
            <div class="col-12 col-lg-3">
                <div class="d-flex flex-wrap gap-2 pms-registration-search-actions">
                    <button type="submit" class="btn btn-primary btn-sm flex-grow-1">
                        <i class="bi bi-search me-1" aria-hidden="true"></i>Search
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm flex-grow-1">
                        <i class="bi bi-arrow-counterclockwise me-1" aria-hidden="true"></i>Clear
                    </a>
                </div>
            </div>
        </div>
    </div>
</form>

<!-- Data Grid -->
<div class="card pms-grid-card pms-listing-flat pms-registration-listing">
    <div class="card-body">
        <partial name="Listing/_GridToolbar" />

        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle pms-enterprise-table" id="registrationsTable">
                    <thead>
                        <tr>
                            <th>Actions</th>
                            <th>Registration ID</th>
                            <th>Full Name</th>
                            <th>Project</th>
                            <th>Form No</th>
                            <th>Size</th>
                            <th>SubProject</th>
                            <th>CNIC</th>
                            <th>Contact</th>
                            <th>Registration Date</th>
                            <th>Status</th>
                            <th>Customer Link</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var registration in Model)
                        {
                            <tr>
                                <td>
                                    <div class="btn-group pms-action-group" role="group">
                                        @if (ViewBag.CanEdit == true)
                                        {
                                            <a asp-action="Edit" asp-route-id="@registration.RegID"
                                               class="btn btn-sm btn-outline-primary" title="Edit">
                                                <i class="bi bi-pencil-square" aria-hidden="true"></i>
                                            </a>
                                        }
                                        <a asp-action="Details" asp-route-id="@registration.RegID"
                                           class="btn btn-sm btn-outline-secondary" title="View Details">
                                            <i class="bi bi-eye" aria-hidden="true"></i>
                                        </a>
                                        @if ((ViewBag.CanDelete == true) && (registration.Customers == null || !registration.Customers.Any()))
                                        {
                                            <a asp-action="Delete" asp-route-id="@registration.RegID"
                                               class="btn btn-sm btn-outline-danger" title="Delete">
                                                <i class="bi bi-trash" aria-hidden="true"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                                <td><code>@registration.RegID</code></td>
                                <td><strong class="pms-cell-truncate" title="@registration.FullName">@registration.FullName</strong></td>
                                <td><span class="pms-cell-truncate" title="@(registration.Project?.ProjectName ?? "—")">@(registration.Project?.ProjectName ?? "—")</span></td>
                                <td>@(registration.FormNo ?? "—")</td>
                                <td>@(registration.Size ?? "—")</td>
                                <td>@(registration.SubProject ?? "—")</td>
                                <td>@(registration.CNIC ?? "N/A")</td>
                                <td>
                                    <div>
                                        <i class="fas fa-phone text-primary me-1"></i>@registration.Phone
                                    </div>
                                    @if (!string.IsNullOrEmpty(registration.Email))
                                    {
                                        <div>
                                            <small class="text-muted pms-cell-truncate d-block" title="@registration.Email">
                                                <i class="fas fa-envelope me-1"></i>@registration.Email
                                            </small>
                                        </div>
                                    }
                                </td>
                                <td>
                                    @registration.CreatedAt.ToString("MMM dd, yyyy")
                                    <br />
                                    <small class="text-muted">@registration.CreatedAt.ToString("hh:mm tt")</small>
                                </td>
                                <td>
                                    @if (registration.Status == "Pending")
                                    {
                                        <span class="badge bg-warning text-dark">
                                            <i class="fas fa-clock me-1"></i>Pending
                                        </span>
                                    }
                                    else if (registration.Status == "Approved")
                                    {
                                        <span class="badge bg-success">
                                            <i class="fas fa-check-circle me-1"></i>Approved
                                        </span>
                                    }
                                    else if (registration.Status == "Rejected")
                                    {
                                        <span class="badge bg-danger">
                                            <i class="fas fa-times-circle me-1"></i>Rejected
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@registration.Status</span>
                                    }
                                </td>
                                <td>
                                    @if (registration.Customers != null && registration.Customers.Any())
                                    {
                                        var customer = registration.Customers.FirstOrDefault();
                                        @if (customer != null)
                                        {
                                            <a asp-controller="Customer" asp-action="Details" asp-route-id="@(customer.CustomerID ?? "")"
                                               class="btn btn-sm btn-success">
                                                <i class="bi bi-person me-1"></i>View
                                            </a>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Not converted</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="pms-empty-state">
                <i class="bi bi-inbox display-4 d-block mb-3 text-muted"></i>
                <h5 class="text-muted">No Registrations Found</h5>
                <p class="text-muted mb-3">@(ViewBag.SearchTerm != null && ViewBag.SearchTerm != "" ? "Try different search criteria." : "Start by creating a new registration.")</p>
                @if (ViewBag.CanCreate == true)
                {
                    <a asp-action="Create" class="btn btn-primary">
                        <i class="bi bi-plus-lg me-1"></i>Create First Registration
                    </a>
                }
            </div>
        }
    </div>
</div>

<style>
    html[data-theme="dark"] #registrationsTable thead th {
        background-color: #0f172a !important;
        color: var(--text-primary) !important;
    }

    html[data-theme="dark"] #registrationsTable tbody td {
        color: var(--text-primary) !important;
    }

    html[data-theme="dark"] #registrationsTable code {
        background: rgba(148, 163, 184, 0.18);
        color: #e5e7eb;
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#registrationsTable').DataTable({
                "pageLength": 25,
                "order": [[9, "desc"]],
                "columnDefs": [
                    { "orderable": false, "targets": [0, 11] }
                ]
            });
        });
    </script>
}
