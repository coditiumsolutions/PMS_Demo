@model PMS.Models.Registration

@{
    ViewData["Title"] = "Registration Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div class="d-flex align-items-center gap-4">
        <!-- <h2 class="mb-0">
            <i class="fas fa-file-alt me-2"></i>Registration Details
        </h2> -->
        <div class="d-flex align-items-center gap-3 ms-4">
            <div class="badge bg-light text-dark px-3 py-2" style="font-size: 14px;">
                <i class="fas fa-calendar-check me-2" style="color: #6f42c1;"></i>
                <strong>Registered:</strong> @Model.CreatedAt.ToString("MMMM dd, yyyy")
                <span class="text-muted ms-2">(@((DateTime.Now - Model.CreatedAt).Days) days ago)</span>
            </div>
        </div>
    </div>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.RegID" class="btn btn-primary me-2">
            <i class="fas fa-edit me-2"></i>Edit
        </a>
        <a asp-action="Index" class="btn btn-outline-primary">
            <i class="fas fa-arrow-left me-2"></i>Back to List
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="fas fa-info-circle me-2"></i>Registration Information
                </h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <div class="detail-field">
                            <label><i class="fas fa-id-badge me-2"></i>Registration ID</label>
                            <p><code>@Model.RegID</code></p>
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <div class="detail-field">
                            <label><i class="fas fa-toggle-on me-2"></i>Status</label>
                            <p>
                                @if (Model.Status == "Pending")
                                {
                                    <span class="badge bg-warning">
                                        <i class="fas fa-clock me-1"></i>Pending
                                    </span>
                                }
                                else if (Model.Status == "Approved")
                                {
                                    <span class="badge bg-success">
                                        <i class="fas fa-check-circle me-1"></i>Approved
                                    </span>
                                }
                                else if (Model.Status == "Rejected")
                                {
                                    <span class="badge bg-danger">
                                        <i class="fas fa-times-circle me-1"></i>Rejected
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@Model.Status</span>
                                }
                            </p>
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <div class="detail-field">
                            <label><i class="fas fa-user me-2"></i>Full Name</label>
                            <p>@Model.FullName</p>
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <div class="detail-field">
                            <label><i class="fas fa-id-card me-2"></i>CNIC</label>
                            <p>@(Model.CNIC ?? "N/A")</p>
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <div class="detail-field">
                            <label><i class="fas fa-passport me-2"></i>Passport Number</label>
                            <p>@(Model.PassportNo ?? "N/A")</p>
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <div class="detail-field">
                            <label><i class="fas fa-phone me-2"></i>Phone</label>
                            <p>@Model.Phone</p>
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <div class="detail-field">
                            <label><i class="fas fa-envelope me-2"></i>Email</label>
                            <p>@(Model.Email ?? "N/A")</p>
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <div class="detail-field">
                            <label><i class="fas fa-building me-2"></i>Project</label>
                            <p>@(Model.Project?.ProjectName ?? "N/A")</p>
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <div class="detail-field">
                            <label><i class="fas fa-ruler-combined me-2"></i>Size</label>
                            <p>@(Model.Size ?? "N/A")</p>
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <div class="detail-field">
                            <label><i class="fas fa-layer-group me-2"></i>SubProject</label>
                            <p>@(Model.SubProject ?? "N/A")</p>
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <div class="detail-field">
                            <label><i class="fas fa-calendar me-2"></i>Registration Date</label>
                            <p>@Model.CreatedAt.ToString("MMMM dd, yyyy hh:mm tt")</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <!-- Status Update Card -->
        <div class="card mb-3">
            <div class="card-header bg-primary text-white">
                <h6 class="mb-0">
                    <i class="fas fa-tasks me-2"></i>Update Status
                </h6>
            </div>
            <div class="card-body">
                <form asp-action="UpdateStatus" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="regID" value="@Model.RegID" />
                    
                    <div class="mb-3">
                        <label class="form-label">Current Status</label>
                        <p>
                            @if (Model.Status == "Pending")
                            {
                                <span class="badge bg-warning">Pending</span>
                            }
                            else if (Model.Status == "Approved")
                            {
                                <span class="badge bg-success">Approved</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Rejected</span>
                            }
                        </p>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Change Status To</label>
                        <select name="status" class="form-select" required>
                            <option value="">Select Status...</option>
                            <option value="Pending">Pending</option>
                            <option value="Approved">Approved</option>
                            <option value="Rejected">Rejected</option>
                        </select>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-check me-2"></i>Update Status
                    </button>
                </form>
            </div>
        </div>

        <!-- Customer Link Card -->
        @if (Model.Customers != null && Model.Customers.Any())
        {
            var customer = Model.Customers.FirstOrDefault();
            @if (customer != null)
            {
                <div class="card">
                    <div class="card-header bg-success text-white">
                        <h6 class="mb-0">
                            <i class="fas fa-user-check me-2"></i>Customer Created
                        </h6>
                    </div>
                    <div class="card-body">
                        <div class="text-center mb-3">
                            <i class="fas fa-user-circle fa-3x" style="color: #6f42c1;"></i>
                        </div>
                        <div class="detail-field mb-2">
                            <label>Customer ID</label>
                            <p><code>@(customer.CustomerID ?? "")</code></p>
                        </div>
                        <div class="detail-field mb-3">
                            <label>Full Name</label>
                            <p><strong>@(customer.FullName ?? "")</strong></p>
                        </div>
                        <a asp-controller="Customer" asp-action="Details" asp-route-id="@(customer.CustomerID ?? "")" 
                           class="btn btn-success w-100">
                            <i class="fas fa-eye me-2"></i>View Customer Details
                        </a>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="card">
                <div class="card-body text-center">
                    <i class="fas fa-user-plus fa-3x mb-3 text-muted"></i>
                    <p class="text-muted mb-0">Not converted to customer yet</p>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .detail-field {
        padding: 8px 10px;
        background: linear-gradient(135deg, #f8f9fa 0%, #f3f0ff 100%);
        border-radius: 6px;
    }

    .detail-field label {
        display: block;
        margin-bottom: 3px;
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #666;
        font-weight: 600;
    }

    .detail-field p {
        font-size: 14px;
        color: var(--text-dark);
        margin-bottom: 0;
        font-weight: 500;
    }

    code {
        background: rgba(156, 106, 222, 0.1);
        color: #9C6ADE;
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
    }
</style>

