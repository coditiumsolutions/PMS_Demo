@model PMS.Models.Refund
@{
    ViewData["Title"] = "Refund Details – " + Model.RefundID;
    var initiatedStatus = (string?)ViewBag.InitiatedStatus ?? "Initiated";
    var approvedStatus = (string?)ViewBag.ApprovedStatus ?? "Approved";
    var declinedStatus = (string?)ViewBag.DeclinedStatus ?? "Declined";
    var wf = Model.WorkflowStatus ?? initiatedStatus;
    var badgeClass = string.Equals(wf, approvedStatus, StringComparison.OrdinalIgnoreCase)
        ? "bg-success"
        : string.Equals(wf, declinedStatus, StringComparison.OrdinalIgnoreCase)
            ? "bg-danger"
            : "bg-warning text-dark";
    var selectedPayments = ViewBag.SelectedPayments as List<PMS.Models.Payment> ?? new List<PMS.Models.Payment>();
}

<div style="display:none;">@Html.AntiForgeryToken()</div>

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h2 class="mb-0"><i class="fas fa-undo-alt me-2"></i>Refund <code>@Model.RefundID</code></h2>
    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-secondary btn-sm"><i class="fas fa-arrow-left me-1"></i>Back</a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Status Banner -->
<div class="alert @(string.Equals(wf, approvedStatus, StringComparison.OrdinalIgnoreCase) ? "alert-success" : string.Equals(wf, declinedStatus, StringComparison.OrdinalIgnoreCase) ? "alert-danger" : "alert-warning") d-flex align-items-center gap-2 mb-4">
    <i class="fas @(string.Equals(wf, approvedStatus, StringComparison.OrdinalIgnoreCase) ? "fa-check-circle" : string.Equals(wf, declinedStatus, StringComparison.OrdinalIgnoreCase) ? "fa-times-circle" : "fa-clock") fa-lg"></i>
    <div>
        <strong>Status: @wf</strong>
        @if (!string.Equals(wf, initiatedStatus, StringComparison.OrdinalIgnoreCase) && Model.ApprovedAt.HasValue)
        {
            <span class="ms-2 small">on @Model.ApprovedAt.Value.ToString("MMM dd, yyyy HH:mm") by @(Model.ApprovedByUser?.FullName ?? Model.ApprovedBy)</span>
        }
    </div>
    <span class="ms-auto badge @badgeClass fs-6">@wf</span>
</div>

<div class="row g-4">
    <!-- Left: Refund Info -->
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header bg-primary text-white fw-semibold"><i class="fas fa-file-invoice me-2"></i>Refund Information</div>
            <div class="card-body">
                <table class="table table-sm table-borderless">
                    <tr><th style="width:40%">Refund ID</th><td><code>@Model.RefundID</code></td></tr>
                    <tr><th>Refund Type</th><td><span class="badge bg-secondary">@(Model.RefundType ?? "—")</span></td></tr>
                    <tr><th>Paid Amount</th><td>PKR @Model.PaidAmount.ToString("N0")</td></tr>
                    <tr><th>Deduction</th><td class="text-danger">PKR @Model.DeductionAmount.ToString("N0")</td></tr>
                    <tr><th>Refunded Amount</th><td class="fw-bold text-success fs-5">PKR @Model.RefundedAmount.ToString("N0")</td></tr>
                    <tr><th>Reason</th><td>@(Model.Reason ?? "—")</td></tr>
                    <tr><th>Notes</th><td>@(Model.Notes ?? "—")</td></tr>
                    <tr><th>Created By</th><td>@(Model.CreatedByUser?.FullName ?? Model.CreatedBy ?? "—")</td></tr>
                    <tr><th>Created At</th><td>@Model.CreatedAt.ToString("MMM dd, yyyy HH:mm")</td></tr>
                </table>
            </div>
        </div>
    </div>

    <!-- Right: Customer Info -->
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header fw-semibold"><i class="fas fa-user me-2"></i>Customer</div>
            <div class="card-body">
                @if (Model.Customer != null)
                {
                    <table class="table table-sm table-borderless">
                        <tr><th style="width:40%">Customer ID</th><td><code>@Model.Customer.CustomerID</code></td></tr>
                        <tr><th>Full Name</th><td>@(Model.Customer.FullName ?? "—")</td></tr>
                        <tr><th>Father Name</th><td>@(Model.Customer.FatherName ?? "—")</td></tr>
                        <tr><th>CNIC</th><td>@(Model.Customer.CNIC ?? "—")</td></tr>
                        <tr><th>Phone</th><td>@(Model.Customer.Phone ?? "—")</td></tr>
                        <tr><th>Project</th><td>@(Model.Customer.PaymentPlan?.Project?.ProjectName ?? "—")</td></tr>
                    </table>
                }
                else
                {
                    <p class="text-muted">Customer details unavailable.</p>
                }
            </div>
        </div>
    </div>
</div>

<!-- Selected Payments -->
<div class="card mt-4">
    <div class="card-header fw-semibold">
        <i class="fas fa-money-check-alt me-2"></i>Payments Selected for Refund
        <span class="badge bg-secondary ms-2">@selectedPayments.Count</span>
    </div>
    <div class="card-body">
        @if (selectedPayments.Count == 0)
        {
            <p class="text-muted">No payment records found.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Payment ID</th>
                            <th>#</th>
                            <th>Description</th>
                            <th class="text-end">Amount (PKR)</th>
                            <th>Method</th>
                            <th>Date</th>
                            <th>Ref #</th>
                            @if (string.Equals(wf, approvedStatus, StringComparison.OrdinalIgnoreCase))
                            {
                                <th>Status</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in selectedPayments)
                        {
                            <tr>
                                <td><code>@p.PaymentID</code></td>
                                <td>@(p.PaymentSchedule?.InstallmentNo)</td>
                                <td>@(p.PaymentSchedule?.PaymentDescription ?? "—")</td>
                                <td class="text-end">@p.Amount.ToString("N0")</td>
                                <td>@(p.Method ?? "—")</td>
                                <td>@p.PaymentDate.ToString("MMM dd, yyyy")</td>
                                <td>@(p.ReferenceNo ?? "—")</td>
                                @if (string.Equals(wf, approvedStatus, StringComparison.OrdinalIgnoreCase))
                                {
                                    <td><span class="badge bg-success">Refunded</span></td>
                                }
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="table-secondary fw-bold">
                            <td colspan="3" class="text-end">Total:</td>
                            <td class="text-end">PKR @selectedPayments.Sum(p => p.Amount).ToString("N0")</td>
                            <td colspan="@(string.Equals(wf, approvedStatus, StringComparison.OrdinalIgnoreCase) ? 4 : 3)"></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        }
    </div>
</div>

<!-- Attachments -->
<div class="card mt-4">
    <div class="card-header fw-semibold">
        <i class="fas fa-paperclip me-2"></i>Attachments
    </div>
    <div class="card-body">
        <p class="text-muted small mb-3">Upload multiple supporting files. Accepted: JPG, PNG, GIF, BMP, PDF. Max 8MB per file.</p>
        @if (ViewBag.CanEdit == true)
        {
            <div class="row g-2 mb-3">
                <div class="col-md-6">
                    <input type="file" id="refundFile" class="form-control form-control-sm" accept=".jpg,.jpeg,.png,.gif,.bmp,.pdf" />
                </div>
                <div class="col-md-4">
                    <input type="text" id="refundDescription" class="form-control form-control-sm" placeholder="Description (optional)" />
                </div>
                <div class="col-md-2 d-grid">
                    <button type="button" class="btn btn-sm btn-primary" id="uploadRefundBtn">
                        <i class="fas fa-upload me-1"></i>Upload
                    </button>
                </div>
            </div>
        }
        <div id="refundAttachmentsList" class="refund-att-list"></div>
    </div>
</div>

<!-- Workflow actions -->
@if (!string.Equals(wf, approvedStatus, StringComparison.OrdinalIgnoreCase))
{
    <div class="alert alert-info mt-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <i class="fas fa-info-circle me-2"></i>Use Edit to move status one step forward/backward according to configured refundworkflow.
        </div>
        @if (ViewBag.CanEdit == true)
        {
            <a asp-action="Edit" asp-route-id="@Model.RefundID" class="btn btn-primary btn-sm">
                <i class="fas fa-edit me-1"></i>Open Workflow Controls
            </a>
        }
    </div>
}

<style>
    .refund-att-list .att-item { display: flex; justify-content: space-between; align-items: center; padding: 6px 0; border-bottom: 1px solid #eee; }
    .refund-att-list .att-item:last-child { border-bottom: none; }
</style>

@section Scripts {
<script>
(function() {
    var refundId = '@Model.RefundID';
    var canDelete = @((ViewBag.CanDelete == true).ToString().ToLowerInvariant());
    var token = document.querySelector('input[name="__RequestVerificationToken"]');
    function getToken() { return token ? token.value : ''; }

    function loadAttachments() {
        $.ajax({
            url: '@Url.Action("GetAttachments", "Refund")',
            method: 'GET',
            data: { refundId: refundId },
            success: function(res) {
                if (res.success && res.attachments) {
                    renderList(res.attachments);
                }
            }
        });
    }

    function renderList(items) {
        var $c = $('#refundAttachmentsList');
        $c.empty();
        if (!items || items.length === 0) {
            $c.html('<p class="text-muted mb-0 small"><i class="fas fa-inbox me-1"></i>No attachments</p>');
            return;
        }
        items.forEach(function(a) {
            var isImg = a.fileType && a.fileType.indexOf('image') === 0;
            var isPdf = a.fileType && a.fileType.indexOf('pdf') >= 0;
            var icon = isImg ? 'fa-image' : (isPdf ? 'fa-file-pdf text-danger' : 'fa-file');
            var delBtn = canDelete
                ? '<button type="button" class="btn btn-sm btn-outline-danger delete-att" data-id="' + a.attachmentID + '" title="Delete"><i class="fas fa-trash"></i></button>'
                : '';
            var row = '<div class="att-item">' +
                '<span><i class="fas ' + icon + ' me-2"></i>' + (a.fileName || 'File') + '</span>' +
                '<span>' +
                '<a href="' + a.filePath + '" target="_blank" class="btn btn-sm btn-outline-primary me-1" title="View"><i class="fas fa-eye"></i></a>' +
                delBtn +
                '</span></div>';
            $c.append(row);
        });
        $c.find('.delete-att').on('click', function() {
            var id = $(this).data('id');
            if (!confirm('Delete this attachment?')) return;
            $.post('@Url.Action("DeleteAttachment", "Refund")', { __RequestVerificationToken: getToken(), attachmentId: id })
                .done(function(r) { if (r.success) loadAttachments(); else alert(r.message); })
                .fail(function() { alert('Error deleting'); });
        });
    }

    function upload() {
        var fileInput = document.getElementById('refundFile');
        var descInput = document.getElementById('refundDescription');
        var btn = document.getElementById('uploadRefundBtn');
        if (!fileInput || !fileInput.files || !fileInput.files[0]) {
            alert('Please select a file.');
            return;
        }
        var fd = new FormData();
        fd.append('refundId', refundId);
        fd.append('file', fileInput.files[0]);
        fd.append('description', descInput ? descInput.value : '');
        fd.append('__RequestVerificationToken', getToken());
        $(btn).prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-1"></i>Uploading...');
        $.ajax({
            url: '@Url.Action("UploadAttachment", "Refund")',
            method: 'POST',
            data: fd,
            processData: false,
            contentType: false,
            success: function(r) {
                if (r.success) {
                    fileInput.value = '';
                    if (descInput) descInput.value = '';
                    loadAttachments();
                } else alert(r.message || 'Upload failed');
                $(btn).prop('disabled', false).html('<i class="fas fa-upload me-1"></i>Upload');
            },
            error: function() {
                alert('Upload failed.');
                $(btn).prop('disabled', false).html('<i class="fas fa-upload me-1"></i>Upload');
            }
        });
    }

    $('#uploadRefundBtn').on('click', upload);
    loadAttachments();
})();
</script>
}
