@model PMS.Models.Refund
@{
    ViewData["Title"] = "Refund Details – " + Model.RefundID;
    var wf = Model.WorkflowStatus ?? "Initiated";
    var badgeClass = wf == "Approved" ? "bg-success" : wf == "Declined" ? "bg-danger" : "bg-warning text-dark";
    var selectedPayments = ViewBag.SelectedPayments as List<PMS.Models.Payment> ?? new List<PMS.Models.Payment>();
    bool isPending = wf == "Initiated";
    bool isAdmin = ViewBag.CanDelete == true;
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h2 class="mb-0"><i class="fas fa-undo-alt me-2"></i>Refund <code>@Model.RefundID</code></h2>
    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-secondary btn-sm"><i class="fas fa-arrow-left me-1"></i>Back</a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Status Banner -->
<div class="alert @(wf == "Approved" ? "alert-success" : wf == "Declined" ? "alert-danger" : "alert-warning") d-flex align-items-center gap-2 mb-4">
    <i class="fas @(wf == "Approved" ? "fa-check-circle" : wf == "Declined" ? "fa-times-circle" : "fa-clock") fa-lg"></i>
    <div>
        <strong>Status: @wf</strong>
        @if (!isPending && Model.ApprovedAt.HasValue)
        {
            <span class="ms-2 small">on @Model.ApprovedAt.Value.ToString("MMM dd, yyyy HH:mm") by @(Model.ApprovedByUser?.FullName ?? Model.ApprovedBy)</span>
        }
    </div>
    <span class="ms-auto badge @badgeClass fs-6">@wf</span>
</div>

<div class="row g-4">
    <!-- Left: Refund Info -->
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header bg-primary text-white fw-semibold"><i class="fas fa-file-invoice me-2"></i>Refund Information</div>
            <div class="card-body">
                <table class="table table-sm table-borderless">
                    <tr><th style="width:40%">Refund ID</th><td><code>@Model.RefundID</code></td></tr>
                    <tr><th>Refund Type</th><td><span class="badge bg-secondary">@(Model.RefundType ?? "—")</span></td></tr>
                    <tr><th>Paid Amount</th><td>PKR @Model.PaidAmount.ToString("N0")</td></tr>
                    <tr><th>Deduction</th><td class="text-danger">PKR @Model.DeductionAmount.ToString("N0")</td></tr>
                    <tr><th>Refunded Amount</th><td class="fw-bold text-success fs-5">PKR @Model.RefundedAmount.ToString("N0")</td></tr>
                    <tr><th>Reason</th><td>@(Model.Reason ?? "—")</td></tr>
                    <tr><th>Notes</th><td>@(Model.Notes ?? "—")</td></tr>
                    <tr><th>Created By</th><td>@(Model.CreatedByUser?.FullName ?? Model.CreatedBy ?? "—")</td></tr>
                    <tr><th>Created At</th><td>@Model.CreatedAt.ToString("MMM dd, yyyy HH:mm")</td></tr>
                </table>
            </div>
        </div>
    </div>

    <!-- Right: Customer Info -->
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header fw-semibold"><i class="fas fa-user me-2"></i>Customer</div>
            <div class="card-body">
                @if (Model.Customer != null)
                {
                    <table class="table table-sm table-borderless">
                        <tr><th style="width:40%">Customer ID</th><td><code>@Model.Customer.CustomerID</code></td></tr>
                        <tr><th>Full Name</th><td>@(Model.Customer.FullName ?? "—")</td></tr>
                        <tr><th>Father Name</th><td>@(Model.Customer.FatherName ?? "—")</td></tr>
                        <tr><th>CNIC</th><td>@(Model.Customer.CNIC ?? "—")</td></tr>
                        <tr><th>Phone</th><td>@(Model.Customer.Phone ?? "—")</td></tr>
                        <tr><th>Project</th><td>@(Model.Customer.PaymentPlan?.Project?.ProjectName ?? "—")</td></tr>
                    </table>
                }
                else
                {
                    <p class="text-muted">Customer details unavailable.</p>
                }
            </div>
        </div>
    </div>
</div>

<!-- Selected Payments -->
<div class="card mt-4">
    <div class="card-header fw-semibold">
        <i class="fas fa-money-check-alt me-2"></i>Payments Selected for Refund
        <span class="badge bg-secondary ms-2">@selectedPayments.Count</span>
    </div>
    <div class="card-body">
        @if (selectedPayments.Count == 0)
        {
            <p class="text-muted">No payment records found.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Payment ID</th>
                            <th>#</th>
                            <th>Description</th>
                            <th class="text-end">Amount (PKR)</th>
                            <th>Method</th>
                            <th>Date</th>
                            <th>Ref #</th>
                            @if (wf == "Approved")
                            {
                                <th>Status</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in selectedPayments)
                        {
                            <tr>
                                <td><code>@p.PaymentID</code></td>
                                <td>@(p.PaymentSchedule?.InstallmentNo)</td>
                                <td>@(p.PaymentSchedule?.PaymentDescription ?? "—")</td>
                                <td class="text-end">@p.Amount.ToString("N0")</td>
                                <td>@(p.Method ?? "—")</td>
                                <td>@p.PaymentDate.ToString("MMM dd, yyyy")</td>
                                <td>@(p.ReferenceNo ?? "—")</td>
                                @if (wf == "Approved")
                                {
                                    <td><span class="badge bg-danger">Deleted on Approval</span></td>
                                }
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="table-secondary fw-bold">
                            <td colspan="3" class="text-end">Total:</td>
                            <td class="text-end">PKR @selectedPayments.Sum(p => p.Amount).ToString("N0")</td>
                            <td colspan="@(wf == "Approved" ? 4 : 3)"></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        }
    </div>
</div>

<!-- Actions (only for Initiated) -->
@if (isPending && isAdmin)
{
    <div class="row g-3 mt-2">
        <div class="col-md-6">
            <div class="card border-success">
                <div class="card-header bg-success text-white fw-semibold"><i class="fas fa-check me-2"></i>Approve Refund</div>
                <div class="card-body">
                    <p class="small text-muted mb-2">
                        Approving will <strong>permanently delete</strong> the selected payments from the system and cannot be undone.
                    </p>
                    <form asp-action="Approve" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="refundId" value="@Model.RefundID" />
                        <div class="mb-3">
                            <label class="form-label">Approval Notes (optional)</label>
                            <textarea name="notes" class="form-control" rows="2" maxlength="500"></textarea>
                        </div>
                        <button type="submit" class="btn btn-success w-100"
                                onclick="return confirm('CONFIRM: This will permanently delete @selectedPayments.Count payment(s). Proceed?')">
                            <i class="fas fa-check me-2"></i>Approve &amp; Delete Payments
                        </button>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white fw-semibold"><i class="fas fa-times me-2"></i>Decline Refund</div>
                <div class="card-body">
                    <p class="small text-muted mb-2">Declining will reject the refund request. No payments will be deleted.</p>
                    <form asp-action="Decline" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="refundId" value="@Model.RefundID" />
                        <div class="mb-3">
                            <label class="form-label">Reason for Decline <span class="text-danger">*</span></label>
                            <textarea name="notes" class="form-control" rows="2" maxlength="500" required></textarea>
                        </div>
                        <button type="submit" class="btn btn-danger w-100">
                            <i class="fas fa-times me-2"></i>Decline Refund
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}
else if (isPending)
{
    <div class="alert alert-info mt-3">
        <i class="fas fa-info-circle me-2"></i>This refund is awaiting admin approval. Only admins can approve or decline.
    </div>
}
