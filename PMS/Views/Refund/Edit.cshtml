@model PMS.Models.Refund
@{
    ViewData["Title"] = "Edit Refund";
    var selectedPayments = ViewBag.SelectedPayments as List<PMS.Models.Payment> ?? new List<PMS.Models.Payment>();
    var workflowStatuses = ViewBag.WorkflowStatuses as List<string> ?? new List<string>();
    var currentWorkflowIndex = ViewBag.CurrentWorkflowIndex != null ? (int)ViewBag.CurrentWorkflowIndex : -1;
    var hasPreviousStep = ViewBag.HasPreviousStep == true;
    var hasNextStep = ViewBag.HasNextStep == true;
    var previousStepLabel = ViewBag.PreviousStepLabel as string;
    var nextStepLabel = ViewBag.NextStepLabel as string;
    var approvedStatusEdit = (string?)ViewBag.ApprovedStatus ?? "Approved";
    var wfEdit = Model.WorkflowStatus ?? "";
    ViewBag.RefundChequesRefundId = Model.RefundID;
    ViewBag.RefundChequesCap = Model.RefundedAmount;
    ViewBag.RefundChequesCanManage = ViewBag.CanEdit == true && !string.Equals(wfEdit, approvedStatusEdit, StringComparison.OrdinalIgnoreCase);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="fas fa-edit me-2"></i>Edit Refund <code>@Model.RefundID</code></h2>
    <a asp-action="Details" asp-route-id="@Model.RefundID" class="btn btn-secondary btn-sm"><i class="fas fa-arrow-left me-1"></i>Back</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card mb-4">
    <div class="card-header fw-semibold"><i class="fas fa-route me-2"></i>Workflow Status</div>
    <div class="card-body">
        <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
            @for (var i = 0; i < workflowStatuses.Count; i++)
            {
                var step = workflowStatuses[i];
                var isCurrent = i == currentWorkflowIndex;
                <span class="badge @(isCurrent ? "bg-primary" : "bg-secondary")">@(i + 1). @step</span>
                @if (i < workflowStatuses.Count - 1)
                {
                    <i class="fas fa-arrow-right text-muted"></i>
                }
            }
        </div>
        <div class="d-flex flex-wrap gap-2">
            <form asp-action="MoveStatus" asp-route-id="@Model.RefundID" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="direction" value="backward" />
                <button type="submit" class="btn btn-outline-secondary" @(hasPreviousStep ? null : "disabled")>
                    <i class="fas fa-arrow-left me-1"></i>Move Back @(string.IsNullOrWhiteSpace(previousStepLabel) ? "" : $"to {previousStepLabel}")
                </button>
            </form>
            <form asp-action="MoveStatus" asp-route-id="@Model.RefundID" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="direction" value="forward" />
                <button type="submit" class="btn btn-primary" @(hasNextStep ? null : "disabled")>
                    <i class="fas fa-arrow-right me-1"></i>Move Forward @(string.IsNullOrWhiteSpace(nextStepLabel) ? "" : $"to {nextStepLabel}")
                </button>
            </form>
        </div>
    </div>
</div>

<form asp-action="Edit" asp-route-id="@Model.RefundID" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-danger small mb-3"></div>
    <div class="card mb-4">
        <div class="card-header fw-semibold">Refund Details</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Refund Type <span class="text-danger">*</span></label>
                    <select asp-for="RefundType" class="form-select" required>
                        <option value="">-- Select --</option>
                        <option value="Full">Full</option>
                        <option value="Partial">Partial</option>
                    </select>
                    <span asp-validation-for="RefundType" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Paid Amount (PKR)</label>
                    <input value="@Model.PaidAmount.ToString("N2")" class="form-control" readonly />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Deduction Amount (PKR)</label>
                    <input asp-for="DeductionAmount" class="form-control" type="number" min="0" step="0.01" />
                    <span asp-validation-for="DeductionAmount" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Refunded Amount (PKR)</label>
                    <input value="@Model.RefundedAmount.ToString("N2")" class="form-control" readonly />
                </div>
                <div class="col-md-8">
                    <label class="form-label fw-semibold">Reason <span class="text-danger">*</span></label>
                    <input asp-for="Reason" class="form-control" required maxlength="255" />
                    <span asp-validation-for="Reason" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Notes</label>
                    <textarea asp-for="Notes" class="form-control" rows="2" maxlength="500"></textarea>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header fw-semibold">
            <i class="fas fa-money-check-alt me-2"></i>Selected Payments (Read-only)
        </div>
        <div class="card-body">
            @if (selectedPayments.Count == 0)
            {
                <p class="text-muted mb-0">No payment records found.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Payment ID</th>
                                <th>#</th>
                                <th>Description</th>
                                <th class="text-end">Amount (PKR)</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in selectedPayments)
                            {
                                <tr>
                                    <td><code>@p.PaymentID</code></td>
                                    <td>@(p.PaymentSchedule?.InstallmentNo)</td>
                                    <td>@(p.PaymentSchedule?.PaymentDescription ?? "—")</td>
                                    <td class="text-end">@p.Amount.ToString("N0")</td>
                                    <td>@p.PaymentDate.ToString("MMM dd, yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary"><i class="fas fa-save me-2"></i>Save Changes</button>
        <a asp-action="Details" asp-route-id="@Model.RefundID" class="btn btn-secondary">Cancel</a>
    </div>
</form>

<div class="card mt-4">
    <div class="card-header fw-semibold"><i class="fas fa-money-check me-2"></i>Refund cheques</div>
    <div class="card-body">
        @await Html.PartialAsync("_RefundChequesPanel")
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_RefundChequesScripts"); }
}
