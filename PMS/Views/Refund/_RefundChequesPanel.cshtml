@{
    var rid = ViewBag.RefundChequesRefundId as string ?? "";
    var capVal = ViewBag.RefundChequesCap is decimal capDec ? capDec : 0m;
    var canM = ViewBag.RefundChequesCanManage as bool? == true;
}
<div class="refund-cheques-panel"
     data-refund-id="@rid"
     data-cap="@capVal.ToString(System.Globalization.CultureInfo.InvariantCulture)"
     data-can-manage="@(canM.ToString().ToLowerInvariant())">
    <p class="text-muted small mb-3">
        Record one or more cheques issued for this refund. The sum of cheque amounts cannot exceed the refund
        <strong>Refunded amount</strong> (PKR @capVal.ToString("N2")).
    </p>
    <div id="rcAlert" class="alert d-none mb-3 py-2 small" role="alert"></div>
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-2">
        <div id="rcTotals" class="small"></div>
        @if (canM)
        {
            <button type="button" class="btn btn-sm btn-primary" id="rcBtnAdd" data-bs-toggle="modal" data-bs-target="#rcChequeModal">
                <i class="fas fa-plus me-1"></i>Add cheque
            </button>
        }
    </div>
    <div class="table-responsive">
        <table class="table table-sm table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Cheque no.</th>
                    <th>Date</th>
                    <th class="text-end">Amount (PKR)</th>
                    <th>Bank</th>
                    <th>Details</th>
                    @if (canM)
                    {
                        <th style="width:7rem"></th>
                    }
                </tr>
            </thead>
            <tbody id="rcChequesTbody">
                <tr><td colspan="@(canM ? 7 : 6)" class="text-muted small">Loading…</td></tr>
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="rcChequeModal" tabindex="-1" aria-labelledby="rcChequeModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="rcChequeModalTitle">Cheque</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="rcFieldId" value="0" />
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label" for="rcFieldChequeNo">Cheque no. <span class="text-danger">*</span></label>
                        <input type="text" class="form-control form-control-sm" id="rcFieldChequeNo" maxlength="100" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" for="rcFieldChequeDate">Cheque date <span class="text-danger">*</span></label>
                        <input type="date" class="form-control form-control-sm" id="rcFieldChequeDate" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" for="rcFieldAmount">Amount (PKR) <span class="text-danger">*</span></label>
                        <input type="number" class="form-control form-control-sm" id="rcFieldAmount" min="0.01" step="0.01" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" for="rcFieldBank">Bank</label>
                        <input type="text" class="form-control form-control-sm" id="rcFieldBank" maxlength="200" />
                    </div>
                    <div class="col-12">
                        <label class="form-label" for="rcFieldDetails">Details</label>
                        <textarea class="form-control form-control-sm" id="rcFieldDetails" rows="2"></textarea>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary btn-sm" id="rcModalSave">Save</button>
            </div>
        </div>
    </div>
</div>
