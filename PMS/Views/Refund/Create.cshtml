@model PMS.Models.Refund
@{
    ViewData["Title"] = "New Refund";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="fas fa-undo-alt me-2"></i>New Refund</h2>
    <a asp-action="Index" class="btn btn-secondary btn-sm"><i class="fas fa-arrow-left me-1"></i>Back</a>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Customer Search -->
<div class="card mb-4">
    <div class="card-header bg-primary text-white fw-semibold"><i class="fas fa-search me-2"></i>Customer Search</div>
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label fw-semibold">Customer ID <span class="text-danger">*</span></label>
                <div class="input-group">
                    <input type="text" id="customerIdInput" class="form-control" placeholder="Enter Customer ID" />
                    <button type="button" class="btn btn-primary" id="searchCustomerBtn">
                        <i class="fas fa-search"></i> Search
                    </button>
                </div>
            </div>
        </div>
        <!-- Customer Info Panel (hidden until found) -->
        <div id="customerInfoPanel" class="mt-3" style="display:none;">
            <div class="row g-2">
                <div class="col-md-3"><span class="fw-semibold">Name:</span> <span id="custName"></span></div>
                <div class="col-md-3"><span class="fw-semibold">CNIC:</span> <span id="custCnic"></span></div>
                <div class="col-md-3"><span class="fw-semibold">Phone:</span> <span id="custPhone"></span></div>
                <div class="col-md-3"><span class="fw-semibold">Project:</span> <span id="custProject"></span></div>
            </div>
        </div>
        <div id="customerSearchError" class="text-danger mt-2" style="display:none;"></div>
    </div>
</div>

<!-- Payment Selection -->
<div id="paymentsSection" style="display:none;">
    <div class="card mb-4">
        <div class="card-header fw-semibold"><i class="fas fa-money-check-alt me-2"></i>Select Payments to Refund</div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle" id="paymentsTable">
                    <thead class="table-dark">
                        <tr>
                            <th><input type="checkbox" id="selectAll" title="Select All" /></th>
                            <th>#</th>
                            <th>Description</th>
                            <th class="text-end">Amount (PKR)</th>
                            <th>Method</th>
                            <th>Date</th>
                            <th>Ref #</th>
                        </tr>
                    </thead>
                    <tbody id="paymentsTableBody"></tbody>
                    <tfoot>
                        <tr class="table-secondary fw-bold">
                            <td colspan="3" class="text-end">Selected Total:</td>
                            <td class="text-end" id="selectedTotal">PKR 0</td>
                            <td colspan="3"></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

    <!-- Refund Form -->
    <form asp-action="Create" method="post" id="refundForm" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" name="CustomerID" id="hiddenCustomerId" />
        <input type="hidden" name="PaidAmount" id="hiddenPaidAmount" value="0" />
        <input type="hidden" name="selectedPaymentIdsJson" id="hiddenSelectedIds" />

        <div class="card mb-4">
            <div class="card-header fw-semibold"><i class="fas fa-file-invoice me-2"></i>Refund Details</div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Refund Type <span class="text-danger">*</span></label>
                        <select name="RefundType" class="form-select" required>
                            <option value="">-- Select --</option>
                            <option value="Full">Full</option>
                            <option value="Partial">Partial</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Paid Amount (PKR)</label>
                        <input type="number" id="paidAmountDisplay" class="form-control" readonly style="background:#f8f9fa;" />
                        <small class="text-muted">Auto-calculated from selected payments</small>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Deduction Amount (PKR)</label>
                        <input type="number" name="DeductionAmount" id="deductionInput" class="form-control" value="0" min="0" step="0.01" />
                        <small class="text-muted">Fees or charges to withhold</small>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Refunded Amount (PKR)</label>
                        <input type="number" name="RefundedAmount" id="refundedAmountDisplay" class="form-control" readonly style="background:#e8f5e9; font-weight:600;" />
                        <small class="text-muted">Paid Amount − Deduction</small>
                    </div>
                    <div class="col-md-8">
                        <label class="form-label fw-semibold">Reason <span class="text-danger">*</span></label>
                        <input type="text" name="Reason" class="form-control" required maxlength="255" placeholder="Reason for refund" />
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Notes</label>
                        <textarea name="Notes" class="form-control" rows="2" maxlength="500" placeholder="Additional notes (optional)"></textarea>
                    </div>
                    <div class="col-md-6">
                        <label for="refundAttachment" class="form-label fw-semibold">
                            <i class="fas fa-paperclip me-1"></i>Attachment (Optional)
                        </label>
                        <input type="file" name="refundAttachment" id="refundAttachment" class="form-control" accept=".jpg,.jpeg,.png,.gif,.bmp,.pdf" />
                        <small class="text-muted d-block mt-1">Allowed: JPG, PNG, GIF, BMP, PDF (max 8MB)</small>
                    </div>
                    <div class="col-md-6">
                        <label for="refundAttachmentDescription" class="form-label fw-semibold">
                            <i class="fas fa-file-alt me-1"></i>Attachment Title / Notes (Optional)
                        </label>
                        <input type="text" name="refundAttachmentDescription" id="refundAttachmentDescription" class="form-control" maxlength="500" placeholder="e.g. Approval Note, Bank Slip" />
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-success" id="submitBtn">
                <i class="fas fa-save me-2"></i>Submit Refund
            </button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
<script>
(function () {
    let payments = [];

    function formatPKR(n) {
        return 'PKR ' + Number(n).toLocaleString('en-PK', { minimumFractionDigits: 0, maximumFractionDigits: 2 });
    }

    $('#searchCustomerBtn').on('click', searchCustomer);
    $('#customerIdInput').on('keypress', function (e) {
        if (e.key === 'Enter') { e.preventDefault(); searchCustomer(); }
    });

    function searchCustomer() {
        var id = $('#customerIdInput').val().trim();
        if (!id) return;
        $('#customerSearchError').hide();
        $.post('@Url.Action("SearchCustomerForRefund")', { customerId: id }, function (res) {
            if (!res.success) {
                $('#customerSearchError').text(res.message).show();
                $('#customerInfoPanel').hide();
                $('#paymentsSection').hide();
                return;
            }
            $('#custName').text(res.fullName);
            $('#custCnic').text(res.cnic);
            $('#custPhone').text(res.phone);
            $('#custProject').text(res.project);
            $('#customerInfoPanel').show();
            $('#hiddenCustomerId').val(res.customerID);
            payments = res.payments;
            renderPayments();
            $('#paymentsSection').show();
        }).fail(function () {
            $('#customerSearchError').text('Error searching customer. Try again.').show();
        });
    }

    function renderPayments() {
        var tbody = $('#paymentsTableBody').empty();
        if (!payments || payments.length === 0) {
            tbody.append('<tr><td colspan="7" class="text-center text-muted py-3">No payments found for this customer.</td></tr>');
            recalc();
            return;
        }
        payments.forEach(function (p) {
            var row = `<tr>
                <td><input type="checkbox" class="pay-check" data-amount="${p.amount}" data-id="${p.paymentId}" /></td>
                <td>${p.installmentNo ?? '—'}</td>
                <td>${p.description}</td>
                <td class="text-end">${formatPKR(p.amount)}</td>
                <td>${p.method}</td>
                <td>${p.date}</td>
                <td>${p.referenceNo}</td>
            </tr>`;
            tbody.append(row);
        });
        recalc();
    }

    $(document).on('change', '.pay-check', recalc);
    $('#selectAll').on('change', function () {
        $('.pay-check').prop('checked', $(this).is(':checked'));
        recalc();
    });
    $('#deductionInput').on('input', recalc);

    function recalc() {
        var total = 0;
        var ids = [];
        $('.pay-check:checked').each(function () {
            total += parseFloat($(this).data('amount')) || 0;
            ids.push($(this).data('id'));
        });
        var deduction = parseFloat($('#deductionInput').val()) || 0;
        var refunded = total - deduction;
        if (refunded < 0) refunded = 0;
        $('#paidAmountDisplay').val(total.toFixed(2));
        $('#hiddenPaidAmount').val(total.toFixed(2));
        $('#refundedAmountDisplay').val(refunded.toFixed(2));
        $('#selectedTotal').text(formatPKR(total));
        $('#hiddenSelectedIds').val(JSON.stringify(ids));
    }
})();
</script>
}
