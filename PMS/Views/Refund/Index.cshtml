@model IEnumerable<PMS.Models.Refund>
@{
    ViewData["Title"] = "Refunds";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h2 class="mb-0"><i class="fas fa-undo-alt me-2"></i>Refunds</h2>
    @if (ViewBag.CanCreate == true)
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>New Refund
        </a>
    }
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Summary Cards -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-4">
        <a href="@Url.Action("Index", new { workflowFilter = "Initiated" })" class="text-decoration-none">
            <div class="card border-0 h-100" style="background:#fff3cd;">
                <div class="card-body text-center py-3">
                    <div class="small text-muted text-uppercase fw-semibold">Initiated</div>
                    <div class="fs-3 fw-bold text-warning">@(ViewBag.InitiatedCount ?? 0)</div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-6 col-md-4">
        <a href="@Url.Action("Index", new { workflowFilter = "Approved" })" class="text-decoration-none">
            <div class="card border-0 h-100" style="background:#d4edda;">
                <div class="card-body text-center py-3">
                    <div class="small text-muted text-uppercase fw-semibold">Approved</div>
                    <div class="fs-3 fw-bold text-success">@(ViewBag.ApprovedCount ?? 0)</div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-6 col-md-4">
        <a href="@Url.Action("Index", new { workflowFilter = "Declined" })" class="text-decoration-none">
            <div class="card border-0 h-100" style="background:#f8d7da;">
                <div class="card-body text-center py-3">
                    <div class="small text-muted text-uppercase fw-semibold">Declined</div>
                    <div class="fs-3 fw-bold text-danger">@(ViewBag.DeclinedCount ?? 0)</div>
                </div>
            </div>
        </a>
    </div>
</div>

<!-- Filters -->
<form method="get" asp-action="Index" class="mb-4">
    <div class="card">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Status</label>
                    <select name="workflowFilter" class="form-select form-select-sm" onchange="this.form.submit()">
                        <option value="">All</option>
                        @foreach (var s in (ViewBag.WorkflowStatuses as List<string> ?? new List<string>()))
                        {
                            <option value="@s" selected="@(ViewBag.WorkflowFilter == s)">@s</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Customer ID</label>
                    <div class="input-group input-group-sm">
                        <input type="text" name="customerFilter" class="form-control" placeholder="Filter by customer" value="@ViewBag.CustomerFilter" />
                        <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i></button>
                    </div>
                </div>
                <div class="col-md-4">
                    <a asp-action="Index" class="btn btn-secondary btn-sm"><i class="fas fa-times me-1"></i>Clear</a>
                </div>
            </div>
        </div>
    </div>
</form>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle" id="refundTable">
                <thead class="table-dark">
                    <tr>
                        <th>Refund ID</th>
                        <th>Customer</th>
                        <th>Type</th>
                        <th class="text-end">Paid (PKR)</th>
                        <th class="text-end">Deduction</th>
                        <th class="text-end">Refunded</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        var wf = r.WorkflowStatus ?? "Initiated";
                        var badge = wf == "Approved" ? "bg-success" : wf == "Declined" ? "bg-danger" : "bg-warning text-dark";
                        <tr>
                            <td><code>@r.RefundID</code></td>
                            <td>
                                <div><code>@r.CustomerID</code></div>
                                <div class="small text-muted">@(r.Customer?.FullName ?? "—")</div>
                            </td>
                            <td><span class="badge bg-secondary">@(r.RefundType ?? "—")</span></td>
                            <td class="text-end">@r.PaidAmount.ToString("N0")</td>
                            <td class="text-end text-danger">@r.DeductionAmount.ToString("N0")</td>
                            <td class="text-end fw-bold text-success">@r.RefundedAmount.ToString("N0")</td>
                            <td><span class="badge @badge">@wf</span></td>
                            <td>@r.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@r.RefundID" class="btn btn-sm btn-outline-info" title="Details">
                                    <i class="fas fa-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
    $(document).ready(function () {
        $('#refundTable').DataTable({
            pageLength: 25,
            order: [[7, 'desc']],
            columnDefs: [{ orderable: false, targets: 8 }]
        });
    });
</script>
}
