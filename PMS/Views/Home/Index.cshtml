    <!-- Chart 2: Monthly Payment Collection -->
    <div class="col-md-6 mb-3">
        <div class="card">
            <div class="card-header">
                <h6 class="card-title mb-0">
                    <i class="fas fa-chart-line me-2" style="color: var(--accent-gold);"></i>Monthly Payment Collection
                </h6>
            </div>
            <div class="card-body">
                <canvas id="monthlyPaymentsChart" height="250"></canvas>
            </div>
        </div>
