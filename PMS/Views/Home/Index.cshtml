@model PMS.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    var monthlyRevenue = Model.MonthlyPaymentsData.Any()
        ? Model.MonthlyPaymentsData.Last().Value
        : Model.TotalPayments;
    var pendingRequests = Model.PendingTransfers + Model.PendingAllotments + Model.PendingWaivers
        + Model.PendingRefunds + Model.PendingCustomers;
    string FormatCurrency(decimal value)
    {
        if (value >= 1_000_000m) return $"{(value / 1_000_000m):0.##}M";
        if (value >= 1_000m) return $"{(value / 1_000m):0.#}K";
        return value.ToString("N0");
    }
}

<div class="pms-dashboard">
    <!-- KPI Cards -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-xl-2">
            <div class="pms-kpi-card">
                <div class="pms-kpi-icon blue"><i class="bi bi-buildings" aria-hidden="true"></i></div>
                <div class="pms-kpi-value">@Model.TotalProperties</div>
                <div class="pms-kpi-label">Total Properties</div>
            </div>
        </div>
        <div class="col-6 col-xl-2">
            <div class="pms-kpi-card">
                <div class="pms-kpi-icon green"><i class="bi bi-door-open" aria-hidden="true"></i></div>
                <div class="pms-kpi-value">@Model.AllottedProperties</div>
                <div class="pms-kpi-label">Occupied Units</div>
            </div>
        </div>
        <div class="col-6 col-xl-2">
            <div class="pms-kpi-card">
                <div class="pms-kpi-icon amber"><i class="bi bi-house" aria-hidden="true"></i></div>
                <div class="pms-kpi-value">@Model.AvailableProperties</div>
                <div class="pms-kpi-label">Vacant Units</div>
            </div>
        </div>
        <div class="col-6 col-xl-2">
            <div class="pms-kpi-card">
                <div class="pms-kpi-icon indigo"><i class="bi bi-people" aria-hidden="true"></i></div>
                <div class="pms-kpi-value">@Model.TotalCustomers</div>
                <div class="pms-kpi-label">Total Residents</div>
            </div>
        </div>
        <div class="col-6 col-xl-2">
            <div class="pms-kpi-card">
                <div class="pms-kpi-icon red"><i class="bi bi-tools" aria-hidden="true"></i></div>
                <div class="pms-kpi-value">@pendingRequests</div>
                <div class="pms-kpi-label">Pending Requests</div>
            </div>
        </div>
        <div class="col-6 col-xl-2">
            <div class="pms-kpi-card">
                <div class="pms-kpi-icon slate"><i class="bi bi-cash-stack" aria-hidden="true"></i></div>
                <div class="pms-kpi-value">@FormatCurrency(monthlyRevenue)</div>
                <div class="pms-kpi-label">Monthly Revenue (PKR)</div>
            </div>
        </div>
    </div>

    <!-- Charts -->
    <div class="row g-3 mb-4">
        <div class="col-lg-6">
            <div class="pms-panel">
                <div class="pms-panel-header">
                    <h6><i class="bi bi-pie-chart me-2 text-primary" aria-hidden="true"></i>Occupancy Rate</h6>
                </div>
                <div class="pms-panel-body">
                    <div class="pms-chart-wrap">
                        <canvas id="propertyStatusChart" aria-label="Occupancy rate chart"></canvas>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="pms-panel">
                <div class="pms-panel-header">
                    <h6><i class="bi bi-clipboard-data me-2 text-primary" aria-hidden="true"></i>Collection Status</h6>
                </div>
                <div class="pms-panel-body">
                    <div class="pms-chart-wrap">
                        <canvas id="paymentStatusChart" aria-label="Payment and collection status chart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const colors = {
            primary: '#2563eb',
            primaryLight: '#3b82f6',
            accent: '#1d4ed8',
            accentGold: '#f59e0b',
            success: '#10b981',
            warning: '#f59e0b',
            danger: '#ef4444',
            info: '#0ea5e9'
        };

        const propertyStatusCtx = document.getElementById('propertyStatusChart').getContext('2d');
        new Chart(propertyStatusCtx, {
            type: 'doughnut',
            data: {
                labels: [@Html.Raw(string.Join(",", Model.PropertyStatusData.Keys.Select(k => $"'{k}'")))],
                datasets: [{
                    data: [@string.Join(",", Model.PropertyStatusData.Values)],
                    backgroundColor: [colors.success, colors.warning, colors.danger, colors.info, colors.accentGold],
                    borderWidth: 2,
                    borderColor: '#fff'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: { padding: 12, font: { size: 11, family: 'Inter' } }
                    }
                }
            }
        });

        const paymentStatusCtx = document.getElementById('paymentStatusChart').getContext('2d');
        new Chart(paymentStatusCtx, {
            type: 'bar',
            data: {
                labels: [@Html.Raw(string.Join(",", Model.PaymentStatusData.Keys.Select(k => $"'{k}'")))],
                datasets: [{
                    label: 'Count',
                    data: [@string.Join(",", Model.PaymentStatusData.Values)],
                    backgroundColor: [colors.danger, colors.warning, colors.info, colors.success],
                    borderRadius: 8
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: { x: { beginAtZero: true, ticks: { stepSize: 1 } } }
            }
        });
    </script>
}
