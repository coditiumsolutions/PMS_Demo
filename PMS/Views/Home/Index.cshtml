        <div class="card">
            <div class="card-header">
                <h6 class="card-title mb-0">
                    <i class="fas fa-exclamation-triangle me-2" style="color: #dc3545;"></i>Payment Status Overview
                </h6>
            </div>
            <div class="card-body">
                <canvas id="paymentStatusChart" height="250"></canvas>
            </div>
