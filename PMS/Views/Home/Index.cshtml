    }

    /* List Group Items */
    .list-group-item {
        border: none;
        padding: 12px 0;
        border-bottom: 1px solid var(--border);
    }

    .list-group-item:last-child {
        border-bottom: none;
    }

    /* Responsive */
    @@media (max-width: 991.98px) {
        .dashboard-banner-content {
            flex-direction: column;
        }

        .dashboard-meta {
            width: 100%;
            text-align: left !important;
        }

        .dashboard-user {
            display: inline-flex;
        }
    }

    @@media (max-width: 575.98px) {
        .dashboard-banner {
            padding: 14px;
        }

        .dashboard-title {
            font-size: 18px;
        }

        .dashboard-subtitle {
            font-size: 11px;
        }

        .dashboard-date {
            font-size: 11px;
            padding: 6px 10px;
            margin-top: 6px;
        }

        .dashboard-user {
            font-size: 11px;
            padding: 6px 10px;
        }

        .stats-card .stats-number {
            font-size: 1.35rem;
        }

        .stats-card .stats-label {
            font-size: 11px;
        }

        .stats-card {
            padding: 14px 10px;
        }

        .report-link {
            padding: 10px;
        }

        .report-link strong {
            font-size: 0.85rem;
        }

        .report-link small {
            font-size: 0.7rem;
        }

        .theme-btn {
            padding: 4px 8px;
            font-size: 11px;
        }
    }
</style>

@section Scripts {
    <script>
        // Theme switcher (persists in localStorage, applies site-wide)
        (function () {
            var storageKey = 'pms-theme';
            function applyTheme(theme) {
                theme = theme || 'original';
                document.documentElement.setAttribute('data-theme', theme);
                try { localStorage.setItem(storageKey, theme); } catch (e) {}
                document.querySelectorAll('.theme-btn').forEach(function (btn) {
                    btn.classList.toggle('active', btn.getAttribute('data-theme') === theme);
                });
            }
            document.querySelectorAll('.theme-btn').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    applyTheme(this.getAttribute('data-theme'));
                });
            });
            var current = document.documentElement.getAttribute('data-theme') || 'original';
            document.querySelectorAll('.theme-btn').forEach(function (btn) {
                btn.classList.toggle('active', btn.getAttribute('data-theme') === current);
            });
        })();

        // JUBA Smart City Theme Colors - Purple Palette
        const colors = {
            primary: '#9C6ADE',
            primaryLight: '#C9B3FF',
            accent: '#E879F9',
            accentGold: '#f59e0b',
            success: '#10b981',
            warning: '#f59e0b',
            danger: '#ef4444',
            info: '#3b82f6'
        };

        // Chart 1: Property Status Distribution (Doughnut Chart)
        const propertyStatusCtx = document.getElementById('propertyStatusChart').getContext('2d');
        new Chart(propertyStatusCtx, {
            type: 'doughnut',
            data: {
                labels: [@Html.Raw(string.Join(",", Model.PropertyStatusData.Keys.Select(k => $"'{k}'")))],
                datasets: [{
                    data: [@string.Join(",", Model.PropertyStatusData.Values)],
                    backgroundColor: [colors.success, colors.warning, colors.danger, colors.info, colors.accentGold],
                    borderWidth: 2,
                    borderColor: '#fff'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            padding: 15,
                            font: { size: 12, family: 'Inter' }
                        }
                    },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                const total = context.dataset.data.reduce((a, b) => a + b, 0);
                                const percentage = ((context.parsed / total) * 100).toFixed(1);
                                return context.label + ': ' + context.parsed + ' (' + percentage + '%)';
                            }
                        }
                    }
                }
            }
        });

        // Chart 2: Monthly Payment Collection (Bar Chart)
        const monthlyPaymentsCtx = document.getElementById('monthlyPaymentsChart').getContext('2d');
        new Chart(monthlyPaymentsCtx, {
            type: 'bar',
            data: {
                labels: [@Html.Raw(string.Join(",", Model.MonthlyPaymentsData.Keys.Select(k => $"'{k}'")))],
                datasets: [{
                    label: 'Payments (PKR)',
                    data: [@string.Join(",", Model.MonthlyPaymentsData.Values)],
                    backgroundColor: colors.primary,
                    borderColor: colors.primaryLight,
                    borderWidth: 1,
                    borderRadius: 8
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                return 'PKR ' + context.parsed.y.toLocaleString('en-US', {minimumFractionDigits: 2});
                            }
                        }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            callback: function(value) {
                                return 'PKR ' + value.toLocaleString('en-US');
                            }
                        }
                    }
                }
            }
        });

        // Chart 3: Payment Status Overview (Horizontal Bar Chart)
        const paymentStatusCtx = document.getElementById('paymentStatusChart').getContext('2d');
        new Chart(paymentStatusCtx, {
            type: 'bar',
            data: {
                labels: [@Html.Raw(string.Join(",", Model.PaymentStatusData.Keys.Select(k => $"'{k}'")))],
                datasets: [{
                    label: 'Count',
                    data: [@string.Join(",", Model.PaymentStatusData.Values)],
                    backgroundColor: [colors.danger, colors.warning, colors.info, colors.success],
                    borderWidth: 0,
                    borderRadius: 8
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    x: {
                        beginAtZero: true,
                        ticks: { stepSize: 1 }
                    }
                }
            }
        });

        // Chart 4: Customer Registration Trend (Line Chart)
        const customerTrendCtx = document.getElementById('customerTrendChart').getContext('2d');
        new Chart(customerTrendCtx, {
            type: 'line',
            data: {
                labels: [@Html.Raw(string.Join(",", Model.CustomerTrendData.Keys.Select(k => $"'{k}'")))],
                datasets: [{
                    label: 'New Customers',
                    data: [@string.Join(",", Model.CustomerTrendData.Values)],
                    borderColor: colors.primary,
                    backgroundColor: 'rgba(156, 106, 222, 0.1)',
                    borderWidth: 3,
                    fill: true,
                    tension: 0.4,
                    pointRadius: 5,
                    pointBackgroundColor: colors.accent,
                    pointBorderColor: '#fff',
                    pointBorderWidth: 2
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: { stepSize: 1 }
                    }
                }
            }
        });

        // Chart 5: Dealer Performance Overview (Bar Chart)
        @if (Model.DealerData != null && Model.DealerData.Any())
        {
            <text>
            const dealerChartCtx = document.getElementById('dealerChart');
            if (dealerChartCtx) {
                const dealerData = [
                    @foreach (var dealer in Model.DealerData)
                    {
                        <text>{
                            dealershipName: '@Html.Raw(dealer.DealershipName?.Replace("'", "\\'") ?? "")',
                            customers: @dealer.Customers,
                            properties: @dealer.Properties
                        },</text>
                    }
                ];
                
                new Chart(dealerChartCtx.getContext('2d'), {
                    type: 'bar',
                    data: {
                        labels: dealerData.map(d => d.dealershipName.length > 20 ? d.dealershipName.substring(0, 20) + '...' : d.dealershipName),
                        datasets: [
                            {
                                label: 'Customers',
                                data: dealerData.map(d => d.customers),
                                backgroundColor: 'rgba(156, 106, 222, 0.8)',
                                borderColor: '#9C6ADE',
                                borderWidth: 2,
                                borderRadius: 8
                            },
                            {
                                label: 'Properties',
                                data: dealerData.map(d => d.properties),
                                backgroundColor: 'rgba(232, 121, 249, 0.8)',
                                borderColor: '#E879F9',
                                borderWidth: 2,
                                borderRadius: 8
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: true,
                        plugins: {
                            legend: {
                                display: true,
                                position: 'top',
                                labels: {
                                    font: {
                                        family: 'Inter, sans-serif',
                                        size: 12
                                    },
                                    padding: 15,
                                    usePointStyle: true
                                }
                            },
                            tooltip: {
                                backgroundColor: 'rgba(30, 30, 45, 0.9)',
                                padding: 12,
                                titleFont: {
                                    family: 'Inter, sans-serif',
                                    size: 13,
                                    weight: '600'
                                },
                                bodyFont: {
                                    family: 'Inter, sans-serif',
                                    size: 12
                                },
                                cornerRadius: 8,
                                callbacks: {
                                    label: function(context) {
                                        return context.dataset.label + ': ' + context.parsed.y;
                                    }
                                }
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                ticks: {
                                    stepSize: 1,
                                    font: {
                                        family: 'Inter, sans-serif',
                                        size: 11
                                    }
                                },
                                grid: {
                                    color: 'rgba(229, 231, 235, 0.5)'
                                }
                            },
                            x: {
                                ticks: {
                                    font: {
                                        family: 'Inter, sans-serif',
                                        size: 11
                                    }
                                },
                                grid: {
                                    display: false
                                }
                            }
                        }
                    }
                });
            }
            </text>
        }
    </script>
}
