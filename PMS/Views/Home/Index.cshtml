</div>

<!-- Dealer Report Graph -->
<div class="row mb-4">
    <div class="col-12">
        <div class="card card-premium">
            <div class="card-header card-header-premium" style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%); color: white; border: none;">
                <h5 class="mb-0"><i class="fas fa-chart-bar me-2"></i>Dealer Performance Overview</h5>
            </div>
            <div class="card-body">
