@model PMS.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<!-- Dashboard Header Banner -->
<div class="dashboard-banner mb-4">
    <div class="d-flex align-items-start justify-content-between gap-3 dashboard-banner-content">
        <div class="dashboard-intro">
            <h3 class="dashboard-title mb-2">
                <i class="fas fa-tachometer-alt me-2"></i>Dashboard
            </h3>
            <p class="dashboard-subtitle mb-0">Welcome to ZKB - Property Management System</p>
            <div class="theme-switcher mt-2">
                <span class="theme-label me-2">Theme:</span>
                <button type="button" class="theme-btn active" data-theme="original" title="Original theme">Original</button>
                <button type="button" class="theme-btn" data-theme="dark" title="Dark theme">Dark</button>
                <button type="button" class="theme-btn" data-theme="modern" title="Modern theme">Modern</button>
                <span id="server-label" style="font-size:11px;padding:4px 10px;border-radius:20px;background:rgba(255,255,255,0.25);color:white;font-weight:700;border:1px solid rgba(255,255,255,0.5);letter-spacing:.5px;margin-left:4px;display:none;"></span>
            </div>
            <script>
                (function(){
                    var h = window.location.hostname;
                    var el = document.getElementById('server-label');
                    if (h === 'localhost' || h === '127.0.0.1') {
                        el.innerHTML = '<span style="color:#4ade80;">&#9679;</span> Server 1';
                        el.title = 'Running on localhost (dev)';
                        el.style.display = 'inline';
                    } else if (h === '172.20.228.2') {
                        el.innerHTML = '<span style="color:#fb923c;">&#9679;</span> Server 2';
                        el.title = 'Running on IIS (172.20.228.2)';
                        el.style.display = 'inline';
                    }
                })();
            </script>
        </div>
        <div class="text-end dashboard-meta">
            <div class="dashboard-date">
                <i class="far fa-calendar-alt me-2"></i>
                <span>@DateTime.Now.ToString("MMMM dd, yyyy")</span>
            </div>
            <div class="dashboard-user mt-2">
                <i class="fas fa-user me-2"></i>
                <span>Logged in as @User.Identity?.Name</span>
            </div>
        </div>
    </div>
</div>

<!-- Statistics Cards -->
<div class="dashboard-stats row mb-4">
    <div class="col-6 col-lg-3 mb-3">
        <div class="stats-card">
            <div class="stats-number">@Model.TotalCustomers</div>
            <div class="stats-label">Total Customers</div>
            <i class="fas fa-users fa-2x text-primary mt-2" style="color: var(--primary-light) !important;"></i>
        </div>
    </div>
    <div class="col-6 col-lg-3 mb-3">
        <div class="stats-card">
            <div class="stats-number">@Model.TotalProjects</div>
            <div class="stats-label">Total Projects</div>
            <i class="fas fa-building fa-2x mt-2" style="color: var(--primary-light) !important;"></i>
        </div>
    </div>
    <div class="col-6 col-lg-3 mb-3">
        <div class="stats-card">
            <div class="stats-number">@Model.TotalProperties</div>
            <div class="stats-label">Total Properties</div>
            <i class="fas fa-home fa-2x mt-2" style="color: var(--primary-light) !important;"></i>
        </div>
    </div>
    <div class="col-6 col-lg-3 mb-3">
        <div class="stats-card">
            <div class="stats-number">
                @{
                    var totalPayments = Model.TotalPayments;
                    string formattedPayments;
                    
                    if (totalPayments >= 1000000)
                    {
                        formattedPayments = $"{(totalPayments / 1000000):0.##}m";
                    }
                    else if (totalPayments >= 1000)
                    {
                        formattedPayments = $"{(totalPayments / 1000):0.#}k";
                    }
                    else
                    {
                        formattedPayments = $"{totalPayments:N0}";
                    }
                }
                @formattedPayments
            </div>
            <div class="stats-label">Total Payments (PKR)</div>
            <i class="fas fa-dollar-sign fa-2x mt-2" style="color: var(--primary-light) !important;"></i>
        </div>
    </div>
</div>

@if (Model.ShowPendingTasks)
{
    <!-- Pending Tasks -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h6 class="card-title mb-0">
                        <i class="fas fa-tasks me-2" style="color: var(--warning);"></i>Pending Tasks
                    </h6>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-6 col-md-4 pending-task-col">
                            <a href="@Url.Action("Index", "Customer", new { statusFilter = "Pending" })" class="report-link pending-task-link">
                                <span class="report-icon"><i class="fas fa-user-clock"></i></span>
                                <span>
                                    <strong>Pending Customers</strong>
                                    <small>@Model.PendingCustomers</small>
                                </span>
                            </a>
                        </div>
                        <div class="col-6 col-md-4 pending-task-col">
                            <a href="@Url.Action("UpdateRequests", "Customer", new { status = "Pending" })" class="report-link pending-task-link">
                                <span class="report-icon"><i class="fas fa-clipboard-check"></i></span>
                                <span>
                                    <strong>Pending Customer Update Requests</strong>
                                    <small>@Model.PendingCustomerUpdateRequests</small>
                                </span>
                            </a>
                        </div>
                        <div class="col-6 col-md-4 pending-task-col">
                            <a href="@Url.Action("Index", "Waiver", new { statusFilter = Model.PendingWaiverStatusFilter })" class="report-link pending-task-link">
                                <span class="report-icon"><i class="fas fa-file-signature"></i></span>
                                <span>
                                    <strong>Pending Waivers</strong>
                                    <small>@Model.PendingWaivers</small>
                                </span>
                            </a>
                        </div>
                        <div class="col-6 col-md-4 pending-task-col">
                            <a href="@Url.Action("Index", "Transfer", new { workflowFilter = "Pending" })" class="report-link pending-task-link">
                                <span class="report-icon"><i class="fas fa-random"></i></span>
                                <span>
                                    <strong>Pending Transfers</strong>
                                    <small>@Model.PendingTransfers</small>
                                </span>
                            </a>
                        </div>
                        <div class="col-6 col-md-4 pending-task-col">
                            <a href="@Url.Action("Index", "Refund", new { workflowFilter = "Pending" })" class="report-link pending-task-link">
                                <span class="report-icon"><i class="fas fa-undo-alt"></i></span>
                                <span>
                                    <strong>Pending Refunds</strong>
                                    <small>@Model.PendingRefunds</small>
                                </span>
                            </a>
                        </div>
                        <div class="col-6 col-md-4 pending-task-col">
                            <a href="@Url.Action("Index", "Allotment", new { statusFilter = "All" })" class="report-link pending-task-link">
                                <span class="report-icon"><i class="fas fa-hand-holding"></i></span>
                                <span>
                                    <strong>Pending Allotments</strong>
                                    <small>@Model.PendingAllotments</small>
                                </span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Reports Hub -->
<div class="row mb-4">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h6 class="card-title mb-0">
                    <i class="fas fa-file-alt me-2" style="color: var(--accent);"></i>Reports Hub
                </h6>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-12 col-sm-6 col-xl-3">
                        <a href="@Url.Action("Defaulters", "Reports")" class="report-link">
                            <span class="report-icon"><i class="fas fa-user-clock"></i></span>
                            <span>
                                <strong>Defaulters</strong>
                                <small>Overdue customers report</small>
                            </span>
                        </a>
                    </div>
                    <div class="col-12 col-sm-6 col-xl-3">
                        <a href="@Url.Action("NotAllotted", "Reports")" class="report-link">
                            <span class="report-icon"><i class="fas fa-map-marked-alt"></i></span>
                            <span>
                                <strong>Not Allotted</strong>
                                <small>Customers without allotment</small>
                            </span>
                        </a>
                    </div>
                    <div class="col-12 col-sm-6 col-xl-3">
                        <a href="@Url.Action("PropertyReport", "Reports")" class="report-link">
                            <span class="report-icon"><i class="fas fa-building"></i></span>
                            <span>
                                <strong>Property Report</strong>
                                <small>Allotted vs not allotted</small>
                            </span>
                        </a>
                    </div>
                    <div class="col-12 col-sm-6 col-xl-3">
                        <a href="@Url.Action("RequestedReport", "Reports", new { id = "daily-transfer-report", title = "Daily Transfer Report" })" class="report-link">
                            <span class="report-icon"><i class="fas fa-exchange-alt"></i></span>
                            <span>
                                <strong>Transfer Activity</strong>
                                <small>Daily transfer analytics</small>
                            </span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Property Status Cards -->
<div class="row mb-4">
    <div class="col-md-6 mb-3">
        <div class="card">
            <div class="card-body">
                <h6 class="card-title mb-3">
                    <i class="fas fa-chart-pie me-2" style="color: var(--primary-light);"></i>Property Status
