                            <small class="text-muted">Available</small>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="text-center">
                            <h2 class="mb-1" style="color: var(--primary-light);">@Model.AllottedProperties</h2>
                            <small class="text-muted">Allotted</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-3">
        <div class="card">
            <div class="card-body">
                <h6 class="card-title mb-3">
                    <i class="fas fa-bolt me-2" style="color: var(--accent);"></i>Quick Actions
                </h6>
                <div class="d-grid gap-2">
                    <a href="@Url.Action("Create", "Customer")" class="btn btn-primary btn-sm">
                        <i class="fas fa-user-plus me-2"></i>Add New Customer
                    </a>
                    <a href="@Url.Action("Create", "Project")" class="btn btn-success btn-sm">
                        <i class="fas fa-plus-circle me-2"></i>Create Project
                    </a>
                    <a href="@Url.Action("Index", "Property")" class="btn btn-outline-primary btn-sm">
                        <i class="fas fa-building me-2"></i>Manage Properties
                    </a>
                    <a href="@Url.Action("Index", "Payment")" class="btn btn-outline-success btn-sm">
                        <i class="fas fa-credit-card me-2"></i>View Payments
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Analytics Charts -->
<div class="row">
    <!-- Chart 1: Property Status Distribution -->
    <div class="col-md-6 mb-3">
        <div class="card">
            <div class="card-header">
                <h6 class="card-title mb-0">
                    <i class="fas fa-chart-pie me-2" style="color: var(--primary-green);"></i>Property Status Distribution
                </h6>
            </div>
            <div class="card-body">
                <canvas id="propertyStatusChart" height="250"></canvas>
