    }

    .report-icon {
        width: 34px;
        height: 34px;
        border-radius: 9px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: rgba(156, 106, 222, 0.12);
        color: var(--primary-light);
        flex-shrink: 0;
    }

    /* Smaller Stats Card Styling */
    .stats-card {
        padding: 20px;
        background: var(--surface);
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
        transition: all 0.2s ease-in-out;
