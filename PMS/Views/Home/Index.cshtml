    <div class="col-md-6 mb-3">
        <div class="card">
            <div class="card-header">
                <h6 class="card-title mb-0">
                    <i class="fas fa-chart-area me-2" style="color: var(--primary-green);"></i>Customer Registration Trend
                </h6>
            </div>
            <div class="card-body">
                <canvas id="customerTrendChart" height="250"></canvas>
            </div>
        </div>
