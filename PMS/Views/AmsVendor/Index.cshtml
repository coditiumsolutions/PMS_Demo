@model List<AccVendor>
@{
    ViewData["Title"] = "Vendors (AP)";
}
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <partial name="_AmsExportCsv" model="@("Vendors")" />

    <p class="mb-0 text-muted small">Vendor master. Optional AP GL link per vendor.</p>
    @if (ViewBag.CanCreate == true)
    {
        <a class="btn btn-primary btn-sm" asp-action="Create"><i class="fas fa-plus me-1"></i>New vendor</a>
    }
</div>
<div class="table-responsive">
    <table class="table table-sm table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Code</th>
                <th>Name</th>
                <th>Type</th>
                <th>AP GL</th>
                <th>Active</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var v in Model)
            {
                <tr>
                    <td class="text-nowrap">@v.VendorCode</td>
                    <td>@v.VendorName</td>
                    <td>@v.VendorType</td>
                    <td class="small">@(v.AccountHead != null ? $"{v.AccountHead.AccountCode} — {v.AccountHead.AccountName}" : "—")</td>
                    <td>@(v.IsActive ? "Yes" : "No")</td>
                    <td>
                        @if (ViewBag.CanEdit == true)
                        {
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@v.VendorID">Edit</a>
                        }
                        @if (ViewBag.CanDelete == true)
                        {
                            ViewData["AmsDeleteEntity"] = "vendor";
                            ViewData["AmsDeleteId"] = v.VendorID;
                            <partial name="_AmsDeleteButton" />
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
@if (!Model.Any())
{
    <p class="text-muted">No vendors yet.</p>
}
