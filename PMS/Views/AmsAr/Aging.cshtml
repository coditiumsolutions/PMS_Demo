@model List<AmsArAgingRowVm>
@{
    ViewData["Title"] = "AR aging";
}
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <partial name="_AmsExportCsv" model="@("ArAging")" />

    <p class="mb-0 text-muted small">Open AR by due date (days past due vs today, UTC date).</p>
    <a class="btn btn-outline-secondary btn-sm" asp-action="IndexInvoices">Invoices</a>
</div>
<div class="table-responsive">
    <table class="table table-sm table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Invoice</th>
                <th>Customer</th>
                <th>Due</th>
                <th class="text-end">Balance</th>
                <th class="text-end">Days past due</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model)
            {
                <tr class="@(r.DaysPastDue > 0 ? "table-warning" : null)">
                    <td>@r.InvoiceNo</td>
                    <td>@r.CustomerId</td>
                    <td>@r.DueDate.ToString("yyyy-MM-dd")</td>
                    <td class="text-end">@r.Balance.ToString("N2")</td>
                    <td class="text-end">@r.DaysPastDue</td>
                </tr>
            }
        </tbody>
    </table>
</div>
@if (!Model.Any())
{
    <p class="text-muted">No open AR balances.</p>
}
