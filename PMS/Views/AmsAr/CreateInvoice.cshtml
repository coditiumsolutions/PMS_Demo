@model AccARInvoice
@{
    ViewData["Title"] = "New AR invoice";
    var customers = ViewBag.Customers as IEnumerable<Customer> ?? Array.Empty<Customer>();
    var heads = ViewBag.ArHeads as IEnumerable<AccAccountHead> ?? Array.Empty<AccAccountHead>();
}
<form asp-action="CreateInvoice" method="post">
    @Html.AntiForgeryToken()
    <div class="row g-3">
        <div class="col-md-4">
            <label asp-for="InvoiceNo" class="form-label"></label>
            <input asp-for="InvoiceNo" class="form-control" maxlength="30" required />
            <span asp-validation-for="InvoiceNo" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="CustomerID" class="form-label">Customer</label>
            <select asp-for="CustomerID" class="form-select" required>
                <option value="">— Select —</option>
                @foreach (var c in customers)
                {
                    var cid = (c.CustomerID ?? string.Empty).Trim();
                    <option value="@cid">@cid — @c.FullName</option>
                }
            </select>
        </div>
        <div class="col-md-4">
            <label asp-for="AccountHeadID" class="form-label">AR / revenue GL</label>
            <select asp-for="AccountHeadID" class="form-select ams-ledger-select" required data-placeholder="Search AR / revenue GL…" data-allow-clear="false">
                <option value="0">— Select —</option>
                @foreach (var h in heads)
                {
                    <option value="@h.AccountHeadID">@h.AccountCode — @h.AccountName</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label asp-for="InvoiceDate" class="form-label"></label>
            <input asp-for="InvoiceDate" class="form-control" type="date" />
        </div>
        <div class="col-md-3">
            <label asp-for="DueDate" class="form-label"></label>
            <input asp-for="DueDate" class="form-control" type="date" />
        </div>
        <div class="col-md-3">
            <label asp-for="InvoiceType" class="form-label"></label>
            <input asp-for="InvoiceType" class="form-control" maxlength="50" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Sub-total</label>
            <input asp-for="SubTotal" class="form-control" type="number" step="0.01" />
        </div>
        <div class="col-md-3">
            <label asp-for="TaxAmount" class="form-label"></label>
            <input asp-for="TaxAmount" class="form-control" type="number" step="0.01" />
        </div>
        <div class="col-md-3">
            <label asp-for="DiscountAmount" class="form-label"></label>
            <input asp-for="DiscountAmount" class="form-control" type="number" step="0.01" />
        </div>
        <div class="col-md-3">
            <label asp-for="PMSPaymentScheduleID" class="form-label">PMS schedule ID (opt.)</label>
            <input asp-for="PMSPaymentScheduleID" class="form-control" maxlength="10" />
        </div>
        <div class="col-md-3">
            <label asp-for="PMSPenaltyID" class="form-label">PMS penalty ID (opt.)</label>
            <input asp-for="PMSPenaltyID" class="form-control" maxlength="10" />
        </div>
        <div class="col-12">
            <label asp-for="Notes" class="form-label"></label>
            <textarea asp-for="Notes" class="form-control" rows="2" maxlength="500"></textarea>
        </div>
    </div>
    <div asp-validation-summary="All" class="text-danger mt-2"></div>
    <button type="submit" class="btn btn-primary mt-2">Save</button>
    <a asp-action="IndexInvoices" class="btn btn-outline-secondary mt-2">Cancel</a>
</form>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
