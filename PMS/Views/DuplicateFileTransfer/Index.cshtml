@model IEnumerable<PMS.Models.DuplicateFileTransfer>
@{
    ViewData["Title"] = "Duplicate File Transfer";
    ViewData["ListingTitle"] = "Duplicate File Transfer";
    ViewData["ListingDescription"] = "Duplicate file transfer requests";
    ViewData["ListingRecordCount"] = Model?.Count() ?? 0;
    ViewData["ListingAddUrl"] = ViewBag.CanCreate == true ? Url.Action("Create") : null;
    ViewData["ListingAddText"] = "New Request";
    const string Initiated = "Initiated";
    const string Approved = "Approved";
    const string Declined = "Declined";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-3 mb-4">
    <div class="col-6 col-md-4">
        <a href="@Url.Action("Index", new { workflowFilter = Initiated })" class="text-decoration-none">
            <div class="card border-0 h-100" style="background:#fff3cd;">
                <div class="card-body text-center py-3">
                    <div class="small text-muted text-uppercase fw-semibold">@Initiated</div>
                    <div class="fs-3 fw-bold text-warning">@(ViewBag.InitiatedCount ?? 0)</div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-6 col-md-4">
        <a href="@Url.Action("Index", new { workflowFilter = Approved })" class="text-decoration-none">
            <div class="card border-0 h-100" style="background:#d4edda;">
                <div class="card-body text-center py-3">
                    <div class="small text-muted text-uppercase fw-semibold">@Approved</div>
                    <div class="fs-3 fw-bold text-success">@(ViewBag.ApprovedCount ?? 0)</div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-6 col-md-4">
        <a href="@Url.Action("Index", new { workflowFilter = Declined })" class="text-decoration-none">
            <div class="card border-0 h-100" style="background:#f8d7da;">
                <div class="card-body text-center py-3">
                    <div class="small text-muted text-uppercase fw-semibold">@Declined</div>
                    <div class="fs-3 fw-bold text-danger">@(ViewBag.DeclinedCount ?? 0)</div>
                </div>
            </div>
        </a>
    </div>
</div>

<form method="get" asp-action="Index" class="mb-4 pms-listing-page">
    <div class="pms-listing-search-wrap">
        <div class="row g-2 align-items-end flex-lg-nowrap">
            <div class="col-12 col-md-6 col-lg-3">
                <div class="pms-compact-field pms-select-dropdown">
                    <label for="workflowFilter" class="form-label">Status</label>
                    @{
                        var wfSel = ViewBag.WorkflowFilter as string ?? "";
                    }
                    <select name="workflowFilter" id="workflowFilter" class="form-select" onchange="this.form.submit()">
                        @if (wfSel == "")
                        {
                            <option value="" selected>All</option>
                        }
                        else
                        {
                            <option value="">All</option>
                        }
                        @if (wfSel == Initiated)
                        {
                            <option value="@Initiated" selected>@Initiated</option>
                        }
                        else
                        {
                            <option value="@Initiated">@Initiated</option>
                        }
                        @if (wfSel == Approved)
                        {
                            <option value="@Approved" selected>@Approved</option>
                        }
                        else
                        {
                            <option value="@Approved">@Approved</option>
                        }
                        @if (wfSel == Declined)
                        {
                            <option value="@Declined" selected>@Declined</option>
                        }
                        else
                        {
                            <option value="@Declined">@Declined</option>
                        }
                    </select>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-5">
                <div class="pms-compact-field">
                    <label for="customerFilter" class="form-label">Customer ID</label>
                    <input type="text" name="customerFilter" id="customerFilter" class="form-control" placeholder="Filter" value="@ViewBag.CustomerFilter" />
                </div>
            </div>
            <div class="col-12 col-lg-4">
                <div class="d-flex flex-wrap gap-2 pms-listing-search-actions">
                    <button type="submit" class="btn btn-primary btn-sm flex-grow-1">
                        <i class="bi bi-search me-1" aria-hidden="true"></i>Search
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm flex-grow-1">
                        <i class="bi bi-arrow-counterclockwise me-1" aria-hidden="true"></i>Clear
                    </a>
                </div>
            </div>
        </div>
    </div>
</form>

<div class="card pms-grid-card pms-listing-flat pms-saas-grid pms-listing-page">
    <div class="card-body">
        <partial name="Listing/_GridToolbar" />

        <div class="table-responsive pms-saas-table-wrap">
            <table class="table pms-saas-table" id="dftTable">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Customer</th>
                        <th class="text-end">Fee Due</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th class="pms-saas-th-actions">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        var wf = r.Status ?? Initiated;
                        var pillClass = string.Equals(wf, Approved, StringComparison.OrdinalIgnoreCase) ? "pms-pill--success"
                            : string.Equals(wf, Declined, StringComparison.OrdinalIgnoreCase) ? "pms-pill--danger" : "pms-pill--warning";
                        <tr>
                            <td data-label="ID"><code>@r.Id</code></td>
                            <td data-label="Customer">
                                <div><code>@r.CustomerID</code></div>
                                <div class="small text-muted">@(r.CustomerName ?? "—")</div>
                            </td>
                            <td class="text-end" data-label="Fee Due">@(r.FeeDue.HasValue ? $"PKR {r.FeeDue:N0}" : "—")</td>
                            <td data-label="Status"><span class="pms-pill @pillClass">@wf</span></td>
                            <td data-label="Created"><span class="text-nowrap">@r.CreatedAt.ToString("MMM dd, yyyy")</span></td>
                            <td class="pms-saas-td-actions" data-label="Actions">
                                <div class="pms-row-actions" role="group">
                                    <a asp-action="Details" asp-route-id="@r.Id" class="btn btn-sm btn-outline-secondary" title="Details"><i class="bi bi-eye" aria-hidden="true"></i></a>
                                    @if (string.Equals(wf, Approved, StringComparison.OrdinalIgnoreCase))
                                    {
                                        <a asp-action="DuplicateFileLetter" asp-route-id="@r.Id" target="_blank" class="btn btn-sm btn-outline-success" title="Letter"><i class="bi bi-file-earmark-text" aria-hidden="true"></i></a>
                                    }
                                    @if (ViewBag.CanEdit == true && string.Equals(wf, Initiated, StringComparison.OrdinalIgnoreCase))
                                    {
                                        <a asp-action="Edit" asp-route-id="@r.Id" class="btn btn-sm btn-outline-primary" title="Edit"><i class="bi bi-pencil-square" aria-hidden="true"></i></a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
    $(function () {
        $('#dftTable').DataTable({ pageLength: 25, order: [[4, 'desc']], columnDefs: [{ orderable: false, targets: 5 }] });
    });
</script>
}
