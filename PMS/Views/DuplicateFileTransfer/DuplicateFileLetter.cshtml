@model PMS.Models.DuplicateFileTransfer
@{
    Layout = null;
    ViewData["Title"] = "Duplicate File Issuance Certificate - " + Model.Id;
    var orgName = "ZKB";
    var orgSubName = "Property Management System";
    var headOfficeAddress = "Head Office";
    var fileNo = Model.CustomerID ?? "—";
    var jointOwnerNames = (Model.Customer?.JointOwners ?? new List<PMS.Models.JointOwner>())
        .Select(j => j.JointOwnerName?.Trim())
        .Where(n => !string.IsNullOrWhiteSpace(n))
        .ToList();
    var primaryName = (Model.Customer?.FullName ?? Model.CustomerName ?? "—").Trim();
    var ownerName = jointOwnerNames.Any()
        ? string.Join(" / ", (new[] { primaryName }).Concat(jointOwnerNames.Where(n => !string.Equals(n, primaryName, StringComparison.OrdinalIgnoreCase))))
        : primaryName;
    var cnic = (Model.Customer?.CNIC ?? Model.CustomerCNIC ?? "").Trim();
    var passport = (Model.Customer?.PassportNo ?? "").Trim();
    var cnicPassportLine = !string.IsNullOrEmpty(cnic) && !string.IsNullOrEmpty(passport)
        ? cnic + " / " + passport
        : (!string.IsNullOrEmpty(cnic) ? cnic : (!string.IsNullOrEmpty(passport) ? passport : "—"));
    var phone = (Model.Customer?.Phone ?? "").Trim();
    var mobile = (Model.Customer?.MobileNo ?? "").Trim();
    var contactLine = string.Join(" / ", new[] { phone, mobile }.Where(s => !string.IsNullOrEmpty(s)));
    if (string.IsNullOrEmpty(contactLine)) contactLine = "—";
    var issueDate = DateTime.Now;
    var headerProject = ViewBag.LetterHeaderProject as string ?? "—";
    var scheme = ViewBag.PropertyProjectScheme as string ?? "Not allotted";
    var phaseSector = ViewBag.PropertyPhaseSector as string ?? "Not allotted";
    var plotNo = ViewBag.PropertyPlotNo as string ?? "Not allotted";
    var propSize = ViewBag.PropertySize as string ?? "Not allotted";
    var remarks = string.IsNullOrWhiteSpace(Model.Comments) ? null : Model.Comments.Trim();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Juba Smart City PMS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/juba-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
</head>
<body>

<div class="d-flex justify-content-between align-items-center mb-3 no-print">
    <h3 class="mb-0"><i class="fas fa-file-alt me-2"></i>Duplicate File Issuance Certificate</h3>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-secondary btn-sm" type="button" onclick="window.print()"><i class="fas fa-print me-1"></i>Print</button>
    </div>
</div>

<div class="a4-container">
    <div class="a4-header">
        <div class="header-grid">
            <div class="header-logo-wrap">
                <img src="~/images/logo.jpeg" alt="Organization Logo" class="a4-logo" />
            </div>
            <div class="header-center">
                <div class="org-name">@orgName</div>
                <div class="org-subname">@orgSubName</div>
                <div class="statement-title">Duplicate File Issuance Certificate</div>
            </div>
            <div class="header-meta">
                <div><strong>Date:</strong> @issueDate.ToString("MMM dd, yyyy")</div>
                <div><strong>Ref No:</strong> @Model.Id</div>
                <div><strong>File No:</strong> @fileNo</div>
            </div>
        </div>
        <div class="header-secondary mt-2">
            <div><strong>Head Office:</strong> @headOfficeAddress</div>
            <div><strong>Project (record):</strong> @headerProject</div>
        </div>
    </div>

    <div class="a4-section">
        <p class="certificate-paragraph mt-1">
            This is to certify that the original file pertaining to the below mentioned property has been reported lost/misplaced by the owner/applicant.
            Upon completion of all required formalities, submission of necessary documents, and verification from our official record, a Duplicate File is hereby issued under the following particulars:
        </p>
    </div>

    <div class="a4-section">
        <div class="a4-section-title">Property Details</div>
        <div class="a4-info-block">
            <div class="a4-info-row"><span class="a4-info-label">Project / Scheme:</span><span class="a4-info-value">@scheme</span></div>
            <div class="a4-info-row"><span class="a4-info-label">Phase / Sector:</span><span class="a4-info-value">@phaseSector</span></div>
            <div class="a4-info-row"><span class="a4-info-label">Plot No:</span><span class="a4-info-value">@plotNo</span></div>
            <div class="a4-info-row"><span class="a4-info-label">Size:</span><span class="a4-info-value">@propSize</span></div>
        </div>
    </div>

    <div class="a4-section">
        <div class="a4-section-title">Owner Details</div>
        <div class="a4-info-block">
            <div class="a4-info-row"><span class="a4-info-label">Name:</span><span class="a4-info-value">@ownerName</span></div>
            <div class="a4-info-row"><span class="a4-info-label">CNIC / Passport No:</span><span class="a4-info-value">@cnicPassportLine</span></div>
            <div class="a4-info-row"><span class="a4-info-label">Contact No:</span><span class="a4-info-value">@contactLine</span></div>
        </div>
    </div>

    <div class="a4-section">
        <div class="a4-section-title">Declaration</div>
        <ol class="declaration-list mb-0">
            <li>The original file has been declared lost and is considered null &amp; void.</li>
            <li>In case the original file is found, it must be immediately surrendered to the organization.</li>
            <li>The owner shall be fully responsible for any dispute, claim, or liability arising from the loss of the original file.</li>
            <li>This Duplicate File shall be treated as the valid and official record for all future transactions.</li>
        </ol>
    </div>

    <div class="a4-section">
        <div class="a4-section-title">Request record (system)</div>
        <div class="a4-info-block">
            <div class="a4-info-row"><span class="a4-info-label">Status:</span><span class="a4-info-value">@(Model.Status ?? "—")</span></div>
            <div class="a4-info-row"><span class="a4-info-label">Fee due (PKR):</span><span class="a4-info-value">@(Model.FeeDue.HasValue ? Model.FeeDue.Value.ToString("N2") : "—")</span></div>
            <div class="a4-info-row"><span class="a4-info-label">Fee paid (PKR):</span><span class="a4-info-value">@(Model.FeePaid.HasValue ? Model.FeePaid.Value.ToString("N2") : "—")</span></div>
            <div class="a4-info-row"><span class="a4-info-label">Challan / Reference:</span><span class="a4-info-value">@(Model.ChallanID ?? "—")</span></div>
        </div>
    </div>

    <div class="a4-section">
        <p class="certificate-paragraph mb-1"><strong>Remarks (if any):</strong></p>
        @if (remarks != null)
        {
            <div class="a4-info-block"><p class="mb-0 small">@remarks</p></div>
        }
        else
        {
            <div class="letter-blank-line">________________________________________________________________________________</div>
        }
    </div>

    <div class="a4-section">
        <div class="a4-section-title">Authorized Signatory</div>
        <div class="a4-info-block">
            <div class="a4-info-row"><span class="a4-info-label">Authorized Signatory:</span><span class="a4-info-value letter-blank-line d-inline-block" style="min-width:55%; border-bottom:1px solid #333;">&nbsp;</span></div>
            <div class="a4-info-row mt-2"><span class="a4-info-label">Designation:</span><span class="a4-info-value letter-blank-line d-inline-block" style="min-width:55%; border-bottom:1px solid #333;">&nbsp;</span></div>
        </div>
    </div>

    <div class="a4-footer">
        <div>This certificate relates to duplicate file issuance only and does not, by itself, transfer title or ownership.</div>
        <div>Errors and omissions are subject to correction.</div>
        <div>For queries or feedback, please email: care@zkbeclipse.com</div>
    </div>
</div>

<style>
    .declaration-list {
        font-size: 11px;
        line-height: 1.55;
        color: #2b2b2b;
        padding-left: 1.1rem;
    }
    .declaration-list li { margin-bottom: 6px; }

    .letter-blank-line {
        font-size: 11px;
        color: #333;
        letter-spacing: 1px;
    }

    .a4-container {
        width: 210mm;
        min-height: 297mm;
        margin: 0 auto;
        padding: 15mm;
        background: white;
        box-shadow: 0 0 10px rgba(0,0,0,0.1);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        overflow: hidden;
    }

    .a4-header {
        border-bottom: 2px solid #333;
        padding-bottom: 10px;
        margin-bottom: 12px;
    }

    .header-grid {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 8px;
    }

    .header-logo-wrap {
        display: flex;
        align-items: center;
        justify-content: flex-start;
    }

    .header-center {
        text-align: center;
    }

    .org-name {
        font-size: 18px;
        font-weight: 700;
        letter-spacing: .4px;
        color: #111;
        line-height: 1.1;
        text-transform: uppercase;
    }

    .org-subname {
        font-size: 11px;
        color: #666;
        margin-top: 2px;
        line-height: 1.2;
    }

    .statement-title {
        margin-top: 6px;
        font-size: 13px;
        font-weight: 700;
        color: #222;
        text-transform: uppercase;
        letter-spacing: .4px;
    }

    .header-meta {
        font-size: 11px;
        color: #333;
        text-align: right;
        line-height: 1.45;
        justify-self: end;
    }

    .header-secondary {
        margin-top: 8px;
        padding-top: 8px;
        border-top: 1px dashed #ddd;
        display: flex;
        justify-content: space-between;
        gap: 12px;
        font-size: 11px;
        color: #444;
    }

    .a4-section {
        margin-bottom: 12px;
    }

    .a4-section-title {
        font-size: 13px;
        font-weight: 700;
        color: #333;
        margin-bottom: 8px;
        padding-bottom: 3px;
        border-bottom: 1px solid #ddd;
    }

    .certificate-paragraph {
        font-size: 11px;
        line-height: 1.55;
        color: #2b2b2b;
        margin: 0;
        text-align: justify;
    }

    .a4-info-block {
        background: #fafafa;
        padding: 10px;
        border-radius: 2px;
        border: 1px solid #d9d9d9;
        margin-bottom: 0;
    }

    .a4-info-row {
        display: flex;
        justify-content: space-between;
        gap: 10px;
        margin-bottom: 4px;
        font-size: 11px;
    }

    .a4-info-label {
        font-weight: 600;
        color: #555;
        white-space: nowrap;
    }

    .a4-info-value {
        color: #333;
        text-align: right;
    }

    .a4-footer {
        margin-top: 14px;
        padding-top: 8px;
        border-top: 1px solid #ddd;
        font-size: 9px;
        color: #666;
        text-align: center;
    }

    .a4-logo {
        max-width: 80px;
        max-height: 80px;
        object-fit: contain;
    }

    @@media print {
        @@page { size: A4; margin: 0; }
        body { margin: 0; padding: 0; background: white; }
        .a4-container { width: 210mm; min-height: 297mm; margin: 0; padding: 12mm; box-shadow: none; }
        .no-print { display: none !important; }
    }

    @@media screen {
        body { background: #f5f5f5; padding: 20px; }
        .a4-container { margin: 20px auto; }
    }
</style>
</body>
</html>
