@model IEnumerable<PMS.Models.Payment>

@{
    ViewData["Title"] = "Payment Audit";
    int pendingCount  = ViewBag.PendingCount  ?? 0;
    int approvedCount = ViewBag.ApprovedCount ?? 0;
    int declinedCount = ViewBag.DeclinedCount ?? 0;
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h2 class="mb-0"><i class="fas fa-search-dollar me-2"></i>Payment Audit</h2>
    <a href="@Url.Action("Index", "Home")" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-arrow-left me-1"></i>Back to Workspace
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Summary Cards -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-4">
        <a href="@Url.Action("Index", new { auditFilter = "Pending" })" class="text-decoration-none">
            <div class="card border-0 h-100" style="background:#fff3cd;">
                <div class="card-body text-center py-3">
                    <div class="small text-muted text-uppercase fw-semibold">Pending</div>
                    <div class="fs-3 fw-bold text-warning">@pendingCount</div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-6 col-md-4">
        <a href="@Url.Action("Index", new { auditFilter = "Approved" })" class="text-decoration-none">
            <div class="card border-0 h-100" style="background:#d4edda;">
                <div class="card-body text-center py-3">
                    <div class="small text-muted text-uppercase fw-semibold">Approved</div>
                    <div class="fs-3 fw-bold text-success">@approvedCount</div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-6 col-md-4">
        <a href="@Url.Action("Index", new { auditFilter = "Declined" })" class="text-decoration-none">
            <div class="card border-0 h-100" style="background:#f8d7da;">
                <div class="card-body text-center py-3">
                    <div class="small text-muted text-uppercase fw-semibold">Declined</div>
                    <div class="fs-3 fw-bold text-danger">@declinedCount</div>
                </div>
            </div>
        </a>
    </div>
</div>

<!-- Filters -->
<form method="get" asp-action="Index" class="mb-4">
    <div class="card">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Audit Status</label>
                    <select name="auditFilter" class="form-select form-select-sm" onchange="this.form.submit()">
                        <option value="" selected="@(string.IsNullOrEmpty(ViewBag.AuditFilter as string))">All</option>
                        <option value="Pending"  selected="@(ViewBag.AuditFilter == "Pending")">Pending</option>
                        <option value="Approved" selected="@(ViewBag.AuditFilter == "Approved")">Approved</option>
                        <option value="Declined" selected="@(ViewBag.AuditFilter == "Declined")">Declined</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Customer ID</label>
                    <div class="input-group input-group-sm">
                        <input type="text" name="customerFilter" class="form-control" placeholder="Filter by customer ID" value="@ViewBag.CustomerFilter" />
                        <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i></button>
                    </div>
                </div>
                <div class="col-md-4">
                    <a asp-action="Index" class="btn btn-secondary btn-sm"><i class="fas fa-times me-1"></i>Clear</a>
                </div>
            </div>
        </div>
    </div>
</form>

<!-- Payments Table -->
<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle pms-enterprise-table align-middle" id="auditTable">
                <thead>
                    <tr>
                        <th>Payment ID</th>
                        <th>Customer</th>
                        <th>Installment</th>
                        <th class="text-end">Amount (PKR)</th>
                        <th>Method</th>
                        <th>Payment Date</th>
                        <th>Audit Status</th>
                        <th>Audited By</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        var auditStatus = p.AuditStatus ?? "Pending";
                        var badgeClass  = auditStatus == "Approved" ? "bg-success"
                                        : auditStatus == "Declined" ? "bg-danger"
                                        : "bg-warning text-dark";
                        <tr>
                            <td><code>@p.PaymentID</code></td>
                            <td>
                                <div><code>@p.CustomerID</code></div>
                                <div class="small text-muted">@(p.Customer?.FullName ?? "—")</div>
                            </td>
                            <td>
                                <div class="small">@(p.PaymentSchedule?.PaymentDescription ?? "—")</div>
                                @if (p.PaymentSchedule?.InstallmentNo != null)
                                {
                                    <span class="badge bg-light text-dark border">#@p.PaymentSchedule.InstallmentNo</span>
                                }
                            </td>
                            <td class="text-end fw-semibold">@p.Amount.ToString("N0")</td>
                            <td>@(p.Method ?? "—")</td>
                            <td>@p.PaymentDate.ToString("MMM dd, yyyy")</td>
                            <td><span class="badge @badgeClass">@auditStatus</span></td>
                            <td>
                                @if (!string.IsNullOrEmpty(p.AuditedBy))
                                {
                                    <div class="small">@(p.AuditedByUser?.UserID ?? p.AuditedBy)</div>
                                    <div class="small text-muted">@p.AuditedAt?.ToString("MMM dd, yyyy")</div>
                                }
                                else
                                {
                                    <span class="text-muted small">—</span>
                                }
                            </td>
                            <td>
                                <div class="btn-group" role="group">
                                    @if (ViewBag.CanEdit == true && auditStatus == "Pending")
                                    {
                                        <a asp-action="Audit" asp-route-id="@p.PaymentID" class="btn btn-sm btn-primary" title="Audit this payment">
                                            <i class="fas fa-gavel me-1"></i>Audit
                                        </a>
                                    }
                                    else
                                    {
                                        <a asp-action="Audit" asp-route-id="@p.PaymentID" class="btn btn-sm btn-outline-info" title="View audit details">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                    }
                                    @if (ViewBag.CanAdmin == true && auditStatus != "Pending")
                                    {
                                        <form asp-action="ResetAudit" method="post" class="d-inline"
                                              onsubmit="return confirm('Reset audit status to Pending for @p.PaymentID?')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="paymentId" value="@p.PaymentID" />
                                            <button type="submit" class="btn btn-sm btn-outline-secondary" title="Reset to Pending">
                                                <i class="fas fa-undo"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
    $(document).ready(function () {
        $('#auditTable').DataTable({
            pageLength: 25,
            order: [[5, 'desc']],
            columnDefs: [{ orderable: false, targets: 8 }]
        });
    });
</script>
}
