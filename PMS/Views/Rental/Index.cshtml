@model IEnumerable<PMS.Models.Rental>

@{
    ViewData["Title"] = "Rentals";
    ViewData["ListingTitle"] = "Rentals";
    ViewData["ListingDescription"] = "Property rental agreements";
    ViewData["ListingRecordCount"] = Model?.Count() ?? 0;
    ViewData["ListingAddUrl"] = Url.Action("Create");
    ViewData["ListingAddText"] = "New Rental";
}

<form method="get" asp-action="Index" class="mb-4 pms-listing-page">
    <div class="pms-listing-search-wrap">
        <div class="row g-2 align-items-end flex-lg-nowrap">
            <div class="col-12 col-md-6 col-lg-4">
                <div class="pms-compact-field">
                    <label for="propertyIdFilter" class="form-label">Property ID</label>
                    <input type="text" name="propertyIdFilter" id="propertyIdFilter" class="form-control" placeholder="Search by Property ID" value="@ViewBag.PropertyIdFilter" />
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <div class="pms-compact-field pms-select-dropdown">
                    <label for="statusFilter" class="form-label">Status</label>
                    <select name="statusFilter" id="statusFilter" class="form-select" onchange="this.form.submit()">
                        <option value="">All</option>
                        @if (ViewBag.Statuses != null)
                        {
                            foreach (var s in (string[])ViewBag.Statuses)
                            {
                                <option value="@s" selected="@(ViewBag.StatusFilter == s)">@s</option>
                            }
                        }
                    </select>
                </div>
            </div>
            <div class="col-12 col-lg-4">
                <div class="d-flex flex-wrap gap-2 pms-listing-search-actions">
                    <button type="submit" class="btn btn-primary btn-sm flex-grow-1">
                        <i class="bi bi-search me-1" aria-hidden="true"></i>Search
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm flex-grow-1">
                        <i class="bi bi-arrow-counterclockwise me-1" aria-hidden="true"></i>Clear
                    </a>
                </div>
            </div>
        </div>
    </div>
</form>

<div class="card pms-grid-card pms-listing-flat pms-saas-grid pms-listing-page">
    <div class="card-body">
        <partial name="Listing/_GridToolbar" />

        <div class="table-responsive pms-saas-table-wrap">
            <table class="table pms-saas-table" id="rentalsTable">
                <thead>
                    <tr>
                        <th>Rental ID</th>
                        <th>Property</th>
                        <th>Tenant</th>
                        <th>Start</th>
                        <th>Monthly Rent</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th class="pms-saas-th-actions">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td data-label="Rental ID"><span class="badge bg-secondary">@r.RentalID</span></td>
                            <td data-label="Property">
                                <div>
                                    <code>@r.PropertyID</code>
                                    @if (!string.IsNullOrWhiteSpace(r.Property?.PlotNo))
                                    {
                                        <div class="text-muted small">Plot: @r.Property?.PlotNo (@(r.Property?.Block ?? "—"))</div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(r.Property?.Project?.ProjectName))
                                    {
                                        <span class="pms-pill pms-pill--info mt-1">@r.Property.Project.ProjectName</span>
                                    }
                                </div>
                            </td>
                            <td data-label="Tenant">
                                <strong>@r.TenantName</strong>
                                @if (!string.IsNullOrWhiteSpace(r.TenantPhone))
                                {
                                    <div class="text-muted small">@r.TenantPhone</div>
                                }
                            </td>
                            <td data-label="Start"><span class="text-nowrap">@r.StartDate.ToString("MMM dd, yyyy")</span></td>
                            <td data-label="Monthly Rent">
                                <strong>@r.MonthlyRent.ToString("N0")</strong>
                                <span class="text-muted small">@r.Currency</span>
                            </td>
                            <td data-label="Status">
                                @if (r.Status == PMS.Models.Rental.StatusActive)
                                { <span class="pms-pill pms-pill--success">@r.Status</span> }
                                else if (r.Status == PMS.Models.Rental.StatusCompleted)
                                { <span class="pms-pill pms-pill--neutral">@r.Status</span> }
                                else
                                { <span class="pms-pill pms-pill--warning">@r.Status</span> }
                            </td>
                            <td data-label="Created"><span class="text-nowrap">@r.CreatedAt.ToString("MMM dd, yyyy")</span></td>
                            <td class="pms-saas-td-actions" data-label="Actions">
                                <div class="pms-row-actions" role="group">
                                    <a asp-action="Details" asp-route-id="@r.RentalID" class="btn btn-sm btn-outline-secondary" title="Details">
                                        <i class="bi bi-eye" aria-hidden="true"></i>
                                    </a>
                                    <a asp-action="Create" asp-route-propertyId="@r.PropertyID" class="btn btn-sm btn-outline-primary" title="New Rental (Same Property)">
                                        <i class="bi bi-plus-lg" aria-hidden="true"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#rentalsTable').DataTable({
                pageLength: 25,
                order: [[6, 'desc']],
                columnDefs: [{ orderable: false, targets: 7 }]
            });
        });
    </script>
}
