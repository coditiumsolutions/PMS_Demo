@model IEnumerable<PMS.Models.Rental>

@{
    ViewData["Title"] = "Rentals";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"></h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus me-2"></i>New Rental
    </a>
</div>

<form method="get" asp-action="Index" class="mb-4">
    <div class="card">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label fw-bold">Property ID</label>
                    <input type="text" name="propertyIdFilter" class="form-control form-control-sm" placeholder="Search by Property ID" value="@ViewBag.PropertyIdFilter" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">Status</label>
                    <select name="statusFilter" class="form-select form-select-sm" onchange="this.form.submit()">
                        <option value="">All</option>
                        @if (ViewBag.Statuses != null)
                        {
                            foreach (var s in (string[])ViewBag.Statuses)
                            {
                                <option value="@s" selected="@(ViewBag.StatusFilter == s)">@s</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">&nbsp;</label>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-sm">
                            <i class="fas fa-search me-2"></i>Search
                        </button>
                        <a asp-action="Index" class="btn btn-secondary btn-sm">
                            <i class="fas fa-times me-2"></i>Clear
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover" id="rentalsTable">
                <thead class="table-dark">
                    <tr>
                        <th>Rental ID</th>
                        <th>Property</th>
                        <th>Tenant</th>
                        <th>Start</th>
                        <th>Monthly Rent</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td><span class="badge bg-secondary">@r.RentalID</span></td>
                            <td>
                                <div>
                                    <code>@r.PropertyID</code>
                                    @if (!string.IsNullOrWhiteSpace(r.Property?.PlotNo))
                                    {
                                        <div class="text-muted small">Plot: @r.Property?.PlotNo (@(r.Property?.Block ?? "—"))</div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(r.Property?.Project?.ProjectName))
                                    {
                                        <span class="badge bg-info mt-1">@r.Property.Project.ProjectName</span>
                                    }
                                </div>
                            </td>
                            <td>
                                <strong>@r.TenantName</strong>
                                @if (!string.IsNullOrWhiteSpace(r.TenantPhone))
                                {
                                    <div class="text-muted small">@r.TenantPhone</div>
                                }
                            </td>
                            <td>@r.StartDate.ToString("MMM dd, yyyy")</td>
                            <td>
                                <strong>@r.MonthlyRent.ToString("N0")</strong>
                                <span class="text-muted small">@r.Currency</span>
                            </td>
                            <td>
                                @if (r.Status == PMS.Models.Rental.StatusActive)
                                { <span class="badge bg-success">@r.Status</span> }
                                else if (r.Status == PMS.Models.Rental.StatusCompleted)
                                { <span class="badge bg-secondary">@r.Status</span> }
                                else
                                { <span class="badge bg-warning">@r.Status</span> }
                            </td>
                            <td>@r.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a asp-action="Details" asp-route-id="@r.RentalID" class="btn btn-sm btn-outline-info" title="Details">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="Create" asp-route-propertyId="@r.PropertyID" class="btn btn-sm btn-outline-primary" title="New Rental (Same Property)">
                                        <i class="fas fa-plus"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#rentalsTable').DataTable({
                pageLength: 25,
                order: [[6, 'desc']],
                columnDefs: [{ orderable: false, targets: 7 }]
            });
        });
    </script>
}

