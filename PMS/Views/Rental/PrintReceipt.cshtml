@model PMS.Models.RentalPayment
@{
    Layout = null;
    ViewData["Title"] = "Rental Payment Receipt";
    var r = Model.Rental;
    var prop = r?.Property;
    var project = prop?.Project;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Rental Payment Receipt - @Model.RentalPaymentID - PMS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
</head>
<body>

<div class="d-flex justify-content-between align-items-center mb-3 no-print">
    <h3 class="mb-0"><i class="fas fa-receipt me-2"></i>Rental Payment Receipt</h3>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-primary btn-sm" onclick="window.print()"><i class="fas fa-print me-1"></i>Print</button>
    </div>
</div>

<div class="a4-container">
    <div class="a4-header text-center">
        <img src="~/images/logo.jpeg" alt="Logo" class="a4-logo" />
        <div class="a4-title">Rental Payment Receipt</div>
        <div class="a4-subtitle">Property Management System</div>
        <div class="a4-subtitle">Generated on: @DateTime.Now.ToString("MMMM dd, yyyy HH:mm")</div>
    </div>

    <!-- Tenant & Rental -->
    <div class="a4-section">
        <div class="a4-section-title">Tenant & Rental</div>
        <div class="a4-info-grid">
            <div class="a4-info-block">
                <div class="a4-info-row"><span class="a4-info-label">Rental ID:</span><span class="a4-info-value"><strong>@(r?.RentalID ?? "—")</strong></span></div>
                <div class="a4-info-row"><span class="a4-info-label">Tenant:</span><span class="a4-info-value">@(r?.TenantName ?? "—")</span></div>
                <div class="a4-info-row"><span class="a4-info-label">Phone:</span><span class="a4-info-value">@(r?.TenantPhone ?? "—")</span></div>
                <div class="a4-info-row"><span class="a4-info-label">CNIC:</span><span class="a4-info-value">@(r?.TenantCNIC ?? "—")</span></div>
            </div>
            <div class="a4-info-block">
                <div class="a4-info-row"><span class="a4-info-label">Property ID:</span><span class="a4-info-value"><code>@(prop?.PropertyID ?? "—")</code></span></div>
                <div class="a4-info-row"><span class="a4-info-label">Project:</span><span class="a4-info-value">@(project?.ProjectName ?? "—")</span></div>
                <div class="a4-info-row"><span class="a4-info-label">Plot / Block:</span><span class="a4-info-value">@(prop?.PlotNo ?? "—") / @(prop?.Block ?? "—")</span></div>
                <div class="a4-info-row"><span class="a4-info-label">Monthly Rent:</span><span class="a4-info-value">@(r?.MonthlyRent.ToString("N0") ?? "—") @(r?.Currency ?? "")</span></div>
            </div>
        </div>
    </div>

    <!-- Payment Details -->
    <div class="a4-section">
        <div class="a4-section-title">Payment Details</div>
        <div class="a4-info-grid">
            <div class="a4-info-block">
                <div class="a4-info-row"><span class="a4-info-label">Payment ID:</span><span class="a4-info-value"><strong>@Model.RentalPaymentID</strong></span></div>
                <div class="a4-info-row"><span class="a4-info-label">Period:</span><span class="a4-info-value">@Model.BillingYear-@Model.BillingMonth.ToString("D2")</span></div>
                <div class="a4-info-row"><span class="a4-info-label">Due Date:</span><span class="a4-info-value">@Model.DueDate.ToString("MMMM dd, yyyy")</span></div>
                <div class="a4-info-row"><span class="a4-info-label">Amount Due:</span><span class="a4-info-value"><strong>@Model.AmountDue.ToString("N0") @(r?.Currency ?? "PKR")</strong></span></div>
            </div>
            <div class="a4-info-block">
                <div class="a4-info-row"><span class="a4-info-label">Status:</span><span class="a4-info-value">@Model.Status</span></div>
                <div class="a4-info-row"><span class="a4-info-label">Paid On:</span><span class="a4-info-value">@(Model.PaidOn.HasValue ? Model.PaidOn.Value.ToString("MMMM dd, yyyy") : "—")</span></div>
                <div class="a4-info-row"><span class="a4-info-label">Paid Amount:</span><span class="a4-info-value"><strong>@Model.AmountPaid.ToString("N0") @(r?.Currency ?? "PKR")</strong></span></div>
                <div class="a4-info-row"><span class="a4-info-label">Method:</span><span class="a4-info-value">@(string.IsNullOrWhiteSpace(Model.PaymentMethod) ? "—" : Model.PaymentMethod)</span></div>
                <div class="a4-info-row"><span class="a4-info-label">Reference:</span><span class="a4-info-value">@(string.IsNullOrWhiteSpace(Model.ReferenceNo) ? "—" : Model.ReferenceNo)</span></div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Remarks))
    {
        <div class="a4-section">
            <div class="a4-section-title">Remarks</div>
            <p class="a4-statement">@Model.Remarks</p>
        </div>
    }

    <div class="a4-footer">
        This is a system-generated rental payment receipt.<br />
        Payment ID: @Model.RentalPaymentID | Rental: @(r?.RentalID ?? "—") | Generated @DateTime.Now.ToString("yyyy-MM-dd HH:mm")
    </div>
</div>

<style>
    .a4-container {
        width: 210mm;
        min-height: 297mm;
        margin: 0 auto;
        padding: 15px 20px;
        background: white;
        box-shadow: 0 0 10px rgba(0,0,0,0.1);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }
    .a4-header { border-bottom: 2px solid #333; padding-bottom: 10px; margin-bottom: 12px; }
    .a4-title { font-size: 20px; font-weight: bold; color: #333; margin-bottom: 5px; }
    .a4-subtitle { font-size: 11px; color: #666; margin-bottom: 3px; }
    .a4-section { margin-bottom: 12px; }
    .a4-section-title { font-size: 13px; font-weight: bold; color: #333; margin-bottom: 8px; padding-bottom: 3px; border-bottom: 1px solid #ddd; }
    .a4-info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 12px; }
    .a4-info-block { background: #f8f9fa; padding: 10px; border-radius: 5px; border-left: 4px solid #007bff; }
    .a4-info-row { display: flex; justify-content: space-between; margin-bottom: 3px; font-size: 11px; }
    .a4-info-label { font-weight: 600; color: #555; }
    .a4-info-value { color: #333; }
    .a4-statement { font-size: 11px; line-height: 1.5; color: #333; margin-bottom: 0; }
    .a4-footer { margin-top: 15px; padding-top: 8px; border-top: 1px solid #ddd; font-size: 9px; color: #666; text-align: center; }
    .a4-logo { max-width: 120px; height: auto; margin-bottom: 10px; }
    @@media print {
        @@page { size: A4; margin: 0; }
        body { margin: 0; padding: 0; background: white; }
        .a4-container { width: 210mm; min-height: 297mm; margin: 0; padding: 12mm; box-shadow: none; }
        .no-print { display: none !important; }
    }
    @@media screen {
        body { background: #f5f5f5; padding: 20px; }
        .a4-container { margin: 20px auto; }
    }
</style>
</body>
</html>
