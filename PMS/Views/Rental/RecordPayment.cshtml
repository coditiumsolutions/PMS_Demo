@model PMS.Models.RentalPayment

@{
    ViewData["Title"] = "Record Rental Payment";
    var rental = Model.Rental;
    var property = rental?.Property;
    var projectName = property?.Project?.ProjectName ?? "—";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0"><i class="fas fa-receipt me-2"></i>Record Rental Payment</h2>
    <a asp-action="Details" asp-route-id="@Model.RentalID" class="btn btn-outline-primary">
        <i class="fas fa-arrow-left me-2"></i>Back to Rental
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header" style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);">
        <h5 class="mb-0 text-white"><i class="fas fa-calendar-check me-2"></i>Payment Info</h5>
    </div>
    <div class="card-body">
        <div class="row g-3 mb-3">
            <div class="col-md-3">
                <div class="text-muted small">Rental</div>
                <div class="fw-bold"><span class="badge bg-secondary">@Model.RentalID</span></div>
            </div>
            <div class="col-md-3">
                <div class="text-muted small">Property</div>
                <div class="fw-bold"><code>@(rental?.PropertyID ?? "—")</code></div>
                <div class="text-muted small">@projectName</div>
            </div>
            <div class="col-md-3">
                <div class="text-muted small">Period</div>
                <div class="fw-bold"><span class="badge bg-info">@Model.BillingYear-@Model.BillingMonth.ToString("D2")</span></div>
            </div>
            <div class="col-md-3">
                <div class="text-muted small">Due Date</div>
                <div class="fw-bold">@Model.DueDate.ToString("MMM dd, yyyy")</div>
            </div>
            <div class="col-md-3">
                <div class="text-muted small">Amount Due</div>
                <div class="fw-bold">@Model.AmountDue.ToString("N0")</div>
            </div>
            <div class="col-md-3">
                <div class="text-muted small">Current Status</div>
                <div class="fw-bold">
                    @if (Model.Status == PMS.Models.RentalPayment.StatusPaid)
                    {
                        <span class="badge bg-success">@Model.Status</span>
                    }
                    else if (Model.Status == PMS.Models.RentalPayment.StatusPartiallyPaid)
                    {
                        <span class="badge bg-warning">@Model.Status</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">@Model.Status</span>
                    }
                </div>
            </div>
        </div>

        <form asp-action="RecordPayment" method="post" class="mt-2">
            @Html.AntiForgeryToken()
            <input type="hidden" name="rentalPaymentId" value="@Model.RentalPaymentID" />

            <div class="row g-2">
                <div class="col-md-3">
                    <label class="form-label">Amount Paid <span class="text-danger">*</span></label>
                    <input type="number" step="0.01" name="amountPaid" class="form-control" value="@Model.AmountDue" required />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Method</label>
                    <select name="paymentMethod" class="form-select">
                        <option value="Cash">Cash</option>
                        <option value="Bank Transfer">Bank Transfer</option>
                        <option value="Cheque">Cheque</option>
                        <option value="Card">Card</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Reference No</label>
                    <input type="text" name="referenceNo" class="form-control" placeholder="Optional" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Remarks</label>
                    <input type="text" name="remarks" class="form-control" placeholder="Optional" />
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-2"></i>Save Payment
                </button>
                <a asp-action="Details" asp-route-id="@Model.RentalID" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

