@model PMS.Models.TransferFee

@{
    ViewData["Title"] = "Edit Transfer Fee";
    var projects = ViewBag.Projects as IEnumerable<PMS.Models.Project> ?? Enumerable.Empty<PMS.Models.Project>();
    var subProjects = ViewBag.SubProjects as IList<string> ?? new List<string>();
    var transferTypes = ViewBag.TransferTypes as IList<string> ?? new List<string>();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0"><i class="fas fa-edit me-2"></i>Edit Transfer Fee</h2>
    <a asp-action="Index" class="btn btn-outline-primary"><i class="fas fa-arrow-left me-2"></i>Back to List</a>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="ProjectID" class="form-label">Project</label>
                    <select asp-for="ProjectID" class="form-select" id="projectId" required>
                        <option value="">-- Select Project --</option>
                        @foreach (var p in projects)
                        {
                            <option value="@p.ProjectID" selected="@(Model.ProjectID == p.ProjectID)">@p.ProjectName</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label asp-for="SubProject" class="form-label">SubProject</label>
                    <select asp-for="SubProject" class="form-select" id="subProject" required>
                        <option value="">-- Select SubProject --</option>
                        @foreach (var s in subProjects)
                        {
                            <option value="@s" selected="@(Model.SubProject == s)">@s</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label asp-for="TransferType" class="form-label">Transfer Type</label>
                    <select asp-for="TransferType" class="form-select" required>
                        <option value="">-- Select Transfer Type --</option>
                        @foreach (var t in transferTypes)
                        {
                            <option value="@t" selected="@(Model.TransferType == t)">@t</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label asp-for="TransferPriority" class="form-label">Transfer Priority</label>
                    <select asp-for="TransferPriority" class="form-select">
                        <option value="Normal" selected="@(Model.TransferPriority == "Normal")">Normal</option>
                        <option value="Urgent" selected="@(Model.TransferPriority == "Urgent")">Urgent</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label asp-for="AmountPerUnit" class="form-label">Amount Per Unit</label>
                    <input asp-for="AmountPerUnit" class="form-control" type="number" step="0.01" min="0.01" required />
                </div>
                <div class="col-12">
                    <label asp-for="Details" class="form-label">Details</label>
                    <textarea asp-for="Details" class="form-control" rows="3"></textarea>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-2"></i>Save Changes
                </button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        (function () {
            var projectSelect = document.getElementById('projectId');
            var subProjectSelect = document.getElementById('subProject');

            function refreshSubProjects(projectId, selectedValue) {
                if (!projectId) {
                    subProjectSelect.innerHTML = '<option value="">-- Select SubProject --</option>';
                    return;
                }

                fetch('@Url.Action("GetProjectSubProjects", "TransferFee")?projectId=' + encodeURIComponent(projectId))
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                        subProjectSelect.innerHTML = '<option value="">-- Select SubProject --</option>';
                        if (!data || !data.success || !Array.isArray(data.subProjects)) return;
                        data.subProjects.forEach(function (sp) {
                            var opt = document.createElement('option');
                            opt.value = sp;
                            opt.text = sp;
                            if (selectedValue && selectedValue.toLowerCase() === sp.toLowerCase()) {
                                opt.selected = true;
                            }
                            subProjectSelect.appendChild(opt);
                        });
                    });
            }

            projectSelect.addEventListener('change', function () {
                refreshSubProjects(this.value, '');
            });
        })();
    </script>
}
