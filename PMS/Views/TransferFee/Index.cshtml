@model IEnumerable<PMS.Models.TransferFee>

@{
    ViewData["Title"] = "Transfer Fee";
    var projects = ViewBag.Projects as IEnumerable<PMS.Models.Project> ?? Enumerable.Empty<PMS.Models.Project>();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0"><i class="fas fa-tags me-2"></i>Transfer Fee</h2>
    @if (ViewBag.CanCreate == true)
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Add Transfer Fee
        </a>
    }
</div>

<form method="get" asp-action="Index" class="card mb-3">
    <div class="card-body">
        <div class="row g-2">
            <div class="col-md-4">
                <label class="form-label fw-bold">Project</label>
                <select name="projectFilter" class="form-select form-select-sm">
                    <option value="">All Projects</option>
                    @foreach (var p in projects)
                    {
                        <option value="@p.ProjectID" selected="@(ViewBag.ProjectFilter == p.ProjectID)">@p.ProjectName</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold">SubProject</label>
                <input type="text" name="subProjectFilter" class="form-control form-control-sm" value="@ViewBag.SubProjectFilter" placeholder="SubProject" />
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold">Priority</label>
                <select name="priorityFilter" class="form-select form-select-sm">
                    <option value="">All</option>
                    <option value="Normal" selected="@(ViewBag.PriorityFilter == "Normal")">Normal</option>
                    <option value="Urgent" selected="@(ViewBag.PriorityFilter == "Urgent")">Urgent</option>
                </select>
            </div>
            <div class="col-md-2 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-primary btn-sm">
                    <i class="fas fa-search me-1"></i>Search
                </button>
                <a asp-action="Index" class="btn btn-secondary btn-sm">Clear</a>
            </div>
        </div>
    </div>
</form>

<div class="card">
    <div class="card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Actions</th>
                            <th>ID</th>
                            <th>Project</th>
                            <th>SubProject</th>
                            <th>Transfer Type</th>
                            <th>Priority</th>
                            <th>Amount/Unit</th>
                            <th>Created On</th>
                            <th>Created By</th>
                            <th>Modified By</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model)
                        {
                            <tr>
                                <td>
                                    @if (ViewBag.CanEdit == true)
                                    {
                                        <a asp-action="Edit" asp-route-id="@row.Id" class="btn btn-sm btn-outline-warning" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                    }
                                    @if (ViewBag.CanDelete == true)
                                    {
                                        <form asp-action="Delete" asp-route-id="@row.Id" method="post" class="d-inline" onsubmit="return confirm('Delete this transfer fee row?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </td>
                                <td><code>@row.Id</code></td>
                                <td>@(row.Project?.ProjectName ?? row.ProjectID)</td>
                                <td>@(row.SubProject ?? "—")</td>
                                <td>@(row.TransferType ?? "—")</td>
                                <td><span class="badge bg-info text-dark">@(row.TransferPriority ?? "—")</span></td>
                                <td>@row.AmountPerUnit.ToString("N2")</td>
                                <td>@row.CreatedOn.ToString("MMM dd, yyyy HH:mm")</td>
                                <td>@(row.CreatedBy ?? "—")</td>
                                <td>@(row.ModifiedBy ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-4 text-muted">
                <i class="fas fa-inbox fa-3x mb-2 d-block"></i>
                <p class="mb-0">No transfer fee rows found.</p>
            </div>
        }
    </div>
</div>
