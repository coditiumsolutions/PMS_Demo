@model AmsJvEditVm
@using PMS.Utilities
@{
    ViewData["Title"] = "New journal voucher";
    var fiscalYears = ViewBag.OpenFiscalYears as IEnumerable<AccFiscalYear> ?? Array.Empty<AccFiscalYear>();
    var heads = ViewBag.AccountHeads as IEnumerable<AccAccountHead> ?? Array.Empty<AccAccountHead>();
}
<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div class="row g-3 mb-3">
        <div class="col-md-4">
            <label asp-for="FiscalYearID" class="form-label">Financial year</label>
            <select asp-for="FiscalYearID" class="form-select" required>
                <option value="">— Select —</option>
                @foreach (var fy in fiscalYears)
                {
                    <option value="@fy.FiscalYearID">@AmsAccountingPeriodGuard.FormatFiscalYearOption(fy)</option>
                }
            </select>
            <span asp-validation-for="FiscalYearID" class="text-danger"></span>
        </div>
        <div class="col-md-2">
            <label asp-for="VoucherDate" class="form-label"></label>
            <input asp-for="VoucherDate" class="form-control" type="date" required />
        </div>
        <div class="col-md-3">
            <label class="form-label">Vr. #</label>
            <input type="text" class="form-control" value="@(ViewBag.NextVoucherNo as string ?? "—")" readonly />
            <span class="form-text">Assigned on save</span>
        </div>
        <div class="col-md-3">
            <label asp-for="ReferenceNo" class="form-label"></label>
            <input asp-for="ReferenceNo" class="form-control" maxlength="100" />
        </div>
        <div class="col-12">
            <label asp-for="Narration" class="form-label"></label>
            <textarea asp-for="Narration" class="form-control" rows="2" maxlength="1000"></textarea>
        </div>
    </div>
    <p class="small text-muted">Enter at least two lines; total debits must equal total credits. The accounting month is set automatically from the voucher date.</p>
    <div class="table-responsive">
        <table class="table table-sm align-middle">
            <thead class="table-light">
                <tr>
                    <th style="width:40%">Account</th>
                    <th class="text-end">Debit</th>
                    <th class="text-end">Credit</th>
                    <th>Description</th>
                </tr>
            </thead>
            <tbody>
                @for (var i = 0; i < Model.Lines.Count; i++)
                {
                    <tr>
                        <td>
                            <select name="Lines[@i].AccountHeadID" class="form-select form-select-sm ams-ledger-select" data-placeholder="Search account code or name…">
                                <option value="0">—</option>
                                @foreach (var h in heads)
                                {
                                    if (Model.Lines[i].AccountHeadID == h.AccountHeadID)
                                    {
                                        <option value="@h.AccountHeadID" selected="selected">@h.AccountCode — @h.AccountName</option>
                                    }
                                    else
                                    {
                                        <option value="@h.AccountHeadID">@h.AccountCode — @h.AccountName</option>
                                    }
                                }
                            </select>
                        </td>
                        <td><input name="Lines[@i].DebitAmount" class="form-control form-control-sm text-end" type="number" step="0.01" value="@Model.Lines[i].DebitAmount" /></td>
                        <td><input name="Lines[@i].CreditAmount" class="form-control form-control-sm text-end" type="number" step="0.01" value="@Model.Lines[i].CreditAmount" /></td>
                        <td><input name="Lines[@i].Description" class="form-control form-control-sm" maxlength="500" value="@Model.Lines[i].Description" /></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div asp-validation-summary="All" class="text-danger"></div>
    <button type="submit" class="btn btn-primary">Save draft</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
</form>
<partial name="_AmsDuplicateVoucherModal" />
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
