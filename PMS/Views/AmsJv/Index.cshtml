@model List<AccVoucher>
@{
    ViewData["Title"] = "Journal vouchers";
}
@if (ViewBag.Error != null)
{
    <div class="alert alert-warning">@ViewBag.Error</div>
}
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <partial name="_AmsExportCsv" model="@("JournalVouchers")" />

    <p class="mb-0 text-muted small">Manual journal vouchers. Numbering format: <code>{TypeCode}-{YY}-{NNNNNN}</code>.</p>
    @if (ViewBag.CanCreate == true)
    {
        <a class="btn btn-primary btn-sm" asp-action="Create"><i class="fas fa-plus me-1"></i>New JV</a>
    }
</div>
<div class="table-responsive">
    <table class="table table-sm table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>No.</th>
                <th>Date</th>
                <th>Status</th>
                <th class="text-end">Debit</th>
                <th class="text-end">Credit</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var v in Model)
            {
                <tr>
                    <td class="text-nowrap">@v.VoucherNo</td>
                    <td>@v.VoucherDate.ToString("yyyy-MM-dd")</td>
                    <td>@v.Status</td>
                    <td class="text-end">@v.TotalDebit.ToString("N2")</td>
                    <td class="text-end">@v.TotalCredit.ToString("N2")</td>
                    <td class="text-nowrap">
                        <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@v.VoucherID">Open</a>
                        @if (ViewBag.CanDelete == true)
                        {
                            ViewData["AmsDeleteEntity"] = "voucher";
                            ViewData["AmsDeleteId"] = v.VoucherID;
                            ViewData["AmsDeleteConfirm"] = $"Delete voucher {v.VoucherNo}?";
                            <partial name="_AmsDeleteButton" />
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
@if (!Model.Any())
{
    <p class="text-muted">No journal vouchers yet.</p>
}
