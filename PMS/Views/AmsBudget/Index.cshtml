@model List<AccBudget>
@{
    ViewData["Title"] = "Budgets";
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success py-2">@TempData["Success"]</div>
}
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <partial name="_AmsExportCsv" model="@("Budgets")" />

    <p class="mb-0 text-muted small">Budgets: <code>acc.Budget</code> and <code>BudgetLine</code>.</p>
    @if (ViewBag.CanCreate == true)
    {
        <a class="btn btn-primary btn-sm" asp-action="Create"><i class="fas fa-plus me-1"></i>New budget</a>
    }
</div>
<div class="table-responsive">
    <table class="table table-sm table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Name</th>
                <th>Fiscal year</th>
                <th>Type</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var b in Model)
            {
                <tr>
                    <td>@b.BudgetName</td>
                    <td>@(b.FiscalYear?.YearName)</td>
                    <td>@b.BudgetType</td>
                    <td>@b.Status</td>
                    <td>
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@b.BudgetID">Lines</a>
                        @if (ViewBag.CanEdit == true)
                        {
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@b.BudgetID">Edit</a>
                        }
                        @if (ViewBag.CanDelete == true)
                        {
                            ViewData["AmsDeleteEntity"] = "budget";
                            ViewData["AmsDeleteId"] = b.BudgetID;
                            <partial name="_AmsDeleteButton" />
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
@if (!Model.Any())
{
    <p class="text-muted">No budgets yet.</p>
}
