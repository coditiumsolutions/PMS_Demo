@model AccBudgetLine
@{
    ViewData["Title"] = "Edit budget line";
    var heads = ViewBag.AccountHeads as IEnumerable<AccAccountHead> ?? Array.Empty<AccAccountHead>();
    var periods = ViewBag.Periods as IEnumerable<AccAccountingPeriod> ?? Array.Empty<AccAccountingPeriod>();
    var ccs = ViewBag.CostCenters as IEnumerable<AccCostCenter> ?? Array.Empty<AccCostCenter>();
}
<form asp-action="EditLine" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="BudgetLineID" />
    <input type="hidden" asp-for="BudgetID" />
    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="AccountHeadID" class="form-label">Account</label>
            <select asp-for="AccountHeadID" class="form-select ams-ledger-select" required data-placeholder="Search account…" data-allow-clear="false">
                @foreach (var h in heads)
                {
                    <option value="@h.AccountHeadID">@h.AccountCode — @h.AccountName</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label asp-for="PeriodID" class="form-label">Period (optional)</label>
            <select asp-for="PeriodID" class="form-select">
                <option value="">— None —</option>
                @foreach (var p in periods)
                {
                    <option value="@p.PeriodID">@p.PeriodName</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label asp-for="CostCenterID" class="form-label">Cost center (optional)</label>
            <select asp-for="CostCenterID" class="form-select">
                <option value="">— None —</option>
                @foreach (var c in ccs)
                {
                    <option value="@c.CostCenterID">@c.CostCenterCode</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label asp-for="BudgetedAmount" class="form-label"></label>
            <input asp-for="BudgetedAmount" class="form-control" type="number" step="0.01" />
        </div>
        <div class="col-md-3">
            <label asp-for="RevisedAmount" class="form-label">Revised (optional)</label>
            <input asp-for="RevisedAmount" class="form-control" type="number" step="0.01" />
        </div>
        <div class="col-md-12">
            <label asp-for="Remarks" class="form-label"></label>
            <input asp-for="Remarks" class="form-control" maxlength="300" />
        </div>
    </div>
    <div asp-validation-summary="All" class="text-danger mt-2"></div>
    <button type="submit" class="btn btn-primary mt-2">Save</button>
    <a asp-action="Details" asp-route-id="@Model.BudgetID" class="btn btn-outline-secondary mt-2">Cancel</a>
</form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
