@model List<AmsCoaController.AmsCoaRowVm>
@{
    ViewData["Title"] = "Chart of Accounts";
    var categories = ViewBag.Categories as IEnumerable<AccAccountCategory> ?? Array.Empty<AccAccountCategory>();
    var selCat = ViewBag.SelectedCategoryId as int?;
}
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <form method="get" class="d-flex align-items-center gap-2">
        <label class="form-label mb-0">Category</label>
        <select name="categoryId" class="form-select form-select-sm" style="width:220px" onchange="this.form.submit()">
            <option value="">All</option>
            @foreach (var c in categories)
            {
                if (selCat == c.AccountCategoryID)
                {
                    <option value="@c.AccountCategoryID" selected="selected">@c.CategoryName</option>
                }
                else
                {
                    <option value="@c.AccountCategoryID">@c.CategoryName</option>
                }
            }
        </select>
    </form>
    <div class="btn-group">
        <partial name="_AmsExportCsv" model="@("Coa")" />
        @if (ViewBag.CanCreate == true)
        {
            <a class="btn btn-primary btn-sm" asp-action="Create"><i class="fas fa-plus me-1"></i>New account</a>
            <a class="btn btn-outline-secondary btn-sm" asp-action="Import">Import CSV</a>
            <a class="btn btn-outline-secondary btn-sm" asp-action="DownloadTemplate">Template</a>
        }
        @if (ViewBag.CanDelete == true)
        {
            <a class="btn btn-outline-danger btn-sm" asp-action="ClearAll">Clear all (re-import)</a>
        }
        <a class="btn btn-outline-secondary btn-sm" asp-controller="AmsPeriod" asp-action="Index">Fiscal years</a>
        <a class="btn btn-outline-secondary btn-sm" asp-controller="AmsOpeningBalance" asp-action="Index">Opening balances</a>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-sm table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Code</th>
                <th>Name</th>
                <th>Category</th>
                <th>Lvl</th>
                <th>Posting</th>
                <th>OB</th>
                <th>Active</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model)
            {
                var h = r.Head;
                <tr>
                    <td><span style="padding-left:@(r.Depth * 16)px">@h.AccountCode</span></td>
                    <td>@h.AccountName</td>
                    <td>@h.Category?.CategoryName</td>
                    <td>@h.AccountLevel</td>
                    <td>@(h.AllowDirectPosting ? "Yes" : "No")</td>
                    <td class="text-end">@h.OpeningBalance.ToString("N2")</td>
                    <td>@(h.IsActive ? "Yes" : "No")</td>
                    <td class="text-nowrap">
                        @if (ViewBag.CanEdit == true)
                        {
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@h.AccountHeadID">Edit</a>
                        }
                        @if (ViewBag.CanEdit == true && h.IsActive)
                        {
                            <form asp-action="Deactivate" asp-route-id="@h.AccountHeadID" method="post" class="d-inline" onsubmit="return confirm('Deactivate this account?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-warning">Deactivate</button>
                            </form>
                        }
                        @if (ViewBag.CanDelete == true)
                        {
                            ViewData["AmsDeleteEntity"] = "accounthead";
                            ViewData["AmsDeleteId"] = h.AccountHeadID;
                            ViewData["AmsDeleteConfirm"] = $"Permanently delete account {h.AccountCode}?";
                            <partial name="_AmsDeleteButton" />
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
@if (!Model.Any())
{
    <p class="text-muted">No accounts yet. Create or import a chart of accounts.</p>
}
