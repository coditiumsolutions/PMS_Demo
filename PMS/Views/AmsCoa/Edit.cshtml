@model AccAccountHead
@{
    ViewData["Title"] = "Edit account head";
    var categories = ViewBag.Categories as IEnumerable<AccAccountCategory> ?? Array.Empty<AccAccountCategory>();
    var parents = ViewBag.ParentHeads as IEnumerable<AccAccountHead> ?? Array.Empty<AccAccountHead>();
}
<form asp-action="Edit" asp-route-id="@Model.AccountHeadID" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="AccountHeadID" />
    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="AccountCategoryID" class="form-label">Category</label>
            <select asp-for="AccountCategoryID" class="form-select" asp-items="@(new SelectList(categories, "AccountCategoryID", "CategoryName"))"></select>
        </div>
        <div class="col-md-6">
            <label asp-for="ParentAccountHeadID" class="form-label">Parent (optional)</label>
            <select asp-for="ParentAccountHeadID" class="form-select">
                <option value="">— None —</option>
                @foreach (var p in parents)
                {
                    <option value="@p.AccountHeadID">@p.AccountCode — @p.AccountName</option>
                }
            </select>
        </div>
        <div class="col-md-4">
            <label asp-for="AccountCode" class="form-label"></label>
            <input asp-for="AccountCode" class="form-control" maxlength="30" required />
            <span asp-validation-for="AccountCode" class="text-danger"></span>
        </div>
        <div class="col-md-8">
            <label asp-for="AccountName" class="form-label"></label>
            <input asp-for="AccountName" class="form-control" maxlength="150" required />
        </div>
        <div class="col-md-3">
            <label asp-for="AccountLevel" class="form-label"></label>
            <input asp-for="AccountLevel" class="form-control" type="number" min="1" max="9" />
        </div>
        <div class="col-md-3 d-flex align-items-end">
            <div class="form-check">
                <input asp-for="IsControlAccount" class="form-check-input" />
                <label asp-for="IsControlAccount" class="form-check-label">Control account</label>
            </div>
        </div>
        <div class="col-md-3 d-flex align-items-end">
            <div class="form-check">
                <input asp-for="AllowDirectPosting" class="form-check-input" />
                <label asp-for="AllowDirectPosting" class="form-check-label">Allow posting</label>
            </div>
        </div>
        <div class="col-md-3 d-flex align-items-end">
            <div class="form-check">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label">Active</label>
            </div>
        </div>
        <div class="col-md-4">
            <label asp-for="OpeningBalance" class="form-label"></label>
            <input asp-for="OpeningBalance" class="form-control" type="number" step="0.01" />
        </div>
        <div class="col-md-4">
            <label asp-for="OpeningBalanceDate" class="form-label"></label>
            <input asp-for="OpeningBalanceDate" class="form-control" type="date" />
        </div>
        <div class="col-md-4">
            <label asp-for="OpeningBalanceType" class="form-label">OB type</label>
            <select asp-for="OpeningBalanceType" class="form-select">
                <option value="">—</option>
                <option value="Debit">Debit</option>
                <option value="Credit">Credit</option>
            </select>
        </div>
        <div class="col-12">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control" rows="2" maxlength="500"></textarea>
        </div>
    </div>
    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</form>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
