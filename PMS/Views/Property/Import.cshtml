@{
    ViewData["Title"] = "Import Properties";
}

<div class="row">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2><i class="fas fa-file-upload me-2"></i></h2>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Back to List
            </a>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-triangle me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (ViewBag.MissingSubProjects != null || ViewBag.SubProjectsMissingPrefix != null)
        {
            var missing = ViewBag.MissingSubProjects as List<string> ?? new List<string>();
            var missingPrefix = ViewBag.SubProjectsMissingPrefix as List<string> ?? new List<string>();
            var selectedProjectId = ViewBag.SelectedProjectID as string ?? "";
            if (missing.Count > 0 || missingPrefix.Count > 0)
            {
                <div class="alert alert-warning">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <div class="fw-semibold mb-1">
                                <i class="fas fa-exclamation-circle me-2"></i>SubProject validation failed
                            </div>
                            <div class="small text-muted">
                                Please add the missing subprojects (and their prefixes) in the selected project before importing.
                            </div>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(selectedProjectId))
                        {
                            <a class="btn btn-sm btn-outline-primary" target="_blank"
                               asp-controller="Project" asp-action="Edit" asp-route-id="@selectedProjectId">
                                <i class="fas fa-external-link-alt me-2"></i>Open Project (Edit)
                            </a>
                        }
                    </div>
                    @if (missing.Count > 0)
                    {
                        <hr />
                        <div class="small fw-semibold">Missing subprojects in mapping:</div>
                        <ul class="mb-0">
                            @foreach (var m in missing)
                            {
                                <li><code>@m</code></li>
                            }
                        </ul>
                    }
                    @if (missingPrefix.Count > 0)
                    {
                        <hr />
                        <div class="small fw-semibold">Subprojects missing prefix:</div>
                        <ul class="mb-0">
                            @foreach (var m in missingPrefix)
                            {
                                <li><code>@m</code></li>
                            }
                        </ul>
                    }
                </div>
            }
        }

        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>Import Instructions</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <h6 class="text-primary">File Format Requirements:</h6>
                        <ul>
                            <li>Supported formats: <strong>CSV (.csv)</strong> or <strong>Excel (.xlsx, .xls)</strong></li>
                            <li>First row must contain column headers</li>
                            <li>Data starts from row 2</li>
                        </ul>

                        <h6 class="text-primary mt-3">Columns sequence (A to H, optional ProjectID in column A):</h6>
                        <ol>
                            <li><strong>SubProject</strong> - Subproject name (required, must exist in selected project's subproject mappings)</li>
                            <li><strong>Tower</strong> - Tower identifier (required)</li>
                            <li><strong>Size</strong> - Property size (required)</li>
                            <li><strong>Unit No</strong> - Unit number (required)</li>
                            <li><strong>Floor</strong> - Floor (optional, e.g. G, 1, 2, Basement)</li>
                            <li><strong>Unit Type (Category)</strong> - Unit type / category (required)</li>
                            <li><strong>Additional Info</strong> - Additional notes (optional)</li>
                            <li><strong>Street</strong> - Street (optional)</li>
                        </ol>
                    </div>
                    <div class="col-md-6">
                        <h6 class="text-primary">Example Format:</h6>
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered">
                                <thead class="table-light">
                                    <tr>
                                        <th>SubProject</th>
                                        <th>Tower</th>
                                        <th>Size</th>
                                        <th>Unit No</th>
                                        <th>Floor</th>
                                        <th>Unit Type (Category)</th>
                                        <th>Additional Info</th>
                                        <th>Street</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>Phase 1</td>
                                        <td>A</td>
                                        <td>10 Marla</td>
                                        <td>1</td>
                                        <td>G</td>
                                        <td>Corner</td>
                                        <td>Main Street Plot</td>
                                        <td></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <div class="alert alert-info mt-3">
                            <i class="fas fa-lightbulb me-2"></i>
                            <strong>Note:</strong> 
                            <ul class="mb-0 mt-2">
                                <li>PropertyID will be auto-generated</li>
                                <li>Status will be set to "Available"</li>
                                <li>Project must be selected before upload</li>
                                <li>All imported properties will be assigned to the selected project</li>
                                <li>Dealer must be selected before upload</li>
                                <li>All imported properties will be assigned to the selected dealer</li>
                                <li>CreatedAt will be set automatically</li>
                                <li>Duplicate properties (same selected project + Unit No + Tower) will be skipped</li>
                                <li>SubProject is read from the uploaded file (first column)</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card mt-4">
            <div class="card-header">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="fas fa-upload me-2"></i>Upload File</h5>
                    <a asp-action="DownloadSample" class="btn btn-outline-success btn-sm">
                        <i class="fas fa-download me-2"></i>Download Sample
                    </a>
                </div>
            </div>
            <div class="card-body">
                <form asp-action="ImportPreview" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    
                    <div class="row">
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label for="projectId" class="form-label">Project *</label>
                                <select class="form-select" id="projectId" name="projectId" required>
                                    <option value="">Select Project</option>
                                    @if (ViewBag.Projects != null)
                                    {
                                        @foreach (var project in ViewBag.Projects)
                                        {
                                            <option value="@project.ProjectID" selected="@(ViewBag.SelectedProjectID == project.ProjectID ? "selected" : null)">
                                                @project.ProjectName (@project.ProjectID)
                                            </option>
                                        }
                                    }
                                </select>
                                <small class="form-text text-muted">Select one project for this bulk upload</small>
                                <span class="text-danger field-validation-valid" data-valmsg-for="projectId" data-valmsg-replace="true"></span>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">SubProject</label>
                                <div class="form-control-plaintext text-muted small">
                                    Read from uploaded file (first column).
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label for="dealerId" class="form-label">Dealer *</label>
                                <select class="form-select" id="dealerId" name="dealerId" required>
                                    <option value="">Select Dealer</option>
                                    @if (ViewBag.Dealers != null)
                                    {
                                        @foreach (var dealer in ViewBag.Dealers)
                                        {
                                            <option value="@dealer.DealerID" selected="@(ViewBag.SelectedDealerID == dealer.DealerID ? "selected" : null)">
                                                @dealer.DealershipName
                                            </option>
                                        }
                                    }
                                </select>
                                <small class="form-text text-muted">Select the dealer for all imported properties</small>
                                <span class="text-danger field-validation-valid" data-valmsg-for="dealerId" data-valmsg-replace="true"></span>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label for="file" class="form-label">Select File (CSV or Excel) *</label>
                                <input type="file" class="form-control" id="file" name="file" accept=".csv,.xlsx,.xls" required />
                                <small class="form-text text-muted">Maximum file size: 10MB</small>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-upload me-2"></i>Upload and Preview
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // File size validation
        document.getElementById('file').addEventListener('change', function(e) {
            var file = e.target.files[0];
            if (file) {
                var fileSize = file.size / 1024 / 1024; // Size in MB
                if (fileSize > 10) {
                    alert('File size exceeds 10MB. Please select a smaller file.');
                    e.target.value = '';
                }
            }
        });
    </script>
}

