@model PMS.Models.Property

@{
    ViewData["Title"] = "Property Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div class="d-flex align-items-center gap-4">
        <h2 class="mb-0">
            <i class="fas fa-home me-2"></i>Property Details
        </h2>
        <div class="d-flex align-items-center gap-3 ms-4">
            <div class="badge bg-light text-dark px-3 py-2" style="font-size: 14px;">
                <i class="fas fa-calendar-check me-2" style="color: #6f42c1;"></i>
                <strong>Created:</strong> @Model.CreatedAt.ToString("MMMM dd, yyyy")
                <span class="text-muted ms-2">(@((DateTime.Now - Model.CreatedAt).Days) days ago)</span>
            </div>
        </div>
    </div>
    <div>
        @if (Model.Status == "Available")
        {
            <a asp-action="Allot" asp-route-id="@Model.PropertyID" class="btn btn-success me-2">
                <i class="fas fa-hand-holding me-2"></i>Allot Property
            </a>
        }
        <a asp-action="Edit" asp-route-id="@Model.PropertyID" class="btn btn-primary me-2">
            <i class="fas fa-edit me-2"></i>Edit
        </a>
        <a asp-action="Index" class="btn btn-outline-primary">
            <i class="fas fa-arrow-left me-2"></i>Back to List
        </a>
    </div>
</div>

<div class="row">
    <!-- Main Content with Tabs -->
    <div class="col-12">
        <div class="card">
            <div class="card-header p-0">
                <ul class="nav nav-tabs property-tabs" id="propertyTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="property-tab" data-bs-toggle="tab" data-bs-target="#property" type="button" role="tab" aria-controls="property" aria-selected="true">
                            <i class="fas fa-building me-2"></i>Property Info
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="allotments-tab" data-bs-toggle="tab" data-bs-target="#allotments" type="button" role="tab" aria-controls="allotments" aria-selected="false">
                            <i class="fas fa-users me-2"></i>Allotments
                            @if (Model.Allotments != null && Model.Allotments.Any())
                            {
                                <span class="badge bg-primary rounded-pill ms-1">@Model.Allotments.Count</span>
                            }
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="possessions-tab" data-bs-toggle="tab" data-bs-target="#possessions" type="button" role="tab" aria-controls="possessions" aria-selected="false">
                            <i class="fas fa-key me-2"></i>Possessions
                            @if (Model.Possessions != null && Model.Possessions.Any())
                            {
                                <span class="badge bg-success rounded-pill ms-1">@Model.Possessions.Count</span>
                            }
                        </button>
                    </li>
                </ul>
            </div>
            <div class="card-body">
                <div class="tab-content" id="propertyTabContent">
                    <!-- Property Info Tab -->
                    <div class="tab-pane fade show active" id="property" role="tabpanel" aria-labelledby="property-tab">
                        <div class="row">
                            <!-- Property Details -->
                            <div class="col-md-8">
                                <h6 class="mb-3"><i class="fas fa-building me-2"></i>Property Details</h6>
                                <div class="row">
                                    <div class="col-md-4 mb-2">
                                        <div class="detail-field">
                                            <label><i class="fas fa-id-badge me-2"></i>Property ID</label>
                                            <p><code>@Model.PropertyID</code></p>
                                        </div>
                                    </div>
                                    <div class="col-md-4 mb-2">
                                        <div class="detail-field">
                                            <label><i class="fas fa-toggle-on me-2"></i>Status</label>
                                            <p>
                                                <span class="badge @(Model.Status == "Available" ? "bg-success" : Model.Status == "Allotted" ? "bg-warning" : "bg-danger")">
                                                    @Model.Status
                                                </span>
                                            </p>
                                        </div>
                                    </div>
                                    <div class="col-md-4 mb-2">
                                        <div class="detail-field">
                                            <label><i class="fas fa-map-marker-alt me-2"></i>Unit No</label>
                                            <p>@Model.PlotNo</p>
                                        </div>
                                    </div>
                                    <div class="col-md-4 mb-2">
                                        <div class="detail-field">
                                            <label><i class="fas fa-sitemap me-2"></i>Subproject</label>
                                            <p>@(string.IsNullOrWhiteSpace(Model.SubProject) ? "—" : Model.SubProject)</p>
                                        </div>
                                    </div>
                                    <div class="col-md-4 mb-2">
                                        <div class="detail-field">
                                            <label><i class="fas fa-th-large me-2"></i>Tower</label>
                                            <p>@Model.Block</p>
                                        </div>
                                    </div>
                                    <div class="col-md-4 mb-2">
                                        <div class="detail-field">
                                            <label><i class="fas fa-layer-group me-2"></i>Floor</label>
                                            <p>@(Model.Floor ?? "N/A")</p>
                                        </div>
                                    </div>
                                    <div class="col-md-4 mb-2">
                                        <div class="detail-field">
                                            <label><i class="fas fa-tag me-2"></i>Unit Type (Category)</label>
                                            <p>@Model.PlotType</p>
                                        </div>
                                    </div>
                                    <div class="col-md-4 mb-2">
                                        <div class="detail-field">
                                            <label><i class="fas fa-ruler-combined me-2"></i>Size</label>
                                            <p>@Model.Size</p>
                                        </div>
                                    </div>
                                    @if (!string.IsNullOrEmpty(Model.AdditionalInfo))
                                    {
                                        <div class="col-md-12 mb-2">
                                            <div class="detail-field">
                                                <label><i class="fas fa-info-circle me-2"></i>Additional Information</label>
                                                <p>@Model.AdditionalInfo</p>
                                            </div>
                                        </div>
                                    }
                                </div>

                                <!-- Project Information -->
                                @if (Model.Project != null)
                                {
                                    <h6 class="mb-3 mt-4"><i class="fas fa-project-diagram me-2"></i>Project Information</h6>
                                    <div class="row">
                                        <div class="col-md-6 mb-2">
                                            <div class="detail-field">
                                                <label><i class="fas fa-tag me-2"></i>Project Name</label>
                                                <p>@Model.Project.ProjectName</p>
                                            </div>
                                        </div>
                                        <div class="col-md-6 mb-2">
                                            <div class="detail-field">
                                                <label><i class="fas fa-building me-2"></i>Type</label>
                                                <p>@Model.Project.Type</p>
                                            </div>
                                        </div>
                                        <div class="col-md-6 mb-2">
                                            <div class="detail-field">
                                                <label><i class="fas fa-map-marker-alt me-2"></i>Location</label>
                                                <p>@Model.Project.Location</p>
                                            </div>
                                        </div>
                                        @if (!string.IsNullOrEmpty(Model.Project.Description))
                                        {
                                            <div class="col-md-12 mb-2">
                                                <div class="detail-field">
                                                    <label><i class="fas fa-info-circle me-2"></i>Description</label>
                                                    <p>@Model.Project.Description</p>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>

                            <!-- Sidebar: Stats and Current Owner -->
                            <div class="col-md-4">
                                <!-- Property Stats -->
                                <h6 class="mb-3"><i class="fas fa-chart-bar me-2"></i>Statistics</h6>
                                <div class="stat-item mb-2">
                                    <i class="fas fa-users text-primary"></i>
                                    <span class="stat-label">Allotments:</span>
                                    <strong>@(Model.Allotments?.Count ?? 0)</strong>
                                </div>
                                <div class="stat-item mb-2">
                                    <i class="fas fa-key text-success"></i>
                                    <span class="stat-label">Possessions:</span>
                                    <strong>@(Model.Possessions?.Count ?? 0)</strong>
                                </div>
                                <!-- Current Owner -->
                                @if (Model.Allotments != null && Model.Allotments.Any())
                                {
                                    var currentAllotment = Model.Allotments.OrderByDescending(a => a.AllotmentDate).FirstOrDefault();
                                    if (currentAllotment?.Customer != null)
                                    {
                                        <h6 class="mb-3 mt-4"><i class="fas fa-user me-2"></i>Current Owner</h6>
                                        <div class="owner-card p-3 border rounded">
                                            <div class="text-center mb-3">
                                                <i class="fas fa-user-circle fa-3x" style="color: #6f42c1;"></i>
                                            </div>
                                            <div class="detail-field mb-2">
                                                <label><i class="fas fa-user me-2"></i>Name</label>
                                                <p>@currentAllotment.Customer.FullName</p>
                                            </div>
                                            <div class="detail-field mb-2">
                                                <label><i class="fas fa-id-card me-2"></i>Customer ID</label>
                                                <p><code>@currentAllotment.Customer.CustomerID</code></p>
                                            </div>
                                            <div class="detail-field mb-3">
                                                <label><i class="fas fa-phone me-2"></i>Phone</label>
                                                <p>@currentAllotment.Customer.Phone</p>
                                            </div>
                                            <a asp-controller="Customer" asp-action="Details" asp-route-id="@currentAllotment.Customer.CustomerID" 
                                               class="btn btn-outline-primary btn-sm w-100">
                                                <i class="fas fa-eye me-2"></i>View Details
                                            </a>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Allotments Tab -->
                    <div class="tab-pane fade" id="allotments" role="tabpanel" aria-labelledby="allotments-tab">
                        @if (Model.Allotments != null && Model.Allotments.Any())
                        {
                            var allotment = Model.Allotments.OrderByDescending(a => a.AllotmentDate).FirstOrDefault();
                            if (allotment != null)
                            {
                                <div class="alert alert-info mb-3">
                                    <i class="fas fa-info-circle me-2"></i>
                                    <strong>Business Rule:</strong> 1 Property = 1 Customer. This property can only have ONE allotment.
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <h6 class="mb-3"><i class="fas fa-file-contract me-2"></i>Allotment Information</h6>
                                        <div class="row">
                                            <div class="col-md-6 mb-2">
                                                <div class="detail-field">
                                                    <label><i class="fas fa-id-badge me-2"></i>Allotment ID</label>
                                                    <p><code>@allotment.AllotmentID</code></p>
                                                </div>
                                            </div>
                                            <div class="col-md-6 mb-2">
                                                <div class="detail-field">
                                                    <label><i class="fas fa-tag me-2"></i>Type</label>
                                                    <p>@allotment.AllottmentType</p>
                                                </div>
                                            </div>
                                            <div class="col-md-6 mb-2">
                                                <div class="detail-field">
                                                    <label><i class="fas fa-calendar me-2"></i>Allotment Date</label>
                                                    <p>@allotment.AllotmentDate.ToString("MMMM dd, yyyy")</p>
                                                </div>
                                            </div>
                                            <div class="col-md-6 mb-2">
                                                <div class="detail-field">
                                                    <label><i class="fas fa-info-circle me-2"></i>Status</label>
                                                    <p>
                                                        <span class="badge bg-primary">@allotment.WorkFlowStatus</span>
                                                    </p>
                                                </div>
                                            </div>
                                            @if (!string.IsNullOrEmpty(allotment.ApprovedBy))
                                            {
                                                <div class="col-md-6 mb-2">
                                                    <div class="detail-field">
                                                        <label><i class="fas fa-user-check me-2"></i>Approved By</label>
                                                        <p>@allotment.ApprovedBy</p>
                                                    </div>
                                                </div>
                                            }
                                            @if (!string.IsNullOrEmpty(allotment.Comments))
                                            {
                                                <div class="col-md-12 mb-2">
                                                    <div class="detail-field">
                                                        <label><i class="fas fa-comment me-2"></i>Comments</label>
                                                        <p>@allotment.Comments</p>
                                                    </div>
                                                </div>
                                            }
                                            @if (!string.IsNullOrEmpty(allotment.AdditionalInfo))
                                            {
                                                <div class="col-md-12 mb-2">
                                                    <div class="detail-field">
                                                        <label><i class="fas fa-sticky-note me-2"></i>Additional Info</label>
                                                        <p>@allotment.AdditionalInfo</p>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        @if (allotment.Customer != null)
                                        {
                                            <h6 class="mb-3"><i class="fas fa-user me-2"></i>Customer Information</h6>
                                            <div class="card border-primary">
                                                <div class="card-body">
                                                    <div class="text-center mb-3">
                                                        <i class="fas fa-user-circle fa-3x" style="color: #6f42c1;"></i>
                                                    </div>
                                                    <div class="detail-field mb-2">
                                                        <label><i class="fas fa-user me-2"></i>Full Name</label>
                                                        <p><strong>@allotment.Customer.FullName</strong></p>
                                                    </div>
                                                    <div class="detail-field mb-2">
                                                        <label><i class="fas fa-id-card me-2"></i>Customer ID</label>
                                                        <p><code>@allotment.Customer.CustomerID</code></p>
                                                    </div>
                                                    <div class="detail-field mb-2">
                                                        <label><i class="fas fa-phone me-2"></i>Phone</label>
                                                        <p>@allotment.Customer.Phone</p>
                                                    </div>
                                                    <div class="detail-field mb-2">
                                                        <label><i class="fas fa-envelope me-2"></i>Email</label>
                                                        <p>@(allotment.Customer.Email ?? "N/A")</p>
                                                    </div>
                                                    <div class="detail-field mb-3">
                                                        <label><i class="fas fa-id-card-alt me-2"></i>CNIC</label>
                                                        <p>@(allotment.Customer.CNIC ?? "N/A")</p>
                                                    </div>
                                                    <a asp-controller="Customer" asp-action="Details" asp-route-id="@allotment.Customer.CustomerID" 
                                                       class="btn btn-primary w-100">
                                                        <i class="fas fa-eye me-2"></i>View Full Customer Details
                                                    </a>
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="alert alert-warning">
                                                <i class="fas fa-exclamation-triangle me-2"></i>
                                                Customer information not available
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center text-muted py-3">
                                <i class="fas fa-inbox fa-2x mb-2 d-block"></i>
                                <p class="mb-2">This property has not been allotted yet.</p>
                                @if (Model.Status == "Available")
                                {
                                    <a asp-action="Allot" asp-route-id="@Model.PropertyID" class="btn btn-success">
                                        <i class="fas fa-hand-holding me-2"></i>Allot Property
                                    </a>
                                }
                            </div>
                        }
                    </div>

                    <!-- Possessions Tab -->
                    <div class="tab-pane fade" id="possessions" role="tabpanel" aria-labelledby="possessions-tab">
                        @if (Model.Possessions != null && Model.Possessions.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead>
                                        <tr>
                                            <th>Possession ID</th>
                                            <th>Customer</th>
                                            <th>Date</th>
                                            <th>Status</th>
                                            <th>Remarks</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var possession in Model.Possessions.OrderByDescending(p => p.PossessionDate))
                                        {
                                            <tr>
                                                <td><code>@possession.PossessionID</code></td>
                                                <td>
                                                    @if (possession.Customer != null)
                                                    {
                                                        <strong>@possession.Customer.FullName</strong>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">N/A</span>
                                                    }
                                                </td>
                                                <td>@possession.PossessionDate.ToString("MMM dd, yyyy")</td>
                                                <td>
                                                    <span class="badge bg-success">@possession.WorkFlowStatus</span>
                                                </td>
                                                <td>@(possession.Remarks ?? "N/A")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="text-center text-muted py-3">
                                <i class="fas fa-inbox fa-2x mb-2 d-block"></i>
                                <p class="mb-0">No possession records found.</p>
                            </div>
                        }
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Tab Styling */
    .property-tabs {
        border-bottom: 2px solid #6f42c1;
        background: linear-gradient(135deg, #f8f9fa 0%, #f3f0ff 100%);
        padding: 0.5rem 1rem 0;
    }

    .property-tabs .nav-link {
        color: #666;
        font-weight: 600;
        border: none;
        border-bottom: 3px solid transparent;
        padding: 0.75rem 1.25rem;
        transition: all 0.3s ease;
        font-size: 14px;
    }

    .property-tabs .nav-link:hover {
        color: #6f42c1;
        background: rgba(111, 66, 193, 0.05);
        border-bottom-color: #9370db;
    }

    .property-tabs .nav-link.active {
        color: #6f42c1;
        background: white;
        border-bottom-color: #6f42c1;
        font-weight: 700;
    }

    .property-tabs .nav-link i {
        font-size: 13px;
    }

    .property-tabs .badge {
        font-size: 10px;
        padding: 3px 6px;
    }

    /* Tab Content */
    .tab-content {
        padding-top: 1rem;
    }

    /* Section Headers within Tabs */
    .tab-pane h6 {
        color: #6f42c1;
        font-weight: 700;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid #e8dcff;
    }

    /* Detail Fields */
    .detail-field {
        padding: 8px 10px;
        background: linear-gradient(135deg, #f8f9fa 0%, #f3f0ff 100%);
        border-radius: 6px;
        transition: all 0.3s ease;
    }

    .detail-field:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 15px rgba(111, 66, 193, 0.1);
    }

    .detail-field label {
        display: block;
        margin-bottom: 3px;
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #666;
        font-weight: 600;
    }

    .detail-field p {
        font-size: 14px;
        color: var(--text-dark);
        margin-bottom: 0;
        font-weight: 500;
    }

    code {
        background: #e8dcff;
        color: #6f42c1;
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 13px;
        font-weight: 600;
    }

    /* Stat Items */
    .stat-item {
        padding: 10px 12px;
        background: linear-gradient(135deg, #f8f9fa 0%, #f3f0ff 100%);
        border-radius: 8px;
        display: flex;
        align-items: center;
        gap: 10px;
        border-left: 3px solid #6f42c1;
    }

    .stat-item i {
        font-size: 18px;
    }

    .stat-label {
        flex: 1;
        font-size: 13px;
        color: var(--text-dark);
    }

    .stat-item strong {
        color: #6f42c1;
        font-size: 16px;
    }

    /* Owner Card */
    .owner-card {
        background: linear-gradient(135deg, #f8f9fa 0%, #f3f0ff 100%);
        border: 2px solid #e8dcff !important;
    }

    /* Responsive Tabs */
    @@media (max-width: 768px) {
        .property-tabs .nav-link {
            padding: 0.5rem 0.75rem;
            font-size: 12px;
        }

        .property-tabs .nav-link i {
            display: none;
        }

        .property-tabs .badge {
            font-size: 9px;
            padding: 2px 4px;
        }
    }
</style>
