@model IEnumerable<PMS.Models.Property>

@{
    ViewData["Title"] = "Reserve Properties";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-hand-paper me-2"></i>Reserve Properties - Bulk Dealer Assignment</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-2"></i>Back to List
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-triangle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card mb-4">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>Instructions</h5>
    </div>
    <div class="card-body">
        <p class="mb-0">
            <strong>How to use:</strong> Select multiple properties from the list below, choose the target dealer, and click "Change Dealer" to bulk assign all selected properties to the new dealer. All changes will be logged for audit purposes.
        </p>
    </div>
</div>

<form id="bulkDealerForm" asp-action="BulkChangeDealer" method="post">
    @Html.AntiForgeryToken()

    <div class="card mb-4">
        <div class="card-header bg-warning text-dark">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="fas fa-edit me-2"></i>Bulk Dealer Assignment</h5>
                <div>
                    <button type="button" class="btn btn-sm btn-light" onclick="selectAll()">
                        <i class="fas fa-check-square me-1"></i>Select All
                    </button>
                    <button type="button" class="btn btn-sm btn-light" onclick="deselectAll()">
                        <i class="fas fa-square me-1"></i>Deselect All
                    </button>
                </div>
            </div>
        </div>
        <div class="card-body">
            <div class="row mb-3">
                <div class="col-md-6">
                    <label for="toDealerId" class="form-label">Assign to Dealer *</label>
                    <select class="form-select" id="toDealerId" name="toDealerId" required>
                        <option value="">Select Dealer</option>
                        @if (ViewBag.Dealers != null)
                        {
                            @foreach (var dealer in ViewBag.Dealers)
                            {
                                <option value="@dealer.DealerID">@dealer.DealershipName</option>
                            }
                        }
                    </select>
                    <small class="form-text text-muted">Selected properties will be assigned to this dealer</small>
                </div>
                <div class="col-md-6">
                    <label for="remarks" class="form-label">Remarks (Optional)</label>
                    <input type="text" class="form-control" id="remarks" name="remarks" placeholder="Enter reason for dealer change" />
                    <small class="form-text text-muted">This will be recorded in the property log</small>
                </div>
            </div>
            <div class="d-flex justify-content-end">
                <button type="submit" class="btn btn-warning" id="changeDealerBtn" disabled>
                    <i class="fas fa-exchange-alt me-2"></i>Change Dealer (<span id="selectedCount">0</span> selected)
                </button>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="fas fa-home me-2"></i>Available Properties (@Model.Count())
                </h5>
                <div class="d-flex align-items-center gap-2">
                    <label for="projectFilter" class="form-label mb-0 me-2">Filter by Project:</label>
                    <select class="form-select form-select-sm" id="projectFilter" style="width: auto; min-width: 200px;" onchange="filterByProject()">
                        <option value="">All Projects</option>
                        @if (ViewBag.Projects != null)
                        {
                            @foreach (var project in ViewBag.Projects)
                            {
                                @if (ViewBag.SelectedProjectId != null && ViewBag.SelectedProjectId.ToString() == project.ProjectID)
                                {
                                    <option value="@project.ProjectID" selected>@project.ProjectName</option>
                                }
                                else
                                {
                                    <option value="@project.ProjectID">@project.ProjectName</option>
                                }
                            }
                        }
                    </select>
                    @if (ViewBag.SelectedProjectId != null)
                    {
                        <a asp-action="Reserve" class="btn btn-sm btn-outline-secondary" title="Clear Filter">
                            <i class="fas fa-times"></i> Clear
                        </a>
                    }
                </div>
            </div>
        </div>
        <div class="card-body">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover" id="propertiesTable">
                        <thead class="table-dark">
                            <tr>
                                <th style="width: 50px;">
                                    <input type="checkbox" id="selectAllCheckbox" onchange="toggleAll(this)" />
                                </th>
                                <th>Property ID</th>
                                <th>Project</th>
                                <th>Plot No</th>
                                <th>Street</th>
                                <th>Block</th>
                                <th>Type</th>
                                <th>Size</th>
                                <th>Current Dealer</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var property in Model)
                            {
                                <tr>
                                    <td>
                                        <input type="checkbox" class="property-checkbox" name="propertyIds" value="@property.PropertyID" onchange="updateSelectedCount()" />
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary">@property.PropertyID</span>
                                    </td>
                                    <td>
                                        @if (property.Project != null)
                                        {
                                            <span class="badge bg-info">@property.Project.ProjectName</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">No Project</span>
                                        }
                                    </td>
                                    <td><strong>@property.PlotNo</strong></td>
                                    <td>@property.Street</td>
                                    <td>@property.Block</td>
                                    <td>
                                        <span class="badge bg-primary">@property.PropertyType</span>
                                    </td>
                                    <td>@property.Size</td>
                                    <td>
                                        @if (property.Dealer != null)
                                        {
                                            <span class="badge bg-success">@property.Dealer.DealershipName</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">No Dealer</span>
                                        }
                                    </td>
                                    <td>
                                        <a asp-action="Details" asp-route-id="@property.PropertyID" 
                                           class="btn btn-sm btn-outline-info" title="View Details">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    <i class="fas fa-info-circle me-2"></i>
                    <strong>No Available Properties Found</strong>
                    <p class="mb-0 mt-2">There are currently no properties with "Available" status.</p>
                </div>
            }
        </div>
    </div>
</form>

@section Scripts {
    <script>
        var dataTable;

        $(document).ready(function() {
            dataTable = $('#propertiesTable').DataTable({
                "pageLength": 25,
                "order": [[ 2, "asc" ]],
                "columnDefs": [
                    { "orderable": false, "targets": [0, 9] }
                ]
            });
        });

        function filterByProject() {
            var projectId = document.getElementById('projectFilter').value;
            if (projectId) {
                window.location.href = '@Url.Action("Reserve", "Property")?projectId=' + projectId;
            } else {
                window.location.href = '@Url.Action("Reserve", "Property")';
            }
        }

        function toggleAll(checkbox) {
            var checkboxes = document.querySelectorAll('.property-checkbox');
            checkboxes.forEach(function(cb) {
                cb.checked = checkbox.checked;
            });
            updateSelectedCount();
        }

        function selectAll() {
            var checkboxes = document.querySelectorAll('.property-checkbox');
            checkboxes.forEach(function(cb) {
                cb.checked = true;
            });
            document.getElementById('selectAllCheckbox').checked = true;
            updateSelectedCount();
        }

        function deselectAll() {
            var checkboxes = document.querySelectorAll('.property-checkbox');
            checkboxes.forEach(function(cb) {
                cb.checked = false;
            });
            document.getElementById('selectAllCheckbox').checked = false;
            updateSelectedCount();
        }

        function updateSelectedCount() {
            var selected = document.querySelectorAll('.property-checkbox:checked').length;
            document.getElementById('selectedCount').textContent = selected;
            var changeBtn = document.getElementById('changeDealerBtn');
            if (selected > 0) {
                changeBtn.disabled = false;
                changeBtn.textContent = 'Change Dealer (' + selected + ' selected)';
            } else {
                changeBtn.disabled = true;
                changeBtn.textContent = 'Change Dealer (0 selected)';
            }
        }

        // Form submission confirmation
        document.getElementById('bulkDealerForm').addEventListener('submit', function(e) {
            var selected = document.querySelectorAll('.property-checkbox:checked').length;
            var dealerId = document.getElementById('toDealerId').value;

            if (selected === 0) {
                e.preventDefault();
                alert('Please select at least one property.');
                return false;
            }

            if (!dealerId) {
                e.preventDefault();
                alert('Please select a dealer.');
                return false;
            }

            var dealerName = document.getElementById('toDealerId').options[document.getElementById('toDealerId').selectedIndex].text;
            if (!confirm(`Are you sure you want to change dealer for ${selected} property/properties to "${dealerName}"? This action will be logged.`)) {
                e.preventDefault();
                return false;
            }
        });
    </script>
}

