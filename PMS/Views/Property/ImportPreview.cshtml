@model List<PMS.Models.PropertyImportViewModel>

@{
    ViewData["Title"] = "Preview Import";
}

<div class="row">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2><i class="fas fa-eye me-2"></i>Preview Import</h2>
            <a asp-action="Import" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Back to Upload
            </a>
        </div>

        <div class="alert alert-info">
            <i class="fas fa-file me-2"></i>
            <strong>File:</strong> @ViewBag.FileName
            <span class="ms-3"><strong>Project:</strong> @ViewBag.ProjectName (@ViewBag.ProjectID)</span>
            <span class="ms-3"><strong>Dealer:</strong> @ViewBag.DealerName</span>
            <span class="ms-3"><strong>Total Rows:</strong> @ViewBag.TotalRows</span>
            <span class="ms-3 text-success"><strong>Valid:</strong> @ViewBag.ValidRows</span>
            <span class="ms-3 text-danger"><strong>Invalid:</strong> @ViewBag.InvalidRows</span>
        </div>

        @if (ViewBag.ValidRows > 0)
        {
            <div class="card mb-4">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-check-circle me-2"></i>Valid Properties (@ViewBag.ValidRows)
                    </h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover" id="validTable">
                            <thead class="table-dark">
                                <tr>
                                    <th>Row</th>
                                    <th>Unit No</th>
                                    <th>Street</th>
                                    <th>PlotType</th>
                                    <th>Block</th>
                                    <th>PropertyType</th>
                                    <th>Size</th>
                                    <th>Floor</th>
                                    <th>Additional Info</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var prop in Model.Where(p => p.IsValid))
                                {
                                    <tr>
                                        <td>@prop.RowNumber</td>
                                        <td><strong>@prop.PlotNo</strong></td>
                                        <td>@prop.Street</td>
                                        <td>@prop.PlotType</td>
                                        <td>@prop.Block</td>
                                        <td>@prop.PropertyType</td>
                                        <td>@prop.Size</td>
                                        <td>@prop.Floor</td>
                                        <td>@prop.AdditionalInfo</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        @if (ViewBag.InvalidRows > 0)
        {
            <div class="card mb-4">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-exclamation-triangle me-2"></i>Invalid Properties (@ViewBag.InvalidRows)
                    </h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover" id="invalidTable">
                            <thead class="table-dark">
                                <tr>
                                    <th>Row</th>
                                    <th>Unit No</th>
                                    <th>Street</th>
                                    <th>PlotType</th>
                                    <th>Block</th>
                                    <th>PropertyType</th>
                                    <th>Size</th>
                                    <th>Floor</th>
                                    <th>Error</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var prop in Model.Where(p => !p.IsValid))
                                {
                                    <tr class="table-danger">
                                        <td>@prop.RowNumber</td>
                                        <td>@prop.PlotNo</td>
                                        <td>@prop.Street</td>
                                        <td>@prop.PlotType</td>
                                        <td>@prop.Block</td>
                                        <td>@prop.PropertyType</td>
                                        <td>@prop.Size</td>
                                        <td>@prop.Floor</td>
                                        <td><span class="badge bg-danger">@prop.ErrorMessage</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        @if (ViewBag.ValidRows > 0)
        {
            <div class="card">
                <div class="card-body">
                    <div class="alert alert-success">
                        <i class="fas fa-check-circle me-2"></i>
                        <strong>Ready to Import:</strong> All @ViewBag.ValidRows properties are ready to import to project @ViewBag.ProjectID.
                    </div>

                    <form asp-action="ImportConfirm" method="post">
                        @Html.AntiForgeryToken()
                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Import" class="btn btn-secondary">
                                <i class="fas fa-times me-2"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-success">
                                <i class="fas fa-check me-2"></i>Confirm and Import
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        }
        else if (ViewBag.ValidRows == 0)
        {
            <div class="alert alert-danger">
                <i class="fas fa-exclamation-triangle me-2"></i>
                <strong>No valid properties found!</strong> Please fix the errors and upload again.
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            if ($('#validTable tbody tr').length > 0) {
                $('#validTable').DataTable({
                    "pageLength": 25,
                    "order": [[ 0, "asc" ]]
                });
            }
            
            if ($('#invalidTable tbody tr').length > 0) {
                $('#invalidTable').DataTable({
                    "pageLength": 25,
                    "order": [[ 0, "asc" ]]
                });
            }
        });
    </script>
}

