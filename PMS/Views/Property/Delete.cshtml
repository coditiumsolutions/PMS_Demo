@model PMS.Models.Property

@{
    ViewData["Title"] = "Delete Property";
}

<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="text-danger">
                <i class="fas fa-trash-alt me-2"></i>Delete Property
            </h2>
        </div>

        <div class="alert alert-danger" role="alert">
            <h4 class="alert-heading">
                <i class="fas fa-exclamation-triangle me-2"></i>Warning!
            </h4>
            <p>Are you sure you want to delete this property? This action cannot be undone.</p>
            <hr>
            <p class="mb-0">
                <strong>Note:</strong> Deleting this property may affect related records such as allotments, possessions, and transfers.
            </p>
        </div>

        <div class="card mb-4">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0">
                    <i class="fas fa-home me-2"></i>Property Information
                </h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <div class="detail-field">
                            <label><i class="fas fa-id-badge me-2"></i>Property ID</label>
                            <p><code>@Model.PropertyID</code></p>
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <div class="detail-field">
                            <label><i class="fas fa-toggle-on me-2"></i>Status</label>
                            <p>
                                <span class="badge @(Model.Status == "Available" ? "bg-success" : Model.Status == "Allotted" ? "bg-warning" : "bg-danger")">
                                    @Model.Status
                                </span>
                            </p>
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <div class="detail-field">
                            <label><i class="fas fa-map-marker-alt me-2"></i>Plot No</label>
                            <p>@Model.PlotNo</p>
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <div class="detail-field">
                            <label><i class="fas fa-th-large me-2"></i>Block</label>
                            <p>@Model.Block</p>
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <div class="detail-field">
                            <label><i class="fas fa-home me-2"></i>Property Type</label>
                            <p>@Model.PropertyType</p>
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <div class="detail-field">
                            <label><i class="fas fa-ruler-combined me-2"></i>Size</label>
                            <p>@Model.Size</p>
                        </div>
                    </div>
                    @if (Model.Project != null)
                    {
                        <div class="col-md-12 mb-3">
                            <div class="detail-field">
                                <label><i class="fas fa-building me-2"></i>Project</label>
                                <p>@Model.Project.ProjectName - @Model.Project.Location</p>
                            </div>
                        </div>
                    }
                    <div class="col-md-6">
                        <div class="detail-field">
                            <label><i class="fas fa-calendar-alt me-2"></i>Created Date</label>
                            <p>@Model.CreatedAt.ToString("MMMM dd, yyyy")</p>
                        </div>
                    </div>
                </div>

                @if (Model.Allotments != null && Model.Allotments.Any())
                {
                    <hr>
                    <div class="alert alert-warning">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        <strong>Warning:</strong> This property has <strong>@Model.Allotments.Count</strong> allotment(s). Deleting it will affect these records.
                    </div>
                }
            </div>
        </div>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="PropertyID" />
            <div class="card border-danger">
                <div class="card-body text-center">
                    <h5 class="text-danger mb-4">
                        <i class="fas fa-exclamation-circle me-2"></i>
                        Confirm Deletion
                    </h5>
                    <p class="mb-4">
                        Type <strong>DELETE</strong> below to confirm this action:
                    </p>
                    <div class="mb-4">
                        <input type="text" id="confirmText" class="form-control text-center" 
                               placeholder="Type DELETE to confirm" style="max-width: 300px; margin: 0 auto;" />
                    </div>
                    <div class="d-flex justify-content-center gap-2">
                        <button type="submit" class="btn btn-danger" id="deleteBtn" disabled>
                            <i class="fas fa-trash-alt me-2"></i>Yes, Delete Property
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="fas fa-times me-2"></i>Cancel
                        </a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<style>
    .detail-field {
        padding: 12px;
        background: linear-gradient(135deg, #f8f9fa 0%, #fff5f5 100%);
        border-radius: 8px;
        border-left: 3px solid #dc3545;
    }

    .detail-field label {
        display: block;
        margin-bottom: 5px;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #666;
        font-weight: 600;
    }

    .detail-field p {
        font-size: 15px;
        color: var(--text-dark);
        margin-bottom: 0;
        font-weight: 500;
    }

    code {
        background: #ffe5e5;
        color: #dc3545;
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 13px;
        font-weight: 600;
    }
</style>

@section Scripts {
    <script>
        document.getElementById('confirmText').addEventListener('input', function() {
            const deleteBtn = document.getElementById('deleteBtn');
            if (this.value.toUpperCase() === 'DELETE') {
                deleteBtn.disabled = false;
                deleteBtn.classList.add('pulse');
            } else {
                deleteBtn.disabled = true;
                deleteBtn.classList.remove('pulse');
            }
        });

        // Prevent accidental form submission
        document.querySelector('form').addEventListener('submit', function(e) {
            const confirmText = document.getElementById('confirmText').value;
            if (confirmText.toUpperCase() !== 'DELETE') {
                e.preventDefault();
                alert('Please type DELETE to confirm deletion.');
                return false;
            }
            return confirm('Are you absolutely sure you want to delete this property?');
        });
    </script>

    <style>
        @@keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }

        .pulse {
            animation: pulse 1s infinite;
        }
    </style>
}

