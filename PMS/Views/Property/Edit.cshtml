@model PMS.Models.Property

@{
    ViewData["Title"] = "Edit Property";
}

<div class="row">
    <div class="col-md-10 mx-auto">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>
                <i class="fas fa-edit me-2"></i>Edit Property
            </h2>
            <div>
                <a asp-action="Details" asp-route-id="@Model.PropertyID" class="btn btn-outline-info me-2">
                    <i class="fas fa-eye me-2"></i>View Details
                </a>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Back to List
                </a>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="PropertyID" />
                    <input type="hidden" asp-for="CreatedAt" />
                    <input type="hidden" asp-for="Street" />
                    <input type="hidden" asp-for="PropertyType" />

                    <div class="row">
                        <!-- Property Basic Information -->
                        <div class="col-md-6">
                            <h5 class="text-primary mb-3">
                                <i class="fas fa-info-circle me-2"></i>Basic Information
                            </h5>

                            <div class="mb-3">
                                <label asp-for="ProjectID" class="form-label">Project</label>
                                <select asp-for="ProjectID" class="form-select">
                                    <option value="">Select Project</option>
                                    @if (ViewBag.Projects != null)
                                    {
                                        @foreach (var project in ViewBag.Projects)
                                        {
                                            <option value="@project.ProjectID">@project.ProjectName</option>
                                        }
                                    }
                                </select>
                                <span asp-validation-for="ProjectID" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="SubProject" class="form-label">Subproject *</label>
                                <select asp-for="SubProject" class="form-select" required id="subProject">
                                    <option value="">Select Project first</option>
                                </select>
                                <span asp-validation-for="SubProject" class="text-danger"></span>
                                <small class="text-muted">Options come from the selected project SubProjects list.</small>
                            </div>

                            <div class="mb-3">
                                <label asp-for="PlotNo" class="form-label">Unit No *</label>
                                <input asp-for="PlotNo" class="form-control" required />
                                <span asp-validation-for="PlotNo" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Block" class="form-label">Tower *</label>
                                <input asp-for="Block" class="form-control" required />
                                <span asp-validation-for="Block" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Floor" class="form-label">Floor</label>
                                <input asp-for="Floor" class="form-control" placeholder="e.g. G, 1, 2, Basement" />
                                <span asp-validation-for="Floor" class="text-danger"></span>
                            </div>
                        </div>

                        <!-- Property Details -->
                        <div class="col-md-6">
                            <h5 class="text-primary mb-3">
                                <i class="fas fa-list-alt me-2"></i>Property Details
                            </h5>

                            <div class="mb-3">
                                <label asp-for="PlotType" class="form-label">Unit Type (Category)</label>
                                <input asp-for="PlotType" class="form-control" id="plotType" placeholder="Enter Unit Type (Category)" />
                                <small class="text-muted">Free text value, not restricted to predefined options.</small>
                                <span asp-validation-for="PlotType" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Size" class="form-label">Size *</label>
                                <input asp-for="Size" class="form-control" required id="size" type="number" step="0.01" inputmode="decimal" placeholder="Enter size" />
                                <datalist id="sizeOptions"></datalist>
                                <small class="text-muted">Choose from list or type custom size.</small>
                                <span asp-validation-for="Size" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Status" class="form-label">Status</label>
                                <select asp-for="Status" class="form-select">
                                    <option value="Available">Available</option>
                                    <option value="Allotted">Allotted</option>
                                    <option value="Sold">Sold</option>
                                    <option value="Reserved">Reserved</option>
                                    <option value="Blocked">Blocked</option>
                                </select>
                                <span asp-validation-for="Status" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="DealerID" class="form-label">Dealer *</label>
                                <select asp-for="DealerID" class="form-select" required>
                                    <option value="">Select Dealer</option>
                                    @if (ViewBag.Dealers != null)
                                    {
                                        @foreach (var dealer in ViewBag.Dealers)
                                        {
                                            <option value="@dealer.DealerID">@dealer.DealershipName</option>
                                        }
                                    }
                                </select>
                                <span asp-validation-for="DealerID" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-12">
                            <div class="mb-3">
                                <label asp-for="AdditionalInfo" class="form-label">Additional Information</label>
                                <textarea asp-for="AdditionalInfo" class="form-control" rows="4" placeholder="Enter any additional notes or details about the property"></textarea>
                                <span asp-validation-for="AdditionalInfo" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <hr>

                    <div class="row">
                        <div class="col-12">
                            <div class="d-flex justify-content-end">
                                <button type="submit" class="btn btn-primary me-2">
                                    <i class="fas fa-save me-2"></i>Save Changes
                                </button>
                                <a asp-action="Details" asp-route-id="@Model.PropertyID" class="btn btn-outline-info me-2">
                                    <i class="fas fa-eye me-2"></i>View Details
                                </a>
                                <a asp-action="Index" class="btn btn-secondary">
                                    <i class="fas fa-times me-2"></i>Cancel
                                </a>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        (function () {
            var projectSelect = document.getElementById('ProjectID');
            var subProjectSelect = document.getElementById('subProject');
            var sizeInput = document.getElementById('size');
            var sizeOptions = document.getElementById('sizeOptions');
            var getProjectDetailsUrl = '@Url.Action("GetProjectDetails", "Property")';
            var savedSubProject = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model?.SubProject ?? ""));
            var savedSize = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model?.Size ?? ""));

            function fillSelectFromProject(values, select, saved, emptyLabel) {
                var list = values || [];
                var current = (select.value || saved || '').trim();
                select.innerHTML = '';
                var emptyOpt = document.createElement('option');
                emptyOpt.value = '';
                emptyOpt.textContent = emptyLabel;
                select.appendChild(emptyOpt);
                list.forEach(function (v) {
                    var opt = document.createElement('option');
                    opt.value = v;
                    opt.textContent = v;
                    if (v === current) opt.selected = true;
                    select.appendChild(opt);
                });
                if (current && list.indexOf(current) < 0) {
                    var opt = document.createElement('option');
                    opt.value = current;
                    opt.textContent = current;
                    opt.selected = true;
                    select.appendChild(opt);
                }
            }

            function fillDatalist(listEl, values) {
                if (!listEl) return;
                listEl.innerHTML = '';
                (values || []).forEach(function (v) {
                    var opt = document.createElement('option');
                    opt.value = v;
                    listEl.appendChild(opt);
                });
            }

            function loadProjectDetails() {
                var projectId = projectSelect && projectSelect.value;
                if (!projectId) {
                    subProjectSelect.innerHTML = '<option value="">Select Project first</option>';
                    fillDatalist(sizeOptions, []);
                    if (sizeInput) sizeInput.value = '';
                    return;
                }
                fetch(getProjectDetailsUrl + '?projectId=' + encodeURIComponent(projectId))
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                        fillSelectFromProject(data.subProjects || [], subProjectSelect, savedSubProject, 'Select Subproject');
                        fillDatalist(sizeOptions, data.sizes || []);
                        if (sizeInput && savedSize) sizeInput.value = savedSize;
                    })
                    .catch(function () {
                        subProjectSelect.innerHTML = '<option value="">Select Project first</option>';
                        fillDatalist(sizeOptions, []);
                    });
            }

            if (projectSelect) {
                projectSelect.addEventListener('change', function () {
                    savedSubProject = '';
                    savedSize = '';
                    loadProjectDetails();
                });
                if (projectSelect.value) loadProjectDetails();
            }
        })();
    </script>
}

