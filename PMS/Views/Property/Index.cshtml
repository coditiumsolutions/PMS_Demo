@model IEnumerable<PMS.Models.Property>

@{
    ViewData["Title"] = "Properties";
    ViewData["ListingTitle"] = "All Properties";
    ViewData["ListingRecordCount"] = Model?.Count() ?? 0;
    ViewData["ListingShowAdd"] = false;
    ViewData["ListingExtraActions"] =
        "<a href=\"" + Url.Action("Reserve") + "\" class=\"btn btn-warning btn-sm\">" +
        "<i class=\"bi bi-hand-index me-1\" aria-hidden=\"true\"></i>Reserve Properties</a>" +
        "<a href=\"" + Url.Action("Import") + "\" class=\"btn btn-success btn-sm\">" +
        "<i class=\"bi bi-upload me-1\" aria-hidden=\"true\"></i>Import Properties</a>" +
        "<a href=\"" + Url.Action("Create") + "\" class=\"btn btn-primary btn-sm\">" +
        "<i class=\"bi bi-plus-lg me-1\" aria-hidden=\"true\"></i>Add New Property</a>";
    ViewData["SearchCollapseId"] = "propertySearchCollapse";
}

<form method="get" asp-action="Index" class="mb-4">
    <div class="card pms-search-card">
        <partial name="Listing/_SearchCardHeader" />
        <div class="collapse show" id="propertySearchCollapse">
            <div class="card-body">
                <div class="row g-3 pms-search-fields align-items-end">
                    <div class="col-12 col-md-6 col-lg-3 col-search">
                        <div class="form-floating">
                            <select name="projectFilter" id="projectFilter" class="form-select" onchange="this.form.submit()">
                                <option value="All" selected="@(ViewBag.ProjectFilter == "All")">All Projects</option>
                                @if (ViewBag.Projects != null)
                                {
                                    foreach (var project in ViewBag.Projects)
                                    {
                                        <option value="@project.ProjectID" selected="@(ViewBag.ProjectFilter == project.ProjectID)">
                                            @project.ProjectName
                                        </option>
                                    }
                                }
                            </select>
                            <label for="projectFilter">Filter by Project</label>
                        </div>
                    </div>
                    <div class="col-12 col-md-6 col-lg-9 col-search">
                        <div class="d-flex justify-content-end gap-2 pms-search-actions border-0 mt-0 pt-0">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-counterclockwise me-1" aria-hidden="true"></i>Clear
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

<div class="card pms-grid-card">
    <div class="card-body">
        <partial name="Listing/_GridToolbar" />

        <div class="table-responsive">
            <table class="table table-hover align-middle pms-enterprise-table" id="propertiesTable">
                <thead>
                    <tr>
                        <th>Property ID</th>
                        <th>Project</th>
                        <th>SubProject</th>
                        <th>Tower</th>
                        <th>Floor</th>
                        <th>Unit No</th>
                        <th>Size</th>
                        <th>Unit Type (Category)</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var property in Model)
                    {
                        <tr>
                            <td>
                                <span class="badge bg-secondary">@property.PropertyID</span>
                            </td>
                            <td>
                                @if (property.Project != null)
                                {
                                    <span class="badge bg-info">@property.Project.ProjectName</span>
                                }
                                else
                                {
                                    <span class="text-muted">No Project</span>
                                }
                            </td>
                            <td><span class="pms-cell-truncate" title="@property.SubProject">@(string.IsNullOrWhiteSpace(property.SubProject) ? "—" : property.SubProject)</span></td>
                            <td>@property.Block</td>
                            <td>@(property.Floor ?? "—")</td>
                            <td><strong>@property.PlotNo</strong></td>
                            <td>@property.Size</td>
                            <td>@(string.IsNullOrWhiteSpace(property.PlotType) ? "—" : property.PlotType)</td>
                            <td>
                                @if (property.Status == "Available")
                                {
                                    <span class="badge bg-success">@property.Status</span>
                                }
                                else if (property.Status == "Allotted")
                                {
                                    <span class="badge bg-primary">@property.Status</span>
                                }
                                else if (property.Status == "Vacant")
                                {
                                    <span class="badge bg-secondary">@property.Status</span>
                                }
                                else if (property.Status == "Occupied")
                                {
                                    <span class="badge bg-info">@property.Status</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">@property.Status</span>
                                }
                            </td>
                            <td>
                                <div class="btn-group pms-action-group" role="group">
                                    <a asp-action="Edit" asp-route-id="@property.PropertyID" class="btn btn-sm btn-outline-primary" title="Edit">
                                        <i class="bi bi-pencil-square" aria-hidden="true"></i>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@property.PropertyID" class="btn btn-sm btn-outline-secondary" title="Details">
                                        <i class="bi bi-eye" aria-hidden="true"></i>
                                    </a>
                                    @if (property.Status == "Available")
                                    {
                                        <a asp-action="Allot" asp-route-id="@property.PropertyID"
                                           class="btn btn-sm btn-outline-success" title="Allot Property">
                                            <i class="bi bi-hand-index" aria-hidden="true"></i>
                                        </a>
                                    }
                                    <a asp-action="Delete" asp-route-id="@property.PropertyID"
                                       class="btn btn-sm btn-outline-danger" title="Delete">
                                        <i class="bi bi-trash" aria-hidden="true"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#propertiesTable').DataTable({
                "pageLength": 25,
                "order": [[ 5, "asc" ]],
                "columnDefs": [
                    { "orderable": false, "targets": 9 }
                ]
            });
        });
    </script>
}
