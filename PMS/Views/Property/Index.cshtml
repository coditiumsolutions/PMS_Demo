@model IEnumerable<PMS.Models.Property>

@{
    ViewData["Title"] = "Properties";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-home me-2"></i></h2>
    <div>
        <div>
            <a asp-action="Reserve" class="btn btn-warning me-2">
                <i class="fas fa-hand-paper me-2"></i>Reserve Properties
            </a>
            <a asp-action="Import" class="btn btn-success me-2">
                <i class="fas fa-file-upload me-2"></i>Import Properties
            </a>
            <a asp-action="Create" class="btn btn-primary">
                <i class="fas fa-plus me-2"></i>Add New Property
            </a>
        </div>
    </div>
</div>

<form method="get" asp-action="Index" class="mb-3">
    <div class="card">
        <div class="card-body py-2">
            <div class="row g-2 align-items-end">
                <div class="col-md-4">
                    <label class="form-label mb-1 fw-bold">Filter by Project</label>
                    <select name="projectFilter" class="form-select form-select-sm" onchange="this.form.submit()">
                        <option value="All" selected="@(ViewBag.ProjectFilter == "All")">All Projects</option>
                        @if (ViewBag.Projects != null)
                        {
                            foreach (var project in ViewBag.Projects)
                            {
                                <option value="@project.ProjectID" selected="@(ViewBag.ProjectFilter == project.ProjectID)">
                                    @project.ProjectName
                                </option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                        <i class="fas fa-times me-1"></i>Clear
                    </a>
                </div>
            </div>
        </div>
    </div>
</form>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover" id="propertiesTable">
                <thead class="table-dark">
                    <tr>
                        <th>Property ID</th>
                        <th>Project</th>
                        <th>SubProject</th>
                        <th>Tower</th>
                        <th>Floor</th>
                        <th>Unit No</th>
                        <th>Size</th>
                        <th>Unit Type (Category)</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var property in Model)
                    {
                        <tr>
                            <td>
                                <span class="badge bg-secondary">@property.PropertyID</span>
                            </td>
                            <td>
                                @if (property.Project != null)
                                {
                                    <span class="badge bg-info">@property.Project.ProjectName</span>
                                }
                                else
                                {
                                    <span class="text-muted">No Project</span>
                                }
                            </td>
                            <td>@(string.IsNullOrWhiteSpace(property.SubProject) ? "—" : property.SubProject)</td>
                            <td>@property.Block</td>
                            <td>@(property.Floor ?? "—")</td>
                            <td>
                                <strong>@property.PlotNo</strong>
                            </td>
                            <td>@property.Size</td>
                            <td>@(string.IsNullOrWhiteSpace(property.PlotType) ? "—" : property.PlotType)</td>
                            <td>
                                <span class="badge @(property.Status == "Available" ? "bg-success" : property.Status == "Allotted" ? "bg-warning" : "bg-danger")">
                                    @property.Status
                                </span>
                            </td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a asp-action="Edit" asp-route-id="@property.PropertyID" class="btn btn-sm btn-outline-success" title="Edit">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@property.PropertyID" class="btn btn-sm btn-outline-theme" title="Details">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    @if (property.Status == "Available")
                                    {
                                        <a asp-action="Allot" asp-route-id="@property.PropertyID" 
                                           class="btn btn-sm btn-outline-success" title="Allot Property">
                                            <i class="fas fa-hand-holding"></i>
                                        </a>
                                    }
                                    <a asp-action="Delete" asp-route-id="@property.PropertyID" 
                                       class="btn btn-sm btn-outline-danger" title="Delete">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#propertiesTable').DataTable({
                "pageLength": 25,
                "order": [[ 5, "asc" ]],
                "columnDefs": [
                    { "orderable": false, "targets": 9 }
                ]
            });
        });
    </script>
}
