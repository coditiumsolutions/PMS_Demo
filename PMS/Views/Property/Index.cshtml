@model IEnumerable<PMS.Models.Property>

@{
    ViewData["Title"] = "Properties";
    ViewData["ListingTitle"] = "All Properties";
    ViewData["ListingDescription"] = "Inventory by project and unit";
    ViewData["ListingRecordCount"] = Model?.Count() ?? 0;
    ViewData["ListingShowAdd"] = false;
    ViewData["ListingExtraActions"] =
        "<a href=\"" + Url.Action("Reserve") + "\" class=\"btn btn-outline-warning btn-sm\">" +
        "<i class=\"bi bi-hand-index me-1\" aria-hidden=\"true\"></i>Reserve Properties</a>" +
        "<a href=\"" + Url.Action("Import") + "\" class=\"btn btn-outline-success btn-sm\">" +
        "<i class=\"bi bi-upload me-1\" aria-hidden=\"true\"></i>Import Properties</a>" +
        "<a href=\"" + Url.Action("Create") + "\" class=\"btn btn-primary btn-sm\">" +
        "<i class=\"bi bi-plus-lg me-1\" aria-hidden=\"true\"></i>Add New Property</a>";
}

<form method="get" asp-action="Index" class="mb-4 pms-listing-page">
    <div class="pms-listing-search-wrap">
        <div class="row g-2 align-items-end flex-lg-nowrap">
            <div class="col-12 col-md-6 col-lg-4">
                <div class="pms-compact-field pms-select-dropdown">
                    <label for="projectFilter" class="form-label">Project</label>
                    <select name="projectFilter" id="projectFilter" class="form-select" onchange="this.form.submit()">
                        <option value="All" selected="@(ViewBag.ProjectFilter == "All")">All Projects</option>
                        @if (ViewBag.Projects != null)
                        {
                            foreach (var project in ViewBag.Projects)
                            {
                                <option value="@project.ProjectID" selected="@(ViewBag.ProjectFilter == project.ProjectID)">
                                    @project.ProjectName
                                </option>
                            }
                        }
                    </select>
                </div>
            </div>
            <div class="col-12 col-lg-8">
                <div class="d-flex flex-wrap gap-2 pms-listing-search-actions justify-content-lg-end">
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-arrow-counterclockwise me-1" aria-hidden="true"></i>Clear
                    </a>
                </div>
            </div>
        </div>
    </div>
</form>

<div class="card pms-grid-card pms-listing-flat pms-saas-grid pms-listing-page">
    <div class="card-body">
        <partial name="Listing/_GridToolbar" />

        <div class="table-responsive pms-saas-table-wrap">
            <table class="table pms-saas-table" id="propertiesTable">
                <thead>
                    <tr>
                        <th>Property ID</th>
                        <th>Project</th>
                        <th>SubProject</th>
                        <th>Tower</th>
                        <th>Floor</th>
                        <th>Unit No</th>
                        <th>Size</th>
                        <th>Unit Type (Category)</th>
                        <th>Status</th>
                        <th class="pms-saas-th-actions">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var property in Model)
                    {
                        var statusPill = property.Status switch
                        {
                            "Available" => "pms-pill--success",
                            "Allotted" => "pms-pill--info",
                            "Vacant" => "pms-pill--neutral",
                            "Occupied" => "pms-pill--info",
                            _ => "pms-pill--danger"
                        };
                        <tr>
                            <td data-label="Property ID"><span class="badge bg-secondary">@property.PropertyID</span></td>
                            <td data-label="Project">
                                @if (property.Project != null)
                                {
                                    <span class="pms-pill pms-pill--info">@property.Project.ProjectName</span>
                                }
                                else
                                {
                                    <span class="text-muted">No Project</span>
                                }
                            </td>
                            <td data-label="SubProject"><span class="pms-cell-truncate" title="@property.SubProject">@(string.IsNullOrWhiteSpace(property.SubProject) ? "—" : property.SubProject)</span></td>
                            <td data-label="Tower">@property.Block</td>
                            <td data-label="Floor">@(property.Floor ?? "—")</td>
                            <td data-label="Unit No"><strong>@property.PlotNo</strong></td>
                            <td data-label="Size">@property.Size</td>
                            <td data-label="Unit Type">@(string.IsNullOrWhiteSpace(property.PlotType) ? "—" : property.PlotType)</td>
                            <td data-label="Status"><span class="pms-pill @statusPill">@property.Status</span></td>
                            <td class="pms-saas-td-actions" data-label="Actions">
                                <div class="pms-row-actions" role="group">
                                    <a asp-action="Edit" asp-route-id="@property.PropertyID" class="btn btn-sm btn-outline-primary" title="Edit">
                                        <i class="bi bi-pencil-square" aria-hidden="true"></i>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@property.PropertyID" class="btn btn-sm btn-outline-secondary" title="Details">
                                        <i class="bi bi-eye" aria-hidden="true"></i>
                                    </a>
                                    @if (property.Status == "Available")
                                    {
                                        <a asp-action="Allot" asp-route-id="@property.PropertyID"
                                           class="btn btn-sm btn-outline-success" title="Allot Property">
                                            <i class="bi bi-hand-index" aria-hidden="true"></i>
                                        </a>
                                    }
                                    <a asp-action="Delete" asp-route-id="@property.PropertyID"
                                       class="btn btn-sm btn-outline-danger" title="Delete">
                                        <i class="bi bi-trash" aria-hidden="true"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#propertiesTable').DataTable({
                pageLength: 25,
                order: [[5, 'asc']],
                columnDefs: [{ orderable: false, targets: 9 }]
            });
        });
    </script>
}
