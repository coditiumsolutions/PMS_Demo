@model IEnumerable<PMS.Models.Property>

@{
    ViewData["Title"] = "Properties";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <!-- <h2><i class="fas fa-home me-2"></i>Properties</h2> -->
    <a asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus me-2"></i>Add New Property
    </a>
</div>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover" id="propertiesTable">
                <thead class="table-dark">
                    <tr>
                        <th>Property ID</th>
                        <th>Plot No</th>
                        <th>Project</th>
                        <th>Block</th>
                        <th>Type</th>
                        <th>Size</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var property in Model)
                    {
                        <tr>
                            <td>
                                <span class="badge bg-secondary">@property.PropertyID</span>
                            </td>
                            <td>
                                <strong>@property.PlotNo</strong>
                                @if (!string.IsNullOrEmpty(property.Street))
                                {
                                    <br><small class="text-muted">@property.Street</small>
                                }
                            </td>
                            <td>
                                @if (property.Project != null)
                                {
                                    <span class="badge bg-info">@property.Project.ProjectName</span>
                                }
                                else
                                {
                                    <span class="text-muted">No Project</span>
                                }
                            </td>
                            <td>@property.Block</td>
                            <td>
                                <span class="badge bg-primary">@property.PropertyType</span>
                            </td>
                            <td>@property.Size</td>
                            <td>
                                <span class="badge @(property.Status == "Available" ? "bg-success" : property.Status == "Allotted" ? "bg-warning" : "bg-danger")">
                                    @property.Status
                                </span>
                            </td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a asp-action="Details" asp-route-id="@property.PropertyID" 
                                       class="btn btn-sm btn-outline-info" title="View Details">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@property.PropertyID" 
                                       class="btn btn-sm btn-outline-primary" title="Edit">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    @if (property.Status == "Available")
                                    {
                                        <a asp-action="Allot" asp-route-id="@property.PropertyID" 
                                           class="btn btn-sm btn-outline-success" title="Allot Property">
                                            <i class="fas fa-hand-holding"></i>
                                        </a>
                                    }
                                    <a asp-action="Delete" asp-route-id="@property.PropertyID" 
                                       class="btn btn-sm btn-outline-danger" title="Delete">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#propertiesTable').DataTable({
                "pageLength": 25,
                "order": [[ 1, "asc" ]],
                "columnDefs": [
                    { "orderable": false, "targets": 7 }
                ]
            });
        });
    </script>
}
