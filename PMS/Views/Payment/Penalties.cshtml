@model IEnumerable<PMS.Models.Penalty>

@{
    ViewData["Title"] = "Penalties";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>
        <i class="fas fa-exclamation-triangle me-2"></i>Penalties
    </h2>
    <div>
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addPenaltyModal">
            <i class="fas fa-plus me-2"></i>Add Penalty
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary ms-2">
            <i class="fas fa-arrow-left me-2"></i>Back to Payments
        </a>
    </div>
</div>

<!-- Statistics -->
<div class="row mb-4">
    <div class="col-md-4">
        <div class="stats-card">
            <div class="stats-number">@Model.Count()</div>
            <div class="stats-label">Total Penalties</div>
            <i class="fas fa-exclamation-circle fa-2x mt-2" style="color: #dc3545;"></i>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stats-card">
            <div class="stats-number">@Model.Sum(p => p.Amount).ToString("N0")</div>
            <div class="stats-label">Total Amount (PKR)</div>
            <i class="fas fa-money-bill-wave fa-2x mt-2" style="color: #dc3545;"></i>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stats-card">
            <div class="stats-number">@Model.Where(p => p.AppliedOn >= DateTime.Now.AddMonths(-1)).Count()</div>
            <div class="stats-label">This Month</div>
            <i class="fas fa-calendar-alt fa-2x mt-2" style="color: #dc3545;"></i>
        </div>
    </div>
</div>

<!-- Penalties Table -->
<div class="card">
    <div class="card-header">
        <h5 class="mb-0">
            <i class="fas fa-list me-2"></i>All Penalties
        </h5>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover" id="penaltiesTable">
                <thead>
                    <tr>
                        <th>Penalty ID</th>
                        <th>Customer</th>
                        <th>Amount</th>
                        <th>Reason</th>
                        <th>Applied On</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var penalty in Model.OrderByDescending(p => p.AppliedOn))
                    {
                        <tr>
                            <td><code>@penalty.PenaltyID</code></td>
                            <td>
                                @if (penalty.Customer != null)
                                {
                                    <strong>@penalty.Customer.FullName</strong>
                                    <br>
                                    <small class="text-muted">@penalty.Customer.CustomerID</small>
                                }
                                else
                                {
                                    <span class="text-muted">N/A</span>
                                }
                            </td>
                            <td>
                                <strong class="text-danger">@penalty.Amount.ToString("N2") PKR</strong>
                            </td>
                            <td>@penalty.Reason</td>
                            <td>
                                <i class="far fa-calendar-alt me-1"></i>
                                @penalty.AppliedOn.ToString("MMM dd, yyyy")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Add Penalty Modal -->
<div class="modal fade" id="addPenaltyModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="fas fa-exclamation-triangle me-2"></i>Add Penalty
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="AddPenalty" method="post">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="customerId" class="form-label">Customer *</label>
                        <select name="customerId" id="customerId" class="form-select" required>
                            <option value="">Select Customer</option>
                            @{
                                var customers = ViewBag.Customers as List<PMS.Models.Customer>;
                                if (customers != null)
                                {
                                    @foreach (var customer in customers)
                                    {
                                        <option value="@customer.CustomerID">@customer.FullName - @customer.CustomerID</option>
                                    }
                                }
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="amount" class="form-label">Penalty Amount (PKR) *</label>
                        <input type="number" name="amount" id="amount" step="0.01" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label for="reason" class="form-label">Reason *</label>
                        <textarea name="reason" id="reason" class="form-control" rows="3" required></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-save me-2"></i>Add Penalty
                    </button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    code {
        background: #ffe5e5;
        color: #dc3545;
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#penaltiesTable').DataTable({
                "pageLength": 25,
                "order": [[ 4, "desc" ]]
            });
        });
    </script>
}

