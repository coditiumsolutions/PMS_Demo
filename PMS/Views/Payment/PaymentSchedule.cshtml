@model PMS.Models.PaymentPlan

@{
    ViewData["Title"] = "Payment Plan Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>
        <i class="fas fa-file-invoice-dollar me-2"></i>Payment Plan Details
    </h2>
    <div>
        <a asp-action="CreatePaymentSchedule" asp-route-planId="@Model.PlanID" class="btn btn-primary me-2">
            <i class="fas fa-plus me-2"></i>Add Installment
        </a>
        <a asp-action="PaymentPlans" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Back to Plans
        </a>
    </div>
</div>

<!-- Payment Plan Details -->
<div class="card mb-4">
    <div class="card-header" style="background: linear-gradient(135deg, #9C6ADE 0%, #C9B3FF 100%);">
        <h5 class="mb-0 text-white">
            <i class="fas fa-file-invoice-dollar me-2"></i>@Model.PlanName
        </h5>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-3">
                <small class="text-muted">Total Amount (SSP)</small>
                <p class="fw-bold" style="color: #9C6ADE; font-size: 1.2rem;">
                    <span data-format-number="@Model.TotalAmount">@Model.TotalAmount.ToString("N0")</span>
                </p>
            </div>
            <div class="col-md-3">
                <small class="text-muted">Duration</small>
                <p class="fw-bold">@Model.DurationMonths Months</p>
            </div>
            <div class="col-md-3">
                <small class="text-muted">Frequency</small>
                <p class="fw-bold">@Model.Frequency</p>
            </div>
            <div class="col-md-3">
                <small class="text-muted">Total Schedules</small>
                <p class="fw-bold">@(Model.PaymentSchedules?.Count ?? 0)</p>
            </div>
        </div>
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <hr>
            <small class="text-muted">Description</small>
            <p class="mb-0">@Model.Description</p>
        }
    </div>
</div>

<!-- Customers on This Plan -->
@if (Model.Customers != null && Model.Customers.Any())
{
    <div class="card mb-4">
        <div class="card-header">
            <h6 class="mb-0">
                <i class="fas fa-users me-2"></i>Customers on This Plan (@Model.Customers.Count)
            </h6>
        </div>
        <div class="card-body">
            <div class="d-flex flex-wrap gap-2">
                @foreach (var customer in Model.Customers.Take(10))
                {
                    <span class="badge bg-primary" style="font-size: 12px; padding: 8px 12px;">
                        <i class="fas fa-user me-1"></i>@customer.FullName
                    </span>
                }
                @if (Model.Customers.Count > 10)
                {
                    <span class="badge bg-secondary" style="font-size: 12px; padding: 8px 12px;">
                        +@(Model.Customers.Count - 10) more
                    </span>
                }
            </div>
        </div>
    </div>
}

<!-- Payment Schedules Table -->
<div class="card">
    <div class="card-header" style="background: linear-gradient(135deg, #9C6ADE 0%, #C9B3FF 100%);">
        <h5 class="mb-0 text-white">
            <i class="fas fa-list-alt me-2"></i>Installment Schedule
        </h5>
    </div>
    <div class="card-body">
        @if (Model.PaymentSchedules != null && Model.PaymentSchedules.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Installment #</th>
                            <th>Description</th>
                            <th>Due Date</th>
                            <th>Amount</th>
                            <th>Surcharge</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var schedule in Model.PaymentSchedules.OrderBy(s => s.InstallmentNo))
                        {
                            var totalPaid = schedule.Payments?.Where(p => p.Status == "Completed").Sum(p => p.Amount) ?? 0;
                            var isPaid = totalPaid >= schedule.Amount;
                            var isOverdue = schedule.DueDate < DateTime.Now && !isPaid;
                            
                            <tr class="@(isPaid ? "table-success" : isOverdue ? "table-warning" : "")">
                                <td>
                                    <strong>#@schedule.InstallmentNo</strong>
                                </td>
                                <td>
                                    @schedule.PaymentDescription
                                    @if (!string.IsNullOrEmpty(schedule.Description))
                                    {
                                        <br><small class="text-muted">@schedule.Description</small>
                                    }
                                </td>
                                <td>
                                    <i class="far fa-calendar-alt me-1"></i>
                                    @schedule.DueDate.ToString("MMM dd, yyyy")
                                    @if (isOverdue)
                                    {
                                        <br><small class="text-danger"><i class="fas fa-exclamation-triangle me-1"></i>Overdue</small>
                                    }
                                </td>
                                <td>
                                    <strong style="color: #9C6ADE;">
                                        <span data-format-number="@schedule.Amount">@schedule.Amount.ToString("N0")</span> SSP
                                    </strong>
                                    @if (totalPaid > 0)
                                    {
                                        <br><small class="text-muted">Paid: <span data-format-number="@totalPaid">@totalPaid.ToString("N0")</span> SSP</small>
                                    }
                                </td>
                                <td>
                                    @if (schedule.SurchargeApplied)
                                    {
                                        <span class="badge bg-warning">
                                            @((schedule.SurchargeRate * 100).ToString("N1"))%
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">None</span>
                                    }
                                </td>
                                <td>
                                    @if (isPaid)
                                    {
                                        <span class="badge bg-success">
                                            <i class="fas fa-check-circle me-1"></i>Paid
                                        </span>
                                    }
                                    else if (isOverdue)
                                    {
                                        <span class="badge bg-danger">
                                            <i class="fas fa-exclamation-circle me-1"></i>Overdue
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">
                                            <i class="far fa-clock me-1"></i>Pending
                                        </span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group" role="group">
                                        @if (!isPaid)
                                        {
                                            <a asp-action="RecordPayment" asp-route-scheduleId="@schedule.ScheduleID" 
                                               class="btn btn-sm btn-success" title="Record Payment">
                                                <i class="fas fa-money-bill-wave"></i>
                                            </a>
                                        }
                                        <button type="button" 
                                                class="btn btn-sm btn-outline-info" 
                                                data-bs-toggle="modal" 
                                                data-bs-target="#scheduleModal@(schedule.ScheduleID)"
                                                title="View Details">
                                            <i class="fas fa-eye"></i>
                                        </button>
                                        <button type="button" 
                                                class="btn btn-sm btn-outline-primary" 
                                                data-bs-toggle="modal" 
                                                data-bs-target="#editModal@(schedule.ScheduleID)"
                                                title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        <button type="button" 
                                                class="btn btn-sm btn-outline-danger" 
                                                onclick="deleteSchedule('@schedule.ScheduleID')"
                                                title="Delete">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>

                            <!-- Schedule Details Modal -->
                            <div class="modal fade" id="scheduleModal@(schedule.ScheduleID)" tabindex="-1">
                                <div class="modal-dialog modal-lg">
                                    <div class="modal-content">
                                        <div class="modal-header" style="background: var(--primary-green);">
                                            <h5 class="modal-title text-white">
                                                <i class="fas fa-receipt me-2"></i>Installment #@schedule.InstallmentNo Details
                                            </h5>
                                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                        </div>
                                        <div class="modal-body">
                                            <div class="row mb-3">
                                                <div class="col-6">
                                                    <label class="text-muted small">Schedule ID</label>
                                                    <p><code>@schedule.ScheduleID</code></p>
                                                </div>
                                                <div class="col-6">
                                                    <label class="text-muted small">Installment Number</label>
                                                    <p><strong>#@schedule.InstallmentNo</strong></p>
                                                </div>
                                                <div class="col-12">
                                                    <label class="text-muted small">Description</label>
                                                    <p>@schedule.PaymentDescription</p>
                                                </div>
                                                <div class="col-6">
                                                    <label class="text-muted small">Due Date</label>
                                                    <p>@schedule.DueDate.ToString("MMMM dd, yyyy")</p>
                                                </div>
                                                <div class="col-6">
                                                    <label class="text-muted small">Amount (SSP)</label>
                                                    <p><strong style="color: #9C6ADE;">
                                                        <span data-format-number="@schedule.Amount">@schedule.Amount.ToString("N0")</span>
                                                    </strong></p>
                                                </div>
                                                <div class="col-6">
                                                    <label class="text-muted small">Surcharge Applied</label>
                                                    <p>@(schedule.SurchargeApplied ? "Yes" : "No")</p>
                                                </div>
                                                <div class="col-6">
                                                    <label class="text-muted small">Surcharge Rate</label>
                                                    <p>@((schedule.SurchargeRate * 100).ToString("N1"))%</p>
                                                </div>
                                            </div>

                                            @if (schedule.Payments != null && schedule.Payments.Any())
                                            {
                                                <hr>
                                                <h6 class="mb-3"><i class="fas fa-money-check-alt me-2"></i>Payment History</h6>
                                                <div class="table-responsive">
                                                    <table class="table table-sm">
                                                        <thead>
                                                            <tr>
                                                                <th>Date</th>
                                                                <th>Amount</th>
                                                                <th>Method</th>
                                                                <th>Reference</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            @foreach (var payment in schedule.Payments.OrderByDescending(p => p.PaymentDate))
                                                            {
                                                                <tr>
                                                                    <td>@payment.PaymentDate.ToString("MMM dd, yyyy")</td>
                                                                    <td><strong>@payment.Amount.ToString("N2") SSP</strong></td>
                                                                    <td>@payment.Method</td>
                                                                    <td><small>@payment.ReferenceNo</small></td>
                                                                </tr>
                                                            }
                                                        </tbody>
                                                    </table>
                                                </div>
                                            }
                                        </div>
                                        <div class="modal-footer">
                                            @if (!isPaid)
                                            {
                                                <a asp-action="RecordPayment" asp-route-scheduleId="@schedule.ScheduleID" 
                                                   class="btn btn-success">
                                                    <i class="fas fa-money-bill-wave me-2"></i>Record Payment
                                                </a>
                                            }
                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Edit Schedule Modal -->
                            <div class="modal fade" id="editModal@(schedule.ScheduleID)" tabindex="-1">
                                <div class="modal-dialog">
                                    <div class="modal-content">
                                        <div class="modal-header" style="background: var(--primary);">
                                            <h6 class="modal-title text-white">
                                                <i class="fas fa-edit me-2"></i>Edit Installment #@schedule.InstallmentNo
                                            </h6>
                                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                        </div>
                                        <form asp-action="EditPaymentSchedule" method="post">
                                            <div class="modal-body">
                                                <input type="hidden" name="ScheduleID" value="@schedule.ScheduleID" />
                                                <input type="hidden" name="PlanID" value="@schedule.PlanID" />

                                                <div class="mb-3">
                                                    <label class="form-label">Installment Number</label>
                                                    <input type="number" name="InstallmentNo" class="form-control" value="@schedule.InstallmentNo" required />
                                                </div>

                                                <div class="mb-3">
                                                    <label class="form-label">Description</label>
                                                    <input type="text" name="PaymentDescription" class="form-control" value="@schedule.PaymentDescription" required />
                                                </div>

                                                <div class="mb-3">
                                                    <label class="form-label">Due Date</label>
                                                    <input type="date" name="DueDate" class="form-control" value="@schedule.DueDate.ToString("yyyy-MM-dd")" required />
                                                </div>

                                                <div class="mb-3">
                                                    <label class="form-label">Amount (SSP)</label>
                                                    <input type="number" name="Amount" step="0.01" class="form-control" value="@schedule.Amount" required />
                                                </div>

                                                <div class="mb-3">
                                                    <label class="form-label">Surcharge Rate (%)</label>
                                                    <input type="number" name="SurchargeRate" step="0.01" class="form-control" value="@((schedule.SurchargeRate * 100).ToString("N2"))" />
                                                </div>

                                                <div class="mb-3">
                                                    <div class="form-check form-switch">
                                                        <input type="checkbox" name="SurchargeApplied" class="form-check-input" @(schedule.SurchargeApplied ? "checked" : "") />
                                                        <label class="form-check-label">Apply Surcharge</label>
                                                    </div>
                                                </div>

                                                <div class="mb-3">
                                                    <label class="form-label">Additional Notes</label>
                                                    <textarea name="Description" class="form-control" rows="2">@schedule.Description</textarea>
                                                </div>
                                            </div>
                                            <div class="modal-footer">
                                                <button type="submit" class="btn btn-primary">
                                                    <i class="fas fa-save me-2"></i>Save Changes
                                                </button>
                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-calendar-plus fa-4x mb-3 text-muted"></i>
                <h5 class="text-muted">No Installments Added Yet</h5>
                <p class="text-muted">Create installment schedules for this payment plan.</p>
                <a asp-action="CreatePaymentSchedule" asp-route-planId="@Model.PlanID" class="btn btn-primary">
                    <i class="fas fa-plus me-2"></i>Add First Installment
                </a>
            </div>
        }
    </div>
</div>

<!-- Delete Form (Hidden) -->
<form id="deleteForm" asp-action="DeletePaymentSchedule" method="post" style="display: none;">
    <input type="hidden" id="deleteScheduleID" name="scheduleId" />
    <input type="hidden" name="planId" value="@Model.PlanID" />
</form>

<style>
    code {
        background: rgba(156, 106, 222, 0.1);
        color: var(--primary);
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
    }
</style>

@section Scripts {
    <script>
        function deleteSchedule(scheduleId) {
            if (confirm('Are you sure you want to delete this installment?\n\nThis action cannot be undone.')) {
                document.getElementById('deleteScheduleID').value = scheduleId;
                document.getElementById('deleteForm').submit();
            }
        }
    </script>
}


