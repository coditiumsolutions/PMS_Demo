@model PMS.Models.PaymentPlan
@using System.Globalization

@{
    ViewData["Title"] = "Payment Plan Details";
    var enUs = CultureInfo.GetCultureInfo("en-US");
    var scheduleCount = Model.PaymentSchedules?.Count ?? 0;
    var customerCount = Model.Customers?.Count ?? 0;
    var avgInstallment = scheduleCount > 0 ? (Model.TotalAmount / scheduleCount) : 0m;
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">
        <i class="fas fa-file-invoice-dollar me-2"></i>Payment Plan Details
    </h3>
    <div class="d-flex gap-2">
        <a asp-action="PaymentPlans" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i>Back
        </a>
        <a asp-action="PaymentSchedule" asp-route-planId="@Model.PlanID" class="btn btn-primary">
            <i class="fas fa-calendar-check me-1"></i>View Schedules
        </a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header">
        <h5 class="mb-0">@Model.PlanName</h5>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label text-muted small mb-1">Plan ID</label>
                <div class="form-control bg-light"><code>@Model.PlanID</code></div>
            </div>
            <div class="col-md-6">
                <label class="form-label text-muted small mb-1">Created Date</label>
                <div class="form-control bg-light">@Model.CreatedAt.ToString("MMM dd, yyyy")</div>
            </div>
            <div class="col-md-6">
                <label class="form-label text-muted small mb-1">Project</label>
                <div class="form-control bg-light">@(Model.Project?.ProjectName ?? "N/A")</div>
            </div>
            <div class="col-md-6">
                <label class="form-label text-muted small mb-1">Currency</label>
                <div class="form-control bg-light">@Model.Currency</div>
            </div>
            <div class="col-md-6">
                <label class="form-label text-muted small mb-1">Total Amount</label>
                <div class="form-control bg-light fw-semibold text-success">PKR @Model.TotalAmount.ToString("N0", enUs)</div>
            </div>
            <div class="col-md-6">
                <label class="form-label text-muted small mb-1">Duration</label>
                <div class="form-control bg-light">@(Model.DurationMonths?.ToString() ?? "N/A") Months</div>
            </div>
            <div class="col-md-6">
                <label class="form-label text-muted small mb-1">Frequency</label>
                <div class="form-control bg-light">@Model.Frequency</div>
            </div>
            <div class="col-md-6">
                <label class="form-label text-muted small mb-1">Customers</label>
                <div class="form-control bg-light">@customerCount</div>
            </div>
            <div class="col-md-6">
                <label class="form-label text-muted small mb-1">Schedules</label>
                <div class="form-control bg-light">@scheduleCount</div>
            </div>
            <div class="col-md-6">
                <label class="form-label text-muted small mb-1">Average Installment</label>
                <div class="form-control bg-light">PKR @avgInstallment.ToString("N0", enUs)</div>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <div class="col-12">
                    <label class="form-label text-muted small mb-1">Description</label>
                    <textarea class="form-control bg-light" rows="3" readonly>@Model.Description</textarea>
                </div>
            }
        </div>
    </div>
</div>
