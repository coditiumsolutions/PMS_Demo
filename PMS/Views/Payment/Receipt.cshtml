@model PMS.Models.Payment
@{
    Layout = null;
    ViewData["Title"] = "Payment Receipt";
    var schedule = Model.PaymentSchedule;
    var plan = schedule?.PaymentPlan;
    var project = plan?.Project;
    var customer = Model.Customer;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Payment Receipt - @Model.PaymentID - PMS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
</head>
<body>

<div class="d-flex justify-content-between align-items-center mb-3 no-print">
    <h3 class="mb-0"><i class="fas fa-receipt me-2"></i>Payment Receipt</h3>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-primary btn-sm" onclick="window.print()"><i class="fas fa-print me-1"></i>Print</button>
    </div>
</div>

<div class="a4-container">
    <div class="a4-header text-center">
        <img src="~/images/logo.jpeg" alt="Logo" class="a4-logo" />
        <div class="a4-title">Payment Receipt</div>
        <div class="a4-subtitle">Property Management System</div>
        <div class="a4-subtitle">Generated on: @DateTime.Now.ToString("dd-MM-yyyy HH:mm")</div>
    </div>

    <!-- Customer -->
    <div class="a4-section">
        <div class="a4-section-title">Customer</div>
        <div class="a4-info-grid">
            <div class="a4-info-block">
                <div class="a4-info-row"><span class="a4-info-label">Customer ID:</span><span class="a4-info-value"><strong>@(customer?.CustomerID ?? "—")</strong></span></div>
                <div class="a4-info-row"><span class="a4-info-label">Name:</span><span class="a4-info-value">@(customer?.FullName ?? "—")</span></div>
                <div class="a4-info-row"><span class="a4-info-label">CNIC:</span><span class="a4-info-value">@(customer?.CNIC ?? "—")</span></div>
                <div class="a4-info-row"><span class="a4-info-label">Phone:</span><span class="a4-info-value">@(customer?.Phone ?? "—")</span></div>
                <div class="a4-info-row"><span class="a4-info-label">Email:</span><span class="a4-info-value">@(customer?.Email ?? "—")</span></div>
            </div>
            <div class="a4-info-block">
                <div class="a4-info-row"><span class="a4-info-label">Plan ID:</span><span class="a4-info-value"><code>@(plan?.PlanID ?? "—")</code></span></div>
                <div class="a4-info-row"><span class="a4-info-label">Plan Name:</span><span class="a4-info-value">@(plan?.PlanName ?? "—")</span></div>
                <div class="a4-info-row"><span class="a4-info-label">Project:</span><span class="a4-info-value">@(project?.ProjectName ?? "—")</span></div>
                <div class="a4-info-row"><span class="a4-info-label">Schedule ID:</span><span class="a4-info-value"><code>@(schedule?.ScheduleID ?? "—")</code></span></div>
                <div class="a4-info-row"><span class="a4-info-label">Installment:</span><span class="a4-info-value">@(schedule?.InstallmentNo?.ToString() ?? "—")</span></div>
                <div class="a4-info-row"><span class="a4-info-label">Due Date:</span><span class="a4-info-value">@(schedule?.DueDate.ToString("dd-MM-yyyy") ?? "—")</span></div>
            </div>
        </div>
    </div>

    <!-- Payment Details -->
    <div class="a4-section">
        <div class="a4-section-title">Payment Details</div>
        <div class="a4-info-grid">
            <div class="a4-info-block">
                <div class="a4-info-row"><span class="a4-info-label">Payment ID:</span><span class="a4-info-value"><strong>@Model.PaymentID</strong></span></div>
                <div class="a4-info-row"><span class="a4-info-label">Payment Date:</span><span class="a4-info-value">@Model.PaymentDate.ToString("dd-MM-yyyy")</span></div>
                <div class="a4-info-row"><span class="a4-info-label">Amount:</span><span class="a4-info-value"><strong>@Model.Amount.ToString("N0") @(plan?.Currency ?? "PKR")</strong></span></div>
            </div>
            <div class="a4-info-block">
                <div class="a4-info-row"><span class="a4-info-label">Method:</span><span class="a4-info-value">@(string.IsNullOrWhiteSpace(Model.Method) ? "—" : Model.Method)</span></div>
                <div class="a4-info-row"><span class="a4-info-label">Reference No:</span><span class="a4-info-value">@(string.IsNullOrWhiteSpace(Model.ReferenceNo) ? "—" : Model.ReferenceNo)</span></div>
                <div class="a4-info-row"><span class="a4-info-label">Status:</span><span class="a4-info-value">@(string.IsNullOrWhiteSpace(Model.Status) ? "—" : Model.Status)</span></div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(schedule?.PaymentDescription))
    {
        <div class="a4-section">
            <div class="a4-section-title">Description</div>
            <p class="a4-statement">@schedule.PaymentDescription</p>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.Remarks))
    {
        <div class="a4-section">
            <div class="a4-section-title">Remarks</div>
            <p class="a4-statement">@Model.Remarks</p>
        </div>
    }

    <div class="a4-footer">
        This is a system-generated payment receipt.<br />
        Payment ID: @Model.PaymentID | Customer: @(customer?.CustomerID ?? "—") | Generated @DateTime.Now.ToString("dd-MM-yyyy HH:mm")
    </div>
</div>

<style>
    .a4-container {
        width: 210mm;
        min-height: 297mm;
        margin: 0 auto;
        padding: 15px 20px;
        background: white;
        box-shadow: 0 0 10px rgba(0,0,0,0.1);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }
    .a4-header { border-bottom: 2px solid #333; padding-bottom: 10px; margin-bottom: 12px; }
    .a4-title { font-size: 20px; font-weight: bold; color: #333; margin-bottom: 5px; }
    .a4-subtitle { font-size: 11px; color: #666; margin-bottom: 3px; }
    .a4-section { margin-bottom: 12px; }
    .a4-section-title { font-size: 13px; font-weight: bold; color: #333; margin-bottom: 8px; padding-bottom: 3px; border-bottom: 1px solid #ddd; }
    .a4-info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 12px; }
    .a4-info-block { background: #f8f9fa; padding: 10px; border-radius: 5px; border-left: 4px solid #007bff; }
    .a4-info-row { display: flex; justify-content: space-between; margin-bottom: 3px; font-size: 11px; }
    .a4-info-label { font-weight: 600; color: #555; }
    .a4-info-value { color: #333; }
    .a4-statement { font-size: 11px; line-height: 1.5; color: #333; margin-bottom: 0; }
    .a4-footer { margin-top: 15px; padding-top: 8px; border-top: 1px solid #ddd; font-size: 9px; color: #666; text-align: center; }
    .a4-logo { max-width: 120px; height: auto; margin-bottom: 10px; }
    @@media print {
        @@page { size: A4; margin: 0; }
        body { margin: 0; padding: 0; background: white; }
        .a4-container { width: 210mm; min-height: 297mm; margin: 0; padding: 12mm; box-shadow: none; }
        .no-print { display: none !important; }
    }
    @@media screen {
        body { background: #f5f5f5; padding: 20px; }
        .a4-container { margin: 20px auto; }
    }
</style>
</body>
</html>
