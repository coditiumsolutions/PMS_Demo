@using System.Globalization
@using System.Linq
@{
    ViewData["Title"] = "Record Payment";
    var preSelectedCustomerId = ViewBag.PreSelectedCustomerId as string;
    var preSelectedScheduleId = ViewBag.PreSelectedScheduleId as string;
    var schedule = ViewBag.Schedule as PMS.Models.PaymentSchedule;
    decimal scheduleOutstanding = ViewBag.ScheduleOutstanding != null ? (decimal)ViewBag.ScheduleOutstanding : 0m;
}

<!-- Banner with purple gradient -->
<div class="custom-banner mb-4" style="margin-top: 20px;">
    <div style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%); padding: 25px 30px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.1);">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h2 class="text-white mb-1" style="font-weight: 600; text-shadow: 0 2px 4px rgba(0,0,0,0.2);">
                    <i class="fas fa-money-bill-wave me-2"></i>Record Payment
                </h2>
                <p class="text-white mb-0" style="opacity: 0.95; font-size: 0.95rem;">
                    Record customer payment transactions
                </p>
            </div>
            <div>
                <a asp-action="CustomerPayments" class="btn btn-light">
                    <i class="fas fa-arrow-left me-2"></i>Back to Payments
                </a>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-10 mx-auto">
        
        <!-- Pre-selected Schedule Info -->
        @if (schedule != null)
        {
            <div class="card mb-4 border-0 shadow-sm">
                <div class="card-header" style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);">
                    <h6 class="mb-0 text-white">
                        <i class="fas fa-calendar-alt me-2"></i>Installment #@(schedule.InstallmentNo?.ToString() ?? "N/A") - @schedule.PaymentDescription
                    </h6>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3">
                            <small class="text-muted">Plan Name</small>
                            <p class="fw-bold mb-0">@schedule.PaymentPlan?.PlanName</p>
                            <small class="text-muted">@schedule.PlanID</small>
                        </div>
                        <div class="col-md-3">
                            <small class="text-muted">Due Date</small>
                            <p class="fw-bold mb-0 @(schedule.DueDate < DateTime.Now ? "text-danger" : "text-success")">
                                @schedule.DueDate.ToString("MMM dd, yyyy")
                            </p>
                            @if (schedule.DueDate < DateTime.Now)
                            {
                                <small class="text-danger"><i class="fas fa-exclamation-triangle me-1"></i>Overdue by @((DateTime.Now - schedule.DueDate).Days) days</small>
                            }
                        </div>
                        <div class="col-md-3">
                            <small class="text-muted">Outstanding Amount</small>
                            <p class="fw-bold mb-0" style="color: #9C6ADE; font-size: 1.3rem;">PKR @scheduleOutstanding.ToString("N0")</p>
                            <small class="text-muted d-block">Total: PKR @schedule.Amount.ToString("N0")</small>
                            <small class="text-muted d-block">Paid: PKR @((schedule.Amount - scheduleOutstanding).ToString("N0"))</small>
                        </div>
                        <div class="col-md-3">
                            <small class="text-muted">Surcharge Rate</small>
                            <p class="fw-bold mb-0">
                                @if (schedule.SurchargeApplied && schedule.DueDate < DateTime.Now)
                                {
                                    <span class="text-warning">@((schedule.SurchargeRate * 100).ToString("N1"))%</span>
                                }
                                else
                                {
                                    <span class="text-muted">N/A</span>
                                }
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Payment Form -->
        <div class="card border-0 shadow-sm">
            <div class="card-header" style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);">
                <h5 class="mb-0 text-white">
                    <i class="fas fa-receipt me-2"></i>Payment Details
                </h5>
            </div>
            <div class="card-body p-4">
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                <form asp-action="RecordPayment" method="post" id="paymentForm" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="preSelectedScheduleId" value="@(preSelectedScheduleId ?? "")" />

                    <div class="row g-3">
                        <!-- Customer ID Search (required first step) -->
                        <div class="col-md-6">
                            <label for="customerIdInput" class="form-label fw-semibold">
                                <i class="fas fa-user me-1" style="color: #9C6ADE;"></i>Customer ID *
                            </label>
                            <div class="d-flex gap-2">
                                <input type="text" id="customerIdInput" class="form-control" placeholder="Enter Customer ID" value="@preSelectedCustomerId" autocomplete="off" />
                                <button type="button" id="btnSearchCustomer" class="btn btn-primary flex-shrink-0">
                                    <i class="fas fa-search me-1"></i>Search
                                </button>
                            </div>
                            <input type="hidden" name="customerId" id="customerId" value="" />
                            <div id="customerSearchMessage" class="small mt-1"></div>
                            <div id="customerNameDisplay" class="alert alert-success py-2 mt-2 mb-0" style="display: none;">
                                <i class="fas fa-check-circle me-1"></i><strong id="customerNameText"></strong>
                            </div>
                            <small class="text-muted">Enter Customer ID and click Search. Installments will load for this customer only.</small>
                        </div>

                        <!-- Schedule/Installment Selection (populated after search) -->
                        <div class="col-md-6">
                            <label for="scheduleId" class="form-label fw-semibold">
                                <i class="fas fa-calendar-check me-1" style="color: #9C6ADE;"></i>Installment/Schedule *
                            </label>
                            <select name="scheduleId" id="scheduleId" class="form-select" required disabled>
                                <option value="">Search by Customer ID first</option>
                            </select>
                            <small class="text-muted" id="scheduleHint">Select customer first to see due installments</small>
                        </div>

                        <!-- Amount (editable for partial payments; must not exceed Total Due) -->
                        <div class="col-md-6">
                            <label for="amount" class="form-label fw-semibold">
                                <i class="fas fa-coins me-1" style="color: #9C6ADE;"></i>Amount Received (PKR) *
                            </label>
                            <input type="text" name="amount" id="amount" class="form-control" 
                                   placeholder="Enter amount" value="" required disabled 
                                   inputmode="numeric" />
                            <small class="text-muted" id="amountHint">You can enter a partial amount (e.g. two payments of 500 for 1000)</small>
                            <div id="amountValidationError" class="invalid-feedback d-block" style="display: none !important;"></div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">
                                <i class="fas fa-plus-circle me-1" style="color: #9C6ADE;"></i>Extra Payment
                            </label>
                            <div class="form-check form-switch mb-2">
                                <input class="form-check-input" type="checkbox" id="addExtraPayment" name="addExtraPayment" value="true" />
                                <label class="form-check-label" for="addExtraPayment">
                                    Add extra payment beyond selected installment
                                </label>
                            </div>
                            <div class="input-group">
                                <span class="input-group-text">PKR</span>
                                <input type="text" name="extraAmount" id="extraAmount" class="form-control"
                                       inputmode="numeric"
                                       placeholder="Extra amount" disabled />
                            </div>
                            <small class="text-muted d-block mt-1">Use this when customer pays more than installment due (e.g. due 9,990, paid 10,000 -> extra 10).</small>
                        </div>

                        <!-- Payment Method -->
                        <div class="col-md-6">
                            <label for="method" class="form-label fw-semibold">
                                <i class="fas fa-credit-card me-1" style="color: #9C6ADE;"></i>Payment Method *
                            </label>
                            <select name="method" id="method" class="form-select" required>
                                <option value="">Select Payment Method</option>
                                <option value="DD/DS" selected>DD/DS</option>
                                <option value="Cash">💵 Cash</option>
                                <option value="Bank Transfer">🏦 Bank Transfer</option>
                                <option value="Cheque">📝 Cheque</option>
                                <option value="Online">💳 Online Payment</option>
                                <option value="Mobile Money">📱 Mobile Money</option>
                            </select>
                        </div>

                        <!-- Reference Number -->
                        <div class="col-md-6">
                            <label for="referenceNo" class="form-label fw-semibold">
                                <i class="fas fa-hashtag me-1" style="color: #9C6ADE;"></i>Reference Number *
                            </label>
                            <input type="text" name="referenceNo" id="referenceNo" class="form-control" 
                                   placeholder="Transaction/Receipt/Cheque Number" required />
                            <small class="text-muted" id="refHint">Enter transaction reference number</small>
                        </div>

                        <div class="col-md-6">
                            <label for="bankName" class="form-label fw-semibold">
                                <i class="fas fa-university me-1" style="color: #9C6ADE;"></i>Bank Name *
                            </label>
                            <select name="bankName" id="bankName" class="form-select" required>
                                <option value="">Select Bank</option>
                                @foreach (var bank in (ViewBag.BankNames as IEnumerable<string> ?? Array.Empty<string>()))
                                {
                                    <option value="@bank">@bank</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label for="depositDate" class="form-label fw-semibold">
                                <i class="fas fa-calendar-day me-1" style="color: #9C6ADE;"></i>Deposit Date *
                            </label>
                            <input type="date" name="depositDate" id="depositDate" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                        </div>

                        <!-- Payment Status (Paid only when amount = total due; Partially Paid only when amount < total due) -->
                        <div class="col-md-6">
                            <label for="status" class="form-label fw-semibold">
                                <i class="fas fa-check-circle me-1" style="color: #9C6ADE;"></i>Payment Status *
                            </label>
                            <select name="status" id="status" class="form-select" required>
                                @{ var paymentStatusList = ViewBag.PaymentStatuses as IEnumerable<string> ?? new[] { "Pending", "Paid", "Partially Paid" }; }
                                @foreach (var s in paymentStatusList)
                                {
                                    <option value="@s">@s</option>
                                }
                            </select>
                            <small class="text-muted" id="statusHint">Full payment → Paid; partial → Partially Paid</small>
                        </div>

                        <!-- Remarks -->
                        <div class="col-12">
                            <label for="remarks" class="form-label fw-semibold">
                                <i class="fas fa-comment me-1" style="color: #9C6ADE;"></i>Remarks
                            </label>
                            <textarea name="remarks" id="remarks" class="form-control" rows="3" 
                                      placeholder="Enter any additional notes or remarks about this payment"></textarea>
                        </div>

                        <div class="col-12">
                            <label for="proofAttachment" class="form-label fw-semibold">
                                <i class="fas fa-paperclip me-1" style="color: #9C6ADE;"></i>Payment Proof (Optional)
                            </label>
                            <input type="file" name="proofAttachment" id="proofAttachment" class="form-control" accept=".jpg,.jpeg,.png,.gif,.bmp,.pdf" />
                            <small class="text-muted d-block mt-1">Allowed: JPG, PNG, GIF, BMP, PDF (max 8MB)</small>
                        </div>
                        <div class="col-12">
                            <label for="proofDescription" class="form-label fw-semibold">
                                <i class="fas fa-file-alt me-1" style="color: #9C6ADE;"></i>Proof Title / Notes (Optional)
                            </label>
                            <input type="text" name="proofDescription" id="proofDescription" class="form-control" maxlength="500" placeholder="e.g. Deposit Slip, Bank Receipt #123" />
                        </div>
                    </div>

                    <!-- Selected Installment Info -->
                    <div id="scheduleInfo" class="alert mt-4" style="background: rgba(156, 106, 222, 0.08); border: 1px solid rgba(156, 106, 222, 0.2); display: none;">
                        <div class="row">
                            <div class="col-md-4">
                                <small class="text-muted d-block">Installment</small>
                                <strong id="infoDescription">-</strong>
                            </div>
                            <div class="col-md-4">
                                <small class="text-muted d-block">Due Date</small>
                                <strong id="infoDueDate">-</strong>
                            </div>
                            <div class="col-md-4">
                                <small class="text-muted d-block">Outstanding</small>
                                <strong id="infoAmount" style="color: #9C6ADE;">-</strong>
                                <small class="text-muted d-block">Total: <span id="infoTotal">-</span></small>
                                <small class="text-muted d-block">Paid: <span id="infoPaid">-</span></small>
                            </div>
                        </div>
                        <div id="surchargeWarning" class="mt-2 p-2 rounded" style="background: rgba(245, 158, 11, 0.15); border: 1px solid rgba(245, 158, 11, 0.4); display: none;">
                            <i class="fas fa-exclamation-triangle text-warning me-1"></i>
                            <span id="surchargeWarningText"></span>
                        </div>
                    </div>

                    <div class="alert alert-info mt-3" style="background: rgba(156, 106, 222, 0.08); border: 1px solid rgba(156, 106, 222, 0.2);">
                        <i class="fas fa-info-circle me-2"></i>
                        <strong>Note:</strong> You can record multiple partial payments for the same installment (e.g. two entries of PKR 500 for a PKR 1000 installment). Amount can be edited.
                    </div>

                    <hr class="my-4">

                    <div class="d-flex justify-content-end gap-2">
                        <button type="submit" id="btnSubmitPayment" class="btn btn-lg" style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%); color: white; border: none;" disabled>
                            <i class="fas fa-check me-2"></i>Record Payment
                        </button>
                        <a asp-action="CustomerPayments" class="btn btn-lg btn-outline-secondary">
                            <i class="fas fa-times me-2"></i>Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>

        <!-- Late Payment Warning -->
        @if (schedule != null && schedule.SurchargeApplied && schedule.DueDate < DateTime.Now)
        {
            var daysLate = (DateTime.Now - schedule.DueDate).Days;
            var surchargeAmount = schedule.Amount * schedule.SurchargeRate;
            var totalWithSurcharge = schedule.Amount + surchargeAmount;

            <div class="card mt-4 border-0 shadow-sm" style="border-left: 4px solid #f59e0b !important;">
                <div class="card-header" style="background: linear-gradient(135deg, #f59e0b 0%, #fbbf24 100%);">
                    <h6 class="mb-0 text-white">
                        <i class="fas fa-exclamation-triangle me-2"></i>Late Payment Surcharge Applied
                    </h6>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4">
                            <small class="text-muted">Days Overdue</small>
                            <p class="fw-bold text-danger mb-0">@daysLate days</p>
                        </div>
                        <div class="col-md-4">
                            <small class="text-muted">Surcharge (@((schedule.SurchargeRate * 100).ToString("N1"))%)</small>
                            <p class="fw-bold text-warning mb-0">PKR @surchargeAmount</p>
                        </div>
                        <div class="col-md-4">
                            <small class="text-muted">Total Amount Due</small>
                            <p class="fw-bold mb-0" style="color: #9C6ADE; font-size: 1.3rem;">PKR @totalWithSurcharge</p>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        $(document).ready(function() {
            var formatCurrency = function(value) {
                var numeric = Number(value || 0);
                return numeric.toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 0 });
            };

            var schedulesData = []; // store schedule objects from last search for schedule change handler
            function parseWhole(value) {
                var digits = String(value || '').replace(/[^\d]/g, '');
                return digits ? parseInt(digits, 10) : 0;
            }
            function sanitizeWholeInput($input, minValue) {
                var n = parseWhole($input.val());
                if (n > 0) {
                    if (minValue && n < minValue) n = minValue;
                    $input.val(String(n));
                } else {
                    $input.val('');
                }
                return n;
            }

            function setSubmitState() {
                var hasCustomer = $('#customerId').val();
                var hasSchedule = $('#scheduleId').val() && !$('#scheduleId').prop('disabled');
                var hasAmount = parseWhole($('#amount').val()) > 0;
                $('#btnSubmitPayment').prop('disabled', !hasCustomer || !hasSchedule || !hasAmount);
            }

            // Search customer
            $('#btnSearchCustomer').on('click', function() {
                var input = $('#customerIdInput').val().trim();
                var $msg = $('#customerSearchMessage');
                var $nameDisplay = $('#customerNameDisplay');
                var $scheduleSelect = $('#scheduleId');
                var $amount = $('#amount');

                $msg.removeClass('text-danger text-success').text('');
                $nameDisplay.hide();
                $('#customerId').val('');
                $scheduleSelect.prop('disabled', true).find('option:not(:first)').remove();
                $scheduleSelect.find('option:first').text('Search by Customer ID first');
                $amount.val('').prop('disabled', true);
                $('#scheduleInfo').hide();
                schedulesData = [];
                setSubmitState();

                if (!input) {
                    $msg.addClass('text-danger').text('Please enter a Customer ID.');
                    return;
                }

                $('#btnSearchCustomer').prop('disabled', true);
                // #region agent log
                var _logPayload = function(hid, msg, d) {
                    var pl = { hypothesisId: hid, location: 'RecordPayment.cshtml:Search', message: msg, data: d || {}, timestamp: Date.now(), runId: 'run1' };
                    fetch('http://127.0.0.1:7242/ingest/cc130dc8-453b-402a-adc9-30e483adfe54', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(pl) }).catch(function() {});
                };
                // #endregion
                $.get('@Url.Action("GetCustomerPaymentInfo", "Payment")', { customerId: input })
                    .done(function(data) {
                        _logPayload('H5', 'done', { found: data.found, message: data.message });
                        if (data.found) {
                            $('#customerId').val(data.customerId);
                            $('#customerIdInput').val(data.customerId);
                            $('#customerNameText').text(data.fullName + ' (' + data.customerId + ')');
                            $nameDisplay.show();
                            $msg.addClass('text-success').text('Customer found. Select an installment below.');
                            schedulesData = data.schedules || [];
                            $scheduleSelect.prop('disabled', false);
                            if (schedulesData.length === 0) {
                                $scheduleSelect.find('option:first').text('No due installments');
                            } else {
                                $scheduleSelect.find('option:first').text('Select Installment');
                                schedulesData.forEach(function(s) {
                                    var outstandingLabel = (s.isOverdue ? ' (Outstanding)' : '');
                                    var optText = '[' + (s.planName || '') + '] Installment #' + (s.installmentNo != null ? s.installmentNo : 'N/A') + ' - Due ' + (s.dueDate || '') + ' - PKR ' + formatCurrency(s.outstanding) + outstandingLabel;
                                    var opt = $('<option></option>')
                                        .val(s.scheduleId)
                                        .text(optText)
                                        .data('amount', s.outstanding)
                                        .data('total', s.amount)
                                        .data('paid', s.paid)
                                        .data('description', s.paymentDescription)
                                        .data('duedate', s.dueDate)
                                        .data('surchargeApplied', s.surchargeApplied)
                                        .data('surchargeRate', s.surchargeRate)
                                        .data('isOverdue', s.isOverdue);
                                    $scheduleSelect.append(opt);
                                });
                                var preSel = $('#preSelectedScheduleId').val();
                                if (preSel) {
                                    $scheduleSelect.val(preSel);
                                    if ($scheduleSelect.val() === preSel) $scheduleSelect.trigger('change');
                                }
                            }
                        } else {
                            $msg.addClass('text-danger').text(data.message || 'Customer not found.');
                        }
                    })
                    .fail(function(jqXHR, textStatus, errorThrown) {
                        var rt = (jqXHR && jqXHR.responseText) ? String(jqXHR.responseText).substring(0, 500) : '';
                        _logPayload('H2', 'fail', { status: jqXHR && jqXHR.status, statusText: jqXHR && jqXHR.statusText, textStatus: textStatus, errorThrown: errorThrown, responsePreview: rt });
                        $msg.addClass('text-danger').text('Search failed. Please try again.');
                    })
                    .always(function() {
                        $('#btnSearchCustomer').prop('disabled', false);
                    });
            });

            $('#customerIdInput').on('keypress', function(e) {
                if (e.which === 13) {
                    e.preventDefault();
                    $('#btnSearchCustomer').click();
                }
            });

            // Schedule selection: show info, pre-fill amount (editable), enable amount
            $('#scheduleId').on('change', function() {
                var val = $(this).val();
                if (!val) {
                    $('#scheduleInfo').hide();
                    $('#amount').val('').prop('disabled', true);
                    setSubmitState();
                    return;
                }
                var selected = $(this).find('option:selected');
                var amount = parseFloat(selected.data('amount')) || 0;
                var total = parseFloat(selected.data('total')) || 0;
                var paid = parseFloat(selected.data('paid')) || 0;
                var description = selected.data('description');
                var dueDate = selected.data('duedate');
                var surchargeApplied = selected.data('surchargeApplied');
                var surchargeRate = selected.data('surchargeRate');
                var isOverdue = selected.data('isOverdue');

                $('#scheduleInfo').show();
                $('#infoDescription').text(description || '-');
                $('#infoDueDate').text(dueDate || '-');
                $('#infoAmount').text('PKR ' + formatCurrency(amount));
                $('#infoTotal').text('PKR ' + formatCurrency(total));
                $('#infoPaid').text('PKR ' + formatCurrency(paid));

                if (surchargeApplied && isOverdue && surchargeRate > 0) {
                    var surchargeAmount = total * surchargeRate;
                    var totalWithSurcharge = total + surchargeAmount;
                    $('#surchargeWarning').show();
                    $('#surchargeWarningText').text('Late payment surcharge ' + (surchargeRate * 100).toFixed(1) + '% may apply. Total with surcharge: PKR ' + formatCurrency(totalWithSurcharge));
                } else {
                    $('#surchargeWarning').hide();
                }

                $('#amount').prop('disabled', false).attr('max', amount).removeClass('is-invalid');
                $('#amountValidationError').hide().removeClass('text-danger').text('');
                if (amount > 0) {
                    $('#amount').val(Math.round(amount));
                    $('#amountHint').text('Total Due: PKR ' + formatCurrency(amount) + '. You can enter a partial amount; must not exceed this.');
                }
                updateStatusOptions();
                setSubmitState();
            });

            function updateStatusOptions() {
                var maxDue = parseFloat($('#scheduleId').find('option:selected').data('amount')) || 0;
                var amount = parseWhole($('#amount').val());
                var $status = $('#status');
                $status.find('option').prop('disabled', false).end().removeClass('is-invalid');
                if (maxDue <= 0) return;
                var isFullPayment = (amount >= maxDue);
                if (isFullPayment) {
                    if (!$status.val() || $status.val() === 'Pending') {
                        $status.val('Paid');
                    }
                    $('#statusHint').text('Full payment detected. Recommended status: Paid.');
                } else {
                    if (!$status.val() || $status.val() === 'Pending') {
                        $status.val('Partially Paid');
                    }
                    $('#statusHint').text('Partial payment detected. Recommended status: Partially Paid (you may keep Paid if needed).');
                }
            }

            $('#amount').on('input', function() {
                sanitizeWholeInput($(this), 1);
                setSubmitState();
                var maxDue = parseFloat($('#scheduleId').find('option:selected').data('amount')) || 0;
                var val = parseWhole($(this).val());
                var $err = $('#amountValidationError');
                if (maxDue > 0 && val > maxDue) {
                    $err.css('display', 'block').addClass('text-danger').text('Amount must not exceed Total Due (PKR ' + formatCurrency(maxDue) + ').');
                    $('#amount').addClass('is-invalid');
                } else {
                    $err.hide().removeClass('text-danger').text('');
                    $('#amount').removeClass('is-invalid');
                }
                updateStatusOptions();
            });

            $('#addExtraPayment').on('change', function() {
                var enabled = $(this).is(':checked');
                $('#extraAmount').prop('disabled', !enabled);
                if (!enabled) {
                    $('#extraAmount').val('').removeClass('is-invalid');
                }
                setSubmitState();
            });

            $('#extraAmount').on('input', function() {
                sanitizeWholeInput($(this), 1);
                setSubmitState();
            });

            // Form submit: ensure amount does not exceed Total Due
            $('#paymentForm').on('submit', function(e) {
                var $schedule = $('#scheduleId').find('option:selected');
                var maxDue = parseFloat($schedule.data('amount')) || 0;
                var amount = parseWhole($('#amount').val());
                var addExtraPayment = $('#addExtraPayment').is(':checked');
                var extraAmount = parseWhole($('#extraAmount').val());
                if (maxDue > 0 && amount > maxDue) {
                    e.preventDefault();
                    $('#amountValidationError').css('display', 'block').addClass('text-danger')
                        .text('Amount must not exceed Total Due (PKR ' + formatCurrency(maxDue) + ').');
                    $('#amount').addClass('is-invalid').focus();
                    return false;
                }
                if (addExtraPayment && extraAmount <= 0) {
                    e.preventDefault();
                    $('#extraAmount').addClass('is-invalid').focus();
                    alert('Enter extra amount greater than zero, or uncheck Add Extra Payment.');
                    return false;
                }
                if (!addExtraPayment) {
                    $('#extraAmount').val('');
                }
            });

            // Payment method placeholder
            $('#method').on('change', function() {
                var method = $(this).val();
                var refInput = $('#referenceNo');
                var refHint = $('#refHint');
                if (method === 'Cash') refInput.attr('placeholder', 'Receipt Number (optional)');
                else if (method === 'DD/DS') refInput.attr('placeholder', 'DD/DS Reference Number');
                else if (method === 'Bank Transfer') refInput.attr('placeholder', 'Transaction Reference Number');
                else if (method === 'Cheque') refInput.attr('placeholder', 'Cheque Number');
                else if (method === 'Online') refInput.attr('placeholder', 'Online Transaction ID');
                else if (method === 'Mobile Money') refInput.attr('placeholder', 'Mobile Money Transaction ID');
                else refInput.attr('placeholder', 'Transaction/Receipt/Cheque Number');
            });
            $('#method').trigger('change'); // set default DD/DS placeholder on load

            // Pre-fill from URL (e.g. from Payment Schedule link)
            @if (!string.IsNullOrEmpty(preSelectedCustomerId))
            {
                <text>
                $('#customerIdInput').val('@Html.Raw(System.Net.WebUtility.HtmlEncode(preSelectedCustomerId))');
                $('#btnSearchCustomer').click();
                </text>
            }
        });
    </script>
}
