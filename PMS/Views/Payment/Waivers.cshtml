@model IEnumerable<PMS.Models.Waiver>

@{
    ViewData["Title"] = "Waivers";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>
        <i class="fas fa-hand-holding-usd me-2"></i>Waivers
    </h2>
    <div>
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addWaiverModal">
            <i class="fas fa-plus me-2"></i>Add Waiver
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary ms-2">
            <i class="fas fa-arrow-left me-2"></i>Back to Payments
        </a>
    </div>
</div>

<!-- Statistics -->
<div class="row mb-4">
    <div class="col-md-4">
        <div class="stats-card">
            <div class="stats-number">@Model.Count()</div>
            <div class="stats-label">Total Waivers</div>
            <i class="fas fa-hand-holding-usd fa-2x mt-2" style="color: var(--accent-gold);"></i>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stats-card">
            <div class="stats-number">@Model.Sum(w => w.WaivedAmount).ToString("N0")</div>
            <div class="stats-label">Total Amount (PKR)</div>
            <i class="fas fa-money-bill-wave fa-2x mt-2" style="color: var(--accent-gold);"></i>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stats-card">
            <div class="stats-number">@Model.Where(w => w.CreatedAt >= DateTime.Now.AddMonths(-1)).Count()</div>
            <div class="stats-label">This Month</div>
            <i class="fas fa-calendar-alt fa-2x mt-2" style="color: var(--accent-gold);"></i>
        </div>
    </div>
</div>

<!-- Waivers Table -->
<div class="card">
    <div class="card-header">
        <h5 class="mb-0">
            <i class="fas fa-list me-2"></i>All Waivers
        </h5>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover" id="waiversTable">
                <thead>
                    <tr>
                        <th>Waiver ID</th>
                        <th>Customer</th>
                        <th>Amount</th>
                        <th>Reason</th>
                        <th>Approved By</th>
                        <th>Created On</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var waiver in Model.OrderByDescending(w => w.CreatedAt))
                    {
                        <tr>
                            <td><code>@waiver.WaiverID</code></td>
                            <td>
                                @if (waiver.Customer != null)
                                {
                                    <strong>@waiver.Customer.FullName</strong>
                                    <br>
                                    <small class="text-muted">@waiver.Customer.CustomerID</small>
                                }
                                else
                                {
                                    <span class="text-muted">N/A</span>
                                }
                            </td>
                            <td>
                                <strong style="color: var(--accent-gold);">@waiver.WaivedAmount.ToString("N0") PKR</strong>
                            </td>
                            <td>@waiver.Comments</td>
                            <td>
                                @if (waiver.ApprovedByUser != null)
                                {
                                    <span>@waiver.ApprovedByUser.FullName</span>
                                }
                                else
                                {
                                    <span class="text-muted">N/A</span>
                                }
                            </td>
                            <td>
                                <i class="far fa-calendar-alt me-1"></i>
                                @waiver.CreatedAt.ToString("dd-MM-yyyy")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Add Waiver Modal -->
<div class="modal fade" id="addWaiverModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header" style="background: var(--accent-gold);">
                <h5 class="modal-title text-white">
                    <i class="fas fa-hand-holding-usd me-2"></i>Add Waiver
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="AddWaiver" method="post">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="customerId" class="form-label">Customer *</label>
                        <select name="customerId" id="customerId" class="form-select" required>
                            <option value="">Select Customer</option>
                            @{
                                var customers = ViewBag.Customers as List<PMS.Models.Customer>;
                                if (customers != null)
                                {
                                    @foreach (var customer in customers)
                                    {
                                        <option value="@customer.CustomerID">@customer.FullName - @customer.CustomerID</option>
                                    }
                                }
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="amount" class="form-label">Waiver Amount (PKR) *</label>
                        <input type="number" name="amount" id="amount" step="1" min="1" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label for="reason" class="form-label">Reason *</label>
                        <textarea name="reason" id="reason" class="form-control" rows="3" required></textarea>
                    </div>

                    <div class="alert alert-warning">
                        <i class="fas fa-info-circle me-2"></i>
                        <strong>Note:</strong> Waivers reduce the customer's outstanding balance. This action will be logged.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-2"></i>Add Waiver
                    </button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    code {
        background: #fff9e5;
        color: var(--accent-gold);
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#waiversTable').DataTable({
                "pageLength": 25,
                "order": [[ 5, "desc" ]]
            });
        });
    </script>
}

