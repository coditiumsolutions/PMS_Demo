@model PMS.Models.PaymentSchedule

@{
    ViewData["Title"] = "Create Payment Schedule";
    var paymentPlan = ViewBag.PaymentPlan as PMS.Models.PaymentPlan;
    var planExchangeRate = paymentPlan?.ExchangeRate ?? 0m;
    var planTotalUsd = paymentPlan?.TotalAmountUSD ?? 0m;
}

<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>
                <i class="fas fa-calendar-plus me-2"></i>Add Installment
            </h2>
            <a asp-action="PaymentSchedule" asp-route-planId="@paymentPlan?.PlanID" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Back to Schedule
            </a>
        </div>

        <!-- Payment Plan Info -->
        @if (paymentPlan != null)
        {
            <div class="card mb-4">
                <div class="card-header" style="background: linear-gradient(135deg, var(--primary-green) 0%, var(--accent-gold) 100%);">
                    <h6 class="mb-0 text-white">
                        <i class="fas fa-file-invoice-dollar me-2"></i>@paymentPlan.PlanName
                    </h6>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3">
                            <small class="text-muted">Total Amount (PKR)</small>
                            <p class="fw-bold" style="color: var(--primary-green);">@($"{paymentPlan.TotalAmount:N2}") PKR</p>
                        </div>
                        <div class="col-md-3">
                            <small class="text-muted">Total Amount (USD)</small>
                            <p class="fw-bold">@($"{planTotalUsd:N2}") USD</p>
                        </div>
                        <div class="col-md-3">
                            <small class="text-muted">Exchange Rate</small>
                            <p class="fw-bold">@(planExchangeRate > 0 ? $"1 USD = {planExchangeRate:N4} PKR" : "N/A")</p>
                        </div>
                        <div class="col-md-3">
                            <small class="text-muted">Primary Currency</small>
                            <p class="fw-bold text-uppercase">@paymentPlan.Currency</p>
                        </div>
                    </div>
                    <div class="row mt-3">
                        <div class="col-md-4">
                            <small class="text-muted">Duration</small>
                            <p class="fw-bold">@(paymentPlan.DurationMonths?.ToString() ?? "N/A") Months</p>
                        </div>
                        <div class="col-md-4">
                            <small class="text-muted">Frequency</small>
                            <p class="fw-bold">@paymentPlan.Frequency</p>
                        </div>
                        <div class="col-md-4">
                            <small class="text-muted">Existing Schedules</small>
                            <p class="fw-bold">@((paymentPlan.PaymentSchedules?.Count ?? 0).ToString("N0"))</p>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Create Schedule Form -->
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="fas fa-calendar-alt me-2"></i>Installment Details
                </h5>
            </div>
            <div class="card-body">
                <form asp-action="CreatePaymentSchedule" method="post">
                    <input type="hidden" asp-for="PlanID" value="@paymentPlan?.PlanID" />
                    <input type="hidden" id="PlanExchangeRate" value="@planExchangeRate" />

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="InstallmentNo" class="form-label">Installment Number *</label>
                                <input asp-for="InstallmentNo" type="number" class="form-control" placeholder="e.g., 1" required />
                                <span asp-validation-for="InstallmentNo" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="DueDate" class="form-label">Due Date *</label>
                                <input asp-for="DueDate" type="date" class="form-control" required />
                                <span asp-validation-for="DueDate" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12">
                            <div class="mb-3">
                                <label asp-for="PaymentDescription" class="form-label">Description *</label>
                                <input asp-for="PaymentDescription" class="form-control" placeholder="e.g., First Installment" required />
                                <span asp-validation-for="PaymentDescription" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="Amount" class="form-label">Amount (PKR) *</label>
                                <input asp-for="Amount" type="number" step="0.01" class="form-control" placeholder="e.g., 100000" required />
                                <span asp-validation-for="Amount" class="text-danger"></span>
                                <small class="text-muted d-block">Equivalent USD: <span id="amountUsdPreview">0.00</span></small>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Surcharge Rate (%)</label>
                                <input asp-for="SurchargeRate" type="number" step="0.01" class="form-control" placeholder="e.g., 5" />
                                <small class="text-muted">Leave empty for default (5%)</small>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12">
                            <div class="mb-3">
                                <div class="form-check form-switch">
                                    <input asp-for="SurchargeApplied" class="form-check-input" type="checkbox" checked />
                                    <label asp-for="SurchargeApplied" class="form-check-label">
                                        Apply Surcharge on Late Payment
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12">
                            <div class="mb-3">
                                <label asp-for="Description" class="form-label">Additional Notes</label>
                                <textarea asp-for="Description" class="form-control" rows="3" placeholder="Enter any additional notes or terms"></textarea>
                            </div>
                        </div>
                    </div>

                    <div class="alert alert-info">
                        <i class="fas fa-info-circle me-2"></i>
                        <strong>Tip:</strong> Surcharge will be automatically applied if payment is made after the due date.
                        @if (paymentPlan != null)
                        {
                            var existingTotal = paymentPlan.PaymentSchedules?.Sum(ps => ps.Amount) ?? 0m;
                            var remaining = paymentPlan.TotalAmount - existingTotal;
                            <div class="mt-2">
                                <strong>Remaining allowable total:</strong> @($"{remaining:N2}") PKR
                                @if (planExchangeRate > 0m)
                                {
                                    var remainingUsd = Math.Round(remaining / planExchangeRate, 2, MidpointRounding.AwayFromZero);
                                    <span class="text-muted">(USD @($"{remainingUsd:N2}"))</span>
                                }
                            </div>
                        }
                    </div>

                    <hr>

                    <div class="d-flex justify-content-end">
                        <button type="submit" class="btn btn-primary me-2">
                            <i class="fas fa-save me-2"></i>Create Installment
                        </button>
                        <a asp-action="PaymentSchedule" asp-route-planId="@paymentPlan?.PlanID" class="btn btn-secondary">
                            <i class="fas fa-times me-2"></i>Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var rateInput = document.getElementById('PlanExchangeRate');
            var amountInput = document.getElementById('Amount');
            var preview = document.getElementById('amountUsdPreview');

            if (!rateInput || !amountInput || !preview) {
                return;
            }

            var rate = parseFloat(rateInput.value) || 0;

            function updatePreview() {
                var ssp = parseFloat(amountInput.value);
                if (!isFinite(ssp)) {
                    preview.textContent = '0.00';
                    return;
                }

                var usd = rate > 0 ? ssp / rate : 0;
                preview.textContent = usd.toFixed(2);
            }

            amountInput.addEventListener('input', updatePreview);
            updatePreview();
        });
    </script>
}

