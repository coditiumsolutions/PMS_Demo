@model Tuple<IEnumerable<PMS.Models.PaymentSchedule>, string>
@using System.Globalization

@{
    var EnUs = CultureInfo.GetCultureInfo("en-US");
    var schedules = Model.Item1;
    var tableId = Model.Item2 + "Table";
}

<div class="table-responsive">
    <table class="table table-hover" id="@tableId">
        <thead>
            <tr>
                <th>Schedule ID</th>
                <th>Plan / Batch</th>
                <th>Due Date</th>
                <th>Installment #</th>
                <th>Description</th>
                <th>Amount</th>
                <th>Paid</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (schedules != null && schedules.Any())
            {
                @foreach (var schedule in schedules)
                {
                    var totalPaid = schedule.Payments?.Where(p => p.Status == "Completed").Sum(p => p.Amount) ?? 0;
                    var isPaid = totalPaid >= schedule.Amount;
                    var isOverdue = schedule.DueDate < DateTime.Now && !isPaid;
                    var remaining = schedule.Amount - totalPaid;
                    
                    <tr class="@(isPaid ? "table-success" : isOverdue ? "table-warning" : "")">
                        <td><code>@schedule.ScheduleID</code></td>
                        <td>
                            @if (schedule.PaymentPlan != null)
                            {
                                <strong>@schedule.PaymentPlan.PlanName</strong>
                                <br>
                                <small class="text-muted">
                                    <i class="fas fa-users me-1"></i>
                                    @(schedule.PaymentPlan.Customers?.Count ?? 0) customers
                                </small>
                            }
                            else
                            {
                                <span class="text-muted">N/A</span>
                            }
                        </td>
                        <td>
                            <i class="far fa-calendar-alt me-1"></i>
                            @schedule.DueDate.ToString("MMM dd, yyyy")
                            @if (isOverdue)
                            {
                                <br>
                                <small class="text-danger">
                                    <i class="fas fa-exclamation-triangle me-1"></i>
                                    @((DateTime.Now - schedule.DueDate).Days) days overdue
                                </small>
                            }
                            else if (schedule.DueDate > DateTime.Now && schedule.DueDate <= DateTime.Now.AddDays(7))
                            {
                                <br>
                                <small class="text-warning">
                                    <i class="fas fa-clock me-1"></i>
                                    Due in @((schedule.DueDate - DateTime.Now).Days) days
                                </small>
                            }
                        </td>
                        <td>
                            <span class="badge bg-primary">#@(schedule.InstallmentNo?.ToString() ?? "N/A")</span>
                        </td>
                        <td>
                            @schedule.PaymentDescription
                            @if (schedule.SurchargeApplied)
                            {
                                <br>
                                <small class="text-warning">
                                    <i class="fas fa-percentage me-1"></i>
                                    Surcharge: @schedule.SurchargeRate.ToString("0.####")
                                </small>
                            }
                        </td>
                        <td>
                            <strong style="color: var(--primary-green);">@schedule.Amount.ToString("N0", EnUs)</strong>
                            <br>
                            <small class="text-muted">PKR</small>
                        </td>
                        <td>
                            @if (totalPaid > 0)
                            {
                                <strong style="color: var(--accent-gold);">@totalPaid.ToString("N0", EnUs)</strong>
                                <br>
                                <small class="text-muted">PKR</small>
                                @if (remaining > 0)
                                {
                                    <br>
                                    <small class="text-danger">Balance: @remaining.ToString("N0", EnUs)</small>
                                }
                            }
                            else
                            {
                                <span class="text-muted">@decimal.Zero.ToString("N0", EnUs)</span>
                            }
                        </td>
                        <td>
                            @if (isPaid)
                            {
                                <span class="badge bg-success">
                                    <i class="fas fa-check-circle me-1"></i>Paid
                                </span>
                            }
                            else if (isOverdue)
                            {
                                <span class="badge bg-danger">
                                    <i class="fas fa-exclamation-circle me-1"></i>Overdue
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">
                                    <i class="far fa-clock me-1"></i>Pending
                                </span>
                            }
                        </td>
                        <td>
                            <div class="btn-group" role="group">
                                @if (!isPaid)
                                {
                                    <a asp-action="RecordPayment" asp-route-scheduleId="@schedule.ScheduleID" 
                                       class="btn btn-sm btn-success" title="Record Payment">
                                        <i class="fas fa-money-bill-wave"></i>
                                    </a>
                                }
                                <button type="button" 
                                        class="btn btn-sm btn-outline-info" 
                                        data-bs-toggle="modal" 
                                        data-bs-target="#detailModal@(schedule.ScheduleID)"
                                        title="View Details">
                                    <i class="fas fa-eye"></i>
                                </button>
                                <a asp-action="PaymentSchedule" asp-route-planId="@schedule.PlanID" 
                                   class="btn btn-sm btn-outline-primary" title="View Plan">
                                    <i class="fas fa-file-invoice-dollar"></i>
                                </a>
                            </div>
                        </td>
                    </tr>

                    <!-- Detail Modal -->
                    <div class="modal fade" id="detailModal@(schedule.ScheduleID)" tabindex="-1" data-bs-backdrop="false">
                        <div class="modal-dialog">
                            <div class="modal-content">
                                <div class="modal-header" style="background: var(--primary-green);">
                                    <h6 class="modal-title text-white">
                                        <i class="fas fa-receipt me-2"></i>Installment #@(schedule.InstallmentNo?.ToString() ?? "N/A")
                                    </h6>
                                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body">
                                    <div class="row">
                                        <div class="col-6 mb-2">
                                            <small class="text-muted">Schedule ID</small>
                                            <p><code>@schedule.ScheduleID</code></p>
                                        </div>
                                        <div class="col-6 mb-2">
                                            <small class="text-muted">Installment #</small>
                                            <p><strong>#@(schedule.InstallmentNo?.ToString() ?? "N/A")</strong></p>
                                        </div>
                                        <div class="col-12 mb-2">
                                            <small class="text-muted">Description</small>
                                            <p>@schedule.PaymentDescription</p>
                                        </div>
                                        <div class="col-6 mb-2">
                                            <small class="text-muted">Due Date</small>
                                            <p>@schedule.DueDate.ToString("MMM dd, yyyy")</p>
                                        </div>
                                        <div class="col-6 mb-2">
                                            <small class="text-muted">Amount</small>
                                            <p><strong style="color: var(--primary-green);">@schedule.Amount.ToString("N0", EnUs) PKR</strong></p>
                                        </div>
                                        <div class="col-6 mb-2">
                                            <small class="text-muted">Paid Amount</small>
                                            <p><strong style="color: var(--accent-gold);">@totalPaid.ToString("N2", EnUs) PKR</strong></p>
                                        </div>
                                        <div class="col-6 mb-2">
                                            <small class="text-muted">Balance</small>
                                            <p><strong class="@(remaining > 0 ? "text-danger" : "text-success")">@remaining.ToString("N2", EnUs) PKR</strong></p>
                                        </div>
                                    </div>
                                    
                                    @if (schedule.Payments != null && schedule.Payments.Any())
                                    {
                                        <hr>
                                        <h6><i class="fas fa-money-check-alt me-2"></i>Payments Received</h6>
                                        <div class="list-group">
                                            @foreach (var payment in schedule.Payments.OrderByDescending(p => p.PaymentDate))
                                            {
                                                <div class="list-group-item">
                                                    <div class="d-flex justify-content-between">
                                                        <div>
                                                            <strong>@payment.Amount.ToString("N2", EnUs) PKR</strong>
                                                            <br>
                                                            <small class="text-muted">@payment.PaymentDate.ToString("MMM dd, yyyy")</small>
                                                        </div>
                                                        <div class="text-end">
                                                            <span class="badge @(payment.Status == "Completed" ? "bg-success" : "bg-warning")">
                                                                @payment.Status
                                                            </span>
                                                            <br>
                                                            <small class="text-muted">@payment.Method</small>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                                <div class="modal-footer">
                                    @if (!isPaid)
                                    {
                                        <a asp-action="RecordPayment" asp-route-scheduleId="@schedule.ScheduleID" 
                                           class="btn btn-success">
                                            <i class="fas fa-money-bill-wave me-2"></i>Record Payment
                                        </a>
                                    }
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <tr>
                    <td colspan="9" class="text-center py-5">
                        <i class="fas fa-inbox fa-4x mb-3 text-muted d-block"></i>
                        <h5 class="text-muted">No Schedules Found</h5>
                        <p class="text-muted">Create payment plans and add schedules to get started.</p>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<style>
    code {
        background: var(--light-green);
        color: var(--primary-green);
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
    }

    /* Payment Schedule Modals - No Backdrop */
    .modal[data-bs-backdrop="false"] {
        background: transparent !important;
    }

    .modal[data-bs-backdrop="false"] .modal-dialog {
        position: relative;
        z-index: 1055;
    }

    .modal[data-bs-backdrop="false"] .modal-content {
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
        border: none;
    }
</style>

