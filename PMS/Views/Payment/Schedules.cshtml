@model IEnumerable<PMS.Models.PaymentSchedule>

@{
    ViewData["Title"] = "Payment Schedules (Installments)";
    var today = DateTime.Now.Date;
    var totalDue = Model.Where(s => s.DueDate >= today).Sum(s => s.Amount);
    var overdue = Model.Where(s => s.DueDate < today && (s.Payments == null || s.Payments.Where(p => p.Status == "Completed").Sum(p => p.Amount) < s.Amount));
    var overdueAmount = overdue.Sum(s => s.Amount - (s.Payments?.Where(p => p.Status == "Completed").Sum(p => p.Amount) ?? 0));
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>
        <i class="fas fa-calendar-check me-2"></i>Payment Schedules (Installments)
    </h2>
    <div class="btn-group">
        <a asp-action="PaymentPlans" class="btn btn-outline-primary">
            <i class="fas fa-file-invoice-dollar me-2"></i>View Payment Plans
        </a>
    </div>
</div>

<!-- Statistics -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="stats-card">
            <div class="stats-number">@Model.Count()</div>
            <div class="stats-label">Total Schedules</div>
            <i class="fas fa-calendar-alt fa-2x mt-2" style="color: var(--primary-green);"></i>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stats-card">
            <div class="stats-number">@overdue.Count()</div>
            <div class="stats-label">Overdue</div>
            <i class="fas fa-exclamation-triangle fa-2x mt-2" style="color: #dc3545;"></i>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stats-card">
            <div class="stats-number">@totalDue</div>
            <div class="stats-label">Upcoming Due (PKR)</div>
            <i class="fas fa-clock fa-2x mt-2" style="color: var(--accent-gold);"></i>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stats-card">
            <div class="stats-number">@overdueAmount</div>
            <div class="stats-label">Overdue Amount (PKR)</div>
            <i class="fas fa-exclamation-circle fa-2x mt-2" style="color: #dc3545;"></i>
        </div>
    </div>
</div>

<!-- Filter Tabs -->
<ul class="nav nav-tabs mb-3" id="scheduleTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="all-tab" data-bs-toggle="tab" data-bs-target="#all" type="button">
            <i class="fas fa-list me-1"></i>All Schedules
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="overdue-tab" data-bs-toggle="tab" data-bs-target="#overdue" type="button">
            <i class="fas fa-exclamation-triangle me-1"></i>Overdue (@overdue.Count())
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="upcoming-tab" data-bs-toggle="tab" data-bs-target="#upcoming" type="button">
            <i class="fas fa-clock me-1"></i>Upcoming
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="paid-tab" data-bs-toggle="tab" data-bs-target="#paid" type="button">
            <i class="fas fa-check-circle me-1"></i>Paid
        </button>
    </li>
</ul>

<!-- Tab Content -->
<div class="tab-content" id="scheduleTabContent">
    <!-- All Schedules Tab -->
    <div class="tab-pane fade show active" id="all" role="tabpanel">
        <div class="card">
            <div class="card-body">
                @await Html.PartialAsync("_SchedulesTable", new Tuple<IEnumerable<PMS.Models.PaymentSchedule>, string>(Model.OrderBy(s => s.DueDate), "all"))
            </div>
        </div>
    </div>

    <!-- Overdue Tab -->
    <div class="tab-pane fade" id="overdue" role="tabpanel">
        <div class="card">
            <div class="card-body">
                @await Html.PartialAsync("_SchedulesTable", new Tuple<IEnumerable<PMS.Models.PaymentSchedule>, string>(overdue.OrderBy(s => s.DueDate), "overdue"))
            </div>
        </div>
    </div>

    <!-- Upcoming Tab -->
    <div class="tab-pane fade" id="upcoming" role="tabpanel">
        <div class="card">
            <div class="card-body">
                @await Html.PartialAsync("_SchedulesTable", new Tuple<IEnumerable<PMS.Models.PaymentSchedule>, string>(Model.Where(s => s.DueDate >= today).OrderBy(s => s.DueDate), "upcoming"))
            </div>
        </div>
    </div>

    <!-- Paid Tab -->
    <div class="tab-pane fade" id="paid" role="tabpanel">
        <div class="card">
            <div class="card-body">
                @{
                    var paidSchedules = Model.Where(s => s.Payments != null && s.Payments.Where(p => p.Status == "Completed").Sum(p => p.Amount) >= s.Amount);
                }
                @await Html.PartialAsync("_SchedulesTable", new Tuple<IEnumerable<PMS.Models.PaymentSchedule>, string>(paidSchedules.OrderByDescending(s => s.DueDate), "paid"))
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Initialize DataTable only for the active tab
            function initializeDataTable(tabId) {
                var tableId = '#' + tabId + 'Table';
                if ($.fn.DataTable.isDataTable(tableId)) {
                    $(tableId).DataTable().destroy();
                }
                $(tableId).DataTable({
                    "pageLength": 25,
                    "order": [[ 2, "asc" ]],
                    "columnDefs": [
                        { "orderable": false, "targets": -1 }
                    ]
                });
            }

            // Initialize the first tab
            initializeDataTable('all');

            // Initialize when tab is shown
            $('button[data-bs-toggle="tab"]').on('shown.bs.tab', function (e) {
                var target = $(e.target).attr('data-bs-target').replace('#', '');
                initializeDataTable(target);
            });
        });
    </script>
}

