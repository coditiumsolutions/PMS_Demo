@model IEnumerable<PMS.Models.Payment>

@{
    ViewData["Title"] = "Customer Payments";
}

<!-- Banner with purple gradient -->
<div class="custom-banner mb-4" style="margin-top: 20px;">
    <div style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%); padding: 25px 30px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.1);">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h2 class="text-white mb-1" style="font-weight: 600; text-shadow: 0 2px 4px rgba(0,0,0,0.2);">
                    <!-- <i class="fas fa-money-bill-wave me-2"></i>Customer Payments -->
                </h2>
                <p class="text-white mb-0" style="opacity: 0.95; font-size: 0.95rem;">
                    View and manage all payment transactions from customers
                </p>
            </div>
            @if (ViewBag.CanCreate == true)
            {
            <div class="d-flex gap-2">
                <a asp-action="MultiplePayments" class="btn btn-warning">
                    <i class="fas fa-layer-group me-2"></i>Multiple Payments
                </a>
                <a asp-action="RecordPayment" class="btn btn-light">
                    <i class="fas fa-plus me-2"></i>Record Payment
                </a>
            </div>
            }
        </div>
    </div>
</div>

<!-- Summary Cards -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="avatar-sm rounded-circle bg-primary bg-soft text-primary">
                            <i class="fas fa-money-check-alt font-size-24"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="mb-1 text-muted">Total Payments</h6>
                        <h4 class="mb-0">@Model.Count()</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="avatar-sm rounded-circle bg-success bg-soft text-success">
                            <i class="fas fa-coins font-size-24"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="mb-1 text-muted">Total Received (PKR)</h6>
                        <h4 class="mb-0" data-format-number="@Model.Sum(p => p.Amount)">@Model.Sum(p => p.Amount).ToString("N0")</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="avatar-sm rounded-circle bg-info bg-soft text-info">
                            <i class="fas fa-calendar-check font-size-24"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="mb-1 text-muted">This Month</h6>
                        <h4 class="mb-0">@Model.Count(p => p.PaymentDate.Month == DateTime.Now.Month)</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="avatar-sm rounded-circle bg-warning bg-soft text-warning">
                            <i class="fas fa-users font-size-24"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="mb-1 text-muted">Unique Customers</h6>
                        <h4 class="mb-0">@Model.Select(p => p.CustomerID).Distinct().Count()</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Payments Table -->
<div class="card border-0 shadow-sm">
    <div class="card-header" style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);">
        <h5 class="mb-0 text-white">
            <i class="fas fa-list me-2"></i>All Payment Transactions
        </h5>
    </div>
    <div class="card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table id="paymentsTable" class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Actions</th>
                            <th>Payment ID</th>
                            <th>Customer</th>
                            <th>Payment Plan</th>
                            <th>Installment</th>
                            <th>Date</th>
                            <th>Amount</th>
                            <th>Reference</th>
                            <th>Status</th>
                            <th>Method</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var payment in Model)
                        {
                            <tr>
                                <td>
                                    <div class="btn-group" role="group">
                                        <button type="button" 
                                                class="btn btn-sm btn-outline-info" 
                                                data-bs-toggle="modal" 
                                                data-bs-target="#paymentModal@(payment.PaymentID)"
                                                title="View Details">
                                            <i class="fas fa-eye"></i>
                                        </button>
                                        @if (ViewBag.CanEdit == true)
                                        {
                                        <a asp-action="EditPayment" asp-route-paymentId="@payment.PaymentID" 
                                           class="btn btn-sm btn-outline-secondary" 
                                           title="Edit Payment">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        }
                                        <a asp-action="Receipt" asp-route-id="@payment.PaymentID" 
                                           class="btn btn-sm btn-outline-primary" 
                                           title="Print Receipt"
                                           target="_blank">
                                            <i class="fas fa-print"></i>
                                        </a>
                                        @if (ViewBag.CanDelete == true)
                                        {
                                        <form asp-action="DeletePayment" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this payment?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="paymentId" value="@payment.PaymentID" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete Payment">
                                                <i class="fas fa-trash-alt"></i>
                                            </button>
                                        </form>
                                        }
                                    </div>
                                    <small class="text-muted d-block mt-1">@payment.CustomerID</small>
                                </td>
                                <td><code>@payment.PaymentID</code></td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-xs rounded-circle bg-primary bg-soft text-primary me-2">
                                            <i class="fas fa-user"></i>
                                        </div>
                                        <div>
                                            <strong>@payment.Customer?.FullName</strong><br />
                                            <small class="text-muted">@payment.CustomerID</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    @if (payment.PaymentSchedule?.PaymentPlan != null)
                                    {
                                        <div>
                                            <strong>@payment.PaymentSchedule.PaymentPlan.PlanName</strong><br />
                                            <small class="text-muted">@payment.PaymentSchedule.PlanID</small>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    @if (payment.PaymentSchedule != null)
                                    {
                                        <span class="badge bg-info">
                                            Installment #@(payment.PaymentSchedule.InstallmentNo?.ToString() ?? "N/A")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    <i class="fas fa-calendar-alt text-muted me-1"></i>
                                    @payment.PaymentDate.ToString("MMM dd, yyyy")
                                </td>
                                <td>
                                    <strong class="text-success"><span data-format-number="@payment.Amount">@payment.Amount.ToString("N0")</span> PKR</strong>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(payment.ReferenceNo))
                                    {
                                        <code>@payment.ReferenceNo</code>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    @if (payment.Status == "Completed" || payment.Status == "Approved")
                                    {
                                        <span class="badge bg-success">@payment.Status</span>
                                    }
                                    else if (payment.Status == "Pending")
                                    {
                                        <span class="badge bg-warning">@payment.Status</span>
                                    }
                                    else if (payment.Status == "Failed" || payment.Status == "Rejected")
                                    {
                                        <span class="badge bg-danger">@payment.Status</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@payment.Status</span>
                                    }
                                </td>
                                <td>
                                    @if (payment.Method == "Cash")
                                    {
                                        <span class="badge bg-success">
                                            <i class="fas fa-money-bill-wave me-1"></i>@payment.Method
                                        </span>
                                    }
                                    else if (payment.Method == "Bank Transfer")
                                    {
                                        <span class="badge bg-primary">
                                            <i class="fas fa-university me-1"></i>@payment.Method
                                        </span>
                                    }
                                    else if (payment.Method == "Cheque")
                                    {
                                        <span class="badge bg-info">
                                            <i class="fas fa-money-check me-1"></i>@payment.Method
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@payment.Method</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-money-bill-wave fa-4x mb-3 text-muted"></i>
                <h5 class="text-muted">No Payments Recorded Yet</h5>
                <p class="text-muted">Start recording customer payments to track transactions.</p>
                <a asp-action="RecordPayment" class="btn btn-primary">
                    <i class="fas fa-plus me-2"></i>Record First Payment
                </a>
            </div>
        }
    </div>
</div>

<!-- Payment Detail Modals -->
@foreach (var payment in Model)
{
    <!-- Payment Details Modal -->
    <div class="modal fade" id="paymentModal@(payment.PaymentID)" tabindex="-1" aria-labelledby="paymentModalLabel@(payment.PaymentID)" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header" style="background: var(--primary);">
                    <h5 class="modal-title text-white" id="paymentModalLabel@(payment.PaymentID)">
                        <i class="fas fa-receipt me-2"></i>Payment Details - @payment.PaymentID
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="text-muted small">Payment ID</label>
                            <p class="mb-0"><code>@payment.PaymentID</code></p>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small">Payment Date</label>
                            <p class="mb-0">@payment.PaymentDate.ToString("MMMM dd, yyyy hh:mm tt")</p>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small">Customer Name</label>
                            <p class="mb-0"><strong>@payment.Customer?.FullName</strong></p>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small">Customer ID</label>
                            <p class="mb-0"><code>@payment.CustomerID</code></p>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small">Payment Plan</label>
                            <p class="mb-0">@payment.PaymentSchedule?.PaymentPlan?.PlanName</p>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small">Installment Number</label>
                            <p class="mb-0">
                                @if (payment.PaymentSchedule != null)
                                {
                                    <span>Installment #@(payment.PaymentSchedule.InstallmentNo?.ToString() ?? "N/A")</span>
                                }
                            </p>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small">Amount Paid (PKR)</label>
                            <p class="mb-0"><strong class="text-success fs-5" data-format-number="@payment.Amount">@payment.Amount.ToString("N0")</strong></p>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small">Payment Method</label>
                            <p class="mb-0">@payment.Method</p>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small">Reference Number</label>
                            <p class="mb-0"><code>@payment.ReferenceNo</code></p>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small">Status</label>
                            <p class="mb-0">
                                @if (payment.Status == "Completed" || payment.Status == "Approved")
                                {
                                    <span class="badge bg-success">@payment.Status</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning">@payment.Status</span>
                                }
                            </p>
                        </div>
                        @if (!string.IsNullOrEmpty(payment.Remarks))
                        {
                            <div class="col-12">
                                <label class="text-muted small">Remarks</label>
                                <p class="mb-0">@payment.Remarks</p>
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <a asp-action="Receipt" asp-route-id="@payment.PaymentID" 
                       class="btn btn-primary" 
                       target="_blank">
                        <i class="fas fa-print me-2"></i>Print Receipt
                    </a>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .avatar-xs {
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
    }

    .avatar-sm {
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .bg-soft {
        background-color: rgba(var(--bs-primary-rgb), 0.1) !important;
    }

    .bg-success.bg-soft {
        background-color: rgba(25, 135, 84, 0.1) !important;
    }

    .bg-info.bg-soft {
        background-color: rgba(13, 202, 240, 0.1) !important;
    }

    .bg-warning.bg-soft {
        background-color: rgba(255, 193, 7, 0.1) !important;
    }

    code {
        background: rgba(156, 106, 222, 0.1);
        color: var(--primary);
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
    }

    .font-size-24 {
        font-size: 24px;
    }

    /* Payment Modals - No Backdrop (same as Users page) */
    .modal-backdrop {
        display: none !important;
    }

    body.modal-open .modal-backdrop {
        display: none !important;
    }

    /* Disable global dim overlay from layout on this page */
    body.modal-open::before {
        display: none !important;
        background: transparent !important;
    }

    /* Force transparent background for all modals on this page */
    .modal {
        background: transparent !important;
    }

    .modal.show {
        background: transparent !important;
    }

    /* Ensure modals are properly positioned */
    .modal-dialog {
        margin: 1.75rem auto;
    }

    .modal-dialog-centered {
        min-height: calc(100% - 3.5rem);
    }

    /* Fix any potential backdrop issues */
    .modal.show {
        display: block !important;
    }

    .modal.fade .modal-dialog {
        transition: transform 0.3s ease-out;
        transform: translate(0, -50px);
    }

    .modal.show .modal-dialog {
        transform: none;
    }
</style>

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/dataTables.bootstrap5.min.js"></script>
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/dataTables.bootstrap5.min.css" />

    <script>
        $(document).ready(function () {
            $('#paymentsTable').DataTable({
                "order": [[5, "desc"]], // Sort by date descending (column index 5 after Actions first)
                "pageLength": 25,
                "language": {
                    "search": "Search payments:",
                    "lengthMenu": "Show _MENU_ payments per page",
                    "info": "Showing _START_ to _END_ of _TOTAL_ payments",
                    "infoEmpty": "No payments available",
                    "infoFiltered": "(filtered from _MAX_ total payments)"
                }
            });

            // Remove any existing backdrops
            $('.modal-backdrop').remove();

            // Ensure Bootstrap 5 modals have no backdrop and stay above UI (same as Users page)
            $('.modal').on('show.bs.modal', function(e) {
                // Remove any existing backdrops
                $('.modal-backdrop').remove();
                // Ensure instance exists and set backdrop to false
                var modalInstance = bootstrap.Modal.getOrCreateInstance(this, { backdrop: false });
                if (modalInstance && modalInstance._config) {
                    modalInstance._config.backdrop = false;
                }
            });

            // Remove backdrops on shown/hidden as a safeguard
            $('.modal').on('shown.bs.modal hidden.bs.modal', function() {
                $('.modal-backdrop').remove();
            });
        });
    </script>
}

