@model PMS.Models.PaymentPlan

@{
    ViewData["Title"] = "Create Payment Plan";
}

<div class="row">
    <div class="col-md-10 mx-auto">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Back to Payments
            </a>
        </div>

        <form id="paymentPlanForm" asp-action="CreatePaymentPlan" method="post">
            @Html.AntiForgeryToken()

            <!-- Payment Plan Section -->
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-file-invoice-dollar me-2"></i>Payment Plan Information
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="PlanName" class="form-label">Plan Name *</label>
                                <input asp-for="PlanName" id="PlanName" class="form-control" type="text" required placeholder="e.g. 2 Year Plan" />
                                <span asp-validation-for="PlanName" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="ProjectID" class="form-label">Project *</label>
                                <select asp-for="ProjectID" id="ProjectID" class="form-select" required>
                                    <option value="">Select Project</option>
                                    @if (ViewBag.Projects != null)
                                    {
                                        @foreach (var project in ViewBag.Projects)
                                        {
                                            <option value="@project.ProjectID">@project.ProjectName</option>
                                        }
                                    }
                                </select>
                                <span asp-validation-for="ProjectID" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Primary Currency</label>
                                <input type="text" class="form-control" value="PKR (Pakistani Rupee)" readonly />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">Size *</label>
                                <select id="RegisteredSize" class="form-select" required>
                                    <option value="">Select Size</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label">Subproject *</label>
                                <select id="SubProject" class="form-select" required>
                                    <option value="">Select Subproject</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="TotalAmount" class="form-label">Total Amount (PKR) *</label>
                                <input asp-for="TotalAmount" id="TotalAmount" type="number" step="1" min="1" max="1000000000" class="form-control" placeholder="e.g., 5000000" required />
                                <span asp-validation-for="TotalAmount" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="col-md-6" id="durationMonthsGroup" style="display: none;">
                            <div class="mb-3">
                                <label asp-for="DurationMonths" class="form-label">Plan Duration (Months) *</label>
                                <input asp-for="DurationMonths" id="DurationMonths" type="number" class="form-control" placeholder="e.g., 36" required readonly />
                                <span asp-validation-for="DurationMonths" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <input type="hidden" id="ExchangeRate" value="@((decimal?)ViewBag.UsdToPkrRate ?? 1m)" />

                    <!-- Payment Frequency hidden - selected in child section -->
                    <input type="hidden" asp-for="Frequency" id="Frequency" />

                    <div class="row">
                        <div class="col-12">
                            <div class="mb-3">
                                <label asp-for="Description" class="form-label">Description</label>
                                <textarea asp-for="Description" id="Description" class="form-control" rows="3" placeholder="Enter payment plan details and terms"></textarea>
                                <span asp-validation-for="Description" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Payment Schedule Section -->
            <div class="card mb-4">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-calendar-check me-2"></i>Payment Schedule Configuration
                    </h5>
                </div>
                <div class="card-body">
                    <!-- Token Option -->
                    <div class="mb-4 p-3 border rounded bg-light">
                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" id="includeToken" checked>
                            <label class="form-check-label fw-bold" for="includeToken">
                                <i class="fas fa-ticket-alt me-2"></i>Include Token Payment (Installment 0)
                            </label>
                        </div>
                        <div id="tokenAmountSection" class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="tokenAmount" class="form-label">Token Amount (PKR) *</label>
                                    <input type="number" id="tokenAmount" step="1" min="1" max="1000000000" class="form-control" placeholder="e.g., 50000" required />
                                    <small class="text-muted">Token payment amount (Installment 0 - No surcharge applied)</small>
                                </div>
                            </div>
                            <div class="col-md-12">
                                <div class="mb-3">
                                    <label for="tokenPaymentDescription" class="form-label">Token Payment Description *</label>
                                    <input type="text" id="tokenPaymentDescription" class="form-control" placeholder="e.g., Booking Token" required />
                                    <small class="text-muted">Used only for Installment 0 (token).</small>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="tokenDueDate" class="form-label">Token Due Date *</label>
                                    <input type="date" id="tokenDueDate" class="form-control" required />
                                    <small class="text-muted">Due date for installment 0 (token). Independent of the first regular installment date.</small>
                                </div>
                            </div>
                        </div>
                        <small class="text-muted d-block"><i class="fas fa-info-circle me-1"></i>Token payment is a special installment (Installment No: 0). Token has <strong>no surcharge</strong> policy applied.</small>
                    </div>

                    <!-- Possession Option -->
                    <div class="mb-4 p-3 border rounded bg-light">
                        <div class="mb-3">
                            <label for="possessionAmount" class="form-label fw-bold">
                                <i class="fas fa-key me-2"></i>Possession Amount (PKR)
                            </label>
                            <input type="number" id="possessionAmount" step="1" min="0" max="1000000000" class="form-control" value="0" placeholder="e.g., 200000" />
                            <small class="text-muted">If greater than 0, Possession is saved as the last payment.</small>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="possessionPaymentDescription" class="form-label">Possession Account Head</label>
                                    <input type="text" id="possessionPaymentDescription" class="form-control" placeholder="e.g., Possession Charges" />
                                    <small class="text-muted">Required only when possession amount is greater than zero.</small>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="possessionDueDate" class="form-label">Possession Due Date</label>
                                    <input type="date" id="possessionDueDate" class="form-control" />
                                    <small class="text-muted">Required when possession amount is greater than zero.</small>
                                </div>
                            </div>
                        </div>
                        <small class="text-muted d-block"><i class="fas fa-info-circle me-1"></i>Possession has <strong>no surcharge</strong> and is created after regular installments.</small>
                    </div>

                    <!-- Installment Options -->
                    <div class="mb-4">
                        <h6 class="mb-3"><i class="fas fa-list-ol me-2"></i>Bulk Installment Creation</h6>
                        
                        <div class="row">
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label for="totalInstallments" class="form-label">Total Installments (Excluding Token) *</label>
                                    <input type="number" id="totalInstallments" class="form-control" min="1" value="1" required />
                                    <small class="text-muted">Number of installments to create (not including token if selected)</small>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label for="installmentAmount" class="form-label">Installment Amount (PKR) *</label>
                                    <input type="number" id="installmentAmount" step="1" min="1" max="1000000000" class="form-control" placeholder="Enter amount per installment" required />
                                    <small class="text-muted">Manual input allowed. Child total may be less than parent total, but cannot exceed it.</small>
                                </div>
                            </div>

                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="scheduleFrequency" class="form-label">Frequency *</label>
                                    <select id="scheduleFrequency" class="form-select" required>
                                        <option value="">Select Frequency</option>
                                        <option value="Monthly">Monthly</option>
                                        <option value="Quarterly">Quarterly</option>
                                        <option value="Half Yearly">Half Yearly</option>
                                        <option value="Yearly">Yearly</option>
                                    </select>
                                    <small class="text-muted">Used to calculate DueDate for each installment</small>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="firstInstallmentDueDate" class="form-label">1st Installment Due Date *</label>
                                    <input type="date" id="firstInstallmentDueDate" class="form-control" required />
                                    <small class="text-muted">Due date for the first installment (subsequent dates calculated based on frequency)</small>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="paymentDescription" class="form-label">Payment Description *</label>
                                    <input type="text" id="paymentDescription" class="form-control" placeholder="e.g., Monthly Installment" required />
                                    <small class="text-muted">Same description will be used for all installments</small>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="surchargeRate" class="form-label">Surcharge Rate *</label>
                                    <input type="number" id="surchargeRate" step="0.0001" class="form-control" value="0.05" required />
                                    <small class="text-muted">Use fractional rate (e.g., 0.05 means 5% per day). This applies only to regular installments; Token and Possession surcharge are always 0.</small>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="surchargeApplied" checked>
                                <label class="form-check-label" for="surchargeApplied">
                                    Apply Surcharge (Default: Yes)
                                </label>
                            </div>
                        </div>
                    </div>

                    <!-- Preview Section -->
                    <div class="alert alert-info">
                        <h6 class="alert-heading"><i class="fas fa-info-circle me-2"></i>Installment Preview</h6>
                        <div id="installmentPreview" class="mt-2">
                            <p class="mb-1"><strong>Total Installments:</strong> <span id="previewTotalInstallments">0</span></p>
                            <p class="mb-1"><strong>Token:</strong> <span id="previewToken">Not included</span></p>
                            <p class="mb-1"><strong>Possession:</strong> <span id="previewPossession">Not included</span></p>
                            <p class="mb-1"><strong>Amount per Installment:</strong> PKR <span id="previewAmount">0</span></p>
                            <p class="mb-1"><strong>Frequency:</strong> <span id="previewFrequency">-</span></p>
                            <p class="mb-1"><strong>Total Installments Amount:</strong> PKR <span id="previewTotalInstallmentsAmount">0</span></p>
                            <p class="mb-1"><strong>Token Amount:</strong> PKR <span id="previewTokenAmount">0</span></p>
                            <p class="mb-1"><strong>Possession Amount:</strong> PKR <span id="previewPossessionAmount">0</span></p>
                            <p class="mb-0"><strong>Grand Total (Token + Installments + Possession):</strong> PKR <span id="previewGrandTotal">0</span> / Plan Total PKR <span id="previewPlanTotal">0</span></p>
                        </div>
                        <div id="amountValidationMessage" class="mt-2" style="display: none;">
                            <div class="alert alert-danger mb-0">
                                <i class="fas fa-exclamation-triangle me-2"></i><span id="validationMessageText"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Submit Buttons -->
            <div class="card">
                <div class="card-body">
                    <div class="d-flex justify-content-end gap-2">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="fas fa-save me-2"></i>Create Payment Plan & Schedules
                        </button>
                        <a asp-action="Index" class="btn btn-secondary btn-lg">
                            <i class="fas fa-times me-2"></i>Cancel
                        </a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        $(document).ready(function() {
            const maxAmountPkr = 1000000000;
            const numberFormat = { minimumFractionDigits: 0, maximumFractionDigits: 0 };
            let installmentAmountManual = false;

            function formatAmount(value) {
                if (!isFinite(value)) {
                    return '0';
                }
                return value.toLocaleString('en-US', numberFormat);
            }

            function parseAmount(selector) {
                var value = parseFloat($(selector).val());
                return isNaN(value) ? 0 : value;
            }

            function writeAmount(selector, value) {
                if (!isFinite(value)) {
                    $(selector).val('');
                } else {
                    var whole = Math.round(value);
                    if (whole < 0) {
                        whole = 0;
                    }
                    if (whole > maxAmountPkr) {
                        whole = maxAmountPkr;
                    }
                    $(selector).val(whole);
                }
            }

            function sanitizeWholeAmountField(selector, allowZero) {
                var raw = String($(selector).val() || '').trim();
                if (raw === '') {
                    return;
                }

                var amount = parseFloat(raw);
                if (!isFinite(amount)) {
                    $(selector).val('');
                    return;
                }

                amount = Math.round(amount);
                if (amount < 0 || (!allowZero && amount === 0)) {
                    amount = allowZero ? 0 : 1;
                }
                if (amount > maxAmountPkr) {
                    amount = maxAmountPkr;
                }

                $(selector).val(amount);
            }

            function hasDecimal(value) {
                return Math.floor(value) !== value;
            }

            function getExchangeRate() {
                var rate = parseFloat($('#ExchangeRate').val());
                return rate && rate > 0 ? rate : 1;
            }

            function fillDropdown(selector, values, placeholder) {
                const $dd = $(selector);
                $dd.empty();
                $dd.append($('<option/>').val('').text(placeholder));
                (values || []).forEach(function(item) {
                    $dd.append($('<option/>').val(item).text(item));
                });
            }

            async function loadProjectMeta(projectId) {
                fillDropdown('#RegisteredSize', [], 'Select Size');
                fillDropdown('#SubProject', [], 'Select Subproject');

                if (!projectId) {
                    return;
                }

                try {
                    const [sizes, subprojects] = await Promise.all([
                        $.getJSON('@Url.Action("GetProjectSizes", "Payment")', { projectId: projectId }),
                        $.getJSON('@Url.Action("GetProjectSubProjects", "Payment")', { projectId: projectId })
                    ]);

                    fillDropdown('#RegisteredSize', sizes, 'Select Size');
                    fillDropdown('#SubProject', subprojects, 'Select Subproject');
                } catch (e) {
                    console.error('Failed loading project size/subproject values.', e);
                }
            }

            function updatePossessionFieldRequirements() {
                var amount = parseAmount('#possessionAmount');
                var needsDetails = amount > 0;
                $('#possessionPaymentDescription').prop('required', needsDetails);
                $('#possessionDueDate').prop('required', needsDetails);
            }

            function toggleTokenSection() {
                var includeToken = $('#includeToken').is(':checked');
                $('#tokenAmountSection').toggle(includeToken);
                $('#tokenAmount').prop('required', includeToken);
                $('#tokenPaymentDescription').prop('required', includeToken);
                $('#tokenDueDate').prop('required', includeToken);
            }

            function recalculateInstallmentAmount(force) {
                if (installmentAmountManual && !force) {
                    return;
                }

                var planTotalPkr = parseAmount('#TotalAmount');
                var includeToken = $('#includeToken').is(':checked');
                var tokenAmountPkr = includeToken ? parseAmount('#tokenAmount') : 0;
                var possessionAmountPkr = parseAmount('#possessionAmount');
                var totalInstallments = parseInt($('#totalInstallments').val(), 10) || 0;
                var remainder = planTotalPkr - tokenAmountPkr - possessionAmountPkr;
                var installmentPkr = (totalInstallments > 0 && remainder >= 0) ? Math.round(remainder / totalInstallments) : 0;

                writeAmount('#installmentAmount', installmentPkr);
            }

            function validateTotalAmount(planTotalPkr, grandTotalPkr, includeToken, tokenAmountPkr, totalInstallmentsAmountPkr, possessionAmountPkr) {
                var validationDiv = $('#amountValidationMessage');
                var messageText = $('#validationMessageText');

                if (planTotalPkr > 0 && grandTotalPkr > planTotalPkr) {
                    var excessPkr = grandTotalPkr - planTotalPkr;
                    messageText.html(
                        'Total Installments Amount (PKR ' + formatAmount(totalInstallmentsAmountPkr) + ') + ' +
                        'Token Amount (PKR ' + (includeToken ? formatAmount(tokenAmountPkr) : '0') + ') + ' +
                        'Possession Amount (PKR ' + formatAmount(possessionAmountPkr) + ') = PKR ' +
                        formatAmount(grandTotalPkr) +
                        ' exceeds Parent Total Amount (PKR ' + formatAmount(planTotalPkr) + '). Excess: PKR ' +
                        formatAmount(excessPkr) + '.'
                    );
                    validationDiv.show();
                    return false;
                }

                validationDiv.hide();
                return true;
            }

            function updatePreview() {
                recalculateInstallmentAmount(false);

                var totalInstallments = parseInt($('#totalInstallments').val(), 10) || 0;
                var includeToken = $('#includeToken').is(':checked');
                var tokenAmountPkr = includeToken ? parseAmount('#tokenAmount') : 0;
                var possessionAmountPkr = parseAmount('#possessionAmount');
                var installmentAmountPkr = parseAmount('#installmentAmount');
                var frequency = $('#scheduleFrequency').val();
                var planTotalPkr = parseAmount('#TotalAmount');

                var totalInstallmentsAmountPkr = totalInstallments * installmentAmountPkr;
                var grandTotalPkr = totalInstallmentsAmountPkr + (includeToken ? tokenAmountPkr : 0) + possessionAmountPkr;

                var includePossession = possessionAmountPkr > 0;
                var totalCount = totalInstallments + (includeToken ? 1 : 0) + (includePossession ? 1 : 0);

                $('#previewTotalInstallments').text(totalCount);
                $('#previewToken').text(includeToken
                    ? (tokenAmountPkr > 0 ? 'Included (Installment 0) - No surcharge' : 'Included (Installment 0) - Amount not set')
                    : 'Not included');
                $('#previewPossession').text(includePossession ? 'Included (Last Payment)' : 'Not included');
                $('#previewAmount').text(formatAmount(installmentAmountPkr));
                $('#previewFrequency').text(frequency || '-');
                $('#previewTotalInstallmentsAmount').text(formatAmount(totalInstallmentsAmountPkr));
                $('#previewTokenAmount').text(formatAmount(tokenAmountPkr));
                $('#previewPossessionAmount').text(formatAmount(possessionAmountPkr));
                $('#previewGrandTotal').text(formatAmount(grandTotalPkr));
                $('#previewPlanTotal').text(formatAmount(planTotalPkr));

                validateTotalAmount(planTotalPkr, grandTotalPkr, includeToken, tokenAmountPkr, totalInstallmentsAmountPkr, possessionAmountPkr);

                var monthsPerInstallment = { Monthly: 1, Quarterly: 3, 'Half Yearly': 6, Yearly: 12 }[frequency] || 1;
                $('#DurationMonths').val(frequency && totalInstallments > 0 ? totalInstallments * monthsPerInstallment : '');
            }

            $('#includeToken').on('change', function() {
                toggleTokenSection();
                updatePreview();
            });

            $('#scheduleFrequency').on('change', function() {
                $('#Frequency').val($(this).val());
                updatePreview();
            });
            $('#ProjectID').on('change', function() {
                const projectId = $(this).val();
                loadProjectMeta(projectId);
            });

            $('#TotalAmount').on('input blur change', function() {
                sanitizeWholeAmountField('#TotalAmount', false);
                updatePossessionFieldRequirements();
                updatePreview();
            });

            $('#tokenAmount').on('input blur change', function() {
                sanitizeWholeAmountField('#tokenAmount', false);
                updatePossessionFieldRequirements();
                updatePreview();
            });

            $('#possessionAmount').on('input blur change', function() {
                sanitizeWholeAmountField('#possessionAmount', true);
                updatePossessionFieldRequirements();
                updatePreview();
            });

            $('#installmentAmount').on('input blur change', function() {
                sanitizeWholeAmountField('#installmentAmount', false);
                installmentAmountManual = $(this).val() !== '';
                updatePreview();
            });

            $('#totalInstallments, #paymentDescription, #DurationMonths, #tokenPaymentDescription, #possessionPaymentDescription').on('change input', updatePreview);

            toggleTokenSection();
            updatePossessionFieldRequirements();
            recalculateInstallmentAmount(true);
            updatePreview();
            loadProjectMeta($('#ProjectID').val());

            $('#paymentPlanForm').on('submit', function(e) {
                e.preventDefault();

                if (!this.checkValidity()) {
                    e.stopPropagation();
                    $(this).addClass('was-validated');
                    return false;
                }

                if (!$('#ProjectID').val()) {
                    alert('Please select a Project.');
                    $('#ProjectID').focus().addClass('is-invalid');
                    return false;
                }
                if (!$('#RegisteredSize').val()) {
                    alert('Please select a Size.');
                    $('#RegisteredSize').focus().addClass('is-invalid');
                    return false;
                }
                if (!$('#SubProject').val()) {
                    alert('Please select a Subproject.');
                    $('#SubProject').focus().addClass('is-invalid');
                    return false;
                }

                var includeToken = $('#includeToken').is(':checked');
                var tokenAmountPkr = includeToken ? parseAmount('#tokenAmount') : null;
                var possessionAmountPkr = parseAmount('#possessionAmount');
                var totalInstallments = parseInt($('#totalInstallments').val(), 10) || 0;
                var installmentAmountPkr = parseAmount('#installmentAmount');
                var planTotalPkr = parseAmount('#TotalAmount');
                var exchangeRate = getExchangeRate();

                if (planTotalPkr > maxAmountPkr || tokenAmountPkr > maxAmountPkr || possessionAmountPkr > maxAmountPkr || installmentAmountPkr > maxAmountPkr) {
                    alert('Amount cannot exceed PKR 1,000,000,000 (100 crores).');
                    return false;
                }

                if (hasDecimal(planTotalPkr) || (includeToken && hasDecimal(tokenAmountPkr)) || hasDecimal(possessionAmountPkr) || hasDecimal(installmentAmountPkr)) {
                    alert('Only whole amounts are allowed. Decimal values are not permitted.');
                    return false;
                }

                if (includeToken && (!tokenAmountPkr || tokenAmountPkr <= 0)) {
                    alert('Please enter Token Amount if Token is included.');
                    return false;
                }
                if (includeToken && !$('#tokenPaymentDescription').val().trim()) {
                    alert('Please enter Token Payment Description if Token is included.');
                    $('#tokenPaymentDescription').focus();
                    return false;
                }
                if (possessionAmountPkr > 0 && !$('#possessionPaymentDescription').val().trim()) {
                    alert('Please enter Possession Account Head when Possession Amount is greater than zero.');
                    $('#possessionPaymentDescription').focus();
                    return false;
                }
                if (includeToken && !$('#tokenDueDate').val()) {
                    alert('Please enter Token Due Date if Token is included.');
                    $('#tokenDueDate').focus();
                    return false;
                }
                if (possessionAmountPkr > 0 && !$('#possessionDueDate').val()) {
                    alert('Please enter Possession Due Date when Possession Amount is greater than zero.');
                    $('#possessionDueDate').focus();
                    return false;
                }

                var totalInstallmentsAmount = totalInstallments * installmentAmountPkr;
                var grandTotal = totalInstallmentsAmount + (includeToken ? tokenAmountPkr : 0) + possessionAmountPkr;

                if (grandTotal > planTotalPkr) {
                    var excess = grandTotal - planTotalPkr;
                    alert(
                        'Validation Error: Total Installments Amount (PKR ' + formatAmount(totalInstallmentsAmount) + ') + ' +
                        'Token Amount (PKR ' + (includeToken ? formatAmount(tokenAmountPkr) : '0') + ') + ' +
                        'Possession Amount (PKR ' + formatAmount(possessionAmountPkr) + ') = PKR ' +
                        formatAmount(grandTotal) + ' exceeds Parent Total Amount (PKR ' + formatAmount(planTotalPkr) + '). Excess: PKR ' + formatAmount(excess) + '.'
                    );
                    return false;
                }

                var surchargeInput = parseFloat($('#surchargeRate').val());
                if (!isFinite(surchargeInput) || surchargeInput < 0) {
                    surchargeInput = 0.05;
                }

                var planData = {
                    PlanName: $('#PlanName').val(),
                    ProjectID: $('#ProjectID').val() || null,
                    RegisteredSize: $('#RegisteredSize').val() || null,
                    SubProject: $('#SubProject').val() || null,
                    TotalAmount: planTotalPkr,
                    ExchangeRate: exchangeRate,
                    Currency: 'PKR',
                    DurationMonths: parseInt($('#DurationMonths').val(), 10),
                    Frequency: $('#scheduleFrequency').val(),
                    Description: $('#Description').val()
                };

                var scheduleData = {
                    IncludeToken: includeToken,
                    TokenAmount: tokenAmountPkr,
                    TokenPaymentDescription: includeToken ? $('#tokenPaymentDescription').val() : null,
                    TokenDueDate: includeToken ? ($('#tokenDueDate').val() || null) : null,
                    PossessionAmount: possessionAmountPkr,
                    PossessionPaymentDescription: possessionAmountPkr > 0 ? $('#possessionPaymentDescription').val() : null,
                    PossessionDueDate: possessionAmountPkr > 0 ? ($('#possessionDueDate').val() || null) : null,
                    TotalInstallments: totalInstallments,
                    InstallmentAmount: installmentAmountPkr,
                    Frequency: $('#scheduleFrequency').val(),
                    FirstInstallmentDueDate: $('#firstInstallmentDueDate').val(),
                    PaymentDescription: $('#paymentDescription').val(),
                    SurchargeApplied: $('#surchargeApplied').is(':checked'),
                    SurchargeRate: surchargeInput
                };

                var formData = {
                    PaymentPlan: planData,
                    PaymentSchedules: scheduleData
                };

                var token = $('input[name="__RequestVerificationToken"]').val();

                $.ajax({
                    url: '@Url.Action("CreatePaymentPlan", "Payment")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(formData),
                    headers: {
                        RequestVerificationToken: token
                    },
                    success: function(response) {
                        if (response.success) {
                            window.location.href = '@Url.Action("PaymentSchedule", "Payment")?planId=' + response.planId;
                        } else {
                            alert('Error: ' + (response.message || 'Failed to create payment plan'));
                        }
                    },
                    error: function(xhr, status, error) {
                        var errorMessage = 'Error creating payment plan. Please try again.';
                        if (xhr.responseJSON && xhr.responseJSON.message) {
                            errorMessage = xhr.responseJSON.message;
                        }
                        alert(errorMessage);
                        console.error(error);
                    }
                });
            });
        });
    </script>
}
