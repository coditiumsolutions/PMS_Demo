@model PMS.Models.PaymentPlan

@{
    ViewData["Title"] = "Create Payment Plan";
}

<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>
                <i class="fas fa-clipboard-list me-2"></i>Create Payment Plan
            </h2>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Back to Payments
            </a>
        </div>

        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="fas fa-file-invoice-dollar me-2"></i>Payment Plan Information
                </h5>
            </div>
            <div class="card-body">
                <form asp-action="CreatePaymentPlan" method="post">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="PlanName" class="form-label">Plan Name *</label>
                                <input asp-for="PlanName" class="form-control" placeholder="e.g., 3 Year Installment Plan" required />
                                <span asp-validation-for="PlanName" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="ProjectID" class="form-label">Project (Optional)</label>
                                <select asp-for="ProjectID" class="form-select">
                                    <option value="">Select Project</option>
                                    @if (ViewBag.Projects != null)
                                    {
                                        @foreach (var project in ViewBag.Projects)
                                        {
                                            <option value="@project.ProjectID">@project.ProjectName</option>
                                        }
                                    }
                                </select>
                                <span asp-validation-for="ProjectID" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="TotalAmount" class="form-label">Total Amount (SSP) *</label>
                                <input asp-for="TotalAmount" type="number" step="0.01" class="form-control" placeholder="e.g., 5000000" required />
                                <span asp-validation-for="TotalAmount" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="DurationMonths" class="form-label">Duration (Months) *</label>
                                <input asp-for="DurationMonths" type="number" class="form-control" placeholder="e.g., 36" required />
                                <span asp-validation-for="DurationMonths" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12">
                            <div class="mb-3">
                                <label asp-for="Frequency" class="form-label">Payment Frequency *</label>
                                <select asp-for="Frequency" class="form-select" required>
                                    <option value="">Select Frequency</option>
                                    <option value="Monthly">Monthly</option>
                                    <option value="Quarterly">Quarterly (Every 3 Months)</option>
                                    <option value="Semi-Annually">Semi-Annually (Every 6 Months)</option>
                                    <option value="Annually">Annually (Every Year)</option>
                                </select>
                                <span asp-validation-for="Frequency" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-12">
                            <div class="mb-3">
                                <label asp-for="Description" class="form-label">Description</label>
                                <textarea asp-for="Description" class="form-control" rows="3" placeholder="Enter payment plan details and terms"></textarea>
                                <span asp-validation-for="Description" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="alert alert-info">
                        <i class="fas fa-info-circle me-2"></i>
                        <strong>Note:</strong> After creating the payment plan, you will be able to add payment schedules/installments.
                    </div>

                    <hr>

                    <div class="row">
                        <div class="col-12">
                            <div class="d-flex justify-content-end">
                                <button type="submit" class="btn btn-primary me-2">
                                    <i class="fas fa-save me-2"></i>Create Payment Plan
                                </button>
                                <a asp-action="Index" class="btn btn-secondary">
                                    <i class="fas fa-times me-2"></i>Cancel
                                </a>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <!-- Payment Plan Preview -->
        <div class="card mt-4">
            <div class="card-header bg-light">
                <h6 class="mb-0">
                    <i class="fas fa-calculator me-2"></i>Plan Preview
                </h6>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4 mb-2">
                        <small class="text-muted">Total Amount</small>
                        <p id="previewTotal" class="fw-bold" style="color: var(--primary-green);">SSP 0.00</p>
                    </div>
                    <div class="col-md-4 mb-2">
                        <small class="text-muted">Duration</small>
                        <p id="previewDuration" class="fw-bold">0 Months</p>
                    </div>
                    <div class="col-md-4 mb-2">
                        <small class="text-muted">Estimated Installment</small>
                        <p id="previewInstallment" class="fw-bold" style="color: var(--accent-gold);">SSP 0.00</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        $(document).ready(function() {
            function updatePreview() {
                var total = parseFloat($('#TotalAmount').val()) || 0;
                var duration = parseInt($('#DurationMonths').val()) || 0;
                var frequency = $('#Frequency').val();
                
                $('#previewTotal').text('SSP ' + total.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}));
                $('#previewDuration').text(duration + ' Months');
                
                var installments = 0;
                if (frequency === 'Monthly') installments = duration;
                else if (frequency === 'Quarterly') installments = Math.ceil(duration / 3);
                else if (frequency === 'Semi-Annually') installments = Math.ceil(duration / 6);
                else if (frequency === 'Annually') installments = Math.ceil(duration / 12);
                
                var installmentAmount = installments > 0 ? total / installments : 0;
                $('#previewInstallment').text('SSP ' + installmentAmount.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) + 
                    (installments > 0 ? ' (' + installments + ' installments)' : ''));
            }
            
            $('#TotalAmount, #DurationMonths, #Frequency').on('input change', updatePreview);
            updatePreview();
        });
    </script>
}

