@model PMS.Models.PaymentPlan

@{
    ViewData["Title"] = "Create Payment Plan";
}

<div class="row">
    <div class="col-md-10 mx-auto">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Back to Payments
            </a>
        </div>

        <form id="paymentPlanForm" asp-action="CreatePaymentPlan" method="post">
            @Html.AntiForgeryToken()

            <!-- Payment Plan Section -->
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-file-invoice-dollar me-2"></i>Payment Plan Information
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="PlanName" class="form-label">Plan Name *</label>
                                <input asp-for="PlanName" id="PlanName" class="form-control" type="text" required placeholder="e.g. 2 Year Plan" />
                                <span asp-validation-for="PlanName" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="ProjectID" class="form-label">Project *</label>
                                <select asp-for="ProjectID" id="ProjectID" class="form-select" required>
                                    <option value="">Select Project</option>
                                    @if (ViewBag.Projects != null)
                                    {
                                        @foreach (var project in ViewBag.Projects)
                                        {
                                            <option value="@project.ProjectID">@project.ProjectName</option>
                                        }
                                    }
                                </select>
                                <span asp-validation-for="ProjectID" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="Currency" class="form-label">Primary Currency *</label>
                                <select id="Currency" class="form-select">
                                    <option value="PKR" selected>PKR (Pakistani Rupee)</option>
                                    <option value="USD">USD (United States Dollar)</option>
                                </select>
                                <small class="text-muted">Amounts auto-convert using the configured exchange rate.</small>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="TotalAmount" class="form-label">Total Amount (PKR) *</label>
                                <input asp-for="TotalAmount" id="TotalAmount" type="number" step="0.01" class="form-control" placeholder="e.g., 5000000" required />
                                <span asp-validation-for="TotalAmount" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="col-md-6" id="durationMonthsGroup" style="display: none;">
                            <div class="mb-3">
                                <label asp-for="DurationMonths" class="form-label">Plan Duration (Months) *</label>
                                <input asp-for="DurationMonths" id="DurationMonths" type="number" class="form-control" placeholder="e.g., 36" required readonly />
                                <span asp-validation-for="DurationMonths" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="TotalAmountUSD" class="form-label">Total Amount (USD)</label>
                                <input type="number" id="TotalAmountUSD" step="0.01" class="form-control" placeholder="e.g., 10000" />
                                <small class="text-muted">Auto-calculated from PKR when PKR is primary.</small>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="ExchangeRate" class="form-label">Exchange Rate (1 USD = PKR)</label>
                                <input type="number" id="ExchangeRate" step="0.0001" class="form-control" value="@((decimal?)ViewBag.UsdToPkrRate ?? 1m)" readonly />
                                <small class="text-muted">Managed via configuration key <code>Currency:USDToPKR</code>.</small>
                            </div>
                        </div>
                    </div>

                    <!-- Payment Frequency hidden - selected in child section -->
                    <input type="hidden" asp-for="Frequency" id="Frequency" />

                    <div class="row">
                        <div class="col-12">
                            <div class="mb-3">
                                <label asp-for="Description" class="form-label">Description</label>
                                <textarea asp-for="Description" id="Description" class="form-control" rows="3" placeholder="Enter payment plan details and terms"></textarea>
                                <span asp-validation-for="Description" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Payment Schedule Section -->
            <div class="card mb-4">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-calendar-check me-2"></i>Payment Schedule Configuration
                    </h5>
                </div>
                <div class="card-body">
                    <!-- Token Option -->
                    <div class="mb-4 p-3 border rounded bg-light">
                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" id="includeToken" checked>
                            <label class="form-check-label fw-bold" for="includeToken">
                                <i class="fas fa-ticket-alt me-2"></i>Include Token Payment (Installment 0)
                            </label>
                        </div>
                        <div id="tokenAmountSection" class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="tokenAmount" class="form-label">Token Amount (PKR) *</label>
                                    <input type="number" id="tokenAmount" step="0.01" class="form-control" placeholder="e.g., 50000" required />
                                    <small class="text-muted">Token payment amount (Installment 0 - No surcharge applied)</small>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="tokenAmountUSD" class="form-label">Token Amount (USD)</label>
                                    <input type="number" id="tokenAmountUSD" step="0.01" class="form-control" placeholder="Auto-calculated" readonly />
                                </div>
                            </div>
                        </div>
                        <small class="text-muted d-block"><i class="fas fa-info-circle me-1"></i>Token payment is a special installment (Installment No: 0). Token has <strong>no surcharge</strong> policy applied.</small>
                    </div>

                    <!-- Installment Options -->
                    <div class="mb-4">
                        <h6 class="mb-3"><i class="fas fa-list-ol me-2"></i>Bulk Installment Creation</h6>
                        
                        <div class="row">
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label for="totalInstallments" class="form-label">Total Installments (Excluding Token) *</label>
                                    <input type="number" id="totalInstallments" class="form-control" min="1" value="1" required />
                                    <small class="text-muted">Number of installments to create (not including token if selected)</small>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label for="installmentAmount" class="form-label">Installment Amount (PKR) *</label>
                                    <input type="number" id="installmentAmount" step="0.01" class="form-control" placeholder="Auto-calculated" required readonly />
                                    <small class="text-muted">Auto: (Total Amount − Token Amount) ÷ Total Installments</small>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label for="installmentAmountUSD" class="form-label">Installment Amount (USD)</label>
                                    <input type="number" id="installmentAmountUSD" step="0.01" class="form-control" placeholder="Auto-calculated" readonly />
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="scheduleFrequency" class="form-label">Frequency *</label>
                                    <select id="scheduleFrequency" class="form-select" required>
                                        <option value="">Select Frequency</option>
                                        <option value="Monthly">Monthly</option>
                                        <option value="Quarterly">Quarterly</option>
                                        <option value="Half Yearly">Half Yearly</option>
                                        <option value="Yearly">Yearly</option>
                                    </select>
                                    <small class="text-muted">Used to calculate DueDate for each installment</small>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="firstInstallmentDueDate" class="form-label">1st Installment Due Date *</label>
                                    <input type="date" id="firstInstallmentDueDate" class="form-control" required />
                                    <small class="text-muted">Due date for the first installment (subsequent dates calculated based on frequency)</small>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="paymentDescription" class="form-label">Payment Description *</label>
                                    <input type="text" id="paymentDescription" class="form-control" placeholder="e.g., Monthly Installment" required />
                                    <small class="text-muted">Same description will be used for all installments</small>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="surchargeRate" class="form-label">Surcharge Rate (%) *</label>
                                    <input type="number" id="surchargeRate" step="0.01" class="form-control" value="5" required />
                                    <small class="text-muted">Daily surcharge rate percentage (e.g., 5 = 5% per day)</small>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="surchargeApplied" checked>
                                <label class="form-check-label" for="surchargeApplied">
                                    Apply Surcharge (Default: Yes)
                                </label>
                            </div>
                        </div>
                    </div>

                    <!-- Preview Section -->
                    <div class="alert alert-info">
                        <h6 class="alert-heading"><i class="fas fa-info-circle me-2"></i>Installment Preview</h6>
                        <div id="installmentPreview" class="mt-2">
                            <p class="mb-1"><strong>Total Installments:</strong> <span id="previewTotalInstallments">0</span></p>
                            <p class="mb-1"><strong>Token:</strong> <span id="previewToken">Not included</span></p>
                            <p class="mb-1"><strong>Amount per Installment:</strong> PKR <span id="previewAmount">0.00</span> / USD <span id="previewAmountUSD">0.00</span></p>
                            <p class="mb-1"><strong>Frequency:</strong> <span id="previewFrequency">-</span></p>
                            <p class="mb-1"><strong>Total Installments Amount:</strong> PKR <span id="previewTotalInstallmentsAmount">0.00</span> / USD <span id="previewTotalInstallmentsAmountUSD">0.00</span></p>
                            <p class="mb-1"><strong>Token Amount:</strong> PKR <span id="previewTokenAmount">0.00</span> / USD <span id="previewTokenAmountUSD">0.00</span></p>
                            <p class="mb-0"><strong>Grand Total (Token + Installments):</strong> PKR <span id="previewGrandTotal">0.00</span> / USD <span id="previewGrandTotalUSD">0.00</span> / Plan Total PKR <span id="previewPlanTotal">0.00</span> / Plan Total USD <span id="previewPlanTotalUSD">0.00</span></p>
                        </div>
                        <div id="amountValidationMessage" class="mt-2" style="display: none;">
                            <div class="alert alert-danger mb-0">
                                <i class="fas fa-exclamation-triangle me-2"></i><span id="validationMessageText"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Submit Buttons -->
            <div class="card">
                <div class="card-body">
                    <div class="d-flex justify-content-end gap-2">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="fas fa-save me-2"></i>Create Payment Plan & Schedules
                        </button>
                        <a asp-action="Index" class="btn btn-secondary btn-lg">
                            <i class="fas fa-times me-2"></i>Cancel
                        </a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        $(document).ready(function() {
            const numberFormat = { minimumFractionDigits: 2, maximumFractionDigits: 2 };

            function formatAmount(value) {
                if (!isFinite(value)) {
                    return '0.00';
                }
                return value.toLocaleString('en-US', numberFormat);
            }

            function parseAmount(selector) {
                var value = parseFloat($(selector).val());
                return isNaN(value) ? 0 : value;
            }

            function writeAmount(selector, value) {
                if (!isFinite(value)) {
                    $(selector).val('');
                } else {
                    $(selector).val(value.toFixed(2));
                }
            }

            function getExchangeRate() {
                var rate = parseFloat($('#ExchangeRate').val());
                return rate && rate > 0 ? rate : 1;
            }

            function updateCurrencyAccessibility() {
                var currency = $('#Currency').val();
                var isUsd = currency === 'USD';

                $('#TotalAmount').prop('readonly', isUsd);
                $('#TotalAmountUSD').prop('readonly', !isUsd);

                $('#tokenAmount').prop('readonly', isUsd);
                $('#tokenAmountUSD').prop('readonly', !isUsd);
                $('#tokenAmount').prop('required', !isUsd && $('#includeToken').is(':checked'));
                $('#tokenAmountUSD').prop('required', isUsd && $('#includeToken').is(':checked'));

                // Installment amount is always auto-calculated (readonly)
                $('#installmentAmount').prop('readonly', true);
                $('#installmentAmountUSD').prop('readonly', true);
                $('#installmentAmount').prop('required', true);
                $('#installmentAmountUSD').prop('required', false);
            }

            function syncPlanAmounts(sourceCurrency) {
                var rate = getExchangeRate();
                if (sourceCurrency === 'USD') {
                    var usdRaw = $('#TotalAmountUSD').val();
                    if (usdRaw === '') {
                        $('#TotalAmount').val('');
                    } else {
                        var usd = parseFloat(usdRaw);
                        writeAmount('#TotalAmount', usd * rate);
                    }
                } else {
                    var sspRaw = $('#TotalAmount').val();
                    if (sspRaw === '') {
                        $('#TotalAmountUSD').val('');
                    } else {
                        var ssp = parseFloat(sspRaw);
                        writeAmount('#TotalAmountUSD', rate ? ssp / rate : 0);
                    }
                }
            }

            function syncTokenAmounts(sourceCurrency) {
                var rate = getExchangeRate();
                if (sourceCurrency === 'USD') {
                    var usdRaw = $('#tokenAmountUSD').val();
                    if (usdRaw === '') {
                        $('#tokenAmount').val('');
                    } else {
                        var usd = parseFloat(usdRaw);
                        writeAmount('#tokenAmount', usd * rate);
                    }
                } else {
                    var sspRaw = $('#tokenAmount').val();
                    if (sspRaw === '') {
                        $('#tokenAmountUSD').val('');
                    } else {
                        var ssp = parseFloat(sspRaw);
                        writeAmount('#tokenAmountUSD', rate ? ssp / rate : 0);
                    }
                }
            }

            function syncInstallmentAmounts(sourceCurrency) {
                var rate = getExchangeRate();
                if (sourceCurrency === 'USD') {
                    var usdRaw = $('#installmentAmountUSD').val();
                    if (usdRaw === '') {
                        $('#installmentAmount').val('');
                    } else {
                        var usd = parseFloat(usdRaw);
                        writeAmount('#installmentAmount', usd * rate);
                    }
                } else {
                    var sspRaw = $('#installmentAmount').val();
                    if (sspRaw === '') {
                        $('#installmentAmountUSD').val('');
                    } else {
                        var ssp = parseFloat(sspRaw);
                        writeAmount('#installmentAmountUSD', rate ? ssp / rate : 0);
                    }
                }
            }

            /** Auto-calculate Installment Amount (PKR) = (Total Amount (PKR) - Token Amount (PKR)) / Total Installments */
            function recalculateInstallmentAmount() {
                var planTotalSSP = parseAmount('#TotalAmount');
                var includeToken = $('#includeToken').is(':checked');
                var tokenAmountSSP = includeToken ? parseAmount('#tokenAmount') : 0;
                var totalInstallments = parseInt($('#totalInstallments').val(), 10) || 0;
                var remainder = planTotalSSP - tokenAmountSSP;
                var installmentPKR = (totalInstallments > 0 && remainder >= 0) ? remainder / totalInstallments : 0;
                var rate = getExchangeRate();
                writeAmount('#installmentAmount', installmentPKR);
                writeAmount('#installmentAmountUSD', rate ? installmentPKR / rate : 0);
            }

            function updatePreview() {
                recalculateInstallmentAmount();
                var exchangeRate = getExchangeRate();
                var totalInstallments = parseInt($('#totalInstallments').val(), 10) || 0;
                var includeToken = $('#includeToken').is(':checked');
                var tokenAmountSSP = includeToken ? parseAmount('#tokenAmount') : 0;
                var tokenAmountUSD = exchangeRate ? tokenAmountSSP / exchangeRate : 0;
                var installmentAmountSSP = parseAmount('#installmentAmount');
                var installmentAmountUSD = exchangeRate ? installmentAmountSSP / exchangeRate : 0;
                var frequency = $('#scheduleFrequency').val();
                var planTotalSSP = parseAmount('#TotalAmount');
                var planTotalUSD = parseAmount('#TotalAmountUSD');
                if (planTotalUSD <= 0 && planTotalSSP > 0) {
                    planTotalUSD = exchangeRate ? planTotalSSP / exchangeRate : 0;
                }

                var totalInstallmentsAmountSSP = totalInstallments * installmentAmountSSP;
                var totalInstallmentsAmountUSD = exchangeRate ? totalInstallmentsAmountSSP / exchangeRate : 0;
                var grandTotalSSP = totalInstallmentsAmountSSP + (includeToken ? tokenAmountSSP : 0);
                var grandTotalUSD = exchangeRate ? grandTotalSSP / exchangeRate : 0;

                var totalCount = totalInstallments + (includeToken ? 1 : 0);

                $('#previewTotalInstallments').text(totalCount);
                if (includeToken) {
                    if (tokenAmountSSP > 0) {
                        $('#previewToken').text('Included (Installment 0) - No surcharge');
                    } else {
                        $('#previewToken').text('Included (Installment 0) - Amount not set');
                    }
                } else {
                    $('#previewToken').text('Not included');
                }

                $('#previewAmount').text(formatAmount(installmentAmountSSP));
                $('#previewAmountUSD').text(formatAmount(installmentAmountUSD));
                $('#previewFrequency').text(frequency || '-');
                $('#previewTotalInstallmentsAmount').text(formatAmount(totalInstallmentsAmountSSP));
                $('#previewTotalInstallmentsAmountUSD').text(formatAmount(totalInstallmentsAmountUSD));
                $('#previewTokenAmount').text(formatAmount(tokenAmountSSP));
                $('#previewTokenAmountUSD').text(formatAmount(tokenAmountUSD));
                $('#previewGrandTotal').text(formatAmount(grandTotalSSP));
                $('#previewGrandTotalUSD').text(formatAmount(grandTotalUSD));
                $('#previewPlanTotal').text(formatAmount(planTotalSSP));
                $('#previewPlanTotalUSD').text(formatAmount(planTotalUSD));

                validateTotalAmount(planTotalSSP, grandTotalSSP, includeToken, tokenAmountSSP, totalInstallmentsAmountSSP);

                // Duration (Months) is derived from Frequency and Total Installments (field is hidden)
                var monthsPerInstallment = { 'Monthly': 1, 'Quarterly': 3, 'Half Yearly': 6, 'Yearly': 12 }[frequency] || 1;
                $('#DurationMonths').val(frequency && totalInstallments > 0 ? totalInstallments * monthsPerInstallment : '');
            }

            function validateTotalAmount(planTotalSSP, grandTotalSSP, includeToken, tokenAmountSSP, totalInstallmentsAmountSSP) {
                var validationDiv = $('#amountValidationMessage');
                var messageText = $('#validationMessageText');
                var exchangeRate = getExchangeRate();
                var totalInstallmentsAmountUSD = exchangeRate ? totalInstallmentsAmountSSP / exchangeRate : 0;
                var tokenAmountUSD = exchangeRate ? tokenAmountSSP / exchangeRate : 0;
                var grandTotalUSD = exchangeRate ? grandTotalSSP / exchangeRate : 0;
                var planTotalUSD = exchangeRate ? planTotalSSP / exchangeRate : 0;

                if (planTotalSSP > 0 && grandTotalSSP > planTotalSSP) {
                    var excessSSP = grandTotalSSP - planTotalSSP;
                    var excessUSD = exchangeRate ? excessSSP / exchangeRate : 0;
                    messageText.html(
                        'Total Installments Amount (PKR ' + formatAmount(totalInstallmentsAmountSSP) + ' / USD ' + formatAmount(totalInstallmentsAmountUSD) + ') + ' +
                        'Token Amount (PKR ' + (includeToken ? formatAmount(tokenAmountSSP) : '0.00') + ' / USD ' + (includeToken ? formatAmount(tokenAmountUSD) : '0.00') + ') = PKR ' +
                        formatAmount(grandTotalSSP) + ' / USD ' + formatAmount(grandTotalUSD) +
                        ' exceeds Parent Total Amount (PKR ' + formatAmount(planTotalSSP) + ' / USD ' + formatAmount(planTotalUSD) + '). Excess: PKR ' +
                        formatAmount(excessSSP) + ' / USD ' + formatAmount(excessUSD) + '.'
                    );
                    validationDiv.show();
                    return false;
                }

                validationDiv.hide();
                return true;
            }

            function toggleTokenSection() {
                if ($('#includeToken').is(':checked')) {
                    $('#tokenAmountSection').show();
                    $('#tokenAmount').prop('required', $('#Currency').val() === 'PKR');
                    $('#tokenAmountUSD').prop('required', $('#Currency').val() === 'USD');
                } else {
                    $('#tokenAmountSection').hide();
                    $('#tokenAmount').prop('required', false);
                    $('#tokenAmountUSD').prop('required', false);
                }
            }

            $('#Currency').on('change', function() {
                updateCurrencyAccessibility();
                var currency = $(this).val();
                syncPlanAmounts(currency);
                syncTokenAmounts(currency);
                updatePreview();
            });

            $('#includeToken').on('change', function() {
                toggleTokenSection();
                syncTokenAmounts($('#Currency').val());
                updatePreview();
            });

            $('#scheduleFrequency').on('change', function() {
                $('#Frequency').val($(this).val());
                updatePreview();
            });

            $('#TotalAmount').on('input', function() {
                if ($('#Currency').val() === 'PKR') {
                    syncPlanAmounts('PKR');
                    updatePreview();
                }
            });

            $('#TotalAmountUSD').on('input', function() {
                if ($('#Currency').val() === 'USD') {
                    syncPlanAmounts('USD');
                    updatePreview();
                }
            });

            $('#tokenAmount').on('input', function() {
                if ($('#Currency').val() === 'PKR') {
                    syncTokenAmounts('PKR');
                    updatePreview();
                }
            });

            $('#tokenAmountUSD').on('input', function() {
                if ($('#Currency').val() === 'USD') {
                    syncTokenAmounts('USD');
                    updatePreview();
                }
            });

            $('#installmentAmount').on('input', function() {
                if ($('#Currency').val() === 'PKR') {
                    syncInstallmentAmounts('PKR');
                    updatePreview();
                }
            });

            $('#installmentAmountUSD').on('input', function() {
                if ($('#Currency').val() === 'USD') {
                    syncInstallmentAmounts('USD');
                    updatePreview();
                }
            });

            $('#totalInstallments, #scheduleFrequency, #paymentDescription, #DurationMonths').on('change input', updatePreview);

            // Initialize defaults
            updateCurrencyAccessibility();
            toggleTokenSection();
            syncPlanAmounts($('#Currency').val());
            syncTokenAmounts($('#Currency').val());
            syncInstallmentAmounts($('#Currency').val());
            updatePreview();

            // Form submission
            $('#paymentPlanForm').on('submit', function(e) {
                e.preventDefault();

                if (!this.checkValidity()) {
                    e.stopPropagation();
                    $(this).addClass('was-validated');
                    return false;
                }

                if (!$('#ProjectID').val()) {
                    alert('Please select a Project.');
                    $('#ProjectID').focus().addClass('is-invalid');
                    return false;
                }

                // Ensure amounts are synced before reading values
                var currentCurrency = $('#Currency').val();
                syncPlanAmounts(currentCurrency);
                syncTokenAmounts(currentCurrency);
                syncInstallmentAmounts(currentCurrency);

                var includeToken = $('#includeToken').is(':checked');
                var tokenAmountSSP = includeToken ? parseAmount('#tokenAmount') : null;
                var tokenAmountUSD = includeToken ? parseAmount('#tokenAmountUSD') : null;
                var totalInstallments = parseInt($('#totalInstallments').val(), 10) || 0;
                var installmentAmountSSP = parseAmount('#installmentAmount');
                var planTotalSSP = parseAmount('#TotalAmount');
                var exchangeRate = getExchangeRate();

                if (includeToken && (!tokenAmountSSP || tokenAmountSSP <= 0)) {
                    alert('Please enter Token Amount if Token is included.');
                    return false;
                }

                var totalInstallmentsAmount = totalInstallments * installmentAmountSSP;
                var grandTotal = totalInstallmentsAmount + (includeToken ? tokenAmountSSP : 0);

                if (grandTotal > planTotalSSP) {
                    var excess = grandTotal - planTotalSSP;
                    alert(
                        'Validation Error: Total Installments Amount (PKR ' + formatAmount(totalInstallmentsAmount) + ' / USD ' + formatAmount(exchangeRate ? totalInstallmentsAmount / exchangeRate : 0) + ') + ' +
                        'Token Amount (PKR ' + (includeToken ? formatAmount(tokenAmountSSP) : '0.00') + ' / USD ' + (includeToken ? formatAmount(tokenAmountUSD || 0) : '0.00') + ') = PKR ' +
                        formatAmount(grandTotal) + ' exceeds Parent Total Amount (PKR ' + formatAmount(planTotalSSP) + '). Excess: PKR ' + formatAmount(excess) + '.'
                    );
                    return false;
                }

                var surchargeInput = parseFloat($('#surchargeRate').val()) || 0;
                if (surchargeInput > 0 && surchargeInput < 1) {
                    surchargeInput = surchargeInput * 100;
                    $('#surchargeRate').val(surchargeInput.toFixed(2));
                }

                var planData = {
                    PlanName: $('#PlanName').val(),
                    ProjectID: $('#ProjectID').val() || null,
                    TotalAmount: planTotalSSP,
                    TotalAmountUSD: parseAmount('#TotalAmountUSD'),
                    ExchangeRate: exchangeRate,
                    Currency: currentCurrency,
                    DurationMonths: parseInt($('#DurationMonths').val(), 10),
                    Frequency: $('#scheduleFrequency').val(),
                    Description: $('#Description').val()
                };

                var scheduleData = {
                    IncludeToken: includeToken,
                    TokenAmount: tokenAmountSSP,
                    TokenAmountUSD: includeToken ? tokenAmountUSD : null,
                    TotalInstallments: totalInstallments,
                    InstallmentAmount: installmentAmountSSP,
                    InstallmentAmountUSD: parseAmount('#installmentAmountUSD'),
                    Frequency: $('#scheduleFrequency').val(),
                    FirstInstallmentDueDate: $('#firstInstallmentDueDate').val(),
                    PaymentDescription: $('#paymentDescription').val(),
                    SurchargeApplied: $('#surchargeApplied').is(':checked'),
                    SurchargeRate: surchargeInput / 100
                };

                var formData = {
                    PaymentPlan: planData,
                    PaymentSchedules: scheduleData
                };

                var token = $('input[name="__RequestVerificationToken"]').val();

                $.ajax({
                    url: '@Url.Action("CreatePaymentPlan", "Payment")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(formData),
                    headers: {
                        'RequestVerificationToken': token
                    },
                    success: function(response) {
                        if (response.success) {
                            window.location.href = '@Url.Action("PaymentSchedule", "Payment")?planId=' + response.planId;
                        } else {
                            alert('Error: ' + (response.message || 'Failed to create payment plan'));
                        }
                    },
                    error: function(xhr, status, error) {
                        var errorMessage = 'Error creating payment plan. Please try again.';
                        if (xhr.responseJSON && xhr.responseJSON.message) {
                            errorMessage = xhr.responseJSON.message;
                        }
                        alert(errorMessage);
                        console.error(error);
                    }
                });
            });
        });
    </script>
}
