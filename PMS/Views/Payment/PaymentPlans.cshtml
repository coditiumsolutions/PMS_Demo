@model IEnumerable<PMS.Models.PaymentPlan>
@using System.Globalization

@{
    ViewData["Title"] = "Payment Plans (Batches)";
    var EnUs = CultureInfo.GetCultureInfo("en-US");
    var plansOrdered = Model.OrderBy(p => p.PlanName).ToList();
    var totalValueSsp = plansOrdered.Sum(p => p.TotalAmount);
    var deleteSummaryUrl = Url.Action("GetPaymentPlanDeleteSummary", "Payment");
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>
        <!-- <i class="fas fa-file-invoice-dollar me-2"></i>Payment Plans (Batches) -->
    </h2>
    @if (ViewBag.CanCreate == true)
    {
    <a asp-action="CreatePaymentPlan" class="btn btn-primary">
        <i class="fas fa-plus me-2"></i>Create New Plan
    </a>
    }
</div>

<!-- Statistics (compact typography — global .stats-number is 2.2rem) -->
<div class="row mb-4 payment-plans-stats">
    <div class="col-md-3">
        <div class="stats-card">
            <div class="stats-number">@Model.Count()</div>
            <div class="stats-label">Total Plans</div>
            <i class="fas fa-clipboard-list fa-2x mt-2" style="color: var(--primary-green);"></i>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stats-card">
            <div class="stats-number">@Model.Sum(p => p.Customers?.Count ?? 0)</div>
            <div class="stats-label">Total Customers</div>
            <i class="fas fa-users fa-2x mt-2" style="color: var(--primary-green);"></i>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stats-card">
            <div class="stats-number stats-number-total-value">
                <span class="d-block">PKR @totalValueSsp.ToString("N0", EnUs)</span>
            </div>
            <div class="stats-label">Total Value</div>
            <i class="fas fa-money-bill-wave fa-2x mt-2" style="color: var(--accent-gold);"></i>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stats-card">
            <div class="stats-number">@Model.Sum(p => p.PaymentSchedules?.Count ?? 0)</div>
            <div class="stats-label">Total Schedules</div>
            <i class="fas fa-calendar-alt fa-2x mt-2" style="color: var(--primary-green);"></i>
        </div>
    </div>
</div>

<!-- Payment Plans Table -->
<div class="card">
    <div class="card-header">
        <h5 class="mb-0">
            <i class="fas fa-list me-2"></i>All Payment Plans
        </h5>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover" id="plansTable">
                <thead>
                    <tr>
                        <th>Actions</th>
                        <th>Plan ID</th>
                        <th>Plan Name</th>
                        <th>Project</th>
                        <th>Total Amount</th>
                        <th>Currency</th>
                        <th>Duration</th>
                        <th>Frequency</th>
                        <th>Customers</th>
                        <th>Schedules</th>
                        <th>Balance (PKR)</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var plan in plansOrdered)
                    {
                        var schedulesSumPkr = plan.PaymentSchedules?.Sum(s => s.Amount) ?? 0m;
                        var balancePkr = plan.TotalAmount - schedulesSumPkr;
                        var hasBalanceRemaining = balancePkr > 0.0000001m;
                        <tr class="@(hasBalanceRemaining ? "plan-balance-remaining" : null)">
                            <td>
                                <div class="btn-group" role="group">
                                    <a asp-action="PaymentSchedule" asp-route-planId="@plan.PlanID" 
                                       class="btn btn-sm btn-outline-primary" title="View Schedules">
                                        <i class="fas fa-calendar-check"></i>
                                    </a>
                                    <button type="button" 
                                            class="btn btn-sm btn-outline-info" 
                                            data-bs-toggle="modal" 
                                            data-bs-target="#planModal@(plan.PlanID)"
                                            title="View Details">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                    @if (ViewBag.CanDelete == true)
                                    {
                                        <button type="button"
                                                class="btn btn-sm btn-outline-danger js-delete-payment-plan"
                                                title="Delete payment plan"
                                                data-plan-id="@plan.PlanID"
                                                data-plan-name="@plan.PlanName">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                            <td><code>@plan.PlanID</code></td>
                            <td>
                                <strong>@plan.PlanName</strong>
                                @if (!string.IsNullOrEmpty(plan.Description))
                                {
                                    <br><small class="text-muted">@(plan.Description.Length > 50 ? plan.Description.Substring(0, 50) + "..." : plan.Description)</small>
                                }
                            </td>
                            <td>
                                @if (plan.Project != null)
                                {
                                    <span class="badge bg-info">@plan.Project.ProjectName</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                <strong style="color: var(--primary-green);">
                                    PKR @plan.TotalAmount.ToString("N0", EnUs)
                                </strong>
                            </td>
                            <td>
                                <span class="badge bg-dark text-uppercase">@plan.Currency</span>
                            </td>
                            <td>
                                <i class="far fa-calendar me-1"></i>
                                @(plan.DurationMonths?.ToString() ?? "N/A") Months
                            </td>
                            <td>
                                <span class="badge bg-secondary">@plan.Frequency</span>
                            </td>
                            <td>
                                <span class="badge bg-primary">
                                    <i class="fas fa-users me-1"></i>
                                    @(plan.Customers?.Count ?? 0)
                                </span>
                            </td>
                            <td>
                                <span class="badge @(plan.PaymentSchedules?.Any() == true ? "bg-success" : "bg-warning")">
                                    <i class="fas fa-calendar-alt me-1"></i>
                                    @(plan.PaymentSchedules?.Count ?? 0)
                                </span>
                            </td>
                            <td>
                                <span class="fw-semibold @(hasBalanceRemaining ? "text-success" : balancePkr < -0.0000001m ? "text-danger" : "text-muted")">
                                    @balancePkr.ToString("N0", EnUs)
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (ViewBag.CanDelete == true)
{
    <div class="modal fade" id="deletePaymentPlanModal" tabindex="-1" aria-labelledby="deletePaymentPlanModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title" id="deletePaymentPlanModalLabel">
                        <i class="fas fa-exclamation-triangle me-2"></i>Delete payment plan
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="fw-semibold mb-2" id="deletePlanTitle"></p>
                    <div id="deletePlanSummaryBody" class="small text-muted"></div>
                    <div id="deletePlanCustomerBlock" class="mt-3 d-none">
                        <div class="alert alert-warning mb-2 py-2">
                            <strong id="deletePlanCustomerCountText"></strong> These customers will lose this plan assignment (their Plan ID will be cleared).
                        </div>
                        <div class="border rounded p-2 bg-light" style="max-height: 200px; overflow-y: auto;">
                            <ul class="mb-0 small" id="deletePlanCustomerList"></ul>
                        </div>
                    </div>
                    <p class="text-danger small mt-3 mb-0">
                        This removes the plan and all installment rows. It cannot be undone. You cannot delete a plan that still has payments recorded against any installment.
                    </p>
                </div>
                <div class="modal-footer">
                    <form asp-action="DeletePaymentPlan" method="post" id="deletePaymentPlanForm" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="planId" id="deletePaymentPlanFormPlanId" value="" />
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-danger" id="deletePaymentPlanConfirmBtn">
                            <i class="fas fa-trash-alt me-1"></i>Delete plan
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@foreach (var plan in plansOrdered)
{
    var scheduleCount = plan.PaymentSchedules?.Count ?? 0;
    var avgAmount = scheduleCount > 0 ? (plan.TotalAmount / scheduleCount) : 0m;
    <div class="modal fade" id="planModal@(plan.PlanID)" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header" style="background: linear-gradient(135deg, var(--primary-green) 0%, var(--accent-gold) 100%);">
                    <h5 class="modal-title text-white">
                        <i class="fas fa-file-invoice-dollar me-2"></i>@plan.PlanName
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="text-muted small">Plan ID</label>
                            <p><code>@plan.PlanID</code></p>
                        </div>
                        <div class="col-6 mb-3">
                            <label class="text-muted small">Created Date</label>
                            <p>@plan.CreatedAt.ToString("MMM dd, yyyy")</p>
                        </div>
                        <div class="col-12 mb-3">
                            <label class="text-muted small">Plan Name</label>
                            <p><strong>@plan.PlanName</strong></p>
                        </div>
                        <div class="col-6 mb-3">
                            <label class="text-muted small">Total Amount</label>
                            <p><strong style="color: var(--primary-green);">@plan.TotalAmount.ToString("N0", EnUs) PKR</strong></p>
                        </div>
                        <div class="col-6 mb-3">
                            <label class="text-muted small">Primary Currency</label>
                            <p>@plan.Currency</p>
                        </div>
                        <div class="col-6 mb-3">
                            <label class="text-muted small">Duration</label>
                            <p>@plan.DurationMonths Months</p>
                        </div>
                        <div class="col-6 mb-3">
                            <label class="text-muted small">Frequency</label>
                            <p>@plan.Frequency</p>
                        </div>
                        <div class="col-6 mb-3">
                            <label class="text-muted small">Project</label>
                            <p>@(plan.Project?.ProjectName ?? "N/A")</p>
                        </div>
                        @if (!string.IsNullOrEmpty(plan.Description))
                        {
                            <div class="col-12 mb-3">
                                <label class="text-muted small">Description</label>
                                <p>@plan.Description</p>
                            </div>
                        }
                        <div class="col-12">
                            <label class="text-muted small">Statistics</label>
                            <div class="row">
                                <div class="col-4 text-center">
                                    <div class="p-3 bg-light rounded">
                                        <h4 class="mb-1" style="color: var(--primary-green);">@(plan.Customers?.Count ?? 0)</h4>
                                        <small class="text-muted">Customers</small>
                                    </div>
                                </div>
                                <div class="col-4 text-center">
                                    <div class="p-3 bg-light rounded">
                                        <h4 class="mb-1" style="color: var(--primary-green);">@(plan.PaymentSchedules?.Count ?? 0)</h4>
                                        <small class="text-muted">Schedules</small>
                                    </div>
                                </div>
                                <div class="col-4 text-center">
                                    <div class="p-3 bg-light rounded">
                                        <h4 class="mb-1" style="color: var(--accent-gold);">@avgAmount.ToString("N0", EnUs)</h4>
                                        <small class="text-muted">Avg Installment</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <a asp-action="PaymentSchedule" asp-route-planId="@plan.PlanID" class="btn btn-primary">
                        <i class="fas fa-calendar-check me-2"></i>View Schedules
                    </a>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .payment-plans-stats .stats-card {
        padding: 14px 12px;
    }

    .payment-plans-stats .stats-number {
        font-size: 1.25rem;
        font-weight: 600;
        margin-bottom: 6px;
        line-height: 1.3;
        word-break: break-word;
    }

    .payment-plans-stats .stats-number-total-value {
        font-size: 1.1rem;
        font-weight: 600;
    }

    .payment-plans-stats .stats-label {
        font-size: 10px;
        letter-spacing: 0.35px;
    }

    .payment-plans-stats .stats-card .fa-2x {
        font-size: 1.35rem !important;
        margin-top: 0.35rem !important;
    }

    code {
        background: var(--light-green);
        color: var(--primary-green);
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
    }

    #plansTable tbody tr.plan-balance-remaining {
        box-shadow: inset 4px 0 0 0 var(--accent-gold, #f59e0b);
        background-color: rgba(245, 158, 11, 0.12);
    }

    #plansTable tbody tr.plan-balance-remaining:hover {
        background-color: rgba(245, 158, 11, 0.2);
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#plansTable').DataTable({
                "pageLength": 25,
                "order": [[ 2, "asc" ]],
                "columnDefs": [
                    { "orderable": false, "targets": 0 }
                ]
            });

            var deleteSummaryUrl = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(deleteSummaryUrl));
            var deleteModalEl = document.getElementById('deletePaymentPlanModal');
            var deleteModal = deleteModalEl ? new bootstrap.Modal(deleteModalEl) : null;

            $('#plansTable').on('click', '.js-delete-payment-plan', function () {
                var $btn = $(this);
                var planId = $btn.data('plan-id');
                var planName = $btn.data('plan-name') || '';
                if (!planId || !deleteModal) {
                    return;
                }
                $btn.prop('disabled', true);
                var url = deleteSummaryUrl + (deleteSummaryUrl.indexOf('?') >= 0 ? '&' : '?') + 'planId=' + encodeURIComponent(planId);
                fetch(url, { headers: { 'Accept': 'application/json' }, credentials: 'same-origin' })
                    .then(function (r) { return r.json().then(function (data) { return { ok: r.ok, data: data }; }); })
                    .then(function (res) {
                        if (!res.data || res.data.found === false) {
                            alert(res.data && res.data.message ? res.data.message : 'Could not load plan details for delete.');
                            return;
                        }
                        if (!res.data.canDelete) {
                            alert(res.data.message || 'This plan cannot be deleted because payments are linked to its installments.');
                            return;
                        }
                        $('#deletePlanTitle').text('Delete “' + (res.data.planName || planName) + '” (' + res.data.planId + ')?');
                        var lines = [];
                        lines.push('Installment rows to remove: ' + (res.data.scheduleCount || 0));
                        lines.push('Payments linked to installments: ' + (res.data.paymentCount || 0) + ' (must be zero to delete).');
                        $('#deletePlanSummaryBody').html(lines.join('<br />'));

                        var cc = res.data.customerCount || 0;
                        if (cc > 0) {
                            $('#deletePlanCustomerCountText').text(cc + ' customer(s) are assigned to this plan.');
                            var $ul = $('#deletePlanCustomerList').empty();
                            (res.data.customers || []).forEach(function (c) {
                                var name = (c.fullName || '').trim() || '(no name)';
                                $ul.append($('<li></li>').text((c.customerId || '') + ' — ' + name));
                            });
                            if (cc > (res.data.customers || []).length) {
                                $ul.append($('<li class="text-muted"></li>').text('… and ' + (cc - (res.data.customers || []).length) + ' more (see Activity Log after delete for full snapshot in audit JSON).'));
                            }
                            $('#deletePlanCustomerBlock').removeClass('d-none');
                        } else {
                            $('#deletePlanCustomerBlock').addClass('d-none');
                        }

                        $('#deletePaymentPlanFormPlanId').val(res.data.planId);
                        $('#deletePaymentPlanConfirmBtn').prop('disabled', false);
                        deleteModal.show();
                    })
                    .catch(function () {
                        alert('Could not load delete preview. Check your connection or permissions.');
                    })
                    .finally(function () {
                        $btn.prop('disabled', false);
                    });
            });

            if (deleteModalEl) {
                deleteModalEl.addEventListener('hidden.bs.modal', function () {
                    $('#deletePaymentPlanFormPlanId').val('');
                    $('#deletePlanCustomerList').empty();
                });
            }
        });
    </script>
}

