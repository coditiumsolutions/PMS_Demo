@model PMS.Models.PaymentSchedule
@using System.Globalization

@{
    ViewData["Title"] = "Edit Payment Schedule";
    var enUs = CultureInfo.GetCultureInfo("en-US");
    var paymentPlan = ViewBag.PaymentPlan as PMS.Models.PaymentPlan;
    var customersOnPlan = (int)(ViewBag.CustomersOnPlanCount ?? 0);
    var othersAmountSum = (decimal)(ViewBag.OthersAmountSum ?? 0m);
}

<div class="row">
    <div class="col-md-9 mx-auto">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2><i class="fas fa-edit me-2"></i>Edit Installment</h2>
            <a asp-action="PaymentSchedule" asp-route-planId="@Model.PlanID" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Back to Schedule
            </a>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }

        @if (paymentPlan != null)
        {
            <div class="card mb-4">
                <div class="card-header" style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);">
                    <h6 class="mb-0 text-white">
                        <i class="fas fa-file-invoice-dollar me-2"></i>@paymentPlan.PlanName
                    </h6>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <small class="text-muted d-block">Plan Total (PKR)</small>
                            <strong>@paymentPlan.TotalAmount.ToString("N0", enUs)</strong>
                        </div>
                        <div class="col-md-4">
                            <small class="text-muted d-block">Current Installment Amount (PKR)</small>
                            <strong>@Model.Amount.ToString("N0", enUs)</strong>
                        </div>
                        <div class="col-md-4">
                            <small class="text-muted d-block">Customers on this Plan</small>
                            <strong>@customersOnPlan</strong>
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="fas fa-calendar-alt me-2"></i>Installment Details</h5>
            </div>
            <div class="card-body">
                <form asp-action="EditPaymentSchedule" method="post" id="editScheduleForm"
                      data-plan-total="@((paymentPlan?.TotalAmount ?? 0m).ToString(CultureInfo.InvariantCulture))"
                      data-others-sum="@othersAmountSum.ToString(CultureInfo.InvariantCulture)"
                      data-customers-on-plan="@customersOnPlan">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="ScheduleID" />
                    <input type="hidden" asp-for="PlanID" />

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="InstallmentNo" class="form-label">Installment Number</label>
                            <input asp-for="InstallmentNo" type="number" class="form-control" required />
                            <span asp-validation-for="InstallmentNo" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="DueDate" class="form-label">Due Date</label>
                            <input asp-for="DueDate" type="date" class="form-control" required />
                            <span asp-validation-for="DueDate" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PaymentDescription" class="form-label">Description</label>
                        <input asp-for="PaymentDescription" class="form-control" required />
                        <span asp-validation-for="PaymentDescription" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Amount" class="form-label">Amount (PKR)</label>
                            <input asp-for="Amount" type="number" step="1" min="0" class="form-control js-installment-amount"
                                   value="@Math.Round(Model.Amount, 0, MidpointRounding.AwayFromZero).ToString(CultureInfo.InvariantCulture)" required />
                            <small class="text-muted">Whole number only for UI display.</small>
                            <span asp-validation-for="Amount" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="SurchargeRate" class="form-label">Surcharge Rate</label>
                            <input asp-for="SurchargeRate" type="number" step="0.00001" min="0" max="100" class="form-control"
                                   value="@Model.SurchargeRate.ToString("0.#####", CultureInfo.InvariantCulture)" />
                        </div>
                    </div>

                    <div class="mb-3 form-check form-switch">
                        <input asp-for="SurchargeApplied" class="form-check-input" />
                        <label asp-for="SurchargeApplied" class="form-check-label">Apply Surcharge</label>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Additional Notes</label>
                        <textarea asp-for="Description" rows="3" class="form-control"></textarea>
                    </div>

                    <div class="plan-total-adjust-panel alert alert-warning py-3 mt-2 d-none">
                        <p class="small mb-2 plan-total-adjust-message"></p>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" name="adjustPlanTotal" value="true" id="adjustPlanTotal" />
                            <label class="form-check-label" for="adjustPlanTotal">
                                Increase payment plan total (PKR) to fit this installment change
                            </label>
                        </div>
                        <div class="mb-2">
                            <label class="form-label small">New plan total (PKR)</label>
                            <input type="number" name="newPlanTotalPkr" step="1" min="0" class="form-control form-control-sm input-new-plan-total" placeholder="Defaults to sum of all installments" />
                        </div>
                        <div class="mb-0">
                            <label class="form-label small">Reason for plan total change <span class="text-danger">*</span></label>
                            <textarea name="changeReason" class="form-control form-control-sm input-change-reason" rows="2" maxlength="2000" placeholder="Required when increasing plan total (audit)"></textarea>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-3">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-2"></i>Save Changes
                        </button>
                        <a asp-action="PaymentSchedule" asp-route-planId="@Model.PlanID" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        (function () {
            var form = document.getElementById('editScheduleForm');
            if (!form) return;

            var amountInput = form.querySelector('.js-installment-amount');
            var panel = form.querySelector('.plan-total-adjust-panel');
            var msg = form.querySelector('.plan-total-adjust-message');
            var newTotalInput = form.querySelector('.input-new-plan-total');
            var chk = form.querySelector('input[name="adjustPlanTotal"]');
            var reasonInput = form.querySelector('.input-change-reason');

            function fmt(n) {
                return (Math.round(Number(n) || 0)).toLocaleString();
            }

            function syncPlanAdjustPanel() {
                var planTotal = parseFloat(form.getAttribute('data-plan-total')) || 0;
                var others = parseFloat(form.getAttribute('data-others-sum')) || 0;
                var amt = parseFloat(amountInput && amountInput.value) || 0;
                var projected = others + amt;
                var customers = parseInt(form.getAttribute('data-customers-on-plan') || '0', 10) || 0;

                if (projected > planTotal + 0.000001) {
                    panel.classList.remove('d-none');
                    msg.textContent = 'Sum of installments would be PKR ' + fmt(projected) + ', above current plan total PKR ' + fmt(planTotal) +
                        '. ' + customers + ' customer(s) are on this plan. Enable increase and provide reason, or reduce amount.';
                    var cur = parseFloat(newTotalInput && newTotalInput.value);
                    if (!newTotalInput || !newTotalInput.value || isNaN(cur) || cur < projected - 0.000001) {
                        if (newTotalInput) newTotalInput.value = Math.round(projected).toString();
                    }
                } else {
                    panel.classList.add('d-none');
                    if (chk) chk.checked = false;
                }
            }

            if (amountInput) {
                amountInput.addEventListener('input', syncPlanAdjustPanel);
                amountInput.addEventListener('change', syncPlanAdjustPanel);
            }

            form.addEventListener('submit', function (e) {
                var planTotal = parseFloat(form.getAttribute('data-plan-total')) || 0;
                var others = parseFloat(form.getAttribute('data-others-sum')) || 0;
                var amt = parseFloat(amountInput && amountInput.value) || 0;
                var projected = others + amt;
                if (projected > planTotal + 0.000001) {
                    if (!chk || !chk.checked) {
                        e.preventDefault();
                        alert('This change exceeds plan total. Enable increase with reason, or reduce amount.');
                        return;
                    }
                    var reason = reasonInput ? reasonInput.value.trim() : '';
                    if (!reason) {
                        e.preventDefault();
                        alert('Reason is required for plan total increase.');
                        return;
                    }
                }
            });

            syncPlanAdjustPanel();
        })();
    </script>
}
