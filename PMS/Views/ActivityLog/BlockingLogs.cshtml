@{
    ViewData["Title"] = "Blocking Logs";
    var list = ViewBag.List as IList<PMS.Models.BlockingLog> ?? new List<PMS.Models.BlockingLog>();
    var customerId = ViewBag.CustomerId as string ?? "";
    var userId = ViewBag.UserId as string ?? "";
    var dateFrom = ViewBag.DateFrom as string ?? "";
    var dateTo = ViewBag.DateTo as string ?? "";
    var newStatus = ViewBag.NewStatus as string ?? "";
    var page = (int)(ViewBag.Page ?? 1);
    var pageSize = (int)(ViewBag.PageSize ?? 25);
    var totalCount = (int)(ViewBag.TotalCount ?? 0);
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
    string PageUrl(int p) => Url.Action("BlockingLogs", "ActivityLog", new { customerId, userId, dateFrom, dateTo, newStatus, page = p, pageSize }) ?? "#";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h3 class="mb-1"><i class="fas fa-ban me-2"></i>Blocking Logs</h3>
        <div class="text-muted">Customer block/unblock history with reason and attachment</div>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-history me-2"></i>Activity Log
        </a>
        <a asp-controller="Home" asp-action="Workspace" class="btn btn-outline-secondary">
            <i class="fas fa-th-large me-2"></i>Workspace
        </a>
    </div>
</div>

<form method="get" asp-action="BlockingLogs" class="card mb-4">
    <div class="card-header bg-light">
        <strong><i class="fas fa-filter me-2"></i>Search filters</strong>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-2">
                <label class="form-label small text-muted">Customer ID</label>
                <input type="text" name="customerId" class="form-control form-control-sm" placeholder="e.g. 1C1500001" value="@customerId" />
            </div>
            <div class="col-md-2">
                <label class="form-label small text-muted">User ID</label>
                <input type="text" name="userId" class="form-control form-control-sm" placeholder="User who did action" value="@userId" />
            </div>
            <div class="col-md-2">
                <label class="form-label small text-muted">Date from</label>
                <input type="date" name="dateFrom" class="form-control form-control-sm" value="@dateFrom" />
            </div>
            <div class="col-md-2">
                <label class="form-label small text-muted">Date to</label>
                <input type="date" name="dateTo" class="form-control form-control-sm" value="@dateTo" />
            </div>
            <div class="col-md-2">
                <label class="form-label small text-muted">New status</label>
                <select name="newStatus" class="form-select form-select-sm">
                    <option value="">All</option>
                    <option value="Active" selected="@(newStatus == "Active")">Active</option>
                    <option value="Blocked" selected="@(newStatus == "Blocked")">Blocked</option>
                    <option value="Inactive" selected="@(newStatus == "Inactive")">Inactive</option>
                </select>
            </div>
            <div class="col-md-2 d-flex align-items-end gap-2">
                <input type="hidden" name="pageSize" value="@pageSize" />
                <button type="submit" class="btn btn-primary btn-sm flex-grow-1">
                    <i class="fas fa-search me-1"></i>Search
                </button>
                <a asp-action="BlockingLogs" class="btn btn-outline-secondary btn-sm">Clear</a>
            </div>
        </div>
    </div>
</form>

<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between">
        <strong>Results</strong>
        <span class="text-muted">@totalCount total · Page @(page) of @(totalPages)</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 100px;">Date</th>
                        <th style="width: 100px;">Customer ID</th>
                        <th>Customer name</th>
                        <th style="width: 90px;">User ID</th>
                        <th style="width: 80px;">Previous</th>
                        <th style="width: 80px;">New status</th>
                        <th>Reason</th>
                        <th style="width: 90px;">Attachment</th>
                    </tr>
                </thead>
                <tbody>
                    @if (list.Count == 0)
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">No blocking logs found.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var row in list)
                        {
                            <tr>
                                <td>@row.ActionDate.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>
                                    <a asp-controller="Customer" asp-action="Details" asp-route-id="@row.CustomerID" class="text-decoration-none">@row.CustomerID</a>
                                </td>
                                <td>@(row.Customer?.FullName ?? "—")</td>
                                <td>@row.UserID</td>
                                <td><span class="badge bg-secondary">@(row.PreviousStatus ?? "—")</span></td>
                                <td>
                                    <span class="badge @(row.NewStatus == "Blocked" ? "bg-danger" : row.NewStatus == "Active" ? "bg-success" : "bg-warning text-dark")">@(row.NewStatus ?? "—")</span>
                                </td>
                                <td class="small text-break">@(row.Reason?.Length > 80 ? row.Reason.Substring(0, 80) + "…" : row.Reason ?? "—")</td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(row.AttachmentPath))
                                    {
                                        <a href="~/@row.AttachmentPath" target="_blank" class="btn btn-sm btn-outline-primary" title="Download"> <i class="fas fa-paperclip"></i> </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
    @if (totalPages > 1)
    {
        <div class="card-footer d-flex align-items-center justify-content-between">
            <div class="text-muted small">
                Showing @((totalCount == 0) ? 0 : ((page - 1) * pageSize + 1))–@Math.Min(page * pageSize, totalCount) of @totalCount
            </div>
            <nav>
                <ul class="pagination mb-0">
                    <li class="page-item @(page <= 1 ? "disabled" : "")">
                        <a class="page-link" href="@(page <= 1 ? "#" : PageUrl(page - 1))">Prev</a>
                    </li>
                    @{
                        var start = Math.Max(1, page - 2);
                        var end = Math.Min(totalPages, page + 2);
                    }
                    @for (var p = start; p <= end; p++)
                    {
                        <li class="page-item @(p == page ? "active" : "")">
                            <a class="page-link" href="@PageUrl(p)">@p</a>
                        </li>
                    }
                    <li class="page-item @(page >= totalPages ? "disabled" : "")">
                        <a class="page-link" href="@(page >= totalPages ? "#" : PageUrl(page + 1))">Next</a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>
