@model PMS.Models.Project

@{
    ViewData["Title"] = "Create Project";
}

<div class="row">
    <div class="col-12">
        <!-- <div class="d-flex justify-content-between align-items-center mb-4">
            <h2><i class="fas fa-plus-circle me-2"></i>Create New Project</h2>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Back to List
            </a>
        </div> -->

        <div class="card">
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="ProjectName" class="form-label">Project Name *</label>
                                <input asp-for="ProjectName" class="form-control" placeholder="Enter project name" required />
                                <span asp-validation-for="ProjectName" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Type" class="form-label">Project Type *</label>
                                <input asp-for="Type" class="form-control" list="projectTypeOptions" placeholder="Select or type project type" required />
                                <datalist id="projectTypeOptions">
                                    @if (ViewBag.ProjectTypes != null)
                                    {
                                        @foreach (var projectType in ViewBag.ProjectTypes)
                                        {
                                            <option value="@projectType"></option>
                                        }
                                    }
                                </datalist>
                                <small class="text-muted">You can select from list or type a custom value.</small>
                                <span asp-validation-for="Type" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Location" class="form-label">Location *</label>
                                <input asp-for="Location" class="form-control" placeholder="Enter project location" required />
                                <span asp-validation-for="Location" class="text-danger"></span>
                            </div>

                            <div class="mb-2">
                                <label class="form-label">Sizes</label>
                                <div class="d-flex gap-2 flex-wrap align-items-center mb-1">
                                    <input type="text" id="sizeInput" class="form-control" placeholder="e.g. 5 Marla" style="max-width: 200px;" />
                                    <button type="button" id="btnAddSize" class="btn btn-outline-primary btn-sm">
                                        <i class="fas fa-plus me-1"></i>Add
                                    </button>
                                    <button type="button" id="btnAddMoreSize" class="btn btn-outline-secondary btn-sm">
                                        <i class="fas fa-plus-circle me-1"></i>Add more
                                    </button>
                                </div>
                                <input type="hidden" asp-for="Sizes" id="sizesValue" />
                                <div id="sizesList" class="mt-1 d-flex flex-wrap gap-1 d-none"></div>
                                <small class="text-muted d-block mt-1">Add sizes one by one; stored as comma-separated in database.</small>
                            </div>

                            <div class="mb-2">
                                <label class="form-label">Sub Projects with Prefixes</label>
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <small class="text-muted">Use popup to add entries. Prefixes must be unique per project.</small>
                                    <button type="button" class="btn btn-outline-primary btn-sm" data-bs-toggle="modal" data-bs-target="#subProjectModalCreate">
                                        <i class="fas fa-plus me-1"></i>Add SubProject
                                    </button>
                                </div>
                                <input type="hidden" asp-for="SubProjects" id="subProjectsValue" />
                                <div class="table-responsive">
                                    <table class="table table-sm table-bordered mb-0" id="subProjectsTable">
                                        <thead class="table-light">
                                            <tr>
                                                <th>SubProject</th>
                                                <th>Prefix</th>
                                                <th style="width:90px;">Action</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr id="subProjectsEmptyRow">
                                                <td colspan="3" class="text-muted text-center">No subprojects added.</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                                <span asp-validation-for="SubProjects" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="Description" class="form-label">Description</label>
                                <textarea asp-for="Description" class="form-control" rows="6" 
                                          placeholder="Enter project description and details"></textarea>
                                <span asp-validation-for="Description" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-12">
                            <hr>
                            <div class="d-flex justify-content-end">
                                <button type="submit" class="btn btn-primary me-2">
                                    <i class="fas fa-save me-2"></i>Create Project
                                </button>
                                <a asp-action="Index" class="btn btn-secondary">
                                    <i class="fas fa-times me-2"></i>Cancel
                                </a>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="subProjectModalCreate" tabindex="-1" aria-hidden="true" data-bs-backdrop="false">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title mb-0">Add SubProject</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-2">
                    <label class="form-label">SubProject</label>
                    <input type="text" id="subProjectNameInput" class="form-control form-control-sm" placeholder="e.g. Phase 1" />
                </div>
                <div class="mb-1">
                    <label class="form-label">Prefix</label>
                    <input type="text" id="subProjectPrefixInput" class="form-control form-control-sm" placeholder="e.g. P1" maxlength="7" />
                </div>
                <small id="subProjectModalError" class="text-danger d-none"></small>
            </div>
            <div class="modal-footer py-2">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary btn-sm" id="btnSaveSubProject">Add</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        (function () {
            function initChipInput(config) {
                var input = document.getElementById(config.inputId);
                var hidden = document.getElementById(config.hiddenId);
                var listWrap = document.getElementById(config.listId);
                var addBtn = document.getElementById(config.addButtonId);
                var addMoreBtn = document.getElementById(config.addMoreButtonId);
                var list = [];

                function updateHidden() {
                    hidden.value = list.join(',');
                }

                function renderList() {
                    listWrap.innerHTML = '';
                    listWrap.classList.toggle('d-none', list.length === 0);
                    list.forEach(function (item, idx) {
                        var span = document.createElement('span');
                        span.className = 'size-chip me-1 mb-1';
                        span.innerHTML = item + ' <button type="button" class="btn-close btn-close-white btn-close-sm" data-idx="' + idx + '" aria-label="Remove"></button>';
                        span.querySelector('button').addEventListener('click', function () {
                            list.splice(parseInt(this.getAttribute('data-idx'), 10), 1);
                            renderList();
                            updateHidden();
                        });
                        listWrap.appendChild(span);
                    });
                }

                function addCurrent() {
                    var val = (input.value || '').trim();
                    if (val && list.indexOf(val) === -1) {
                        list.push(val);
                        renderList();
                        updateHidden();
                    }
                    input.value = '';
                }

                addBtn.addEventListener('click', function () {
                    addCurrent();
                });

                addMoreBtn.addEventListener('click', function () {
                    addCurrent();
                    input.focus();
                });

                input.addEventListener('keydown', function (e) {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        addCurrent();
                        input.focus();
                    }
                });
            }

            initChipInput({
                inputId: 'sizeInput',
                hiddenId: 'sizesValue',
                listId: 'sizesList',
                addButtonId: 'btnAddSize',
                addMoreButtonId: 'btnAddMoreSize'
            });

            (function initSubProjectTable() {
                var hidden = document.getElementById('subProjectsValue');
                var tbody = document.querySelector('#subProjectsTable tbody');
                var emptyRow = document.getElementById('subProjectsEmptyRow');
                var nameInput = document.getElementById('subProjectNameInput');
                var prefixInput = document.getElementById('subProjectPrefixInput');
                var addBtn = document.getElementById('btnSaveSubProject');
                var errorEl = document.getElementById('subProjectModalError');
                var modalEl = document.getElementById('subProjectModalCreate');
                var modal = new bootstrap.Modal(modalEl, { backdrop: false });
                var rows = [];

                function showError(msg) {
                    errorEl.textContent = msg || '';
                    errorEl.classList.toggle('d-none', !msg);
                }

                function syncHidden() {
                    hidden.value = rows.map(function (r) { return r.name + '|' + r.prefix; }).join(',');
                }

                function render() {
                    tbody.querySelectorAll('tr[data-row="1"]').forEach(function (r) { r.remove(); });
                    emptyRow.classList.toggle('d-none', rows.length > 0);
                    rows.forEach(function (r, idx) {
                        var tr = document.createElement('tr');
                        tr.setAttribute('data-row', '1');
                        tr.innerHTML = '<td>' + r.name + '</td><td>' + r.prefix + '</td><td><button type="button" class="btn btn-sm btn-outline-danger" data-idx="' + idx + '">Remove</button></td>';
                        tr.querySelector('button').addEventListener('click', function () {
                            rows.splice(parseInt(this.getAttribute('data-idx'), 10), 1);
                            render();
                            syncHidden();
                        });
                        tbody.appendChild(tr);
                    });
                }

                addBtn.addEventListener('click', function () {
                    var name = (nameInput.value || '').trim();
                    var prefix = (prefixInput.value || '').trim().toUpperCase();
                    if (!name || !prefix) { showError('SubProject and Prefix are required.'); return; }
                    if (prefix.length > 7) { showError('Prefix max length is 7.'); return; }
                    if (rows.some(function (r) { return r.name.toLowerCase() === name.toLowerCase(); })) { showError('SubProject already exists.'); return; }
                    if (rows.some(function (r) { return r.prefix.toLowerCase() === prefix.toLowerCase(); })) { showError('Prefix already exists.'); return; }
                    rows.push({ name: name, prefix: prefix });
                    render();
                    syncHidden();
                    nameInput.value = '';
                    prefixInput.value = '';
                    showError('');
                    modal.hide();
                });

                modalEl.addEventListener('shown.bs.modal', function () { nameInput.focus(); });
            })();
        })();
    </script>
}
