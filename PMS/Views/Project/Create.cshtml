@model PMS.Models.Project

@{
    ViewData["Title"] = "Create Project";
}

<div class="row">
    <div class="col-12">
        <!-- <div class="d-flex justify-content-between align-items-center mb-4">
            <h2><i class="fas fa-plus-circle me-2"></i>Create New Project</h2>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Back to List
            </a>
        </div> -->

        <div class="card">
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="ProjectName" class="form-label">Project Name *</label>
                                <input asp-for="ProjectName" class="form-control" placeholder="Enter project name" required />
                                <span asp-validation-for="ProjectName" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Prefix" class="form-label">Prefix *</label>
                                <input asp-for="Prefix" class="form-control" placeholder="Enter project prefix (e.g., JSC, JSC1)" maxlength="4" required />
                                <small class="text-muted">Project prefix for identification (max 4 characters)</small>
                                <span asp-validation-for="Prefix" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Type" class="form-label">Project Type *</label>
                                <select asp-for="Type" class="form-select" required>
                                    <option value="">Select Project Type</option>
                                    @if (ViewBag.ProjectTypes != null)
                                    {
                                        @foreach (var projectType in ViewBag.ProjectTypes)
                                        {
                                            <option value="@projectType">@projectType</option>
                                        }
                                    }
                                </select>
                                <span asp-validation-for="Type" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Location" class="form-label">Location *</label>
                                <input asp-for="Location" class="form-control" placeholder="Enter project location" required />
                                <span asp-validation-for="Location" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Sizes</label>
                                <div class="d-flex gap-2 flex-wrap align-items-center">
                                    <input type="text" id="sizeInput" class="form-control" placeholder="e.g. 5 Marla" style="max-width: 200px;" />
                                    <button type="button" id="btnAddSize" class="btn btn-outline-primary btn-sm">
                                        <i class="fas fa-plus me-1"></i>Add
                                    </button>
                                    <button type="button" id="btnAddMoreSize" class="btn btn-outline-secondary btn-sm">
                                        <i class="fas fa-plus-circle me-1"></i>Add more
                                    </button>
                                </div>
                                <input type="hidden" asp-for="Sizes" id="sizesValue" />
                                <div id="sizesList" class="mt-2 d-flex flex-wrap gap-1"></div>
                                <small class="text-muted">Add sizes one by one; stored as comma-separated in database.</small>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="Description" class="form-label">Description</label>
                                <textarea asp-for="Description" class="form-control" rows="6" 
                                          placeholder="Enter project description and details"></textarea>
                                <span asp-validation-for="Description" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-12">
                            <hr>
                            <div class="d-flex justify-content-end">
                                <button type="submit" class="btn btn-primary me-2">
                                    <i class="fas fa-save me-2"></i>Create Project
                                </button>
                                <a asp-action="Index" class="btn btn-secondary">
                                    <i class="fas fa-times me-2"></i>Cancel
                                </a>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        (function () {
            var sizeInput = document.getElementById('sizeInput');
            var sizesValue = document.getElementById('sizesValue');
            var sizesList = document.getElementById('sizesList');
            var list = [];

            function updateHidden() {
                sizesValue.value = list.join(',');
            }

            function renderList() {
                sizesList.innerHTML = '';
                list.forEach(function (item, idx) {
                    var span = document.createElement('span');
                    span.className = 'badge bg-primary me-1 mb-1';
                    span.innerHTML = item + ' <button type="button" class="btn-close btn-close-white btn-close-sm" style="font-size: 0.6rem; vertical-align: middle;" data-idx="' + idx + '" aria-label="Remove"></button>';
                    span.querySelector('button').addEventListener('click', function () {
                        list.splice(parseInt(this.getAttribute('data-idx'), 10), 1);
                        renderList();
                        updateHidden();
                    });
                    sizesList.appendChild(span);
                });
            }

            function addCurrent() {
                var val = (sizeInput.value || '').trim();
                if (val && list.indexOf(val) === -1) {
                    list.push(val);
                    renderList();
                    updateHidden();
                }
                sizeInput.value = '';
            }

            document.getElementById('btnAddSize').addEventListener('click', function () {
                addCurrent();
            });
            document.getElementById('btnAddMoreSize').addEventListener('click', function () {
                addCurrent();
                sizeInput.focus();
            });
            sizeInput.addEventListener('keydown', function (e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    addCurrent();
                    sizeInput.focus();
                }
            });
        })();
    </script>
}
