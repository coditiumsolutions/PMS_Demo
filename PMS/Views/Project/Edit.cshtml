@model PMS.Models.Project

@{
    ViewData["Title"] = "Edit Project";
}

<div class="row">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2><i class="fas fa-edit me-2"></i>Edit Project</h2>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Back to List
            </a>
        </div>

        <div class="card">
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="ProjectID" />
                    <input type="hidden" asp-for="CreatedAt" />

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="ProjectName" class="form-label">Project Name *</label>
                                <input asp-for="ProjectName" class="form-control" required />
                                <span asp-validation-for="ProjectName" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Prefix" class="form-label">Prefix *</label>
                                <input asp-for="Prefix" class="form-control" placeholder="Enter project prefix (e.g., JSC, JSC1)" maxlength="4" required />
                                <small class="text-muted">Project prefix for identification (max 4 characters)</small>
                                <span asp-validation-for="Prefix" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Type" class="form-label">Project Type *</label>
                                <select asp-for="Type" class="form-select" required>
                                    <option value="">Select Project Type</option>
                                    @if (ViewBag.ProjectTypes != null)
                                    {
                                        @foreach (var projectType in ViewBag.ProjectTypes)
                                        {
                                            <option value="@projectType">@projectType</option>
                                        }
                                    }
                                </select>
                                <span asp-validation-for="Type" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Location" class="form-label">Location *</label>
                                <input asp-for="Location" class="form-control" required />
                                <span asp-validation-for="Location" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Sizes</label>
                                <div class="d-flex gap-2 flex-wrap align-items-center">
                                    <input type="text" id="sizeInput" class="form-control" placeholder="e.g. 5 Marla" style="max-width: 200px;" />
                                    <button type="button" id="btnAddSize" class="btn btn-outline-primary btn-sm">
                                        <i class="fas fa-plus me-1"></i>Add
                                    </button>
                                    <button type="button" id="btnAddMoreSize" class="btn btn-outline-secondary btn-sm">
                                        <i class="fas fa-plus-circle me-1"></i>Add more
                                    </button>
                                </div>
                                <input type="hidden" asp-for="Sizes" id="sizesValue" />
                                <div id="sizesList" class="mt-2 d-flex flex-wrap gap-1"></div>
                                <small class="text-muted">Add sizes one by one; stored as comma-separated in database.</small>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Sub Projects</label>
                                <div class="d-flex gap-2 flex-wrap align-items-center">
                                    <input type="text" id="subProjectInput" class="form-control" placeholder="e.g. Phase 1" style="max-width: 200px;" />
                                    <button type="button" id="btnAddSubProject" class="btn btn-outline-primary btn-sm">
                                        <i class="fas fa-plus me-1"></i>Add
                                    </button>
                                    <button type="button" id="btnAddMoreSubProject" class="btn btn-outline-secondary btn-sm">
                                        <i class="fas fa-plus-circle me-1"></i>Add more
                                    </button>
                                </div>
                                <input type="hidden" asp-for="SubProjects" id="subProjectsValue" />
                                <div id="subProjectsList" class="mt-2 d-flex flex-wrap gap-1"></div>
                                <small class="text-muted">Add sub projects one by one; stored as comma-separated in database.</small>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="Description" class="form-label">Description</label>
                                <textarea asp-for="Description" class="form-control" rows="6"></textarea>
                                <span asp-validation-for="Description" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-12">
                            <hr>
                            <div class="d-flex justify-content-end">
                                <button type="submit" class="btn btn-primary me-2">
                                    <i class="fas fa-save me-2"></i>Update Project
                                </button>
                                <a asp-action="Index" class="btn btn-secondary">
                                    <i class="fas fa-times me-2"></i>Cancel
                                </a>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        (function () {
            function initChipInput(config) {
                var input = document.getElementById(config.inputId);
                var hidden = document.getElementById(config.hiddenId);
                var listWrap = document.getElementById(config.listId);
                var addBtn = document.getElementById(config.addButtonId);
                var addMoreBtn = document.getElementById(config.addMoreButtonId);
                var list = (hidden.value || '').split(',').map(function (s) { return s.trim(); }).filter(Boolean);

                function updateHidden() {
                    hidden.value = list.join(',');
                }

                function renderList() {
                    listWrap.innerHTML = '';
                    list.forEach(function (item, idx) {
                        var span = document.createElement('span');
                        span.className = 'size-chip me-1 mb-1';
                        span.innerHTML = item + ' <button type="button" class="btn-close btn-close-white btn-close-sm" data-idx="' + idx + '" aria-label="Remove"></button>';
                        span.querySelector('button').addEventListener('click', function () {
                            list.splice(parseInt(this.getAttribute('data-idx'), 10), 1);
                            renderList();
                            updateHidden();
                        });
                        listWrap.appendChild(span);
                    });
                }

                function addCurrent() {
                    var val = (input.value || '').trim();
                    if (val && list.indexOf(val) === -1) {
                        list.push(val);
                        renderList();
                        updateHidden();
                    }
                    input.value = '';
                }

                renderList();

                addBtn.addEventListener('click', function () {
                    addCurrent();
                });
                addMoreBtn.addEventListener('click', function () {
                    addCurrent();
                    input.focus();
                });
                input.addEventListener('keydown', function (e) {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        addCurrent();
                        input.focus();
                    }
                });
            }

            initChipInput({
                inputId: 'sizeInput',
                hiddenId: 'sizesValue',
                listId: 'sizesList',
                addButtonId: 'btnAddSize',
                addMoreButtonId: 'btnAddMoreSize'
            });

            initChipInput({
                inputId: 'subProjectInput',
                hiddenId: 'subProjectsValue',
                listId: 'subProjectsList',
                addButtonId: 'btnAddSubProject',
                addMoreButtonId: 'btnAddMoreSubProject'
            });
        })();
    </script>
}
