@model PMS.Models.Project

@{
    ViewData["Title"] = "Delete Project";
}

<div class="row">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="text-danger"><i class="fas fa-exclamation-triangle me-2"></i>Delete Project</h2>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Back to List
            </a>
        </div>

        <div class="alert alert-warning" role="alert">
            <h4 class="alert-heading">Warning!</h4>
            <p>Are you sure you want to delete this project? This action cannot be undone.</p>
            <hr>
            <p class="mb-0">This will also affect all related properties, payment plans, and other associated data.</p>
        </div>

        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">Project Information</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <dl class="row">
                            <dt class="col-sm-4">Project ID:</dt>
                            <dd class="col-sm-8">
                                <span class="badge bg-secondary">@Model.ProjectID</span>
                            </dd>

                            <dt class="col-sm-4">Project Name:</dt>
                            <dd class="col-sm-8">
                                <strong>@Model.ProjectName</strong>
                            </dd>

                            <dt class="col-sm-4">Type:</dt>
                            <dd class="col-sm-8">
                                <span class="badge bg-info">@Model.Type</span>
                            </dd>

                            <dt class="col-sm-4">Location:</dt>
                            <dd class="col-sm-8">@Model.Location</dd>
                        </dl>
                    </div>
                    <div class="col-md-6">
                        <dl class="row">
                            <dt class="col-sm-4">Created Date:</dt>
                            <dd class="col-sm-8">@Model.CreatedAt.ToString("MMM dd, yyyy")</dd>

                            <dt class="col-sm-4">Total Properties:</dt>
                            <dd class="col-sm-8">
                                <span class="badge bg-success">@(Model.Properties?.Count ?? 0) Properties</span>
                            </dd>

                            <dt class="col-sm-4">Payment Plans:</dt>
                            <dd class="col-sm-8">
                                <span class="badge bg-primary">@(Model.PaymentPlans?.Count ?? 0) Plans</span>
                            </dd>
                        </dl>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <hr>
                    <h6>Description:</h6>
                    <p class="text-muted">@Model.Description</p>
                }
            </div>
        </div>

        <form asp-action="Delete" method="post" class="mt-4">
            <input type="hidden" asp-for="ProjectID" />
            <div class="d-flex justify-content-end">
                <button type="submit" class="btn btn-danger me-2">
                    <i class="fas fa-trash me-2"></i>Yes, Delete Project
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-times me-2"></i>Cancel
                </a>
            </div>
        </form>
    </div>
</div>
