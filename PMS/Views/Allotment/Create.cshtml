@{
    ViewData["Title"] = "Create Allotment";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>
        <i class="fas fa-hand-holding me-2"></i>Create Property Allotment
    </h2>
    <div>
        <a asp-action="Index" class="btn btn-outline-primary me-2">
            <i class="fas fa-list me-2"></i>View All Allotments
        </a>
        <a asp-action="UnAllot" class="btn btn-outline-warning">
            <i class="fas fa-undo me-2"></i>Un-Allot Property
        </a>
    </div>
</div>

@* TempData messages are handled in _Layout.cshtml *@

<!-- Business Rule Alert -->
<div class="alert alert-info mb-4">
    <i class="fas fa-info-circle me-2"></i>
    <strong>Business Rule:</strong> 1 Customer = 1 Property | 1 Property = 1 Customer
    <br>
    <small>If a customer wants another property, create a new customer entry with a new Registration ID and Payment Plan.</small>
</div>

<div class="row">
    <!-- Step 1: Search Customer -->
    <div class="col-12">
        <div class="card mb-4">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">
                    <i class="fas fa-search me-2"></i>Step 1: Search Customer
                </h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Customer ID *</label>
                        <div class="input-group">
                            <input type="text" id="customerIDInput" class="form-control" placeholder="Enter Customer ID (e.g., CUST001)" />
                            <button type="button" id="searchCustomerBtn" class="btn btn-primary">
                                <i class="fas fa-search me-2"></i>Search
                            </button>
                        </div>
                        <small class="text-muted">Enter the Customer ID and click Search to validate</small>
                    </div>
                </div>

                <!-- Customer Info Display (Hidden initially) -->
                <div id="customerInfoSection" class="mt-4" style="display: none;">
                    <div class="alert alert-success">
                        <i class="fas fa-check-circle me-2"></i>Customer found and validated!
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="detail-field mb-2">
                                <label><i class="fas fa-id-badge me-2"></i>Customer ID</label>
                                <p id="displayCustomerID"></p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="detail-field mb-2">
                                <label><i class="fas fa-user me-2"></i>Full Name</label>
                                <p id="displayFullName"></p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="detail-field mb-2">
                                <label><i class="fas fa-phone me-2"></i>Phone</label>
                                <p id="displayPhone"></p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="detail-field mb-2">
                                <label><i class="fas fa-ruler-combined me-2"></i>Registered Size</label>
                                <p id="displaySize"></p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="detail-field mb-2">
                                <label><i class="fas fa-credit-card me-2"></i>Payment Plan</label>
                                <p id="displayPlan"></p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="detail-field mb-2">
                                <label><i class="fas fa-project-diagram me-2"></i>Project</label>
                                <p id="displayProject"></p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Error Display -->
                <div id="customerErrorSection" class="mt-3" style="display: none;">
                    <div class="alert alert-danger">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        <span id="customerErrorMessage"></span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Step 2: Select Property (Hidden until customer is validated) -->
        <div class="card mb-4" id="propertySelectionSection" style="display: none;">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0">
                    <i class="fas fa-building me-2"></i>Step 2: Select Property
                </h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-12">
                        <label class="form-label fw-bold">Available Properties *</label>
                        <select id="propertySelect" class="form-select">
                            <option value="">Select a property...</option>
                        </select>
                        <small class="text-muted">Properties filtered by customer's registered size and project</small>
                    </div>
                </div>

                <!-- Property Details Display -->
                <div id="propertyDetailsSection" class="mt-3" style="display: none;">
                    <div class="row">
                        <div class="col-md-3">
                            <div class="detail-field">
                                <label>Plot No</label>
                                <p id="displayPlotNo"></p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="detail-field">
                                <label>Block</label>
                                <p id="displayBlock"></p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="detail-field">
                                <label>Size</label>
                                <p id="displayPropertySize"></p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="detail-field">
                                <label>Type</label>
                                <p id="displayPropertyType"></p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- No Properties Found -->
                <div id="noPropertiesSection" class="mt-3" style="display: none;">
                    <div class="alert alert-warning">
                        <i class="fas fa-exclamation-circle me-2"></i>
                        <span id="noPropertiesMessage"></span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Step 3: Allotment Details & Submit -->
        <div class="card" id="allotmentFormSection" style="display: none;">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0">
                    <i class="fas fa-file-contract me-2"></i>Step 3: Complete Allotment
                </h5>
            </div>
            <div class="card-body">
                <form asp-action="CreateAllotment" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    
                    <input type="hidden" id="selectedCustomerID" name="customerID" />
                    <input type="hidden" id="selectedPropertyID" name="propertyID" />

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Allotment Type *</label>
                            <select name="allotmentType" class="form-select" required>
                                <option value="Regular">Regular</option>
                                <option value="Transfer">Transfer</option>
                                <option value="Balloting">Balloting</option>
                                <option value="Special">Special</option>
                            </select>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Attachment (Optional)</label>
                            <input type="file" name="attachment" class="form-control" accept=".pdf,.jpg,.jpeg,.png,.doc,.docx" />
                            <small class="text-muted">Supported: PDF, JPG, PNG, DOC, DOCX</small>
                        </div>

                        <div class="col-md-12 mb-3">
                            <label class="form-label fw-bold">Comments</label>
                            <textarea name="comments" class="form-control" rows="3" placeholder="Enter any additional comments or notes..."></textarea>
                        </div>
                    </div>

                    <hr>

                    <div class="d-flex justify-content-end gap-2">
                        <button type="reset" class="btn btn-secondary" onclick="resetForm()">
                            <i class="fas fa-times me-2"></i>Cancel
                        </button>
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="fas fa-hand-holding me-2"></i>Allot Property
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .detail-field {
        padding: 8px 10px;
        background: linear-gradient(135deg, #f8f9fa 0%, #f3f0ff 100%);
        border-radius: 6px;
    }

    .detail-field label {
        display: block;
        margin-bottom: 3px;
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #666;
        font-weight: 600;
    }

    .detail-field p {
        font-size: 14px;
        color: var(--text-dark);
        margin-bottom: 0;
        font-weight: 500;
    }
</style>

@section Scripts {
    <script>
        let selectedCustomerData = null;
        let availableProperties = [];

        // Search Customer
        $('#searchCustomerBtn').click(function() {
            var customerID = $('#customerIDInput').val().trim();
            
            if (!customerID) {
                alert('Please enter a Customer ID');
                return;
            }

            // Show loading
            $(this).html('<i class="fas fa-spinner fa-spin me-2"></i>Searching...').prop('disabled', true);

            $.post('@Url.Action("SearchCustomer", "Allotment")', { customerID: customerID }, function(response) {
                if (response.success) {
                    // Display customer info
                    selectedCustomerData = response.customer;
                    $('#displayCustomerID').text(response.customer.customerID);
                    $('#displayFullName').text(response.customer.fullName);
                    $('#displayPhone').text(response.customer.phone);
                    $('#displaySize').text(response.customer.registeredSize || 'N/A');
                    $('#displayPlan').text(response.customer.planName || 'N/A');
                    $('#displayProject').text(response.customer.projectName || 'N/A');

                    $('#customerInfoSection').show();
                    $('#customerErrorSection').hide();
                    $('#selectedCustomerID').val(response.customer.customerID);

                    // Load available properties
                    loadAvailableProperties(customerID);
                } else {
                    // Show error
                    $('#customerErrorMessage').text(response.message);
                    $('#customerErrorSection').show();
                    $('#customerInfoSection').hide();
                    $('#propertySelectionSection').hide();
                    $('#allotmentFormSection').hide();
                }
            }).always(function() {
                $('#searchCustomerBtn').html('<i class="fas fa-search me-2"></i>Search').prop('disabled', false);
            });
        });

        // Load Available Properties
        function loadAvailableProperties(customerID) {
            $.post('@Url.Action("GetAvailableProperties", "Allotment")', { customerID: customerID }, function(response) {
                if (response.success) {
                    availableProperties = response.properties;
                    
                    // Populate dropdown
                    var $select = $('#propertySelect');
                    $select.empty().append('<option value="">Select a property...</option>');
                    
                    $.each(response.properties, function(i, prop) {
                        $select.append($('<option>', {
                            value: prop.propertyID,
                            text: `${prop.plotNo} - Block ${prop.block} - ${prop.size} - ${prop.propertyType}`,
                            'data-property': JSON.stringify(prop)
                        }));
                    });

                    $('#propertySelectionSection').show();
                    $('#noPropertiesSection').hide();
                } else {
                    $('#noPropertiesMessage').text(response.message);
                    $('#noPropertiesSection').show();
                    $('#propertySelectionSection').hide();
                    $('#allotmentFormSection').hide();
                }
            });
        }

        // Property Selection Change
        $('#propertySelect').change(function() {
            var selectedOption = $(this).find('option:selected');
            var propertyID = $(this).val();

            if (propertyID) {
                var propertyData = JSON.parse(selectedOption.attr('data-property'));
                
                // Display property details
                $('#displayPlotNo').text(propertyData.plotNo);
                $('#displayBlock').text(propertyData.block);
                $('#displayPropertySize').text(propertyData.size);
                $('#displayPropertyType').text(propertyData.propertyType);

                $('#selectedPropertyID').val(propertyID);
                $('#propertyDetailsSection').show();
                $('#allotmentFormSection').show();
            } else {
                $('#propertyDetailsSection').hide();
                $('#allotmentFormSection').hide();
            }
        });

        // Reset Form
        function resetForm() {
            $('#customerIDInput').val('');
            $('#customerInfoSection').hide();
            $('#customerErrorSection').hide();
            $('#propertySelectionSection').hide();
            $('#allotmentFormSection').hide();
            selectedCustomerData = null;
            availableProperties = [];
        }

        // Enter key support for customer search
        $('#customerIDInput').keypress(function(e) {
            if (e.which == 13) {
                e.preventDefault();
                $('#searchCustomerBtn').click();
            }
        });
    </script>
}

