@model IEnumerable<PMS.Models.Allotment>

@{
    ViewData["Title"] = "Un-Allot Property";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>
        <i class="fas fa-undo me-2"></i>Un-Allot Property
    </h2>
    <div>
        <a asp-action="Index" class="btn btn-outline-primary me-2">
            <i class="fas fa-list me-2"></i>View All Allotments
        </a>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Create Allotment
        </a>
    </div>
</div>

@* TempData messages are handled in _Layout.cshtml *@

<!-- Warning Alert -->
<div class="alert alert-warning mb-4">
    <i class="fas fa-exclamation-triangle me-2"></i>
    <strong>Warning:</strong> Un-allotting a property will remove the allotment record and make the property available again. This action cannot be undone.
</div>

<div class="card">
    <div class="card-header" style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);">
        <h5 class="mb-0 text-white">
            <i class="fas fa-list me-2"></i>Current Allotments
        </h5>
    </div>
    <div class="card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Allotment ID</th>
                            <th>Property Details</th>
                            <th>Customer Details</th>
                            <th>Allotment Date</th>
                            <th>Type</th>
                            <th>Status</th>
                            <th>Comments</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var allotment in Model)
                        {
                            <tr>
                                <td>
                                    <code>@allotment.AllotmentID</code>
                                </td>
                                <td>
                                    @if (allotment.Property != null)
                                    {
                                        <strong>@allotment.Property.PlotNo</strong>
                                        <br>
                                        <small class="text-muted">
                                            Block: @allotment.Property.Block | Size: @allotment.Property.Size
                                        </small>
                                        <br>
                                        <small class="text-muted">
                                            <i class="fas fa-building me-1"></i>@allotment.Property.Project?.ProjectName
                                        </small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">N/A</span>
                                    }
                                </td>
                                <td>
                                    @if (allotment.Customer != null)
                                    {
                                        <strong>@allotment.Customer.FullName</strong>
                                        <br>
                                        <small class="text-muted">ID: @allotment.Customer.CustomerID</small>
                                        <br>
                                        <small class="text-muted">
                                            <i class="fas fa-phone me-1"></i>@allotment.Customer.Phone
                                        </small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">N/A</span>
                                    }
                                </td>
                                <td>
                                    <i class="fas fa-calendar me-1"></i>@allotment.AllotmentDate.ToString("MMM dd, yyyy")
                                    <br>
                                    <small class="text-muted">@allotment.AllotmentDate.ToString("hh:mm tt")</small>
                                </td>
                                <td>
                                    <span class="badge bg-info">@allotment.AllottmentType</span>
                                </td>
                                <td>
                                    @if (allotment.WorkFlowStatus == "Approved")
                                    {
                                        <span class="badge bg-success">@allotment.WorkFlowStatus</span>
                                    }
                                    else if (allotment.WorkFlowStatus == "Pending Approval")
                                    {
                                        <span class="badge bg-warning">@allotment.WorkFlowStatus</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@allotment.WorkFlowStatus</span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(allotment.Comments))
                                    {
                                        <div style="max-width: 150px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                            @allotment.Comments
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    <button type="button" 
                                            class="btn btn-sm btn-danger" 
                                            data-bs-toggle="modal" 
                                            data-bs-target="#unallotModal@(allotment.AllotmentID.Replace("ALLOT", ""))"
                                            title="Un-Allot">
                                        <i class="fas fa-undo me-1"></i>Un-Allot
                                    </button>
                                    <a asp-controller="Property" 
                                       asp-action="Details" 
                                       asp-route-id="@allotment.PropertyID" 
                                       class="btn btn-sm btn-outline-info"
                                       title="View Property">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                </td>
                            </tr>

                            <!-- Un-Allot Confirmation Modal -->
                            <div class="modal fade" id="unallotModal@(allotment.AllotmentID.Replace("ALLOT", ""))" tabindex="-1">
                                <div class="modal-dialog">
                                    <div class="modal-content">
                                        <div class="modal-header bg-danger text-white">
                                            <h5 class="modal-title">
                                                <i class="fas fa-exclamation-triangle me-2"></i>Confirm Un-Allotment
                                            </h5>
                                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                        </div>
                                        <div class="modal-body">
                                            <div class="alert alert-warning">
                                                <strong>Warning:</strong> This action cannot be undone!
                                            </div>

                                            <h6>Allotment Details:</h6>
                                            <ul>
                                                <li><strong>Allotment ID:</strong> @allotment.AllotmentID</li>
                                                <li><strong>Property:</strong> @allotment.Property?.PlotNo (Block @allotment.Property?.Block)</li>
                                                <li><strong>Customer:</strong> @allotment.Customer?.FullName (@allotment.Customer?.CustomerID)</li>
                                                <li><strong>Date:</strong> @allotment.AllotmentDate.ToString("MMMM dd, yyyy")</li>
                                            </ul>

                                            <form asp-action="ProcessUnAllot" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="allotmentID" value="@allotment.AllotmentID" />

                                                <div class="mb-3">
                                                    <label class="form-label fw-bold">Reason for Un-Allotment *</label>
                                                    <textarea name="reason" class="form-control" rows="3" required placeholder="Enter the reason for cancelling this allotment..."></textarea>
                                                    <small class="text-muted">This will be recorded in the activity log</small>
                                                </div>

                                                <div class="d-flex justify-content-end gap-2">
                                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                                                        <i class="fas fa-times me-2"></i>Cancel
                                                    </button>
                                                    <button type="submit" class="btn btn-danger">
                                                        <i class="fas fa-undo me-2"></i>Confirm Un-Allot
                                                    </button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-inbox fa-4x mb-3 text-muted"></i>
                <h5 class="text-muted">No Allotments Found</h5>
                <p class="text-muted">There are currently no property allotments in the system.</p>
                <a asp-action="Create" class="btn btn-primary">
                    <i class="fas fa-hand-holding me-2"></i>Create First Allotment
                </a>
            </div>
        }
    </div>
</div>

<style>
    code {
        background: rgba(156, 106, 222, 0.1);
        color: #9C6ADE;
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
    }
</style>

