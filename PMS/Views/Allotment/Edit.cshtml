@model PMS.Models.Allotment
@{
    ViewData["Title"] = "Allotment Workflow – " + (Model.AllotmentID ?? "");
    var pipelineStatuses = ViewBag.PipelineStatuses as List<string> ?? new List<string> { "Initiated", "Operations Desk" };
    var hasPipelinePrevious = ViewBag.HasPipelinePrevious == true;
    var hasPipelineNext = ViewBag.HasPipelineNext == true;
    var atDecisionPoint = ViewBag.AtPipelineDecisionPoint == true;
    var isApproved = ViewBag.IsAllotmentApproved == true;
    var isDeclined = ViewBag.IsAllotmentDeclined == true;
    var workflowWarning = ViewBag.WorkflowStatusWarning as string;

    var initiatedStatus = (string?)ViewBag.InitiatedStatus ?? "Initiated";
    var approvedStatus = (string?)ViewBag.ApprovedStatus ?? "Approved";
    var declinedStatus = (string?)ViewBag.DeclinedStatus ?? "Declined";
    var wf = Model.WorkFlowStatus ?? initiatedStatus;
    var badgeClass = isApproved
        ? "bg-success"
        : isDeclined
            ? "bg-danger"
            : "bg-warning text-dark";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h2 class="mb-0"><i class="fas fa-route me-2"></i>Allotment Workflow <code>@Model.AllotmentID</code></h2>
    <div class="d-flex gap-2">
        <a asp-action="Details" asp-route-id="@Model.AllotmentID" class="btn btn-outline-info btn-sm">
            <i class="fas fa-eye me-1"></i>Details
        </a>
        <a asp-action="Index" class="btn btn-secondary btn-sm"><i class="fas fa-arrow-left me-1"></i>Back</a>
    </div>
</div>

<div class="alert @(isApproved ? "alert-success" : isDeclined ? "alert-danger" : "alert-warning") d-flex align-items-center gap-2 mb-4">
    <i class="fas @(isApproved ? "fa-check-circle" : isDeclined ? "fa-times-circle" : "fa-clock") fa-lg"></i>
    <div>
        <strong>Status: @wf</strong>
        @if (!string.IsNullOrWhiteSpace(Model.ApprovedBy) && isApproved)
        {
            <span class="ms-2 small">by @Model.ApprovedBy</span>
        }
    </div>
    <span class="ms-auto badge @badgeClass fs-6">@wf</span>
</div>

@if (isApproved)
{
    <div class="alert alert-secondary border mb-4">
        <i class="fas fa-lock me-2"></i>
        <strong>Locked.</strong> This allotment is approved. The workflow cannot be edited, moved backward, or declined.
    </div>
}

@if (isDeclined)
{
    <div class="alert alert-secondary border mb-4">
        <i class="fas fa-ban me-2"></i>
        <strong>Declined.</strong> This request is closed. Workflow cannot be changed.
    </div>
}

@if (!string.IsNullOrEmpty(workflowWarning))
{
    <div class="alert alert-warning mb-4">@workflowWarning</div>
}

<div class="card mb-4">
    <div class="card-header fw-semibold"><i class="fas fa-route me-2"></i>Workflow</div>
    <div class="card-body">
        <p class="text-muted small mb-3">
            Progress moves along the steps below. <strong>@approvedStatus</strong> and <strong>@declinedStatus</strong> are <em>alternatives</em> (only one applies), not step 3 then step 4.
        </p>

        <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
            @for (var i = 0; i < pipelineStatuses.Count; i++)
            {
                var step = pipelineStatuses[i];
                var isCurrent = !isApproved && !isDeclined && string.Equals(step, wf, StringComparison.OrdinalIgnoreCase);
                <span class="badge @(isCurrent ? "bg-primary" : "bg-secondary")">@(i + 1). @step</span>
                @if (i < pipelineStatuses.Count - 1)
                {
                    <i class="fas fa-arrow-right text-muted"></i>
                }
            }
            <span class="text-muted mx-1">then</span>
            <span class="badge bg-light border border-success text-success"><i class="fas fa-code-branch me-1"></i>@approvedStatus</span>
            <span class="text-muted">or</span>
            <span class="badge border border-danger text-danger"><i class="fas fa-code-branch me-1"></i>@declinedStatus</span>
        </div>

        @if (!isApproved && !isDeclined)
        {
            <div class="d-flex flex-wrap gap-2 align-items-center">
                <form asp-action="MoveStatus" asp-route-id="@Model.AllotmentID" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="direction" value="backward" />
                    <button type="submit" class="btn btn-outline-secondary" @(hasPipelinePrevious ? null : "disabled")>
                        <i class="fas fa-arrow-left me-1"></i>Move back
                    </button>
                </form>
                <form asp-action="MoveStatus" asp-route-id="@Model.AllotmentID" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="direction" value="forward" />
                    <button type="submit" class="btn btn-outline-primary" @(hasPipelineNext ? null : "disabled")>
                        <i class="fas fa-arrow-right me-1"></i>Move forward
                    </button>
                </form>
            </div>

            @if (atDecisionPoint)
            {
                <hr class="my-4" />
                <p class="fw-semibold mb-2">Final decision (choose one):</p>
                <div class="d-flex flex-wrap gap-2">
                    <form asp-action="SetAllotmentOutcome" asp-route-id="@Model.AllotmentID" method="post" class="d-inline" onsubmit="return confirm('Approve this allotment? The customer will be allotted the property and this record will be locked.');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="outcome" value="approve" />
                        <button type="submit" class="btn btn-success">
                            <i class="fas fa-check me-1"></i>@approvedStatus
                        </button>
                    </form>
                    <form asp-action="SetAllotmentOutcome" asp-route-id="@Model.AllotmentID" method="post" class="d-inline" onsubmit="return confirm('Decline this allotment? The property will be released back to available.');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="outcome" value="decline" />
                        <button type="submit" class="btn btn-outline-danger">
                            <i class="fas fa-times me-1"></i>@declinedStatus
                        </button>
                    </form>
                </div>
            }
        }

        <div class="small text-muted mt-3">
            Property stays <strong>reserved</strong> during the pipeline and becomes <strong>allotted</strong> only after <strong>@approvedStatus</strong>.
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header fw-semibold"><i class="fas fa-info-circle me-2"></i>Allotment Summary</div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-4">
                <div class="small text-muted">Customer</div>
                <div><code>@Model.CustomerID</code></div>
            </div>
            <div class="col-md-4">
                <div class="small text-muted">Property</div>
                <div><code>@Model.PropertyID</code></div>
            </div>
            <div class="col-md-4">
                <div class="small text-muted">Allotment Date</div>
                <div>@Model.AllotmentDate.ToString("MMM dd, yyyy HH:mm")</div>
            </div>
        </div>
    </div>
</div>
