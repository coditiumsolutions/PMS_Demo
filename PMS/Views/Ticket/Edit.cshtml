@model PMS.Models.Ticket
@{
    ViewData["Title"] = "Edit Ticket";
    var users = ViewBag.Users as IEnumerable<string> ?? Enumerable.Empty<string>();
    var statuses = ViewBag.Statuses as IEnumerable<string> ?? new[] { "Pending", "Assigned", "Ongoing", "Resolved", "Discarded", "Duplicate" };
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="fas fa-edit me-2"></i>Edit Ticket <code>#@Model.TicketID</code></h2>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-2"></i>Back to Tickets</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header" style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);">
        <h5 class="mb-0 text-white"><i class="fas fa-ticket-alt me-2"></i>Ticket Details</h5>
    </div>
    <div class="card-body">
        <form asp-action="Edit" asp-route-id="@Model.TicketID" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="TicketID" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="CustomerID" class="form-label">Customer ID</label>
                    <input asp-for="CustomerID" class="form-control" placeholder="Optional" />
                    <span asp-validation-for="CustomerID" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" type="email" class="form-control" placeholder="Customer email" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Contact" class="form-label">Contact (Phone)</label>
                    <input asp-for="Contact" class="form-control" placeholder="Phone number" />
                    <span asp-validation-for="Contact" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="AssignedTo" class="form-label">Assign To</label>
                    <select asp-for="AssignedTo" class="form-select">
                        <option value="">-- Unassigned --</option>
                        @foreach (var user in users)
                        {
                            <option value="@user" selected="@(string.Equals(Model.AssignedTo, user, StringComparison.OrdinalIgnoreCase))">@user</option>
                        }
                    </select>
                    <span asp-validation-for="AssignedTo" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Status" class="form-label">Status</label>
                    <select asp-for="Status" class="form-select">
                        @foreach (var status in statuses)
                        {
                            <option value="@status" selected="@(string.Equals(Model.Status, status, StringComparison.OrdinalIgnoreCase))">@status</option>
                        }
                    </select>
                    <span asp-validation-for="Status" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Created At</label>
                    <input type="text" class="form-control" value="@Model.CreatedAt.ToString("MMM dd, yyyy hh:mm tt")" readonly />
                </div>
                <div class="col-12">
                    <label asp-for="Title" class="form-label">Title <span class="text-danger">*</span></label>
                    <input asp-for="Title" class="form-control" required />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Description" class="form-label">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="CROComments" class="form-label">CRO Comments</label>
                    <textarea asp-for="CROComments" class="form-control" rows="4" placeholder="Internal notes"></textarea>
                    <span asp-validation-for="CROComments" class="text-danger small"></span>
                </div>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn btn-primary"><i class="fas fa-save me-2"></i>Save Changes</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
