@model PMS.Models.Waiver
@{
    ViewData["Title"] = "Edit Waiver";
    var workflowStatuses = ViewBag.WorkflowStatuses as List<string> ?? new List<string>();
    var currentWorkflowIndex = ViewBag.CurrentWorkflowIndex != null ? (int)ViewBag.CurrentWorkflowIndex : -1;
    var hasPreviousStep = ViewBag.HasPreviousStep == true;
    var hasNextStep = ViewBag.HasNextStep == true;
    var previousStepLabel = ViewBag.PreviousStepLabel as string;
    var nextStepLabel = ViewBag.NextStepLabel as string;
    var approvedStatus = (string?)ViewBag.ApprovedStatus ?? "Approved";
    var declinedStatus = (string?)ViewBag.DeclinedStatus ?? "Declined";
    var canApproveDecline = ViewBag.CanApproveDecline == true;

    var approvedIndex = workflowStatuses.FindIndex(s => string.Equals(s, approvedStatus, StringComparison.OrdinalIgnoreCase));
    var declinedIndex = workflowStatuses.FindIndex(s => string.Equals(s, declinedStatus, StringComparison.OrdinalIgnoreCase));

    var canMoveToApproved = canApproveDecline && currentWorkflowIndex >= 0 && approvedIndex > currentWorkflowIndex;
    var canMoveToDeclined = canApproveDecline && currentWorkflowIndex >= 0 && declinedIndex > currentWorkflowIndex;
    var isDecisionClosed = string.Equals(Model.Status, approvedStatus, StringComparison.OrdinalIgnoreCase)
        || string.Equals(Model.Status, declinedStatus, StringComparison.OrdinalIgnoreCase);

    var nextStepIsApprovedOrDeclined =
        string.Equals(nextStepLabel, approvedStatus, StringComparison.OrdinalIgnoreCase)
        || string.Equals(nextStepLabel, declinedStatus, StringComparison.OrdinalIgnoreCase);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="fas fa-edit me-2"></i>Edit Waiver <code>@Model.WaiverID</code></h2>
    <a asp-action="Details" asp-route-id="@Model.WaiverID" class="btn btn-secondary btn-sm"><i class="fas fa-arrow-left me-1"></i>Back</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card mb-4">
    <div class="card-header fw-semibold"><i class="fas fa-route me-2"></i>Workflow Status</div>
    <div class="card-body workflow-redesign">
        <div class="workflow-track mb-3">
            <div class="small text-muted mb-2">Current workflow path</div>
            <div class="workflow-steps">
                @for (var i = 0; i < workflowStatuses.Count; i++)
                {
                    var step = workflowStatuses[i];
                    var isCurrent = i == currentWorkflowIndex;
                    var statusClass = isCurrent ? "current" : (i < currentWorkflowIndex ? "done" : "pending");
                    <div class="workflow-step @statusClass">
                        <span class="step-index">@(i + 1)</span>
                        <span class="step-label">@step</span>
                    </div>
                }
            </div>
        </div>

        <div class="workflow-actions-panel mb-3">
            <div class="small text-muted mb-2">General workflow actions</div>
            <div class="d-flex flex-wrap gap-2">
                <form asp-action="MoveStatus" asp-route-id="@Model.WaiverID" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="direction" value="backward" />
                    <button type="submit" class="btn btn-outline-secondary" @(hasPreviousStep ? null : "disabled")>
                        <i class="fas fa-arrow-left me-1"></i>Move Back @(string.IsNullOrWhiteSpace(previousStepLabel) ? "" : $"to {previousStepLabel}")
                    </button>
                </form>
                @if (!canApproveDecline || isDecisionClosed)
                {
                    <form asp-action="MoveStatus" asp-route-id="@Model.WaiverID" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="direction" value="forward" />
                        <button type="submit" class="btn btn-primary" @(hasNextStep && !nextStepIsApprovedOrDeclined ? null : "disabled")>
                            <i class="fas fa-arrow-right me-1"></i>Move Forward @(string.IsNullOrWhiteSpace(nextStepLabel) ? "" : $"to {nextStepLabel}")
                        </button>
                    </form>
                }
            </div>
        </div>

        @if (canApproveDecline && !isDecisionClosed)
        {
            <div class="workflow-decision-panel">
                <div class="small text-muted mb-2">Decision actions (Admin/Manager only)</div>
                <div class="decision-grid">
                    @if (approvedIndex >= 0)
                    {
                        <div class="decision-card decision-card-approve">
                            <form asp-action="MoveStatus" asp-route-id="@Model.WaiverID" method="post" class="d-grid gap-2">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="targetStatus" value="@approvedStatus" />
                                <label class="form-label form-label-sm fw-semibold mb-0">Approve comment</label>
                                <textarea name="moveComments" class="form-control" rows="4" maxlength="2000" required placeholder="Reason for approval..."></textarea>
                                <button type="submit" class="btn btn-success w-100">
                                    <i class="fas fa-check me-1"></i>Move to Approved
                                </button>
                            </form>
                        </div>
                    }

                    @if (declinedIndex >= 0)
                    {
                        <div class="decision-card decision-card-decline">
                            <form asp-action="MoveStatus" asp-route-id="@Model.WaiverID" method="post" class="d-grid gap-2">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="targetStatus" value="@declinedStatus" />
                                <label class="form-label form-label-sm fw-semibold mb-0">Decline comment</label>
                                <textarea name="moveComments" class="form-control" rows="4" maxlength="2000" required placeholder="Reason for decline..."></textarea>
                                <button type="submit" class="btn btn-danger w-100">
                                    <i class="fas fa-times me-1"></i>Move to Declined
                                </button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

<form asp-action="Edit" asp-route-id="@Model.WaiverID" method="post">
    @Html.AntiForgeryToken()
    <div class="card mb-4">
        <div class="card-header fw-semibold">Waiver Details</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Waiver Type</label>
                    <input value="@Model.WaiverType" class="form-control" readonly />
                </div>
                <div class="col-md-4">
                    <label asp-for="AccountHead" class="form-label fw-semibold">Account Head</label>
                    <input asp-for="AccountHead" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Total Surcharge (PKR)</label>
                    <input value="@Model.TotalAmount.ToString("N2")" class="form-control" readonly />
                </div>
                <div class="col-md-4">
                    <label asp-for="WaivedPercentage" class="form-label fw-semibold">Waived Percentage (%)</label>
                    <input asp-for="WaivedPercentage" class="form-control" type="number" min="0" max="100" step="0.01" />
                    <span asp-validation-for="WaivedPercentage" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="WaivedAmount" class="form-label fw-semibold">Waived Amount (PKR)</label>
                    <input asp-for="WaivedAmount" class="form-control" type="number" min="0" step="0.01" />
                    <span asp-validation-for="WaivedAmount" class="text-danger small"></span>
                </div>
                <div class="col-md-12">
                    <label asp-for="Comments" class="form-label fw-semibold">Comments</label>
                    <textarea asp-for="Comments" class="form-control" rows="3" maxlength="2000"></textarea>
                    <span asp-validation-for="Comments" class="text-danger small"></span>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header fw-semibold"><i class="fas fa-paperclip me-2"></i>Attachments</div>
        <div class="card-body">
            <p class="text-muted small mb-3">Accepted: JPG, PNG, GIF, BMP, PDF. Max 8MB per file. Multiple files allowed.</p>
            <div class="row g-3 align-items-end">
                <div class="col-md-5">
                    <label class="form-label">File</label>
                    <input type="file" id="waiverAttachmentFile" class="form-control" />
                </div>
                <div class="col-md-5">
                    <label class="form-label">Description</label>
                    <input type="text" id="waiverAttachmentDescription" class="form-control" placeholder="Description (optional)" />
                </div>
                <div class="col-md-2">
                    <button type="button" id="uploadWaiverAttachmentBtn" class="btn btn-primary w-100">
                        <i class="fas fa-upload me-1"></i>Upload
                    </button>
                </div>
            </div>
            <hr />
            <div id="waiverAttachmentsList" class="small text-muted">Loading attachments...</div>
        </div>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary"><i class="fas fa-save me-2"></i>Save Changes</button>
        <a asp-action="Details" asp-route-id="@Model.WaiverID" class="btn btn-secondary">Cancel</a>
    </div>
</form>

<style>
    .workflow-redesign .workflow-steps {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .workflow-redesign .workflow-step {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        border-radius: 999px;
        border: 1px solid #dfe3e8;
        background: #f8f9fb;
        max-width: 100%;
    }

    .workflow-redesign .workflow-step .step-index {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 22px;
        height: 22px;
        border-radius: 50%;
        font-size: 12px;
        font-weight: 700;
        background: #e9ecef;
        color: #495057;
    }

    .workflow-redesign .workflow-step .step-label {
        font-size: 13px;
        font-weight: 600;
    }

    .workflow-redesign .workflow-step.current {
        border-color: #9c6ade;
        background: #f4ecff;
    }

    .workflow-redesign .workflow-step.current .step-index {
        background: #9c6ade;
        color: #fff;
    }

    .workflow-redesign .workflow-step.done {
        border-color: #2da44e;
        background: #eefaf1;
    }

    .workflow-redesign .workflow-step.done .step-index {
        background: #2da44e;
        color: #fff;
    }

    .workflow-redesign .workflow-actions-panel,
    .workflow-redesign .workflow-decision-panel {
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 12px;
        background: #fff;
        overflow: hidden;
    }

    .workflow-redesign .decision-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 12px;
    }

    .workflow-redesign .decision-card {
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        padding: 12px;
        background: #fff;
        min-width: 0;
    }

    .workflow-redesign .decision-card-approve {
        border-left: 4px solid #198754;
    }

    .workflow-redesign .decision-card-decline {
        border-left: 4px solid #dc3545;
    }
</style>

@section Scripts {
<script>
    (function () {
        const waiverId = '@Model.WaiverID';

        function loadAttachments() {
            $.get('@Url.Action("GetAttachments")', { waiverId: waiverId }, function (res) {
                if (!res || !res.success) {
                    $('#waiverAttachmentsList').html('<div class="text-danger">Unable to load attachments.</div>');
                    return;
                }

                if (!res.attachments || res.attachments.length === 0) {
                    $('#waiverAttachmentsList').html('<div class="text-muted">No attachments uploaded.</div>');
                    return;
                }

                const html = res.attachments.map(function (a) {
                    const fileSizeKb = a.fileSize ? (a.fileSize / 1024).toFixed(1) : '0';
                    return `<div class="d-flex justify-content-between align-items-center border rounded p-2 mb-2">
                        <div>
                            <a href="${a.filePath}" target="_blank">${a.fileName}</a>
                            <div class="text-muted">${a.description || '-'} | ${fileSizeKb} KB | ${a.uploadedAt}</div>
                        </div>
                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteWaiverAttachment('${a.attachmentID}')">
                            <i class="fas fa-trash"></i>
                        </button>
                    </div>`;
                }).join('');
                $('#waiverAttachmentsList').html(html);
            }).fail(function () {
                $('#waiverAttachmentsList').html('<div class="text-danger">Unable to load attachments.</div>');
            });
        }

        $('#uploadWaiverAttachmentBtn').on('click', function () {
            const files = $('#waiverAttachmentFile')[0].files;
            if (!files || files.length === 0) {
                alert('Please choose a file.');
                return;
            }

            const formData = new FormData();
            formData.append('waiverId', waiverId);
            formData.append('file', files[0]);
            formData.append('description', $('#waiverAttachmentDescription').val() || '');

            $.ajax({
                url: '@Url.Action("UploadAttachment")',
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false
            }).done(function (res) {
                if (!res || !res.success) {
                    alert(res && res.message ? res.message : 'Upload failed.');
                    return;
                }
                $('#waiverAttachmentFile').val('');
                $('#waiverAttachmentDescription').val('');
                loadAttachments();
            }).fail(function () {
                alert('Upload failed.');
            });
        });

        window.deleteWaiverAttachment = function (attachmentId) {
            if (!confirm('Delete this attachment?')) return;
            $.post('@Url.Action("DeleteAttachment")', { attachmentId: attachmentId }, function (res) {
                if (!res || !res.success) {
                    alert(res && res.message ? res.message : 'Delete failed.');
                    return;
                }
                loadAttachments();
            }).fail(function () {
                alert('Delete failed.');
            });
        };

        loadAttachments();
    })();
</script>
}
