@model PMS.Models.Waiver
@{
    ViewData["Title"] = "New Waiver";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="fas fa-hand-holding-usd me-2"></i>New Waiver</h2>
    <a asp-action="Index" class="btn btn-secondary btn-sm"><i class="fas fa-arrow-left me-1"></i>Back</a>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card mb-4">
    <div class="card-header bg-primary text-white fw-semibold"><i class="fas fa-search me-2"></i>Customer Search</div>
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label fw-semibold">Customer ID <span class="text-danger">*</span></label>
                <div class="input-group">
                    <input type="text" id="customerIdInput" class="form-control" placeholder="Enter Customer ID" value="@((string?)ViewBag.PreSelectedCustomerId ?? "")" />
                    <button type="button" class="btn btn-primary" id="searchCustomerBtn">
                        <i class="fas fa-search"></i> Search
                    </button>
                </div>
            </div>
        </div>
        <div id="customerInfoPanel" class="mt-3" style="display:none;">
            <div class="row g-2">
                <div class="col-md-3"><span class="fw-semibold">Name:</span> <span id="custName"></span></div>
                <div class="col-md-3"><span class="fw-semibold">CNIC:</span> <span id="custCnic"></span></div>
                <div class="col-md-3"><span class="fw-semibold">Phone:</span> <span id="custPhone"></span></div>
                <div class="col-md-3"><span class="fw-semibold">Project/Plan:</span> <span id="custProjectPlan"></span></div>
            </div>
        </div>
        <div id="customerSearchError" class="text-danger mt-2" style="display:none;"></div>
    </div>
</div>

<div id="installmentsSection" class="card mb-4" style="display:none;">
    <div class="card-header fw-semibold"><i class="fas fa-list me-2"></i>Installments & Surcharge</div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Inst #</th>
                        <th>Due Date</th>
                        <th class="text-end">Amount</th>
                        <th class="text-end">Paid</th>
                        <th class="text-end">Outstanding</th>
                        <th class="text-end">Surcharge</th>
                    </tr>
                </thead>
                <tbody id="linesBody"></tbody>
            </table>
        </div>
    </div>
</div>

<form asp-action="Create" method="post" id="waiverForm">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="CustomerID" id="hiddenCustomerId" />

    <div class="card mb-4">
        <div class="card-header fw-semibold"><i class="fas fa-file-invoice me-2"></i>Waiver Details</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="WaiverType" class="form-label fw-semibold">Waiver Type</label>
                    <input asp-for="WaiverType" class="form-control" value="Surcharge Waiver" readonly />
                </div>
                <div class="col-md-4">
                    <label asp-for="AccountHead" class="form-label fw-semibold">Account Head</label>
                    <input asp-for="AccountHead" class="form-control" value="Surcharge Waived Off" readonly />
                </div>
                <div class="col-md-4">
                    <label asp-for="TotalAmount" class="form-label fw-semibold">Total Surcharge (PKR)</label>
                    <input asp-for="TotalAmount" id="totalSurchargeInput" class="form-control" readonly />
                </div>
                <div class="col-md-4">
                    <label asp-for="WaivedPercentage" class="form-label fw-semibold">Waived Percentage (%)</label>
                    <input asp-for="WaivedPercentage" id="waivedPercentageInput" type="number" class="form-control" min="0" max="100" step="0.01" />
                </div>
                <div class="col-md-4">
                    <label asp-for="WaivedAmount" class="form-label fw-semibold">Waived Amount (PKR) <span class="text-danger">*</span></label>
                    <input asp-for="WaivedAmount" id="waivedAmountInput" type="number" class="form-control" min="0" step="0.01" />
                    <span asp-validation-for="WaivedAmount" class="text-danger small"></span>
                </div>
                <div class="col-md-12">
                    <label asp-for="Comments" class="form-label fw-semibold">Comments <span class="text-danger">*</span></label>
                    <textarea asp-for="Comments" class="form-control" rows="3" maxlength="2000" placeholder="Enter comments"></textarea>
                    <span asp-validation-for="Comments" class="text-danger small"></span>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-success" id="submitBtn">
            <i class="fas fa-save me-2"></i>Submit Waiver
        </button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
<script>
(function () {
    let totalSurcharge = 0;

    function setError(msg) {
        if (!msg) {
            $('#customerSearchError').hide().text('');
            return;
        }
        $('#customerSearchError').text(msg).show();
    }

    function renderLines(lines) {
        const body = $('#linesBody').empty();
        if (!lines || lines.length === 0) {
            body.append('<tr><td colspan="6" class="text-center text-muted py-3">No installment records found.</td></tr>');
            return;
        }
        lines.forEach(function (line) {
            body.append(`<tr>
                <td>${line.installmentNo ?? '-'}</td>
                <td>${line.dueDate}</td>
                <td class="text-end">${Number(line.amount || 0).toLocaleString()}</td>
                <td class="text-end">${Number(line.paid || 0).toLocaleString()}</td>
                <td class="text-end">${Number(line.outstanding || 0).toLocaleString()}</td>
                <td class="text-end">${Number(line.surcharge || 0).toLocaleString()}</td>
            </tr>`);
        });
    }

    function recalculateFromPercentage() {
        const pct = parseFloat($('#waivedPercentageInput').val()) || 0;
        if (pct < 0 || pct > 100) return;
        const amount = totalSurcharge * (pct / 100);
        $('#waivedAmountInput').val(amount.toFixed(2));
    }

    function recalculateFromAmount() {
        const amount = parseFloat($('#waivedAmountInput').val()) || 0;
        if (totalSurcharge <= 0) {
            $('#waivedPercentageInput').val('');
            return;
        }
        const pct = (amount / totalSurcharge) * 100;
        $('#waivedPercentageInput').val(pct.toFixed(2));
    }

    function searchCustomer() {
        const customerId = ($('#customerIdInput').val() || '').trim();
        if (!customerId) {
            setError('Enter a Customer ID.');
            return;
        }
        setError('');
        $.post('@Url.Action("SearchCustomerForWaiver")', { customerId: customerId }, function (res) {
            if (!res.success) {
                $('#customerInfoPanel').hide();
                $('#installmentsSection').hide();
                $('#hiddenCustomerId').val('');
                setError(res.message || 'Unable to fetch customer.');
                return;
            }

            $('#custName').text(res.fullName || '—');
            $('#custCnic').text(res.cnic || '—');
            $('#custPhone').text(res.phone || '—');
            $('#custProjectPlan').text((res.project || '—') + ' / ' + (res.plan || '—'));
            $('#customerInfoPanel').show();
            $('#hiddenCustomerId').val(res.customerID || '');
            $('#searchCustomerBtn').addClass('d-none');

            renderLines(res.lines || []);
            $('#installmentsSection').show();

            totalSurcharge = Number(res.totalSurcharge || 0);
            $('#totalSurchargeInput').val(totalSurcharge.toFixed(2));
            $('#waivedAmountInput').val(totalSurcharge.toFixed(2));
            $('#waivedPercentageInput').val(totalSurcharge > 0 ? '100.00' : '');
        }).fail(function () {
            setError('Error searching customer. Try again.');
        });
    }

    $('#searchCustomerBtn').on('click', searchCustomer);
    $('#customerIdInput').on('keypress', function (e) {
        if (e.key === 'Enter') {
            e.preventDefault();
            searchCustomer();
        }
    });
    $('#waivedPercentageInput').on('input', recalculateFromPercentage);
    $('#waivedAmountInput').on('input', recalculateFromAmount);

    const preSelectedCustomerId = ('@((string?)ViewBag.PreSelectedCustomerId ?? "")' || '').trim();
    if (preSelectedCustomerId) {
        searchCustomer();
    }
})();
</script>
}
