@model PMS.Models.Waiver
@{
    ViewData["Title"] = "Waiver Details";
    var approvedStatus = (string?)ViewBag.ApprovedStatus ?? "Approved";
    var isApproved = string.Equals(Model.Status, approvedStatus, StringComparison.OrdinalIgnoreCase);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="fas fa-eye me-2"></i>Waiver Details <code>@Model.WaiverID</code></h2>
    <a asp-action="Index" class="btn btn-secondary btn-sm"><i class="fas fa-arrow-left me-1"></i>Back</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card mb-4">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-3"><strong>Customer ID:</strong><br /><code>@Model.CustomerID</code></div>
            <div class="col-md-3"><strong>Customer Name:</strong><br />@(Model.Customer?.FullName ?? "—")</div>
            <div class="col-md-3"><strong>Status:</strong><br /><span class="badge bg-secondary">@Model.Status</span></div>
            <div class="col-md-3"><strong>Created:</strong><br />@Model.CreatedAt.ToString("MMM dd, yyyy hh:mm tt")</div>
            <div class="col-md-3"><strong>Waiver Type:</strong><br />@(Model.WaiverType ?? "—")</div>
            <div class="col-md-3"><strong>Account Head:</strong><br />@(Model.AccountHead ?? "—")</div>
            <div class="col-md-3"><strong>Total Surcharge:</strong><br />PKR @Model.TotalAmount.ToString("N0")</div>
            <div class="col-md-3"><strong>Waived Amount:</strong><br />PKR @Model.WaivedAmount.ToString("N0")</div>
            <div class="col-md-3"><strong>Waived Percentage:</strong><br />@(Model.WaivedPercentage?.ToString("N2") ?? "—")%</div>
            <div class="col-md-9"><strong>Comments:</strong><br />@(string.IsNullOrWhiteSpace(Model.Comments) ? "-" : Model.Comments)</div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header fw-semibold"><i class="fas fa-paperclip me-2"></i>Attachments</div>
    <div class="card-body">
        <div id="waiverAttachmentsList" class="small text-muted">Loading attachments...</div>
    </div>
</div>

<div class="d-flex gap-2">
    @if (ViewBag.CanEdit == true && !isApproved)
    {
        <a asp-action="Edit" asp-route-id="@Model.WaiverID" class="btn btn-primary">
            <i class="fas fa-edit me-2"></i>Edit
        </a>
    }
    @if (ViewBag.CanDelete == true)
    {
        <form asp-action="Delete" asp-route-id="@Model.WaiverID" method="post" onsubmit="return confirm('Delete this waiver?');">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger">
                <i class="fas fa-trash me-2"></i>Delete
            </button>
        </form>
    }
</div>

@section Scripts {
<script>
    (function () {
        $.get('@Url.Action("GetAttachments")', { waiverId: '@Model.WaiverID' }, function (res) {
            if (!res || !res.success) {
                $('#waiverAttachmentsList').html('<div class="text-danger">Unable to load attachments.</div>');
                return;
            }
            if (!res.attachments || res.attachments.length === 0) {
                $('#waiverAttachmentsList').html('<div class="text-muted">No attachments uploaded.</div>');
                return;
            }

            const html = res.attachments.map(function (a) {
                const fileSizeKb = a.fileSize ? (a.fileSize / 1024).toFixed(1) : '0';
                return `<div class="border rounded p-2 mb-2">
                    <a href="${a.filePath}" target="_blank">${a.fileName}</a>
                    <div class="text-muted">${a.description || '-'} | ${fileSizeKb} KB | ${a.uploadedAt}</div>
                </div>`;
            }).join('');
            $('#waiverAttachmentsList').html(html);
        }).fail(function () {
            $('#waiverAttachmentsList').html('<div class="text-danger">Unable to load attachments.</div>');
        });
    })();
</script>
}
