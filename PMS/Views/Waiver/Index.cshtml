@model IEnumerable<PMS.Models.Waiver>
@{
    ViewData["Title"] = "Waivers";
    var initiatedStatus = (string?)ViewBag.InitiatedStatus ?? "Initiated";
    var approvedStatus = (string?)ViewBag.ApprovedStatus ?? "Approved";
    var declinedStatus = (string?)ViewBag.DeclinedStatus ?? "Declined";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h2 class="mb-0"><i class="fas fa-hand-holding-usd me-2"></i>Waivers</h2>
    @if (ViewBag.CanCreate == true)
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>New Waiver
        </a>
    }
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-3 mb-4">
    <div class="col-6 col-md-4">
        <a href="@Url.Action("Index", new { statusFilter = initiatedStatus })" class="text-decoration-none">
            <div class="card border-0 h-100" style="background:#fff3cd;">
                <div class="card-body text-center py-3">
                    <div class="small text-muted text-uppercase fw-semibold">@initiatedStatus</div>
                    <div class="fs-3 fw-bold text-warning">@(ViewBag.InitiatedCount ?? 0)</div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-6 col-md-4">
        <a href="@Url.Action("Index", new { statusFilter = approvedStatus })" class="text-decoration-none">
            <div class="card border-0 h-100" style="background:#d4edda;">
                <div class="card-body text-center py-3">
                    <div class="small text-muted text-uppercase fw-semibold">@approvedStatus</div>
                    <div class="fs-3 fw-bold text-success">@(ViewBag.ApprovedCount ?? 0)</div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-6 col-md-4">
        <a href="@Url.Action("Index", new { statusFilter = declinedStatus })" class="text-decoration-none">
            <div class="card border-0 h-100" style="background:#f8d7da;">
                <div class="card-body text-center py-3">
                    <div class="small text-muted text-uppercase fw-semibold">@declinedStatus</div>
                    <div class="fs-3 fw-bold text-danger">@(ViewBag.DeclinedCount ?? 0)</div>
                </div>
            </div>
        </a>
    </div>
</div>

<form method="get" asp-action="Index" class="mb-4">
    <div class="card">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Status</label>
                    <select name="statusFilter" class="form-select form-select-sm" onchange="this.form.submit()">
                        <option value="">All</option>
                        @foreach (var s in (ViewBag.WorkflowStatuses as List<string> ?? new List<string>()))
                        {
                            <option value="@s" selected="@(ViewBag.StatusFilter == s)">@s</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Customer ID</label>
                    <div class="input-group input-group-sm">
                        <input type="text" name="customerFilter" class="form-control" placeholder="Filter by customer" value="@ViewBag.CustomerFilter" />
                        <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i></button>
                    </div>
                </div>
                <div class="col-md-4">
                    <a asp-action="Index" class="btn btn-secondary btn-sm"><i class="fas fa-times me-1"></i>Clear</a>
                </div>
            </div>
        </div>
    </div>
</form>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle" id="waiverTable">
                <thead class="table-dark">
                    <tr>
                        <th>Waiver ID</th>
                        <th>Customer</th>
                        <th>Type</th>
                        <th class="text-end">Total Surcharge</th>
                        <th class="text-end">Waived</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var w in Model)
                    {
                        var status = w.Status ?? initiatedStatus;
                        var isApproved = string.Equals(status, approvedStatus, StringComparison.OrdinalIgnoreCase);
                        var badge = string.Equals(status, approvedStatus, StringComparison.OrdinalIgnoreCase)
                            ? "bg-success"
                            : string.Equals(status, declinedStatus, StringComparison.OrdinalIgnoreCase)
                                ? "bg-danger"
                                : "bg-warning text-dark";
                        <tr>
                            <td><code>@w.WaiverID</code></td>
                            <td>
                                <div><code>@w.CustomerID</code></div>
                                <div class="small text-muted">@(w.Customer?.FullName ?? "—")</div>
                            </td>
                            <td>@(w.WaiverType ?? "—")</td>
                            <td class="text-end">@w.TotalAmount.ToString("N0")</td>
                            <td class="text-end fw-bold text-success">@w.WaivedAmount.ToString("N0")</td>
                            <td><span class="badge @badge">@status</span></td>
                            <td>@w.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@w.WaiverID" class="btn btn-sm btn-outline-info" title="Details">
                                    <i class="fas fa-eye"></i>
                                </a>
                                @if (ViewBag.CanEdit == true && !isApproved)
                                {
                                    <a asp-action="Edit" asp-route-id="@w.WaiverID" class="btn btn-sm btn-outline-primary" title="Edit">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                }
                                @if (ViewBag.CanDelete == true && !isApproved)
                                {
                                    <form asp-action="Delete" asp-route-id="@w.WaiverID" method="post" class="d-inline" onsubmit="return confirm('Delete this waiver?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
    $(function () {
        $('#waiverTable').DataTable({
            pageLength: 25,
            order: [[6, 'desc']],
            columnDefs: [{ orderable: false, targets: 7 }]
        });
    });
</script>
}
